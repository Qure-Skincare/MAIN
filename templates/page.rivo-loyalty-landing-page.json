        "custom_css": "/* === ROOT TOKENS === */\n:root {\n  /* neutrals */\n  --rivo-white: #ffffff;\n  --rivo-grey-100: #f2f5f4;\n  --rivo-grey-300: #f4f4f4;\n  --rivo-grey-400: #b0bfbc;\n\n  /* accents */\n  --rivo-vip-bg: #e5e5ff;\n  --rivo-faq-bg: #e5e5ff;\n  --rivo-zebra-even: #e5e5ff;\n  --rivo-zebra-odd: #f2f2ff;\n  --rivo-card-border: #3d4852;\n\n  /* define in theme */\n  /* --rivo-primary-color: ...; */\n  /* --rivo-secondary-color: ...; */\n}\n\n/* === BUTTONS === */\n.rivo-button,\n.rivo-modal-button,\n.rivo-points-table-load-more-button {\n  background: var(--rivo-primary-color);\n  color: var(--rivo-secondary-color);\n  display: flex;\n  justify-content: center;\n  min-width: 200px;\n  min-height: 50px;\n  padding: 10px;\n  border: none;\n  border-radius: 60px;\n  line-height: 2;\n}\n\n.rivo-button:hover,\n.rivo-modal-button:hover {\n  opacity: 0.9;\n}\n\n.rivo-hero-buttons > .rivo-button:nth-of-type(2) {\n  background: var(--rivo-secondary-color);\n  color: var(--rivo-primary-color);\n}\n\n.rivo-success-button {\n  color: transparent !important;\n}\n\n.rivo-success-button:after {\n  display: none;\n}\n\n.rivo-add-shipping-address,\n.rivo-logout-link {\n  display: flex;\n}\n\n.rivo-add-shipping-address a,\n.rivo-logout-link a,\n.rivo-form-row button[type=submit] {\n  width: 100%;\n  padding: 10px;\n  text-align: center;\n  border-radius: 6px;\n}\n\n.rivo-points-table-load-more-button {\n  padding: 10px;\n  border: 0;\n  border-radius: 4px;\n  font-size: 16px;\n  text-decoration: none;\n}\n\n/* form inputs */\ninput.rivo-coupon-code,\n.rivo-multiplier-input .rivo-form-input,\ninput.rivo-form-input {\n  border: 1px solid var(--rivo-primary-color);\n  font-size: 16px !important;\n  border-radius: 5px;\n}\n\n/* modal links */\n.rivo-modal-p a {\n  text-decoration: underline;\n}\n\n.rivo-modal-p a::after {\n  content: \".\";\n}\n\n/* === HERO === */\n.rivo-content-wrapper {\n  border-radius: 12px;\n}\n\n.rivo-hero-title img {\n  display: block;\n  margin: 0 auto 20px;\n  height: 25px;\n}\n\n.rivo-hero-banner-wrapper {\n  max-width: 1500px;\n}\n\n.rivo-hero-banner-text {\n  display: flex;\n  flex-direction: column;\n}\n\n@media (min-width: 750px) {\n  .rivo-hero-banner-wrapper {\n    padding: 3rem;\n  }\n}\n\n/* === TITLES === */\n#rivo-how-it-works {\n  width: 100%;\n}\n\n.rivo-lp-section-title {\n  font-weight: 300;\n}\n\n.rivo-section-label {\n  display: block;\n  font-size: 24px;\n  color: var(--rivo-secondary-color);\n  font-weight: 600;\n}\n\n/* === HOW IT WORKS === */\n.rivo-step-item {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n}\n\n/* === CARDS === */\n.rivo-card {\n  flex-basis: 23%;\n}\n\n.rivo-arrow-icon {\n  display: none;\n}\n\n.rivo-card-title {\n  text-transform: capitalize;\n}\n\n.rivo-card-description {\n  padding-top: 0;\n}\n\n.rivo-card-body {\n  max-width: 95%;\n  margin: 0 auto;\n}\n\n/* === VIP TIERS TABLE === */\n.rivo-vip-tier-table {\n  border-collapse: separate;\n  border-spacing: 0;\n}\n\n.rivo-vip-tier-table-thead-first-cell {\n  background: transparent !important;\n  border: none !important;\n}\n\n.rivo-th-tier-image {\n  margin-bottom: 12px;\n}\n\nspan.rivo-th-tier-name {\n  text-transform: uppercase;\n  letter-spacing: 0.1em;\n}\n\ntd.rivo-vip-tier-table-row-perk-name {\n  text-align: left;\n  text-transform: uppercase;\n  font-weight: 600;\n  color: var(--rivo-primary-color);\n  background: var(--rivo-secondary-color);\n}\n\ntbody tr,\ntd.rivo-vip-tier-table-row-perk-name,\ntbody tr:nth-child(even) {\n  border-bottom: none;\n}\n\n/* Tier column colors */\n.rivo-vip-tier-table .rivo-tier-column-1,\n.rivo-vip-tier-table .rivo-tier-column-1 .rivo-th-cell-content {\n  background: #F6F6F7 !important;\n}\n\n.rivo-vip-tier-table .rivo-tier-column-2 {\n  background: #C7E5DB !important;\n  color: var(--rivo-primary-color);\n}\n\n.rivo-vip-tier-table .rivo-tier-column-3 {\n  background: #91BAEC !important;\n  color: var(--rivo-secondary-color);\n}\n\n/* Border radius - four outer corners */\n.rivo-vip-tier-table thead tr th.rivo-tier-column-1 {\n  border-radius: 12px 0 0 0;\n  overflow: hidden;\n}\n\n.rivo-vip-tier-table thead tr th.rivo-tier-column-3 {\n  border-radius: 0 12px 0 0;\n  overflow: hidden;\n}\n\n.rivo-vip-tier-table tbody tr:last-child td.rivo-tier-column-1 {\n  border-radius: 0 0 0 12px;\n  overflow: hidden;\n}\n\n.rivo-vip-tier-table tbody tr:last-child td.rivo-tier-column-3 {\n  border-radius: 0 0 12px 0;\n  overflow: hidden;\n}\n\n/* === VIP PROGRESS BAR === */\n.rivo-vip-tier-progress-container {\n  width: 50%;\n}\n\n.rivo-account-progress-container {\n  background: var(--rivo-grey-300);\n}\n\n.rivo-account-progress-bar {\n  background: var(--rivo-primary-color);\n}\n\n.rivo-progress-current-tier-label,\n.rivo-progress-next-tier-label {\n  text-transform: uppercase;\n}\n\n/* === ACTIVITY / LOGS === */\n.rivo-points-expiry {\n  padding: 10px;\n  color: var(--rivo-primary-color);\n  font-weight: 900;\n  font-size: 14px;\n  margin: 16px auto 0;\n  width: fit-content;\n}\n\n#points-logs-activity thead th {\n  background: var(--rivo-primary-color);\n  color: var(--rivo-secondary-color);\n  font-weight: 500;\n}\n\n#points-logs-activity td {\n  color: var(--rivo-primary-color);\n}\n\n/* === SCROLLBARS === */\n.rivo-lp-cards-container::-webkit-scrollbar,\n.rivo-vip-tier-container::-webkit-scrollbar {\n  width: 10px;\n  height: 8px;\n}\n\n.rivo-lp-cards-container::-webkit-scrollbar-track,\n.rivo-vip-tier-container::-webkit-scrollbar-track {\n  background: transparent;\n  border: 1px solid var(--rivo-primary-color);\n  border-radius: 10px;\n}\n\n.rivo-lp-cards-container::-webkit-scrollbar-thumb,\n.rivo-vip-tier-container::-webkit-scrollbar-thumb {\n  background: var(--rivo-primary-color);\n  border-radius: 10px;\n}\n\n/* === MOBILE ≤768px === */\n@media (max-width: 768px) {\n  .rivo-hero-banner-text {\n    padding: 40px;\n  }\n\n  .rivo-content-wrapper {\n    padding: 40px 0;\n  }\n\n  .rivo-section-label {\n    font-size: 16px;\n  }\n\n  .rivo-card-title {\n    font-size: 16px;\n  }\n\n  .rivo-card-description {\n    font-size: 14px;\n  }\n\n  #rivo-ways-to-redeem .rivo-card,\n  #rivo-lp-my-rewards .rivo-card {\n    padding-bottom: 10px;\n  }\n\n  #rivo-ways-to-redeem .rivo-card-icon img,\n  #rivo-lp-my-rewards .rivo-card-icon img {\n    height: 100px !important;\n    width: 100px !important;\n  }\n\n  .rivo-how-it-works-step-image img {\n    height: 100px;\n  }\n\n  .rivo-vip-tier-progress-container {\n    width: 95%;\n  }\n\n  .rivo-vip-tier-container {\n    overflow-x: auto;\n    -webkit-overflow-scrolling: touch;\n    padding-bottom: 20px;\n  }\n\n  .rivo-vip-tier-container {\n    overflow-x: auto;\n    -webkit-overflow-scrolling: touch;\n    padding-bottom: 20px;\n    width: 100%;\n  }\n\n  table.rivo-vip-tier-table {\n    width: auto;\n    min-width: 700px;\n    table-layout: auto;\n  }\n\n  .rivo-vip-tier-table-thead-first-cell,\n  td.rivo-vip-tier-table-row-perk-name {\n    font-size: 11px;\n  }\n\n  table.rivo-vip-tier-table th.rivo-tier-column-1,\n  table.rivo-vip-tier-table th.rivo-tier-column-2,\n  table.rivo-vip-tier-table th.rivo-tier-column-3,\n  table.rivo-vip-tier-table td.rivo-tier-column-1,\n  table.rivo-vip-tier-table td.rivo-tier-column-2,\n  table.rivo-vip-tier-table td.rivo-tier-column-3 {\n    min-width: 160px;\n    width: 160px;\n    height: 60px;\n  }\n\n  table.rivo-vip-tier-table th,\n  table.rivo-vip-tier-table td {\n    width: 100px;\n    height: 60px;\n  }\n}"
