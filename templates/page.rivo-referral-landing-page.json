        "custom_css": "/* === ROOT TOKENS === */\n:root {\n  /* neutrals *\n  --rivo-white: #ffffff;\n  --rivo-grey-100: #f2f5f4;\n  --rivo-grey-300: #f4f4f4;\n  --rivo-grey-400: #b0bfbc;\n\n  /* accents */\n  --rivo-vip-bg: #e5e5ff;\n  --rivo-faq-bg: #e5e5ff;\n  --rivo-zebra-even: #e5e5ff;\n  --rivo-zebra-odd: #f2f2ff;\n  --rivo-card-border: #3d4852;\n\n  /* define in theme */\n  /* --rivo-primary-color: ...; */\n  /* --rivo-secondary-color: ...; */\n}\n\n/* === BUTTONS === */\n.rivo-button,\n.rivo-modal-button,\n.rivo-points-table-load-more-button {\n  background: var(--rivo-primary-color);\n  color: var(--rivo-secondary-color);\n  display: flex;\n  justify-content: center;\n  min-width: 200px;\n  min-height: 50px;\n  padding: 10px;\n  border: none;\n  border-radius: 60px;\n  line-height: 2;\n}\n\n.rivo-button:hover,\n.rivo-modal-button:hover {\n  opacity: 0.9;\n}\n\n.rivo-hero-buttons > .rivo-button:nth-of-type(2) {\n}\n\n.rivo-hero-buttons > .rivo-button:nth-of-type(2){\n  background: var(--rivo-secondary-color);\n  color: var(--rivo-primary-color);\n}\n\n.rivo-success-button {\n  color: transparent !important;\n}\n\n.rivo-success-button:after {\n  display: none;\n}\n\n.rivo-copy-button.rivo-success-button::before, button[aria-label=\"Copy coupon code\"]::before {\n\n}\n\n.rivo-add-shipping-address,\n.rivo-logout-link {\n  display: flex;\n}\n\n.rivo-add-shipping-address a,\n.rivo-logout-link a,\n.rivo-form-row button[type=submit] {\n  width: 100%;\n  padding: 10px;\n  text-align: center;\n  border-radius: 6px;\n}\n\n/* copy-code placeholder */\n.rivo-copy-button.rivo-success-button::before,\nbutton[aria-label=\"Copy coupon code\"]::before {\n}\n\n/* load-more */\n.rivo-points-table-load-more-button {\n  background: var(--rivo-primary-color);\n  color: var(--rivo-secondary-color);\n  padding: 10px;\n  border: 0;\n  border-radius: 4px;\n  font-size: 16px;\n  text-decoration: none;\n}\n\n/* form inputs */\ninput.rivo-coupon-code,\n.rivo-multiplier-input .rivo-form-input,\ninput.rivo-form-input {\n  border: 1px solid var(--rivo-primary-color);\n  font-size: 16px !important;\n  border-radius: 5px;\n}\n\n/* modal links */\n.rivo-modal-p a {\n  text-decoration: underline;\n}\n\n.rivo-modal-p a::after {\n  content: \".\";\n}\n\n/* === HERO === */\n\n.rivo-content-wrapper {\n  border-radius: 12px;\n}\n\n.rivo-hero-title img {\n  display: block;\n  margin: 0 auto 20px;\n  height: 25px;\n}\n\n.rivo-hero-banner-wrapper {\n  max-width: 1500px;\n}\n\n.rivo-hero-banner-text {\n  display: flex;\n  flex-direction: column;\n}\n\n@media (min-width: 750px) {\n  .rivo-hero-banner-wrapper {\n    padding: 3rem;\n  }\n}\n\n/* === TITLES === */\n#rivo-how-it-works {\n  width: 100%;\n}\n\n.rivo-section-label {\n  display: block;\n  font-size: 24px;\n  color: var(--rivo-secondary-color);\n  font-weight: 600;\n}\n\n/* === How it works === */\n\n.rivo-step-item {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n}\n\n/* === CARDS === */\n.rivo-card {\n  flex-basis: 23%;\n}\n\n.rivo-card-title {\n  text-transform: capitalize;\n}\n\n.rivo-card-description {\n  padding-top: 0;\n}\n\n.rivo-card-body {\n  max-width: 95%;\n  margin: 0 auto;\n}\n\n#rivo-ways-to-redeem .rivo-card {\n}\n\n#rivo-ways-to-earn .rivo-card {\n}\n\n#rivo-ways-to-earn .rivo-card.completed:hover {\n}\n\n/* === FAQS === */\n\n/* === VIP TIERS TABLE === */\n.rivo-vip-tier-container {\n  max-width: 100%;\n  overflow: auto;\n}\n\ntable.rivo-vip-tier-table {\n  background: transparent;\n  border-collapse: separate;\n  border-spacing: 10px 0;\n}\n\n.rivo-vip-tier-table-thead-tier-cell {\n  border: 1px solid var(--rivo-secondary-color);\n  background: var(--rivo-vip-bg);\n  color: var(--rivo-primary-color);\n}\n\n/* === VIP PROGRESS BAR === */\n.rivo-vip-tier-progress-container {\n  width: 50%;\n}\n\n@media (max-width: 768px) {\n  .rivo-vip-tier-progress-container {\n    width: 95%;\n  }\n}\n\n.rivo-account-progress-container {\n  background: var(--rivo-grey-300);\n}\n\n.rivo-account-progress-bar {\n  background: var(--rivo-primary-color);\n}\n\n.rivo-progress-current-tier-label,\n.rivo-progress-next-tier-label {\n  text-transform: uppercase;\n}\n\n/* === ACTIVITY / LOGS === */\n.rivo-points-expiry {\n  padding: 10px;\n  color: var(--rivo-primary-color);\n  font-weight: 900;\n  font-size: 14px;\n  margin: 16px auto 0;\n  width: fit-content;\n}\n\n#points-logs-activity thead th {\n  background: var(--rivo-primary-color);\n  color: var(--rivo-secondary-color);\n  font-weight: 500;\n}\n\n#points-logs-activity td {\n  color: var(--rivo-primary-color);\n}\n\n/* === SCROLLBARS === */\n.rivo-lp-cards-container::-webkit-scrollbar,\n.rivo-vip-tier-container::-webkit-scrollbar {\n  width: 10px;\n  height: 8px;\n}\n\n.rivo-lp-cards-container::-webkit-scrollbar-track,\n.rivo-vip-tier-container::-webkit-scrollbar-track {\n  background: var(--rivo-vip-bg);\n  border-radius: 10px;\n}\n\n.rivo-lp-cards-container::-webkit-scrollbar-thumb,\n.rivo-vip-tier-container::-webkit-scrollbar-thumb {\n  background: var(--rivo-secondary-color);\n  border-radius: 10px;\n}\n\n/* === MOBILE ≤768px === */\n@media (max-width: 768px) {\n  .rivo-hero-banner-text {\n    padding: 40px;\n  }\n\n  .rivo-content-wrapper {\n    padding: 40px 0;\n  }\n\n  .rivo-section-label {\n    font-size: 16px;\n  }\n\n  .rivo-card-title {\n    font-size: 16px;\n  }\n\n  .rivo-card-description {\n    font-size: 14px;\n  }\n  \n  .rivo-vip-tier-container {\n    padding-bottom: 20px;\n  }\n  \n  table.rivo-vip-tier-table {\n    padding-bottom: 20px;\n  }\n\n  table.rivo-vip-tier-table th,\n  table.rivo-vip-tier-table td {\n    width: 200px;\n    height: 60px;\n  }\n}"
