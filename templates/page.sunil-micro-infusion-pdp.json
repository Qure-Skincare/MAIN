        "left_accordion_Y64cWD": {
          "type": "left_accordion",
          "settings": {
            "heading": "What can it do for your skin",
            "text": "<p>Reveals a smoother, brighter looking, and evenly radiant complexion to generate a glow effect. Renewal properties to help fade the appearance of dark spots and restore even-looking, smoother-feeling skin.</p><p><strong>Skin Concerns:</strong> Designed for skin with discoloration, rough texture, enlarged pores, acne marks and dark spots.</p>"
          }
        },
        "left_accordion_prDPgR": {
          "type": "left_accordion",
          "settings": {
            "heading": "All Ingredients",
            "text": "<p><strong>Epidermal Growth Factor (EGF):</strong> Works at a cellular level to repair and rejuvenate skin. Reduces appearance of wrinkles, improves hydration, and prevents hyperpigmentation.</p><p><strong>Niacinamide:</strong> Superstar ingredient that helps with most skin concerns from soothing to brightening and clarifying, and reducing look of fine lines and wrinkles. </p><p><strong>Tranexamic Acid:</strong> Helps to fade look of dark spots and discoloration. Assists with brightening and evening look of skin tone. </p><p><strong>All ingredients:</strong>Rosa Damascena Flower Water, Propanediol, Glycerin, Tranexamic Acid, Niacinamide, Panthenol, Chrysanthellum Indicum Extract, Ethylhexylglycerin, Tripeptide-1, Xanthan Gum, Allantoin, Sh-Oligopeptide-1.</p><p><em>Please note that due to innovative updates and changing regulatory guidelines, the ingredient lists provided here may differ slightly from those on our packaging and distributor websites.<br/><br/></em></p>"
          }
        },
        "right_accordion_4V6QHp": {
          "type": "right_accordion",
          "settings": {
            "heading": "What can it do for your skin",
            "text": "<p>Ultra hydration. Hydrates to help plump skin, reducing the look of fine lines and wrinkles, reduce redness, and supports the skin barrier for firmer-feeling, supple looking skin.</p><p><strong>Skin Concerns:</strong>Designed for dull looking skin with wrinkles, fine lines, dehydration, dryness and redness,</p>"
          }
        },
        "right_accordion_hi9p43": {
          "type": "right_accordion",
          "settings": {
            "heading": "All Ingredients",
            "text": "<p><strong>Beta Glucan:</strong> A tall glass of water for your skin. Strengthens skin barrier while leaving skin soft and plump.</p><p><strong>Copper Peptide GHK-Cu:</strong> Known for its powerful anti-aging properties. This switch boosts collagen production and skin healing and gives the serum its distinctive blue hue. </p><p><strong>Sodium Hyaluronate:</strong> Hydrating power to lock in moisture more effectively and plump the skin for a firmer, fresher complexion.</p><p><strong>All ingredients:</strong>Rosa Damascena Flower Water, Propanediol, Glycerin, Panthenol, Niacinamide, Myrothamnus Flabellifolia Leaf/Stem Extract, Water, Butylene Glycol, Hydroxyacetophenone, Copper Tripeptide-1, Beta-Glucan, Chrysanthellum Indicum Extract, Ethylhexylglycerin, Sodium Hyaluronate, Allantoin, Xanthan Gum.</p><p><em>Please note that due to innovative updates and changing regulatory guidelines, the ingredient lists provided here may differ slightly from those on our packaging and distributor websites.<br/><br/></em></p>"
          }
        },
