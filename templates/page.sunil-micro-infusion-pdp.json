          }
        },
        "slider_PQ3RbR": {
          "type": "slider",
          "settings": {
            "heading": "It really works!!",
            "text": "<p>“I committed to the 3 month saver bundle and after 6 treatments (2 weeks apart) I’m SO happy with the results!!! My pores are smaller and I have mainly noticed a difference in my skin texture. My skin goes a little red straight after the treatment but that quickly goes away. It’s a little uncomfortable when I do it on my forehead but it’s fine everywhere else. Totally worth it!!!”</p>",
            "compare_image": "shopify://shop_images/jess.webp",
