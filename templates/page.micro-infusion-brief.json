      "name": "t:sections.n_guide-content-image-block.name",
      "settings": {
        "use_own_file": true,
        "active": true,
        "must_read": false,
        "heading": "Product Information",
        "text": "<h2>Product Information</h2><p>This innovative 2-in-1 system combines precision and care to revitalize your skin from the inside out.</p><p>[image]</p><p><strong>It works in two ways:</strong></p><ol><li>It triggers your skin's natural repair response for smoother and firmer looking skin.</li><li> Its 0.5 mm needles creates tiny, invisible channels in the surface of your skin and infuses the serum of your choice (for Wrinkles / for Dark Spots) directly below the skin barrier, accelerating absorption of active ingredients for faster results.</li></ol><p>The outcome? A radiant, rejuvenated complexion that reflects true skin health.</p>"
      }
    },
    "n_guide_content_step_pUDH8Q": {
      "type": "n_guide-content-step",
      "blocks": {
        "step_by_step_CHKpjA": {
          "type": "step_by_step",
          "settings": {
            "modifier": "text_with_image",
            "image": "shopify://shop_images/micro-infusion-15-step-1_6a06a160-f35c-4619-8acb-4daec9b2d238.webp",
            "text": "<h6>Step 1</h6><p>Cleanse your face thoroughly to remove all traces of makeup and lotions. Pat dry.</p><p>Spritz our <a href=\"#\" title=\"#\">Dermal Mist</a> to refresh and prepare your skin further and wait for it to dry before beginning.</p>"
          }
        },
        "step_by_step_iQ34HT": {
          "type": "step_by_step",
          "settings": {
            "modifier": "text_with_image",
            "image": "shopify://shop_images/micro-infusion-step-2.webp",
            "text": "<h6>Step 2</h6><p>Pour one full Qure serum ampoule into the device chamber.</p><p>[note_green]<strong>Tip:</strong> Use one ampoule per treatment. The serum should only fill the Device halfway.[/note]</p>"
          }
        },
        "step_by_step_BF9ixp": {
          "type": "step_by_step",
          "settings": {
            "modifier": "text_with_image",
            "image": "shopify://shop_images/micro-infusion-step-3.webp",
            "text": "<h6>Step 3</h6><p>Attach the micro-needle head with the plastic cap still on the device.</p><p>Turn the device upside down for 1-2 minutes to allow the serum to saturate the needles.</p>"
          }
        },
        "step_by_step_tikbhB": {
          "type": "step_by_step",
          "settings": {
            "modifier": "text_with_image",
            "image": "shopify://shop_images/micro-infusion-step-4.webp",
            "text": "<h6>Step 4</h6><p>Remove the cap and stamp gently across your face using light pressure.</p><p>[note_green]<strong>Tip:</strong> Do not apply too much pressure! The needles are designed to be gentle on your skin.[/note]</p>"
          }
        },
        "step_by_step_WwD7Gm": {
          "type": "step_by_step",
          "settings": {
            "modifier": "text_with_image",
            "image": "shopify://shop_images/micro-infusion-step-5.webp",
            "text": "<h6>Step 5</h6><p>Work section by section, repeating each area 2-3 times.</p><p>[note_green]<strong>Tip:</strong> Each time you stamp, overlap the previous stamp halfway to ensure each area of the face is stamped at least twice.[/note]</p>"
          }
        },
        "step_by_step_J94Ppq": {
          "type": "step_by_step",
          "settings": {
            "modifier": "text_with_image",
            "image": "shopify://shop_images/micro-infusion-step-6.webp",
            "text": "<h6>Step 6</h6><p>Make sure the serum is always at the needle end while stamping. If the serum is not coming through, tilt the device upward or lean your head back to help it flow. </p><p>You can also pop the lid back on, turn the device upside down, and tap the end firmly to push the serum down.</p>"
          }
        },
        "step_by_step_aR4rNF": {
          "type": "step_by_step",
          "settings": {
            "modifier": "text_with_image",
            "image": "shopify://shop_images/micro-infusion-step-7.webp",
            "text": "<h6>Step 7</h6><p>Once finished, pat any remaining serum into your skin with clean hands.</p>"
          }
        },
        "step_by_step_9N7zCt": {
          "type": "step_by_step",
          "settings": {
            "modifier": "text_with_image",
            "image": "shopify://shop_images/micro-infusion-step-8.webp",
            "text": "<h6>Step 8</h6><p>Carefully unscrew the needle head, put the cap back on, and dispose of the used needle head. Each one is single-use only.</p><p>[note_green]<strong>Tip:</strong> Do not reuse needle heads - even if it looks clean. It is designed for one treatment only.[/note]</p>"
          }
        },
        "wistia_video_qzp6wC": {
          "type": "wistia_video",
          "settings": {
            "desktop": true,
            "wistia_url": "6de5pg0r6e",
            "image": "shopify://shop_images/how_to_v15_e82a0c88-6dbc-4ba6-b528-8bc78fe96359.webp",
            "label_text": "Watch: How To Use"
          }
        },
        "link_gndnmV": {
          "type": "link",
          "settings": {
            "link_text": "Link to online guide",
            "link_url": "#"
          }
        },
        "quote_ejjGdK": {
          "type": "quote",
          "settings": {
            "style": "blue",
            "text": "<p>After your treatment:</p><ul><li>Apply gentle, hydrating skincare if you need it.</li><li>Avoid using makeup or active ingredients (like retinoids or acids) for at least 24 hours.</li><li>Avoid heat, sweating, and direct sun.</li></ul>"
          }
        }
      },
