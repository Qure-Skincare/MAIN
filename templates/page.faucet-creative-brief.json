      "settings": {
        "use_own_file": true,
        "active": true,
        "must_read": false,
        "heading": "Product Information",
        "text": "<h2>Product Information</h2><ul><li>4 stage filtration system removes up to 99% of skin-damaging contaminants.</li><li>360° rotating nozzle for easier face washing.</li><li>Compact design fits into sinks of all shapes and sizes.</li><li>2 minute easy installation with filter replacement needed just once every 3 months.</li><li>Alternate between filtered and unfiltered water modes.</li><li>Meets NSF standards</li></ul>",
        "slides_per_view": ""
      }
    },
    "n_guide_content_d3J7cJ": {
      "type": "n_guide-content",
      "blocks": {
        "link_TbzrQr": {
          "type": "link",
          "settings": {
