      "type": "n_guide-content",
      "name": "t:sections.n_guide-content.name",
      "settings": {
        "use_own_file": true,
        "active": false,
        "must_read": true,
        "heading": "Content Requirements",
        "text": "<h2>Content Requirements</h2><p>Messaging must include:</p><ul><li>Micro-darts help with deeper delivery of active ingredients</li><li>Quick application</li><li>Target multiple concerns</li><li>Versatile treatment (use where needed)</li></ul><p>Content ideas:</p><ul><li>Before and After</li><li>How to use and product details</li><li>What experts say/expert review</li></ul>",
        "slides_per_view": ""
      }
    },
