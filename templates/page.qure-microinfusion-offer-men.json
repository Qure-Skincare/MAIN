        },
        "left_text_with_image_nQcxzA": {
          "type": "left_text_with_image",
          "settings": {
            "icon": "even-looking",
            "text": "<p>Even-looking <br/>tone</p>"
          }
        },
        "left_accordion_TQaAY9": {
          "type": "left_accordion",
          "settings": {
            "heading": "What can it do for your skin",
            "text": "<p>Helps reveal a smoother-looking, more radiant complexion. Formulated to help improve the appearance of dark spots and uneven tone for skin that looks refreshed and luminous.<br/><br/><strong>Skin Concerns</strong>: Ideal for skin that appears uneven in tone or texture and shows visible dark spots or post-blemish marks.</p>"
          }
        },
        "left_accordion_BnCC9L": {
          "type": "left_accordion",
          "settings": {
            "heading": "All Ingredients",
            "text": "<p><strong>Epidermal Growth Factor (EGF):</strong> A science-backed ingredient known to support the look of smoother, hydrated, and more refreshed skin. Helps visibly reduce the look of fine lines and uneven tone.<br/><br/><strong>Niacinamide:</strong> A multi-benefit vitamin known to help improve the look of uneven tone, minimize visible pores, and support smoother-looking skin.<br/><br/><strong>Tranexamic Acid:</strong> A brightening ingredient that helps visibly improve the look of dark spots, uneven tone, and dullness.<br/>All ingredients: Rosa Damascena Flower Water, Propanediol, Glycerin, Tranexamic Acid, Niacinamide, Panthenol, Chrysanthellum Indicum Extract, Ethylhexylglycerin, Tripeptide-1, Xanthan Gum, Allantoin, Sh-Oligopeptide-1.</p><p>[note]Please note that due to innovative updates and changing regulatory guidelines, the ingredient lists provided here may differ slightly from those on our packaging and distributor websites.[/note]</p>"
          }
        },
        "left_feedback_mE7tH6": {
          "type": "left_feedback",
          "settings": {
            "rating": "4.5",
            "text": "<p>“I’m obsessed with this thing, my dark spots have faded within a few days, my fine lines also... wow!”</p>",
            "country_image": "shopify://shop_images/america-flag.webp",
            "username": "Jessie Hardy",
            "badge_text": "Verified customer"
          }
        },
        "text_between_4MGh3r": {
          "type": "text_between",
          "settings": {
