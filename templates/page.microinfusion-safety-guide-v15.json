      },
      "block_order": [
        "image_MNPqqw",
        "quote_9RB8pK"
      ],
      "name": "t:sections.n_guide-content-image-block.name",
      "settings": {
        "use_own_file": true,
        "active": false,
        "must_read": false,
        "heading": "Where to Use",
        "text": "<h2>Where to Use</h2><p>[image]</p><p>The Qure Micro-Infusion device is designed for use on the face and neck only.</p><p>You can safely treat the forehead, cheeks, nose, chin, jawline, and the under-eye area (up to the orbital bone). </p><p>Use light, even pressure and pass over each area 2-3 times. If a section feels too sensitive, it's okay to skip it.</p><p>[quote_content]</p>"
      }
    },
