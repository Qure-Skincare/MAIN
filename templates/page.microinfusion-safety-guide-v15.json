      "name": "t:sections.n_intro.name",
      "settings": {
        "use_own_file": true,
        "text": "<p><strong>Your new Qure Micro-Infusion device</strong> delivers targeted ingredients deep below the surface, helping reduce the look of fine lines, brighten tone, and boost your natural glow.</p><p>This guide will walk you through every step so you can get glowing results safely and confidently.</p>"
      }
    },
