      "name": "t:sections.n_guide-content-step.name",
      "settings": {
        "use_own_file": true,
        "active": true,
        "must_read": false,
        "heading": "Quick Start Guide",
        "text": "<h2>Quick Start Guide</h2><p>[wistia_video]</p><p>To get started with your first treatment, you'll need the following:</p><ul><li>1 sterile needle head (provided)</li><li>1 Micro-Infusion serum vial (provided)</li></ul><p>Ensure your hands are clean before and during the treatment and do not rush yourself.</p>"
      }
    },
    "n_guide_content_image_block_ptjFFA": {
      "type": "n_guide-content-image-block",
      "blocks": {
        "image_P9f9r9": {
