    "n_guide_content_step_bfgn4t": {
      "type": "n_guide-content-step",
      "blocks": {
        "step_by_step_p98rhw": {
          "type": "step_by_step",
          "settings": {
            "image": "shopify://shop_images/micro-infusion-15-step-1.webp",
            "text": "<h6>Step 1</h6><p>Cleanse your face thoroughly to remove all traces of makeup and lotions. Pat dry.</p><p>Spritz our <a href=\"#\" title=\"#\">Dermal Mist</a> to refresh and prepare your skin further and wait for it to dry before beginning.</p>"
          }
        },
        "step_by_step_rRiUhK": {
          "type": "step_by_step",
          "settings": {
            "image": "shopify://shop_images/micro-infusion-15-step-2.webp",
            "text": "<h6>Step 2</h6><p>Twist off the cap of the serum vial and screw on the sterile needle head.</p><p>Hold the device upside down for 1-2 minutes to let the serum flow into the needle head and saturate the area around the needles.</p>"
          }
        },
        "step_by_step_9bwbiE": {
          "type": "step_by_step",
          "settings": {
            "image": "shopify://shop_images/micro-infusion-15-step-3.webp",
            "text": "<h6>Step 3</h6><p>Remove the cap and stamp gently across your face using light pressure.</p><p>[note_green]<strong>Tip:</strong> Do not apply too much pressure! The needles are designed to be gentle on your skin.[/note]</p>"
          }
        },
        "step_by_step_pzjKh4": {
          "type": "step_by_step",
          "settings": {
            "image": "shopify://shop_images/micro-infusion-15-step-4.webp",
            "text": "<h6>Step 4</h6><p>Work section by section, repeating each area 2-3 times. </p><p>[note_green]<strong>Tip:</strong> Each time you stamp, overlap the previous stamp halfway to ensure each area of the face is stamped at least twice.[/note]</p>"
          }
        },
        "step_by_step_XqWUJp": {
          "type": "step_by_step",
          "settings": {
            "image": "shopify://shop_images/micro-infusion-15-step-5.webp",
            "text": "<h6>Step 5</h6><p>When stamping, ensure that the serum remains at the needle head. If the serum does not appear around the needles, tilt the device upward or lean your head back slightly to help the serum flow.</p>"
          }
        },
        "step_by_step_jtjmU9": {
          "type": "step_by_step",
          "settings": {
            "image": "shopify://shop_images/micro-infusion-15-step-6.webp",
            "text": "<h6>Step 6</h6><p>When finished, carefully dispose of the serum vial and needle head. </p><p>[note_green]<strong>Tip:</strong> Do not reuse needle heads - even if it looks clean. It is designed for one treatment only.[/note]</p>"
          }
        },
        "wistia_video_CgPRiF": {
          "type": "wistia_video",
          "settings": {
            "wistia_url": "6de5pg0r6e",
            "image": "shopify://shop_images/how_to_v15.webp"
          }
        },
        "quote_WEMwW4": {
          "type": "quote",
          "settings": {
            "style": "blue",
            "text": "<p><strong>After your treatment:</strong></p><ul><li>Apply gentle, hydrating skincare if you need it.</li><li>Avoid using makeup or active ingredients (like retinoids or acids) for at least 24 hours.</li><li>Avoid heat, sweating, and direct sun.</li></ul>"
          }
        }
      },
      "block_order": [
