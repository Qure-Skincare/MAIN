      "name": "t:sections.n_guide-content.name",
      "settings": {
        "use_own_file": true,
        "active": false,
        "must_read": false,
        "heading": "Usage Instructions",
        "text": "<h2>Usage Instructions</h2><p><strong>How To Use:</strong></p><ol><li>Ensure your hair is clean, dry, and worn down (no clips or ties).</li><li>Unplug the helmet from the charging base. Press the Q button to turn it on.</li><li>Use the LCD screen to select your treatment zone (if applicable). Press Play to begin.</li><li>Place the helmet on your head and adjust fit using the back dial. The light activates only when properly positioned.</li><li>To pause, remove the helmet; placing it back on will resume the session.</li><li>Each session lasts 12 minutes and ends automatically.</li></ol>",
        "slides_per_view": ""
      }
    },
    "n_guide_content_kydpDU": {
      "type": "n_guide-content",
      "name": "t:sections.n_guide-content.name",
      "settings": {
        "use_own_file": true,
        "active": false,
        "must_read": false,
        "heading": "Product Claims",
        "text": "<h2>Product Claims</h2><p>Key claims:</p><ul><li>Combines red LED light therapy and medical-grade lasers to support scalp health.</li><li>Helps to re-activate dormant follicles and keep hair in the growth phase.</li><li>Encourages the appearance of thicker-looking hair with just 12 minutes per session.</li></ul>",
        "slides_per_view": ""
      }
    },
    "n_guide_content_BiRnR4": {
      "type": "n_guide-content",
      "blocks": {
        "quote_A4R7yb": {
          "type": "quote",
          "settings": {
            "style": "blue",
            "text": "<p>Remember to <strong>add a personal touch</strong> to the messaging, and talk about the main reasons you've chosen this device.</p><p>Examples:</p><ul><li>“I've tried so many products for thinning hair, but this is the first device that actually fits into my routine without any hassle.”</li><li>“I chose this helmet because it's backed by science — 370 lights, clinical studies, and it's completely painless.”</li><li>“For me, it wasn't just about hair — it was about feeling like myself again. That's why I chose this helmet.”</li></ul>"
          }
        }
      },
      "block_order": [
        "quote_A4R7yb"
      ],
