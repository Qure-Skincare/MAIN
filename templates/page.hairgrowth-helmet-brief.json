      "name": "t:sections.n_guide-content.name",
      "settings": {
        "use_own_file": true,
        "active": true,
        "must_read": false,
        "heading": "Product Information",
        "text": "<h2>Product Information</h2><ul><li>The Q-Renew LLLT Helmet combines red light therapy (LEDs) and low-level laser therapy (LLLT) to stimulate dormant follicles, support regrowth, and improve scalp health.</li><li>It offers a safe alternative to medications or surgical treatments for hair loss.</li><li>The Q-Renew LLLT Helmet is equipped with 370 medical-grade lights (LEDs + lasers) across optimal wavelengths proven to boost circulation and follicle activity.</li><li>Only requires 12 minutes per session, once daily, 4-7 times a week</li><li>LCD screen allows users to select targeted zones for more personalized treatment.</li><li>Built-in sensors ensure proper placement, with auto-pause if removed.</li><li>Lightweight helmet with adjustable sizing for secure wear</li><li>Rechargeable battery with a sleek charging dock for convenience</li><li>Comes with a 3-year warranty.</li></ul>",
        "slides_per_view": ""
      }
    },
    "n_guide_content_ydzpUb": {
      "type": "n_guide-content",
      "blocks": {
        "link_aJXqza": {
