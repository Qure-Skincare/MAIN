        "faq_item_LwnnrR": {
          "type": "faq_item",
          "settings": {
            "heading": "How often should I use it?",
            "text": "<p>Use it 4-7 times per week for 16 weeks, then every other day to maintain results.</p>"
          }
        },
        "faq_item_M7ynJy": {
          "type": "faq_item",
          "settings": {
            "heading": "Can I use it while charging?",
            "text": "<p>No. Always unplug the device before use.</p>"
          }
        },
        "faq_item_zeiE7c": {
          "type": "faq_item",
          "settings": {
            "heading": "What if I have sensitive skin?",
            "text": "<p>The helmet is suitable for sensitive skin, but always perform the light sensitivity test first.</p>"
