    "n_guide_content_step_EHn488": {
      "type": "n_guide-content-step",
      "blocks": {
        "step_by_step_9kt87n": {
          "type": "step_by_step",
          "settings": {
            "modifier": "numbered_list",
            "text": "<ol><li>Ensure your hair is clean, dry, and worn down (no clips or ties).</li><li>Unplug the helmet from the charging base. Press the Q button to turn it on.</li><li>Use the LCD screen to select your treatment zone (if applicable). Press Play to begin.</li><li>Place the helmet on your head and adjust fit using the back dial. The light activates only when properly positioned.</li><li>To pause, remove the helmet; placing it back on will resume the session. Each session lasts 12 minutes and ends automatically.</li></ol>"
          }
        },
        "wistia_video_GiGfVe": {
          "type": "wistia_video",
          "settings": {
            "desktop": true,
            "wistia_url": "wvoucso35j",
            "image": "shopify://shop_images/quick-start-guide-helmet.webp",
            "label_text": "Watch: How To Use"
          }
        },
        "quote_HWjhEK": {
          "type": "quote",
          "settings": {
            "style": "red",
            "text": "<p><strong>Light sensitivity test:</strong>We recommend performing a light sensitivity test 24 hours before using this device for your first treatment. To perform this, apply the product to your inner forearm, ensuring the light shines directly onto the skin. Use it for a full 3-minute treatment. Wait for 24 hours. If you experience pain, discomfort, or redness lasting more than 2 hours, you might be light-sensitive. Please consult a doctor for advice before continuing use.</p>"
          }
        }
      },
