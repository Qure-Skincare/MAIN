      "name": "t:sections.n_guide-content.name",
      "settings": {
        "use_own_file": true,
        "active": true,
        "must_read": false,
        "heading": "Product Information",
        "text": "<h2>Product Information</h2><ul><li>Triple the Filtration Tech (for Triple the Clean)</li><li>Carbon Fiber Layer - Removes up to 99% of chlorine, reducing skin irritation and dryness, leaving your skin and hair healthier.</li><li>KDF Layer - Targets and removes heavy metals like lead and mercury, providing cleaner water for your shower.</li><li>FOF (Filter of Future) - Reduces limescale buildup and helps minimize heavy mineral residue on skin, scalp, and hair for a softer, more refreshed feeling.</li></ul>",
        "slides_per_view": ""
      }
    },
    "n_guide_content_step_rmGmXc": {
      "type": "n_guide-content-step",
      "blocks": {
        "step_by_step_7NEdVW": {
          "type": "step_by_step",
          "settings": {
            "image": "shopify://shop_images/shower-step-1.webp",
            "text": "<h6>Step 1</h6><p>Remove your old showerhead by unscrewing it from the wall or shower arm.</p>"
          }
        },
        "step_by_step_gzeyrU": {
          "type": "step_by_step",
          "settings": {
            "image": "shopify://shop_images/shower-step-2.webp",
            "text": "<h6>Step 2</h6><p>Attach your new Qure filter by twisting the filter onto the shower pipe.</p><p>Make sure the rubber washer is inside to prevent leaks.</p>"
          }
        },
        "step_by_step_UxUCaX": {
          "type": "step_by_step",
          "settings": {
            "image": "shopify://shop_images/shower-step-3.webp",
            "text": "<h6>Step 3</h6><p>Tighten until secure. Make sure it's snug but not forced.</p>"
          }
        },
        "step_by_step_zBKRa3": {
          "type": "step_by_step",
          "settings": {
            "image": "shopify://shop_images/shower-step-4.webp",
            "text": "<h6>Step 4</h6><p>Let it run for 2-3 minutes to flush out any loose particles.</p><p>Done! You're ready to enjoy filtered, skin-friendly water.</p>"
          }
        },
