        "quote_iBWnUz": {
          "type": "quote",
          "settings": {
            "style": "blue",
            "text": "<p><strong>Tag and mention</strong> @qureskincare #QureSkincare #showerfilter #Skincare #qureshowerfilter #qurefilter</p><p>Include your affiliate or other links provided by Qure in Instagram Stories and content captions. If the link can't be placed in bio, include it in linktr.ee or similar.</p>"
