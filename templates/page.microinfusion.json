            "product_heading": "",
            "product_text": ""
          }
        },
        "slider_eCGH8c": {
          "type": "slider",
          "settings": {
            "heading": "Fade after just two treatments",
            "text": "<p>“I personally think my products absorbed better, my skin looks a bit brighter and that larger acne scar on my right cheek has started to fade after just TWO treatments!”</p>",
