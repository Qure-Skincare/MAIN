    "n_base_section_7G7GJX": {
      "type": "n_base-section",
      "name": "t:sections.n_base-section.name",
      "settings": {
        "use_own_file": true,
        "modifier": "reverse",
        "modifier_2": "none",
        "background_color": "none",
        "heading": "<h2>Qure’s Micro-Infusion goes where your skin cream can’t…</h2>",
        "text": "<p>Its tiny, almost painless, 24K gold-plated, EO-sterilized (ethylene oxide) 0.5 mm microneedles gently press onto the skin’s surface to help<em> improve the feel of firmness</em>, smooth texture, and <em>reduce the look of fine lines and wrinkles</em>.<br/><br/>The invisible micro-channels then deliver science-backed serums onto the skin’s surface, <em>tailored to address specific skin goals</em> — enhancing absorption and helping active ingredients work more effectively where they’re applied.</p>",
        "button_label": "Shop Now",
        "button_url": "#buy_box",
        "wistia_url": "a1pykz2tp0"
      }
    },
