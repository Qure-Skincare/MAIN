    "n_easy_steps_BPz487": {
      "type": "n_easy-steps",
      "blocks": {
        "items_c9npMc": {
          "type": "items",
          "settings": {
            "text": "<h3>Cleanse</h3><p>Cleanse your face thoroughly and spritz the <a href=\"https://qureskincare.com/products/dermal-mist\" title=\"https://qureskincare.com/products/dermal-mist\"><span style=\"text-decoration:underline\">Dermal Mist</span></a> to refresh and prepare your skin further.</p>",
            "image": "shopify://shop_images/mixed_mi_1.webp",
            "image_mobile": "shopify://shop_images/mi-1-mob_10d274d3-9488-48b7-bc9c-4f36e48e9ce1.webp"
          }
        },
        "items_9NgrHQ": {
          "type": "items",
          "settings": {
            "text": "<h3>Prepare</h3><p>Twist off the cap of the serum vial and screw on the sterile needle head.</p>",
            "image": "shopify://shop_images/mixed_mi_2.webp",
            "image_mobile": "shopify://shop_images/mi-2-mob_0692c2e6-eb84-4d03-ac7a-f8f386d88f25.webp"
          }
        },
        "items_7kdhmY": {
          "type": "items",
          "settings": {
            "text": "<h3>Treat</h3><p>Remove the cap and stamp gently across your face using light pressure, working section-by-section.</p>",
            "image": "shopify://shop_images/mixed_mi_3.webp",
            "image_mobile": "shopify://shop_images/mi-3-mob_474650ff-a9f7-4ec8-b784-d9c7da333689.webp"
          }
