      "block_order": [
        "wistia_video_VKQPYd"
      ],
      "name": "t:sections.n_guide-content.name",
      "settings": {
        "use_own_file": true,
        "active": false,
        "must_read": false,
        "heading": "Charging Your Device",
        "text": "<h2>Charging Your Device</h2><p>[wistia_video]</p><p>To charge your device, connect the supplied USB-C cord to your Q-Rejuvalight Pro and plug into a USB power adapter.</p><p>While charging, the indicator will flash white.</p><p>When the battery is fully charged, the indicator will be solid white.</p><p>No light when plugged in means the device is fully charged already.</p><p>Tips to maximize battery life:</p><ul><li>Avoid leaving your device charging for long periods of time.</li><li>Avoid letting the battery completely run out.</li><li>Do not use your device while it's connected to the charger.</li></ul>",
        "slides_per_view": ""
      }
    },
    "n_guide_content_image_block_cPibDj": {
      "type": "n_guide-content-image-block",
      "blocks": {
        "image_with_text_K9ehRX": {
          "type": "image_with_text",
          "settings": {
            "image_position": "bottom",
            "image": "shopify://shop_images/pro-aging-mode_48e6573e-1352-4139-a9f2-f196e7ae9c9e.webp",
            "text": "<p><strong>Skin Rejuvenating Mode</strong></p><p>On Skin Rejuvenating Mode, red and infrared wavelengths work together to help improve the appearance of skin texture and firmness.</p>"
          }
        },
        "image_with_text_MhmTwm": {
          "type": "image_with_text",
          "settings": {
            "image_position": "bottom",
            "image": "shopify://shop_images/anti-breakout_73b4be2a-03f4-450b-842f-70de73a3421b.webp",
            "text": "<p><strong>Skin Clearing Mode</strong></p><p>Our Skin Clearing Mode combines blue and red light wavelengths. Blue targets the bacteria associated with mild-to-moderate acne, while red helps calm and soothe the appearance of irritated skin.</p>"
          }
        }
      },
      "block_order": [
        "image_with_text_K9ehRX",
        "image_with_text_MhmTwm"
