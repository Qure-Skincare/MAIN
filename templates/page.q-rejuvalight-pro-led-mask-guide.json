        "active": false,
        "must_read": true,
        "heading": "Content Requirements",
        "text": "<h2>Content Requirements</h2><p>Messaging must include:</p><ul><li>Backed by clinical research and </li><li>proven to work!</li><li>Clinical results from home - minus the 'clinical' costs</li><li>Personalized treatments - world's first customizable LED mask </li><li>App operated</li><li>Personal experience</li></ul><p>[quote_content]",
        "slides_per_view": ""
      }
