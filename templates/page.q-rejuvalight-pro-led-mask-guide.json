    "n_guide_content_step_abi9bF": {
      "type": "n_guide-content-step",
      "blocks": {
        "step_by_step_JF67Bn": {
          "type": "step_by_step",
          "settings": {
            "image": "shopify://shop_images/q-rejuvalight-pro-step-1_e2d527e9-861d-4c96-b54d-5dc5318eaf88.webp",
            "text": "<h6>Step 1</h6><p>Set up your mask by attaching the adjustable strap.</p><p>With the logos facing down, slide the strap into the first clip. Loop the strap through the adjustor and second clip. </p>"
          }
        },
        "step_by_step_eQEzeJ": {
          "type": "step_by_step",
          "settings": {
            "image": "shopify://shop_images/q-rejuvalight-pro-step-2_be5d4ec2-ece3-43c4-9822-23c13ef963cb.webp",
            "text": "<h6>Step 2</h6><p>Secure the strap with the provided pin on the inner side of the mask.</p>"
          }
        },
        "step_by_step_Te3GP7": {
          "type": "step_by_step",
          "settings": {
            "image": "shopify://shop_images/q-rejuvalight-pro-step-3_96e3327a-e8f5-40c2-8325-6f5a2803c032.webp",
            "text": "<h6>Step 3</h6><p>Insert goggles from the inside of the mask. </p><p>Ensure that the smaller side of the goggles go in first.</p>"
          }
        },
        "step_by_step_tQ9VtV": {
          "type": "step_by_step",
          "settings": {
            "image": "shopify://shop_images/q-rejuvalight-pro-step-4_f322baf5-59d9-4635-b243-f8d19f81047e.webp",
            "text": "<h6>Step 4</h6><p>Prepare your skin for your treatment by cleansing and dry thoroughly.</p><p>[note_green]<strong>Tip:</strong>Use our Dermal Mist to further cleanse and prepare your skin.[/note]</p>"
          }
        },
        "step_by_step_qxHmBK": {
          "type": "step_by_step",
          "settings": {
            "image": "shopify://shop_images/q-rejuvalight-pro-step-5_6736dd64-1d94-4e1e-b77c-e8144d84824d.webp",
            "text": "<h6>Step 5</h6><p>Press and hold the power button ON for 2-3 seconds until the indicator light turns on.</p><p>Position the mask on your face. Adjust the straps to fit your face comfortably.</p>"
          }
        },
        "step_by_step_WnrY8L": {
          "type": "step_by_step",
          "settings": {
            "image": "shopify://shop_images/q-rejuvalight-pro-step-6_8c9bfa6f-f329-4c5e-8e88-ce01533ba462.webp",
            "text": "<h6>Step 6</h6><p>Choose your treatment either in the Qure app or directly on the mask.</p><p>Press the power button once for Skin Rejuvenation mode, or press it twice for Skin Clearing mode.</p>"
          }
        },
        "wistia_video_x766ef": {
          "type": "wistia_video",
          "settings": {
            "desktop": true,
            "wistia_url": "j7op01weqs",
            "image": "shopify://shop_images/quick-start-guide.webp",
            "label_text": "Watch: Quick Start Guide"
          }
        },
        "quote_nLdfQ3": {
          "type": "quote",
          "settings": {
            "style": "red",
            "text": "<p><strong>Light sensitivity test:</strong>We recommend performing a light sensitivity test 24 hours before using this device for your first treatment. To perform this, apply the product to your inner forearm, ensuring the light shines directly onto the skin. Use it for a full 3-minute treatment. Wait for 24 hours. If you experience pain, discomfort, or redness lasting more than 2 hours, you might be light-sensitive. Please consult a doctor for advice before continuing use.</p>"
          }
        }
      },
