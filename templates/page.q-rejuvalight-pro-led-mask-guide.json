      "settings": {
        "use_own_file": true,
        "active": true,
        "must_read": false,
        "heading": "Product Information",
        "text": "<h2>Product Information</h2><ul><li>Quick, 3-minute fully personalized LED mask</li><li>Clinically studied LED wavelengths shown to improve skin’s firmness and texture</li><li>5 light wavelengths including 415nm (Blue), 605nm (Amber), 630nm (Red), 660nm (Deep Red), 880nm (Infrared)</li><li>Choose from 3 treatment modes: Skin Rejuvenation, Skin Clearing, or custom treatment via the app</li><li>Wireless, hands-free operation</li><li>Pairs perfectly with your skincare routine to boost absorption and results</li></ul>",
        "slides_per_view": ""
      }
    },
    "n_guide_content_step_hPhbKk": {
      "type": "n_guide-content-step",
      "blocks": {
        "step_by_step_mz9P9K": {
          "type": "step_by_step",
          "settings": {
            "image": "shopify://shop_images/q-rejuvalight-pro-step-1.webp",
            "text": "<h6>Step 1</h6><p>Set up your mask by attaching the adjustable strap.</p><p>With the logos facing down, slide the strap into the first clip. Loop the strap through the adjustor and second clip. </p>"
          }
        },
        "step_by_step_HKgizn": {
          "type": "step_by_step",
          "settings": {
            "image": "shopify://shop_images/q-rejuvalight-pro-step-2.webp",
            "text": "<h6>Step 2</h6><p>Secure the strap with the provided pin on the inner side of the mask.</p>"
          }
        },
        "step_by_step_WD3NBh": {
          "type": "step_by_step",
          "settings": {
            "image": "shopify://shop_images/q-rejuvalight-pro-step-3.webp",
            "text": "<h6>Step 3</h6><p>Insert goggles from the inside of the mask. </p><p>Ensure that the smaller side of the goggles go in first.</p>"
          }
        },
        "step_by_step_yKczif": {
          "type": "step_by_step",
          "settings": {
            "image": "shopify://shop_images/q-rejuvalight-pro-step-4.webp",
            "text": "<h6>Step 4</h6><p>Prepare your skin for your treatment by cleansing and dry thoroughly.</p><p>[note_green]<strong> Tip:</strong> Use our Dermal Mist to further cleanse and prepare your skin.[/note]</p>"
          }
        },
        "step_by_step_Gyp368": {
          "type": "step_by_step",
          "settings": {
            "image": "shopify://shop_images/q-rejuvalight-pro-step-5.webp",
            "text": "<h6>Step 5</h6><p>Press and hold the power button ON for 2-3 seconds until the indicator light turns on.</p><p>Position the mask on your face. Adjust the straps to fit your face comfortably.</p>"
          }
        },
        "step_by_step_8HjUHy": {
          "type": "step_by_step",
          "settings": {
            "image": "shopify://shop_images/q-rejuvalight-pro-step-6.webp",
            "text": "<h6>Step 6</h6><p>Choose your treatment either in the Qure app or directly on the mask.</p><p>Press the power button once for Skin Rejuvenation mode, or press it twice for Skin Clearing mode.</p>"
          }
        },
