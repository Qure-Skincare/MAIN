    "n_skincare_lifestyle_qhHX4N": {
      "type": "n_skincare-lifestyle",
      "blocks": {
        "numbered_list_PJLt6X": {
          "type": "numbered_list",
          "settings": {
            "text": "<p><strong>Cleanse and exfoliate regularly</strong></p><p>Daily cleansing removes pore-clogging bacteria, while regular exfoliation with Beta-Hydroxy Acid (BHA) helps reduce irritation and prevents future breakouts</p>",
            "image": "shopify://shop_images/sk_life_1_acne.webp"
          }
        },
        "numbered_list_NV3RFz": {
          "type": "numbered_list",
          "settings": {
            "text": "<p><strong>Keep your tools and surfaces clean</strong></p><p>Makeup tools and your phone collect bacteria that clog pores. Cleaning them regularly can reduce the chances of breakouts and help keep your skin fresh.</p>",
            "image": "shopify://shop_images/sk_life_2_acne.webp"
          }
        },
        "numbered_list_YMhmcw": {
          "type": "numbered_list",
          "settings": {
            "text": "<p><strong>Change your pillowcase every 2-3 days</strong></p><p>To prevent buildup of oil, sweat, and bacteria that can lead to breakouts and irritation.</p>",
            "image": "shopify://shop_images/sk_life_3_acne.webp"
          }
        }
      },
      "block_order": [
        "numbered_list_PJLt6X",
        "numbered_list_NV3RFz",
        "numbered_list_YMhmcw"
      ],
      "name": "t:sections.n_skincare-lifestyle.name",
      "settings": {
        "use_own_file": true,
        "text": "<h2>Skincare is a lifestyle</h2><p>Caring for your skin goes beyond the products you use. It\u2019s about adopting habits that support your skin\u2019s health every day. Our dermatologists recommend these expert tips to help you reach your skin goals even faster.</p>"
      }
    },
