    "n_skincare_lifestyle_qhHX4N": {
      "type": "n_skincare-lifestyle",
      "blocks": {
        "numbered_list_q89zRq": {
          "type": "numbered_list",
          "settings": {
            "text": "<p><strong>Exfoliate 1-2 times per week</strong></p><p>With an at-home peel that contains Alpha-Hydroxy Acids (AHAs) to remove dead skin and make fine lines less visible.</p>",
            "image": "shopify://shop_images/sk_life_1.webp"
          }
        },
        "numbered_list_NyjLLc": {
          "type": "numbered_list",
          "settings": {
            "text": "<p><strong>Reduce sugar intake</strong></p><p>High blood sugar triggers glycation, which damages collagen and makes skin lose elasticity, leading to wrinkles and sagging</p>",
            "image": "shopify://shop_images/sk_life_2.webp"
          }
        },
        "numbered_list_JHymyn": {
          "type": "numbered_list",
          "settings": {
            "text": "<p><strong>Sleep on your back</strong></p><p>Sleeping on your back on a <a href=\"http://127.0.0.1:5500/page.skincare-plan-results.html\">Silk Pillowcase</a> reduces friction on the skin and helps prevent wrinkles caused by excess pressure.</p>",
            "image": "shopify://shop_images/sk_life_3.webp"
          }
        }
      },
      "block_order": [
        "numbered_list_q89zRq",
        "numbered_list_NyjLLc",
        "numbered_list_JHymyn"
      ],
      "name": "t:sections.n_skincare-lifestyle.name",
      "settings": {
        "use_own_file": true,
        "text": "<h2>Skincare is a lifestyle</h2><p>Caring for your skin goes beyond the products you use. It’s about adopting habits that support your skin’s health every day. Our dermatologists recommend these expert tips to help you reach your skin goals even faster.</p>"
      }
