    "n_how_it_works_KcAWUk": {
      "type": "n_how-it-works",
      "blocks": {
        "tab_Yh4Eif": {
          "type": "tab",
          "settings": {
            "tab_heading": "Skin Rejuvenating",
            "text": "The Q-Rejuvalight Pro LED mask uses 5 light wavelengths and two modes for customizable skincare. Our FDA-cleared device targets your skin's needs.",
            "image": "shopify://shop_images/mask_aging.webp",
            "sub_heading": "<h6>Skin Rejuvenating Mode</h6>",
            "sub_text": "<p>On Skin Rejuvenating Mode, red and infrared wavelengths work together to help improve the appearance of skin texture and firmness.</p><p>Red light helps improve the look of skin smoothness and radiance. Deep red and infrared light work at different depths of the skin’s surface to help improve the look of wrinkles over time.</p>",
            "color_1": "#840d43",
            "color_text_1": "<p>Infrared <strong>(880 nm)</strong></p>",
            "color_2": "#b80e0d",
            "color_text_2": "<p>Deep Red <strong>(660 nm)</strong></p>",
            "color_3": "#f5181e",
            "color_text_3": "<p>Red <strong>(630 nm)</strong></p>",
            "color_4": "#fd8e15",
            "color_text_4": "<p>Amber <strong>(605 nm)</strong></p>"
          }
        },
        "tab_NQBQjY": {
          "type": "tab",
          "settings": {
            "tab_heading": "Skin Clearing",
            "text": "The Q-Rejuvalight Pro LED mask uses 5 light wavelengths and two modes for customizable skincare. Our FDA-cleared device targets your skin's needs.",
            "image": "shopify://shop_images/mask_breakout.webp",
            "sub_heading": "<h6>Skin Clearing Mode</h6>",
            "sub_text": "<p>Our Skin Clearing Mode combines blue and red light wavelengths. Blue (415 nm) helps with mild-to-moderate acne, while red (630 nm) helps calm and soothe the appearance of irritated skin.</p><p>Together, these wavelengths help improve the appearance of breakouts, support clearer-looking skin, and promote a balanced, healthier-looking complexion.</p>",
            "color_1": "#2b5aa2",
            "color_text_1": "<p>Blue <strong>(415 nm)</strong></p>",
            "color_2": "#f5181e",
            "color_text_2": "<p>Red <strong>(630 nm)</strong></p>",
            "color_3": "",
            "color_text_3": "",
            "color_4": "",
            "color_text_4": ""
          }
        },
        "accordion_nhUHzz": {
          "type": "accordion",
          "settings": {
            "heading": "Technical specifications",
            "text": "<p><strong>TREATMENT TIME: </strong> 3 minutes<br /><strong>CERTIFICATES: </strong> FDA, TGA, CE, UKCA<br /><strong>OPERATION: </strong>Wireless, hands-free<br /><strong>WAVELENGTH: </strong>415nm (Blue), 605nm (Amber), 630nm (Red), 660nm (Deep Red), 880nm (Infrared)<br /><strong>TREATMENT TIME: </strong> 2 hours<br /><strong>CHARGING TIME: </strong> 3 minutes<br /><strong>LEDs: </strong> 160 dual core</p>"
          }
        },
        "accordion_wGfm7F": {
          "type": "accordion",
          "settings": {
            "heading": "Treatment details",
            "text": "<p><strong>USE: </strong> Use daily after cleansing, before topical skincare<br /><strong>PRO-AGING TREATMENT: </strong> 415nm (Blue), 605nm (Amber), 630nm (Red), 660nm (Deep Red), 880nm (Infrared)<br /><strong>ANTI-BREAKOUT TREATMENT: </strong> 415nm (Blue), 630nm (Red)<br /><strong>CUSTOMIZED TREATMENT: </strong> Choose treatment modes for each facial area via app<br /><strong>Skin Type: </strong>Most suitable for Fitzpatrick Skin Types I-IV</p>"
          }
        }
      },
      "block_order": [
        "tab_Yh4Eif",
        "tab_NQBQjY",
        "accordion_nhUHzz",
        "accordion_wGfm7F"
      ],
      "name": "t:sections.n_how-it-works.name",
      "settings": {
        "use_own_file": true,
        "heading": "<h2>How it works</h2>"
      }
    },
