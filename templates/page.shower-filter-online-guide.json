            "text": "<h6>Step 2</h6><p>Remove the old cartridge and replace with a new cartridge. Firmly press the new cartridge into the filter housing.</p>"
          }
        },
        "step_by_step_iKiiwJ": {
          "type": "step_by_step",
          "settings": {
            "image": "shopify://shop_images/shower-replace-step-3.webp",
            "text": "<h6>Step 3</h6><p>Replace the shower cover and turn clockwise to secure it.</p>"
          }
        },
