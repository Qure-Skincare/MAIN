    "mi_faq_page_faq_header_idf6hK": {
      "type": "mi-faq-page-faq-header",
      "name": "t:sections.faq-header.name",
      "settings": {
        "heading": "Enjoy Smoother, Healthier Skin at Home in Just 5 Minutes with Our Micro-Infusion System",
        "text": "<p>Created In Partnership With <strong>Leading Dermatologists</strong></p>",
        "number_of_views": "3,201",
        "number_of_shared": "743",
        "image": "shopify://shop_images/micro_infusion-banner.webp",
        "image_mobile": "shopify://shop_images/micro_infusion-bannerMob.webp"
      }
    },
    "mi_faq_page_richtext_simple_NTk4id": {
      "type": "mi-faq-page-richtext-simple",
      "name": "t:sections.richtext-simple.name",
      "settings": {
        "heading": "What Is the Qure Micro-Infusion System?",
        "text": "<p>The Qure Micro-Infusion System is a simple yet <strong>powerful skincare device</strong> that brings the benefits of micro-needling to your home. It helps to reduce the appearance of fine lines, smooths skin texture, and enhances the effectiveness of your serums to improve your skin’s appearance and boost your confidence.</p><p>Use it for <strong>just 5 minutes</strong> every 2 weeks to infuse active ingredients deep into your skin, promoting a brighter, more radiant complexion.<br/></p>"
      }
    },
    "mi_faq_page_richtext_simple_ykbALR": {
      "type": "mi-faq-page-richtext-simple",
      "name": "t:sections.richtext-simple.name",
      "settings": {
        "heading": "How Fast Can I See Results?",
        "text": "<p>With the Qure Micro-Infusion System, many users notice improvements in their skin’s appearance after the first use.</p><p>While it won’t transform your skin overnight, <strong>you’ll likely see a brighter, more hydrated complexion the next day.</strong></p><p>With consistent use every 2 weeks, you can expect to see a significant reduction in fine lines and a smoother skin texture within a month, helping you <strong>achieve a more youthful and radiant look.</strong></p><p>Dermatologists recommend using the device every 2 weeks for a minimum of 3 months for optimal results. Consistency is key!</p>"
      }
    },
    "mi_faq_page_text_with_image_FBmpip": {
      "type": "mi-faq-page-text-with-image",
      "name": "t:sections.text-with-image.name",
      "settings": {
        "heading": "How Does the Qure Micro-Infusion System Work?",
        "text": "<p><strong>Micro-Needles:</strong> Tiny, gold needles (thinner than a human hair) create micro-channels in your skin. This helps stimulate collagen production and triggers your skin’s natural healing process.</p><p><strong>Serum Delivery:</strong> The micro-channels allow our scientifically-backed serums to penetrate deeply, delivering active ingredients exactly where they are needed to reduce the appearance of wrinkles, fine lines, and dark spots.</p><p><strong>Hydration and Plumping: </strong>The infusion process enhances your skin's ability to retain moisture, resulting in a plumper, more hydrated, and radiant looking complexion.</p>",
        "sub_heading": "The Qure Micro-Infusion System is designed to revitalize your skin through a precise and effective process:",
        "sub_text": "<p>Use the Qure Micro-Infusion System for just 5 minutes every 2 weeks for a minimum of 3 months and <strong>enjoy smoother looking more youthful skin</strong> and a more confident you.</p>",
        "image": "shopify://shop_images/mi_needle.webp"
      }
    },
    "mi_faq_page_richtext_simple_dt3Fhp": {
      "type": "mi-faq-page-richtext-simple",
      "name": "t:sections.richtext-simple.name",
      "settings": {
        "heading": "Can I Use the Qure Micro-Infusion System If I Have Sensitive Skin?",
        "text": "<p>Absolutely! The Qure Micro-Infusion System is designed to be <strong>gentle and effective</strong> for most skin types.</p><p>We know that everyone's skin is unique, and that's why our device is crafted to minimize irritation while maximizing results. The 24k gold plated micro-needles are designed to be virtually painless, and our serums are formulated to soothe and nourish even the most delicate skin.</p>"
      }
    },
