      "settings": {
        "use_own_file": true,
        "active": false,
        "must_read": true,
        "heading": "Content Requirements",
        "text": "<h2>Content Requirements</h2><p>Messaging must include:</p><ul><li>Formulated to target three key skin concerns: uneven texture, fine lines and wrinkles, and dark spots or discoloration.</li><li>Powered by clinically backed actives like peptides, niacinamide, and hyaluronic acid.</li><li>Supports skin renewal and barrier health with daily use</li><li>Lightweight, fast-absorbing, and non-irritating.</li><li>Simplifies your routine with one serum that does it all.</li><li>Visible results with consistent use.</li></ul>",
        "slides_per_view": ""
      }
