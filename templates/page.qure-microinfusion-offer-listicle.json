        "use_own_file": true,
        "text": "<h1>5 Reasons Micro-Infusion Is the Smarter Alternative to Expensive Creams</h1><p><strong>Finally:</strong> A painless, sterile, at-home treatment that targets wrinkles and dark spots… even when skincare stops working.</p>",
        "image": "shopify://shop_images/micro-infusion-listicle-hero.webp",
        "image_mobile": "shopify://shop_images/micro-infusion-listicle-hero-mob.webp",
        "button_url": "",
