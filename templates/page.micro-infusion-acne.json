    "n_science_backed_hdPt9c": {
      "type": "n_science-backed",
      "blocks": {
        "left_accordion_1": {
          "type": "left_accordion",
          "settings": {
            "heading": "What can it do for your skin",
            "text": "<p>Helps reveal a smoother-looking, more radiant complexion. Formulated to help improve the appearance of dark spots and uneven tone for skin that looks refreshed and luminous.<br/><br/><strong>Skin Concerns:</strong> Ideal for skin that appears uneven in tone or texture and shows visible dark spots or post-blemish marks.</p>"
          }
        },
        "left_accordion_2": {
          "type": "left_accordion",
          "settings": {
            "heading": "All Ingredients",
            "text": "<p><strong>Epidermal Growth Factor (EGF):</strong> Works at a cellular level to repair and rejuvenate skin. Reduces appearance of wrinkles, improves hydration, and prevents hyperpigmentation.</p><p><strong>Niacinamide:</strong> Superstar ingredient that helps with most skin concerns from soothing to brightening and clarifying, and reducing look of fine lines and wrinkles.</p><p><strong>Tranexamic Acid:</strong> Helps to fade look of dark spots and discoloration. Assists with brightening and evening look of skin tone.</p><p><strong>All ingredients: </strong>Rosa Damascena Flower Water, Propanediol, Glycerin, Tranexamic Acid, Niacinamide, Panthenol, Chrysanthellum Indicum Extract, Ethylhexylglycerin, Tripeptide-1, Xanthan Gum, Allantoin, Sh-Oligopeptide-1.</p><p>[note]Please note that due to innovative updates and changing regulatory guidelines, the ingredient lists provided here may differ slightly from those on our packaging and distributor websites.[/note]</p>"
          }
        },
        "left_feedback_1": {
          "type": "left_feedback",
          "settings": {
            "rating": "",
            "text": "<p>“Thrilled with the results. I’ve noticed a dramatic reduction in redness and my scars!”</p>",
            "country_image": "shopify://shop_images/america-flag_f1f6c160-90c6-4ba9-8bfc-d9039a28d2af.webp",
            "username": "Jessica K.",
            "badge_text": "Verified customer"
          }
        }
      },
      "block_order": [
        "left_accordion_1",
        "left_accordion_2",
        "left_feedback_1"
      ],
      "name": "t:sections.n_science-backed.name",
      "settings": {
        "use_own_file": true,
        "modifier": "single",
        "text": "",
        "text_mobile": "<h2>Science-Backed Micro-Infusion Serums</h2><p>Choose the exact serum to use in your Micro-Infusion treatment, or get both and mix them together to experience a complete set of benefits that addresses your specific skin concerns.</p>",
        "image": "shopify://shop_images/serums-lady.webp",
        "left_heading": "<h3>Rejuvenating Serum</h3><p>For Dark Spots</p>",
        "right_heading": "",
        "left_image": "shopify://shop_images/Dark_Spots_7.png"
      }
    },
