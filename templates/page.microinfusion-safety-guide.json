    "n_guide_content_step_dqEU6J": {
      "type": "n_guide-content-step",
      "blocks": {
        "step_by_step_rB6VkD": {
          "type": "step_by_step",
          "settings": {
            "modifier": "text_with_image",
            "image": "shopify://shop_images/micro-infusion-2-step-1.webp",
            "text": "<h6>Step 1</h6><p>Cleanse your face thoroughly to remove all traces of makeup and lotions. Pat dry.</p><p>Spritz our <a href=\"#\" title=\"#\">Dermal Mist</a> to refresh and prepare your skin further and wait for it to dry before beginning.</p>"
          }
        },
        "step_by_step_tmY7zP": {
          "type": "step_by_step",
          "settings": {
            "modifier": "text_with_image",
            "image": "shopify://shop_images/micro-infusion-2-step-2.webp",
            "text": "<h6>Step 2</h6><p>Pour one full Qure serum ampoule into the device chamber.</p><p>[note_green]<strong>Tip:</strong> Use one ampoule per treatment. The serum should only fill the Device halfway.[/note]</p>"
          }
        },
        "step_by_step_RRYde7": {
          "type": "step_by_step",
          "settings": {
            "modifier": "text_with_image",
            "image": "shopify://shop_images/micro-infusion-2-step-3.webp",
            "text": "<h6>Step 3</h6><p>Attach the micro-needle head with the plastic cap still on the device.</p><p>Turn the device upside down for 1-2 minutes to allow the serum to saturate the needles.</p>"
          }
        },
        "step_by_step_tBVY9n": {
          "type": "step_by_step",
          "settings": {
            "modifier": "text_with_image",
            "image": "shopify://shop_images/micro-infusion-2-step-4.webp",
            "text": "<h6>Step 4</h6><p>Remove the cap and stamp gently across your face using light pressure.</p><p>[note_green]<strong>Tip:</strong> Do not apply too much pressure! The needles are designed to be gentle on your skin.[/note]</p>"
          }
        },
        "step_by_step_jnfmDm": {
          "type": "step_by_step",
          "settings": {
            "modifier": "text_with_image",
            "image": "shopify://shop_images/micro-infusion-2-step-5.webp",
            "text": "<h6>Step 5</h6><p>Work section by section, repeating each area 2-3 times.</p><p>[note_green]<strong>Tip:</strong> Each time you stamp, overlap the previous stamp halfway to ensure each area of the face is stamped at least twice.[/note]</p>"
          }
        },
        "step_by_step_QtBTaD": {
          "type": "step_by_step",
          "settings": {
            "modifier": "text_with_image",
            "image": "shopify://shop_images/micro-infusion-2-step-6.webp",
            "text": "<h6>Step 6</h6><p>Make sure the serum is always at the needle end while stamping. If the serum is not coming through, tilt the device upward or lean your head back to help it flow. </p><p>You can also pop the lid back on, turn the device upside down, and tap the end firmly to push the serum down.</p>"
          }
        },
        "step_by_step_DVFgC6": {
          "type": "step_by_step",
          "settings": {
            "modifier": "text_with_image",
            "image": "shopify://shop_images/micro-infusion-2-step-7.webp",
            "text": "<h6>Step 7</h6><p>Carefully unscrew the needle head, put the cap back on, and dispose of the used needle head. Each one is single-use only.</p><p>[note_green]<strong>Tip:</strong> Do not reuse needle heads - even if it looks clean. It is designed for one treatment only.[/note]</p>"
          }
        },
        "wistia_video_yTdh9R": {
          "type": "wistia_video",
          "settings": {
            "desktop": true,
            "wistia_url": "68e0msztnb",
            "image": "shopify://shop_images/how_to-mi.webp",
            "label_text": "Watch: How To Use"
          }
        },
        "quote_Updmkd": {
          "type": "quote",
          "settings": {
            "style": "blue",
            "text": "<p><strong>After your treatment:</strong></p><ul><li>Apply gentle, hydrating skincare if you need it.</li><li>Avoid using makeup or active ingredients (like retinoids or acids) for at least 24 hours.</li><li>Avoid heat, sweating, and direct sun.</li></ul>"
          }
        }
      },
