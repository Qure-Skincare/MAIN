      "settings": {
        "use_own_file": true,
        "active": true,
        "must_read": false,
        "heading": "Quick Start Guide",
        "text": "<h2>Quick Start Guide</h2><p>[wistia_video]</p><p>To install your new Faucet Filter, you'll need the following:</p><ul><li>Qure Faucet Filter with 360° nozzle</li><li>Multi-functional adapter (provided)</li><li>Adapter wrench (provided)</li><li>Bubbler wrench (provided)</li><li>Thread adapters (provided)</li><li>Silicone ring (provided)</li></ul>"
      }
    },
    "n_guide_content_step_g8LF3K": {
      "type": "n_guide-content-step",
      "blocks": {
        "step_by_step_3fNAar": {
          "type": "step_by_step",
          "settings": {
            "image": "shopify://shop_images/faucet-replace-step-1.webp",
            "text": "<h6>Step 1</h6><p>Turn off the faucet. Rotate the filter cartridge cover counterclockwise to remove the old filter cartridge.</p>"
          }
        },
        "step_by_step_gnWHrn": {
          "type": "step_by_step",
          "settings": {
            "image": "shopify://shop_images/faucet-replace-step-2.webp",
            "text": "<h6>Step 2</h6><p>Peel off the seal from the new filter cartridge. Install the cartridge into the faucet housing.</p>"
          }
        },
        "step_by_step_BMxdhh": {
          "type": "step_by_step",
          "settings": {
            "image": "shopify://shop_images/faucet-replace-step-3.webp",
            "text": "<h6>Step 3</h6><p>Screw the filter cartridge cover clockwise to secure it.</p>"
          }
        },
        "step_by_step_bkQAj8": {
          "type": "step_by_step",
          "settings": {
            "image": "shopify://shop_images/faucet-replace-step-4.webp",
            "text": "<h6>Step 4</h6><p>Turn on the faucet and let raw water flow for 5 seconds, then switch to purified water mode and let it run for 3 minutes before first use.</p>"
          }
        },
        "wistia_video_bAfYVy": {
          "type": "wistia_video",
          "settings": {
            "desktop": false,
            "wistia_url": "1no4jx6uxf",
            "image": "shopify://shop_images/how_to_replace.webp"
          }
        }
      },
