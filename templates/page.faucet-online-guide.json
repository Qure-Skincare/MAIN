    "n_guide_content_image_block_c7qkcC": {
      "type": "n_guide-content-image-block",
      "blocks": {
        "image_with_text_Brt6yd": {
          "type": "image_with_text",
          "settings": {
            "image_position": "bottom_shower_image",
            "image": "shopify://shop_images/Q-fitler.webp",
            "text": "<p><strong>Filtered water mode</strong></p><p>When the dial is turned to the Q position, the water flows through the filter cartridge located at the front of the device.</p><p>The filtered water then exits through the lower outlet, providing clean, purified water ideal for facial cleansing and other skincare routines.</p>"
          }
        },
        "image_with_text_hEpzBY": {
          "type": "image_with_text",
          "settings": {
            "image_position": "bottom_shower_image",
            "image": "shopify://shop_images/Q-fitler2.webp",
            "text": "<p><strong>Tap water mode</strong></p><p>By turning the dial to the tap water symbol, the water bypasses the filter cartridge and exits directly from the upper outlet of the device.</p><p>This mode is perfect for tasks where filtered water is not required, such as rinsing your hands or filling a container with unfiltered water.</p>"
          }
        }
      },
      "block_order": [
        "image_with_text_Brt6yd",
