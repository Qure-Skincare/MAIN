      "name": "t:sections.n_guide-content-image-block.name",
      "settings": {
        "use_own_file": true,
        "active": false,
        "must_read": false,
        "heading": "Water Mode Selection",
        "text": "<h2>Water Mode Selection</h2><p>The mode selection toggle is located on the side of the faucet filter.</p><p>It is clearly labeled with two symbols: a Q for filtered water and a tap water symbol for unfiltered water.</p>"
      }
    },
    "n_guide_content_nnexwb": {
      "type": "n_guide-content",
      "name": "t:sections.n_guide-content.name",
      "settings": {
        "use_own_file": true,
        "active": false,
        "must_read": false,
        "heading": "Care & Maintenance",
        "text": "<h2>Care & Maintenance</h2><p>To ensure your Qure Faucet Filter works optimally, regular maintenance is important:</p><ul><li>Wipe the filter's surface with a damp cloth.</li><li>Avoid harsh chemicals when cleaning, and do not use steel wool, abrasive cleaners, or corrosive liquids.</li><li>Replace the filter every 3 months, or sooner if the water flow slows down.</li><li>Periodically check the connections to ensure there are no leaks.</li></ul>",
        "slides_per_view": ""
      }
    },
    "n_guide_content_4idDGr": {
      "type": "n_guide-content",
      "name": "t:sections.n_guide-content.name",
      "settings": {
        "use_own_file": true,
        "active": false,
        "must_read": false,
        "heading": "Troubleshooting & Adjustments",
        "text": "<h2>Troubleshooting & Adjustments</h2><p>Having trouble? Don't worry, most issues are quick to solve.</p><p>[hr]</p><h6>Water leaks</h6><p>Ensure that all silicone rings and adapters are properly fitted. If leaks persist, check the connections and tighten as needed.</p><p>[hr]</p><h6>Odor in the water</h6><p>If you notice any unusual odors, flush the filter by running water through the system for several minutes.</p><p>[hr]</p><h6>Low or uneven water pressure</h6><p>Low flow can occur if the filter is clogged. Remove and clean or replace the filter as needed.</p>",
        "slides_per_view": ""
      }
    },
    "n_guide_faq_VCcdx9": {
      "type": "n_guide-faq",
      "blocks": {
        "faq_item_3Laqmb": {
          "type": "faq_item",
          "settings": {
            "heading": "How often should I replace the filter cartridge?",
            "text": "<p>The filter should be replaced every 3 months to ensure optimal performance.</p>"
          }
        },
        "faq_item_RjHhJ4": {
          "type": "faq_item",
          "settings": {
            "heading": "Can I use the water for drinking?",
            "text": "<p>No, the Qure Faucet Filter is designed specifically for skincare purposes and is not suitable for drinking water.</p>"
          }
        },
        "faq_item_UBDQFH": {
          "type": "faq_item",
          "settings": {
            "heading": "What should I do if the water flow slows down?",
            "text": "<p>Remove the filter and clean surface impurities. If the flow doesn't improve, replace the filter.</p>"
          }
        },
        "faq_item_8tRtCr": {
          "type": "faq_item",
          "settings": {
            "heading": "Is this filter compatible with all faucets?",
            "text": "<p>The filter is compatible with most standard faucets, but not with shower heads, induction faucets, or pull-out faucets without detachable aerators.</p>"
          }
        },
