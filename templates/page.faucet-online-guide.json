    "n_guide_content_step_XzrxG3": {
      "type": "n_guide-content-step",
      "blocks": {
        "step_by_step_77Waft": {
          "type": "step_by_step",
          "settings": {
            "image": "shopify://shop_images/faucet-step-1.webp",
            "text": "<h6>Step 1</h6><p>Remove your faucet's aerator or rectifier using the bubbler wrench.</p><p>Locate the threading and identify if it is internal or external. If there's no threading, you'll need the multi-functional adapter.</p>"
          }
        },
        "step_by_step_mVFznz": {
          "type": "step_by_step",
          "settings": {
            "image": "shopify://shop_images/faucet-step-2.webp",
            "text": "<h6>Step 2</h6><p>Use the adapter that matches your faucet type (internal, external, or no threading).</p><p>Make sure the sealing ring is in place inside the adapter.</p>"
          }
        },
        "step_by_step_KEwBab": {
          "type": "step_by_step",
          "settings": {
            "image": "shopify://shop_images/faucet-step-3.webp",
            "text": "<h6>Step 3</h6><p>Screw the adapter onto your faucet by hand first.</p><p>Use the wrench provided to tighten it gently (don't over-tighten).</p>"
          }
        },
        "step_by_step_xmPFwj": {
          "type": "step_by_step",
          "settings": {
            "image": "shopify://shop_images/faucet-step-4.webp",
            "text": "<h6>Step 4</h6><p>Once the adapter is secure, twist on the Qure Faucet Filter. Make sure it's snug but not forced.</p><p>[note_green]<strong>Tip:</strong>You should hear 2 clicks when the Faucet Filter is correctly secured.[/note]</p>"
          }
        },
        "step_by_step_UwCyYB": {
          "type": "step_by_step",
          "settings": {
            "image": "shopify://shop_images/faucet-step-5.webp",
            "text": "<h6>Step 5</h6><p>Let cold water run through the filter for 30-60 seconds to flush the system.</p><p>Done! You're ready to enjoy filtered, skin-friendly water.</p>"
          }
        },
        "wistia_video_WDx3E6": {
          "type": "wistia_video",
          "settings": {
            "desktop": true,
            "wistia_url": "t0xzq5gdvm",
            "image": "shopify://shop_images/how_to_install.webp"
          }
        },
        "quote_a84MEQ": {
          "type": "quote",
          "settings": {
            "style": "red",
            "text": "<p>The Qure Faucet Filter is intended for skincare purposes only. It should not be used for drinking water or any other non-skincare applications. Replace the filter every three months for optimal performance. If you experience any issues such as water leaks or reduced flow, follow the maintenance guidelines in this manual.</p>"
          }
        }
      },
