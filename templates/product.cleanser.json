    "n_faq_cleanser": {
      "type": "n_faq",
      "blocks": {
        "accordion_sensitive_skin": {
          "type": "accordion",
          "settings": {
            "heading": "Is this cleanser suitable for sensitive skin?",
            "text": "<p>Yes. This cleanser is gentle, non-stripping, and dermatologically tested to be suitable for sensitive skin. It is clinically tested, hypoallergenic, non-irritating, and allergy tested. As with any skincare product, we recommend patch testing before first use, especially if you have highly reactive skin.</p>"
          }
        },
        "accordion_dry_out": {
          "type": "accordion",
          "settings": {
            "heading": "Will this cleanser dry out my skin?",
            "text": "<p>No. The formula is glycerin based rather than water based, which helps maintain moisture while cleansing. Most users reported their skin felt hydrated, soft, and comfortable after washing, not tight or stripped.</p>"
          }
        },
        "accordion_daily_use": {
          "type": "accordion",
          "settings": {
            "heading": "Can I use this cleanser every day?",
            "text": "<p>Yes, this cleanser is designed for daily use, morning and night. The formula is pH balanced and suitable for consistent use without disrupting your skin barrier.</p><p>For makeup or sunscreen removal, use a pre-cleanse first. This formula is best suited as a second cleanse or a morning cleanse when your skin needs care - not stripping.</p>"
          }
        },
        "accordion_with_actives": {
          "type": "accordion",
          "settings": {
            "heading": "Can I use this with retinol, vitamin C, or exfoliating acids?",
            "text": "<p>Yes. This cleanser was formulated to work alongside active routines. By supporting the skin barrier, it helps make actives feel more comfortable over time rather than adding extra stress to the skin.</p>"
          }
        },
        "accordion_exfoliate": {
          "type": "accordion",
          "settings": {
            "heading": "Will this cleanser exfoliate my skin?",
            "text": "<p>It contains a gentle level of lactic acid that helps refine the look of skin texture over time. It is not a harsh exfoliant and does not replace dedicated exfoliating treatments.</p>"
          }
        }
      },
