      "type": "n_intro",
      "name": "t:sections.n_intro.name",
      "settings": {
        "use_own_file": true,
        "text": "<p><strong>The Qure Neck & Décolletage LED System</strong> uses LED light therapy to visibly firm, smooth, and brighten the delicate skin on your neck and chest. </p><p>This guide will show you exactly how to use it, care for it, and get the best results from your treatments.</p>"
