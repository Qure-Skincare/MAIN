    "n_guide_content_step_bfgn4t": {
      "type": "n_guide-content-step",
      "blocks": {
        "step_by_step_p98rhw": {
          "type": "step_by_step",
          "settings": {
            "text": "<h6>Step 1</h6><p>Clean and dry your neck and décolletage to ensure the area is clear from any dirt, sweat, or skincare products.</p>"
          }
        },
        "step_by_step_rRiUhK": {
          "type": "step_by_step",
          "settings": {
            "text": "<h6>Step 2</h6><p>Insert the USB-C cable from the Neck & Décolletage LED System into the port located on the top of the controller.</p>"
          }
        },
        "step_by_step_9bwbiE": {
          "type": "step_by_step",
          "settings": {
            "text": "<h6>Step 3</h6><p>Secure the system around the neck to comfortably treat the entire neck and décolletage area.</p><p>Alternatively, position the strap across the shoulders to lower the LED panel slightly and extend coverage further across the décolletage.</p>"
          }
        },
        "step_by_step_pzjKh4": {
          "type": "step_by_step",
          "settings": {
            "text": "<h6>Step 4</h6><p>Press the ON/OFF button on the controller. </p><p>The treatment will automatically run for 10 minutes and shut off at the end of the session.</p>"
          }
        },
        "image_dNMfLP": {
          "type": "image",
          "settings": {
            "image": "shopify://shop_images/neck-decollatage-video.webp"
          }
        },
        "quote_WEMwW4": {
          "type": "quote",
          "settings": {
            "style": "red",
            "text": "<p><strong>Light sensitivity test:</strong> We recommend performing a light sensitivity test 24 hours before using this system for your first treatment. To perform this, apply the product to your inner forearm, ensuring the light shines directly onto the skin. Use it for a full 10-minute treatment. Wait for 24 hours. If you experience pain, discomfort, or redness lasting more than 2 hours, you might be light-sensitive. Please consult a doctor for advice before continuing use.</p>"
          }
        }
      },
