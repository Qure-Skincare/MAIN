{% assign excluded = false %}

{% for block in section.blocks %}
  {% if block.type == 'exclude-page' %}
    {% if page.handle == block.settings['exclude-page'].handle %}
      {% assign excluded = true %}
      {% break %}
    {% endif %}
  {% endif %}
{% endfor %}

<style>
  {% if settings.enable_gamification == false %} 
    #endrock_gamificationHeader {
      display: none;
    }

    {% if excluded %}
      :root {
      --height-bar: 51px !important;
    }
    @media (max-width: 991px) {
      :root {
        --height-bar: 35px !important;
      }
    }
    {% else %}
    :root {
      --height-bar: 40px !important;
    }
    @media (max-width: 991px) {
      :root {
        --height-bar: 32px !important;
      }
    }
    {% endif %}
  {% else  %}
    :root {
        --height-bar: 56px;
    }
    #announcement-bar {
        display: none;
    }
    @media screen and (max-width: 1024px) {
      :root {
        --height-bar: 80px;
      }
    }
  {% endif %}
</style>

{% unless excluded %}
  {{ '__endrock_rotating-announcement.css' | asset_url | stylesheet_tag }}
  {{ 'splide.min.css' | file_url | stylesheet_tag }}

  <div
    id="announcement-bar"
    class="announcement-bar-rotating"
    style="--ans-bar-font-size:16px; --anc-bar-font-weight :400;"
  >
    <div class="announcement-container">
      <div class="splide" aria-label="Splide carousel">
        <div class="splide__track">
          <ul class="splide__list">
            {% for block in section.blocks %}
              {% if block.type == 'announcement' %}
                <li
                  class=" splide__slide announcement-bar-content text-center {% if forloop.first %}active{% endif %} {% if block.settings['button-label'] != blank %}has-button{%  endif %}"
                  data-index="{{ forloop.index0 }}"
                >
                  <a
                    class="announcement-bar-link"
                    {% if block.settings['button-url'] != blank -%}
                      href="{{ block.settings.button-url }}"
                    {%- endif %}
                  >
                    {% if block.settings.icon != blank -%}
                      <img
                        loading="lazy"
                        width="18"
                        height="18"
                        class="icon"
                        src="{{ block.settings.icon | image_url }}"

                        alt="{{ block.settings.icon.alt | escape }}"
                      >
                    {%- endif %}
                    <span>{{ block.settings.heading }}</span>
                    {% if block.settings['button-label'] != blank -%}
                      <div class="button" href="{{ block.settings.button-url }}">
                        {{ block.settings['button-label'] }}
                      </div>
                    {%- endif %}
                  </a>
                </li>
              {% endif %}
            {%- endfor %}
          </ul>
        </div>
        <div class="splide__arrows splide__arrows--ltr">
          <button
            class="splide__arrow splide__arrow--prev"
            type="button"
            aria-label="Previous slide"
            aria-controls="splide01-track"
          >
            {% render '__endrock_rotating-announcement-icon-arrow-right',
              class: 'arrow arrow-icon-left',
              id: 'prevButton'
            %}
          </button>
          <button
            class="splide__arrow splide__arrow--next"
            type="button"
            aria-label="Next slide"
            aria-controls="splide01-track"
          >
            {% render '__endrock_rotating-announcement-icon-arrow-right',
              class: 'arrow arrow-icon-right',
              id: 'nextButton'
            %}
          </button>
        </div>
      </div>
    </div>
  </div>

  <script>
    let delay = {{ section.settings.delay }}
    document.addEventListener('DOMContentLoaded', function() {
        loadScriptOnce('__endrock_splide','{{ 'splide.min.js' | file_url }}');
        loadScriptOnce('__endrock_rotating-announcement','{{ '__endrock_rotating-announcement.js' | asset_url }}');
    });
  </script>
{% endunless %}

{% schema %}
{
  "name": "announcement-bar-rotating",
  "settings": [
    {
      "type": "number",
      "id": "delay",
      "label": "Delay in milliseconds",
      "default": 3000
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",

          "id": "heading",
          "label": "t:common.header"
        },
        {
          "type": "text",
          "id": "button-label",
          "label": "t:common.button-label"
        },
        {
          "type": "text",

          "id": "button-url",
          "label": "t:common.button-url"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "icon"
        }
      ]
    },
    {
      "type": "exclude-page",
      "name": "Exclude page",
      "settings": [
        {
          "type": "page",
          "id": "exclude-page",
          "label": "Page"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.announcement-bar.name"
    }
  ]
}
{% endschema %}
