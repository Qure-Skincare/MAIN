{% doc %}
  Renders a quick title links section for index page 
{% enddoc %}

<!-- QUICK TILE LINKS -->
 {% if section.settings.use_own_file %}
    <link rel="stylesheet" href="https://qureskincaredns.com/sections/new/quick-tile-links/quick-tile-links.css" />
 {% endif %}
<section class="quick-tile-links">
    <div class="container">
        <article>
            <ul>
                {% for block in section.blocks %}
                    {% if block.type == 'items' %}
                        <a href="{{ block.settings.link_url }}"{% if block.settings.new == true %} data-badge="{{ 'sections.n_index-quick-title-links.new' | t }}{% endif %}">
                            {% if block.settings.image != blank %}
                                <img src="{{ block.settings.image | image_url }}" alt="{{ block.settings.image.alt | escape }}"/>
                            {% endif %}
                            {% if block.settings.heading != blank %}
                                <span>{{ block.settings.heading }}</span>
                            {% endif %}
                        </a>
                    {% endif %}
                {% endfor %}
            </ul>
        </article>
    </div>
</section>
<!-- QUICK TILE LINKS END -->


{% schema %}
{
    "name": "t:sections.n_index-quick-title-links.name",
    "settings": [
        {
            "type": "checkbox",
            "id": "use_own_file",
            "label": "t:common.use-own-file",
            "default": false
        }
    ],
    "blocks": [
        {
            "type": "items",
            "name": "t:common.items",
            "settings": [
                {
                    "type": "text",
                    "id": "heading",
                    "label": "t:common.header"
                },
                {
                    "type": "url",
                    "id": "link_url",
                    "label": "t:common.link-url"
                },
                {
                    "type": "image_picker",
                    "id": "image",
                    "label": "t:common.image"
                },
                {
                    "type": "checkbox",
                    "id": "new",
                    "label": "t:common.new",
                    "default": false
                }
            ]
        }
    ]
}
{% endschema %}