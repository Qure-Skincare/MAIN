{% doc %}
  Renders a mobile category slider section for index page 
{% enddoc %}

<link rel="stylesheet" href="https://qureskincaredns-main.com/assets/shopify/css/index-mobile-category-slider.css">
<link rel="stylesheet" href="https://qureskincaredns-main.com/sections/isolated/categories/categories-list.css" />
<div class="category__slider qure__section d-block d-md-none" style="--section-padding-top: 16px;--section-padding-bottom: 16px;--section-padding-top-mob: 16px;--section-padding-bottom-mob: 16px;">
    <div class="container">
        <div class="swiper qure__swiper" id="qure__swiper-categories" data-section-id="categories"
        data-autoplay="false" data-loop="false" data-mobile="4" data-tablet="6" data-desktop="6" data-spacing="15"
        data-pagination-fraction="true">
            <div class="swiper-wrapper">
            {% for block in section.blocks %}
                {% if block.type == 'slider' %}
                    <div class="swiper-slide">
                        {% if block.settings.url != blank %}
                            <a href="{{ block.settings.url }}" class="qure__categories-list">
                                {% if block.settings.image != blank %}
                                    <div class="qure__cat-img"><img src="{{ block.settings.image | image_url }}" class="img-fluid" alt="{{ block.settings.image.alt | escape }}" /></div>
                                {% endif %}
                                {% if block.settings.heading != blank %}
                                    <div class="qure__cat-desc">{{ block.settings.heading }}</div>
                                {% endif %}  
                            </a>
                        {% endif %}
                    </div>
                {% endif %}
            {% endfor %}
            </div>
        </div>
    </div>
</div>


{% schema %}
{
  "name": "t:sections.index-mobile-category-slider.name",
  "blocks": [
        {
        "type": "slider",
        "name": "t:common.slider",
            "settings": [
                {
                    "type": "text",
                    "id": "heading",
                    "label": "t:common.header"
                },
                {
                    "type": "url",
                    "id": "url",
                    "label": "t:common.link-url"
                },
                {
                    "type": "image_picker",
                    "id": "image",
                    "label": "t:common.image"
                }
            ]
        }
    ]
}
{% endschema %}