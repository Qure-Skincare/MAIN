{% doc %}
  Renders a sticky CTA section for micro-infusion-limited-edition-bundle page.
{% enddoc %}

<link rel="stylesheet" href="https://qureskincaredns-main.com/sections/isolated/sticky-cta/sticky-cta.css" />
   <div class="qure__sticky-atc">
        <div class="container">
            <div class="d-flex flex-wrap justify-content-between align-items-center py-16">
                {% if section.settings.heading != blank %}
                    <h1 class="fs-20 m-0 d-none d-md-block">{{ section.settings.heading 
                        | replace: '<p>', '' 
                        | replace: '</p>', '' 
                        | replace: '<em>', '<span class="limited_edition ml-15">'
                        | replace: '</em>', '</span>' }}</h1> 
                {% endif %}
                {% if section.settings.button-label != blank and section.settings.button-url != blank %}
                    <a href="{{ section.settings.button-url }}" class="text-uppercase btn btn--primary">{{ section.settings.button-label }}</a>
                {% endif %}
            </div>
        </div>
        <div class="align-items-center bg-light d-flex fs-16 gap-4 justify-content-center py-6 qure__user-online text-center">
            <div class="pulse"></div>
            {% if section.settings.text != blank %}
                {{ section.settings.text | replace: '<p>', '' | replace: '</p>', '' }}
            {% endif %}
        </div>
    </div>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            loadScriptOnce('sticky-cta', 'https://qureskincaredns-main.com/assets/js/sticky-cta.js');
        });
    </script>

{%  schema  %}
{
  "name": "t:sections.micro-infusion-lim-ed-bundle-sticky-button.name",
  "settings": [
    {
        "type": "richtext",
        "id": "heading",
        "label": "t:common.header"
    },
    {
        "type": "richtext",
        "id": "text",
        "label": "t:common.text"
    },
    {
        "type": "text",
        "id": "button-label",
        "label": "t:common.button-label"
    },
    {
        "type": "text",
        "id": "button-url",
        "label": "t:common.button-url"
    }
  ]
}
{% endschema %}