            "type": "money-back",
            "name": "t:common.money-back",
            "limit": 1,
            "settings": [
                {
                    "type": "text",
                    "id": "heading",
                    "label": "t:common.header"
                },
                {
                    "type": "text",
                    "id": "text",
                    "label": "t:common.text"
                },
                {
                    "type": "image_picker",
                    "id": "image",
                    "label": "t:common.image"
                }
            ]
        },
        {
            "type": "price",
            "name": "t:common.price",
            "limit": 1,
            "settings": [
                {
                    "type": "checkbox",
                    "id": "show_discount",
                    "label": "t:common.show_discount",
                    "default": false
                }
            ]
        },
        {
            "type": "description",
            "name": "t:common.description",
            "limit": 1,
            "settings": []
