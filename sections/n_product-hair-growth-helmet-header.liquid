{% doc %}
  Renders a product hair growth helmet header section
{% enddoc %}

{% if template.name == 'page' %}
    {% include 'n_get-product-data', product_handle: 'hair-growth-helmet' %}
    {% assign carousel_media = page.metafields.custom.carousel_media.value %}
{% else %}
    {% include 'n_get-product-data' %}
    {% assign carousel_media = product.metafields.custom.carousel_media.value %}
{% endif %}

{% if section.settings.use_own_file %}
    <link rel="stylesheet" href="https://qureskincaredns.com/alex/sections/isolated/helmet-home/helmet-home.css" />
{% endif %}
<style>
    .save_perc {
        display:none;
    }
</style>
<div class="qure__section helmet-home" id="helmet-home">
    <div class="container">
        <div class="helmet-home__grid">
            <div class="helmet-home__column">
                <div class="helmet-home__content">
                    <div class="helmet-home__header d-none d-md-block">
                        <div class="helmet-home__header-rating">
                            <img src="https://qureskincaredns.com/alex/sections/isolated/helmet-home/images/review-stars.webp" alt="review-stars">
                            {% if section.settings.seo_heading != blank %}
                                <span>{{ section.settings.seo_heading }}</span>
                            {% endif %}
                        </div>
                        {% if section.settings.heading != blank %}
                            <h1 class="helmet-home__header-title">{{ section.settings.heading }}</h1>
                        {% endif %}

                        {% if black_friday_discount_percent > 0 %}
                            <div class="helmet-home__header-price">
                                <div class="price-offer">
                                    <div class="price-offer__main">
                                        <div class="price-offer__current">{{ product_black_friday_price }}</div>
                                        <div class="price-offer__discount">{{ 'product.settings.save' | t }} {{ product_black_friday_price_save }}</div>
                                        <div class="price-offer__value">({{ 'special-offer.settings.total-value' | t }} {{ product_before_price }})</div>
                                    </div>
                                    <div class="price-offer__bf">
                                        <div class="price-offer__bf-label">{{ 'special-offer.settings.header' | t }}</div>
                                    </div>
                                </div>
                            </div>
                        {% else %}
                            {% include 'n-product-page-blocks-render', allowed_types: 'price' %}
                        {% endif %}
                    </div>

                    {{ 'sections.hair-growth-helmet.header.benefits_html' | t }}

                    {% include 'n-product-page-blocks-render', allowed_types: 'description,button' %}

                    {% if section.settings.reserved == true %}
                        <div class="helmet-home__ordering">
                            <div class="pre-order-info">
                                <div class="pre-order-info__status">{{ 'sections.hair-growth-helmet.header.reserve' | t }}</div>
                                <div class="pre-order-info__expected" data-bs-toggle="modal" data-bs-target="#shipment-modal">
                                    {{ 'sections.hair-growth-helmet.header.reserve_date' | t }}
                                    <img src="https://qureskincaredns.com/alex/sections/isolated/helmet-home/images/expected-arrow.svg" alt="expected-arrow" />
                                </div>
                            </div>
                        </div>
                    {% endif %}
                    
                    {% if section.settings.whitelist == true %}
                        <div class="helmet-home__ordering">
                            <button type="button" class="btn btn--primary" data-bs-toggle="modal" data-bs-target="#email-modal">
                                {{ 'sections.hair-growth-helmet.header.whitelist' | t }}
                                <img src="https://qureskincaredns.com/alex/sections/isolated/helmet-home/images/email-icon.svg" alt="email-icon" />
                            </button>
                            <div class="pre-order-info">
                                <div class="pre-order-info__status">{{ 'sections.hair-growth-helmet.header.unavailable' | t }}</div>
                                <div class="pre-order-info__expected">{{ 'sections.hair-growth-helmet.header.whitelist_date' | t }}</div>
                            </div>
                        </div>
                    {% endif %}

                    <div class="helmet-home__users-experienced" data-bs-toggle="modal" data-bs-target="#info-modal">
                        <img src="https://qureskincaredns.com/alex/sections/isolated/helmet-home/images/qure-headgear-1589-2.webp" alt="">
                        {{ 'sections.hair-growth-helmet.header.info_html' | t }}
                    </div>

                    {% render 'n-product-page-collapsed', product: product, page: page, class: 'helmet-home__according' %}
                    {% include 'n-product-page-blocks-render', allowed_types: 'money-back' %}

                    <div class="helmet-home__jump-to">
                        <h6>{{ 'product.settings.jumpto.header' | t }}</h6>
                        <ul class="jump-to">
                            {% for block in section.blocks %}
                                {% if block.type == 'jumpto' %}
                                    {% if block.settings.button-label != blank %}
                                        <li><a href="{{ block.settings.button-url }}">{{ block.settings.button-label }} <i class="fa-regular fa-arrow-down"></i></a></li>
                                    {% endif %}
                                {% endif %}
                            {% endfor %}
                        </ul>
                    </div>
                </div>
            </div>
            <div class="helmet-home__column">
                <div class="helmet-home__header d-md-none">
                    <div class="helmet-home__header-rating">
                        <img src="https://qureskincaredns.com/alex/sections/isolated/helmet-home/images/review-stars.webp" alt="review-stars">
                        {% if section.settings.seo_heading != blank %}
                            <span>{{ section.settings.seo_heading }}</span>
                        {% endif %}
                    </div>
                    {% if section.settings.heading != blank %}
                        <h1 class="helmet-home__header-title">{{ section.settings.heading }}</h1>
                    {% endif %}

                    {% include 'n-product-page-blocks-render', allowed_types: 'price' %}             
                </div>
                <div class="helmet-home__gallery">
                    <div class="swiper helmet-home__gallery-main" id="helmet-gallery">
                        <div class="swiper-wrapper">
                            {% if carousel_media != blank %}
                                {% render 'n-product-page-media-carousel', input_media_carousel: carousel_media, classname: 'slide-image', size: '720x' %}
                            {% endif %}
                        </div>
                    </div>
                    <div class="swiper helmet-home__gallery-thumbs d-md-none" id="helmet-gallery-thumbs">
                        <div class="swiper-wrapper">
                            {% if product.metafields.custom.carousel_media.value != blank %}
                                {% render 'n-product-page-media-carousel', input_media_carousel: carousel_media, classname: 'slide-thumbnail', size: '240x', thumbnails: true %}
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- MODALS -->
<div class="modal helmet-home-modal fade" id="shipment-modal">
    <div class="modal-dialog">
        <div class="modal-content helmet-home-modal__content">
            <div class="helmet-home-modal__text shipment-popup">
                <span>JOIN OUR EARLY ACCESS</span>
                <h6>Secure your Q-Renew LLLT Helmet before anyone else.</h6>
                <p>We know how hard it is to wait when you're ready for change. Pre-ordering ensures you're <strong>first in line</strong> once shipments begin.</p>
                <p>Your order will ship in January 2026, and you'll get <strong>early access</strong> to updates, usage tips, and progress guides before anyone else.</p>
                <hr />
                <span>Your pre-order includes</span>
                <strong>1-Year Money-Back Guarantee</strong>
                <p>Hair growth isn't instant. That's why we offer a money-back guarantee. If you don't see real results, get a full refund - no questions asked.</p>
                <strong>Free Worldwide Shipping</strong>
                <p>Your pre-order comes with free worldwide shipping.</p>
                <p>Orders shipped outside the U.S. may be subject to import duties, customs fees, or local taxes upon arrival. These are determined by your country’s customs authority and are the responsibility of the customer.</p>
                <button type="button" class="btn btn--primary">Pre-Order Now</button>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="modal">
                <img src="https://qureskincaredns.com/assets/images/cross_black.svg" alt="" />
            </button>
        </div>
    </div>
</div>
<div class="modal helmet-home-modal fade" id="info-modal">
    <div class="modal-dialog">
        <div class="modal-content helmet-home-modal__content">
            <div class="helmet-home-modal__text info-popup">
                    <h6>Discover the hair routine made for you</h6>
                    <p>Hair loss doesn’t look the same for everyone. Choose the concern that feels most familiar to see how Q-Renew can help.</p>
                    <hr />
                    <strong>Select your concern</strong>
                    <ul class="tabs" role="tablist">
                        <li>
                            <button class="active" data-bs-toggle="tab" data-bs-target="#crown-thinning" type="button">Crown thinning</button>
                        </li>
                        <li>
                            <button data-bs-toggle="tab" data-bs-target="#widening-part-line" type="button">Widening part line</button>
                        </li>
                        <li>
                            <button data-bs-toggle="tab" data-bs-target="#receding-hairline" type="button">Receding hairline</button>
                        </li>
                        <li>
                            <button data-bs-toggle="tab" data-bs-target="#reduced-volume" type="button">Reduced volume</button>
                        </li>
                        <li>
                            <button data-bs-toggle="tab" data-bs-target="#weaker-strands" type="button">Weaker strands</button>
                        </li>
                        <li>
                            <button data-bs-toggle="tab" data-bs-target="#shedding" type="button">Shedding</button>
                        </li>
                    </ul>
                    <div class="tab-content">
                        <div class="tab-pane fade show active" id="crown-thinning">
                            <p>For many women, the crown is one of the first areas to show thinning. Hormonal changes during menopause, stress, and genetics can all shorten the natural growth cycle.</p>
                            <p>Over time, follicles in this area can shrink and produce finer strands, which makes the scalp more visible at the top or back of the head.</p>
                            <strong>How Q-Renew helps</strong>
                            <p>By delivering light energy deep into the scalp, Q-Renew supports follicle activity in the crown area, helping to reduce visible thinning and improve overall coverage.</p>
                        </div>
                        <div class="tab-pane fade" id="widening-part-line">
                            <p>One of the most common and distressing signs of thinning is when the part line gets wider. It happens as follicles along the central scalp miniaturize and can produce thinner, weaker hairs.</p>
                            <p>This gradual loss of density makes the scalp more noticeable through the part.</p>
                            <strong>How Q-Renew helps</strong>
                            <p>Q-Renew's lasers are precisely distributed across the scalp, targeting the central line where thinning is most visible. By stimulating follicles along the part, it helps encourage thicker strands and support a more balanced, fuller-looking part line.</p>
                        </div>
                        <div class="tab-pane fade" id="receding-hairline">
                            <p>Thinning around the temples and hairline not only affects volume but can change the shape of the face.</p>
                            <p>This area is particularly vulnerable to hormonal shifts, stress, and genetics, and the delicate hairs here are often the first to weaken or stop growing.</p>
                            <strong>How Q-Renew helps</strong>
                            <p>Q-Renew provides full-front coverage, delivering light directly to the temples and hairline. This helps support follicle activity in these sensitive zones, encouraging healthier growth and support the appearance of a fuller hairline.</p>
                        </div>
                        <div class="tab-pane fade" id="reduced-volume">
                            <p>Hair that looks flat or limp is a sign that follicles are producing finer strands. Over time, this reduction in density changes the overall body and fullness of hair, leaving it without its natural lift and bounce.</p>
                            <strong>How Q-Renew helps</strong>
                            <p>By supporting follicle function across the entire scalp, Q-Renew encourages the appearance of thicker, stronger hair over time. The result is healthier density, giving hair more lift, movement, and natural fullness.</p>
                        </div>
                        <div class="tab-pane fade" id="weaker-strands">
                            <p>When follicles aren’t functioning at their best, the hair they produce grows in finer and more fragile. Weak strands break easily and don’t grow as long, creating the sense that your hair is stuck at a shorter length and never feels strong.</p>
                            <strong>How Q-Renew helps</strong>
                            <p>Q-Renew delivers light energy to the root, encouraging stronger hair fiber production over time. With consistent use, strands can grow in thicker and more resilient, reducing breakage and restoring a healthier look and feel.</p>
                        </div>
                        <div class="tab-pane fade" id="shedding">
                            <p>Excessive daily shedding can feel like an ongoing battle, with hair collecting in the shower, on your pillow, or in your brush. </p>
                            <p>Shedding often occurs when follicles exit the growth phase too early, a process often influenced by stress, hormones, or genetics.</p>
                            <strong>How Q-Renew helps</strong>
                            <p>Q-Renew works with your natural hair cycle, helping to extend the growth phase of follicles. Many users first notice a reduction in excess shedding before seeing new density, which sets the stage for stronger, fuller hair over time.</p>
                        </div>
                    </div>
                </div>
                <div class="helmet-home-modal__disclaimer">
                    *Results based on a 16-week self-reported study. Participants used the helmet 7 times per week. Individual results may vary.
                </div>
            <button type="button" class="btn-close" data-bs-dismiss="modal">
                <img src="https://qureskincaredns.com/assets/images/cross_black.svg" alt="cross_black" />
            </button>
        </div>
    </div>
</div>

{% if section.settings.whitelist == true %}
    <div class="modal email-modal fade" id="email-modal" >
        <div class="modal-dialog">
            <div class="modal-content email-modal__content">
                <div class="email-modal-form">
                    <div class="klaviyo-form-QQP9fe"></div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal">
                    <img src="https://qureskincaredns.com/assets/images/cross_black.svg" alt="cross_black" />
                </button>
            </div>
        </div>
    </div>
{% endif %}
<!-- MODALS -->

<!-- Reusable Wistia Modal -->
<div class="modal fade filter-modal" id="reusableWistiaModal" data-bs-backdrop="static" data-bs-keyboard="false"
    tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-md filter-dialog">
        <div class="modal-content">
            <div class="modal-header border-0">
                <button type="button" class="btn btn-close" data-bs-dismiss="modal" aria-label="Close">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
            <div class="modal-body">
                <div id="wistiaVideoContainer" class="filter-modal-video"></div>
            </div>
        </div>
    </div>
</div>
<!-- Reusable Wistia Modal end -->

<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadScriptOnce('helmet-home-swiper', 'https://qureskincaredns.com/alex/sections/isolated/helmet-home/helmet-home.js');
        loadScriptOnce('wistia-popup', 'https://qureskincaredns.com/assets/js-new/wistia-popup.js');
        loadScriptOnce('wistia-script', 'https://fast.wistia.com/assets/external/E-v1.js');
    });
</script>


{% schema %}
