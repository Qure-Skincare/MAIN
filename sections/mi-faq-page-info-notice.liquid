{% doc %}
Renders a info notice section for microinfusion faq page.
{% enddoc %}

<div class="qure__section" style="--section-padding-top: 10px; --section-padding-bottom: 80px;">
    <div class="container">
        <div class="border color-background px-30 py-25 rounded fs-md-20 fs-18"
            style="--bs-border-width: 2px; --bs-border-style: dashed; --bs-border-color: #212428; --section-background:#FEFCEF;">
            {% if section.settings.heading != blank %}
                <p class="color-orange fw-600 mb-0">{{ section.settings.heading }}</p>
            {% endif %}
            {% if section.settings.text != blank %}
                <p class="fw-600">{{ section.settings.text }}</p>
            {% endif %}
        </div>
    </div>
</div>

{% schema %}
{
    "name": "t:sections.info-notice.name",
    "settings": [
    {
        "type": "text",
        "id": "heading",
        "label": "t:common.header"
    },
    {
        "type": "text",
        "id": "text",
        "label": "t:common.text"
    }
    ]
}
{% endschema %}
