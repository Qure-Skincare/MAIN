{% doc %}
  Renders a “Should know” section with intro copy and a text swiper.
{% enddoc %}

<!-- SHOULD KNOW -->
{% if section.settings.use_own_file %}
    <link rel="stylesheet" href="https://qureskincaredns.com/sections/new/should-know/should-know.css" />
{% endif %}
<section class="should-know">
    <div class="container">
        {% if section.settings.text != blank %}
            <article>
                {{ section.settings.text }}
            </article>
        {% endif %}
        <div
            class="c-swiper"
            data-swiper='{
                    "slidesPerView": 1.1,
                    "spaceBetween": 16,
                    "loop": false,
                    "pagination": {
                        "el": ".c-swiper-pagination",
                        "type": "custom"
                    },
                    "navigation": {
                        "prevEl": ".c-swiper-button-prev",
                        "nextEl": ".c-swiper-button-next"
                    },
                    "breakpoints": {
                        "768": {
                            "slidesPerView": 2,
                            "spaceBetween": 40
                        }
                    }
                }'
        >
            <div class="swiper-wrapper">
                {% for block in section.blocks %}
                    {% if block.type == 'text_slider' %}
                        {% if block.settings.text != blank %}
                            <div class="swiper-slide">
                                    {{ block.settings.text }}
                                {% if block.settings.note != blank %}
                                    <small class="c-note c-note--info">{{ block.settings.note }}</small>
                                {% endif %}
                            </div>
                        {% endif %}
                    {% endif %}
                {% endfor %}
            </div>
            <div class="c-swiper-nav">
                <button type="button" class="c-swiper-button-prev"></button>
                <div class="c-swiper-pagination"></div>
                <button type="button" class="c-swiper-button-next"></button>
            </div>
        </div>
        {% if section.settings.button_label != blank and section.settings.button_url != blank %}
            <a href="{{ section.settings.button_url }}" class="btn btn--primary">
                {{ section.settings.button_label }}
                <i class="e-icon e-icon-arrow"></i>
            </a>
        {% endif %}
    </div>
</section>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        loadScriptOnce('base-slider', 'https://qureskincaredns.com/sections/new/base-slider/base-slider.js');
    });
</script>
<!-- SHOULD KNOW END -->

{% schema %}
{
    "name": "t:sections.n_should-know.name",
    "settings": [
        {
            "type": "checkbox",
            "id": "use_own_file",
            "label": "t:common.use-own-file",
            "default": false
        },
        {
            "type": "richtext",
            "id": "text",
            "label": "t:common.text"
        },
        {
            "type": "text",
            "id": "button_label",
            "label": "t:common.button-label"
        },
        {
            "type": "url",
            "id": "button_url",
            "label": "t:common.button-url"
        }
    ],
    "blocks": [
        {
            "type": "text_slider",
            "name": "t:common.text-slider",
            "settings": [
                {
                    "type": "richtext",
                    "id": "text",
                    "label": "t:common.text"
                },
                {
                    "type": "richtext",
                    "id": "note",
                    "label": "t:common.note"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "t:sections.n_should-know.name"
        }
    ]
}
{% endschema %}
