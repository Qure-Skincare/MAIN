{% doc %}
  Renders a proven results with goods section
{% enddoc %}

<link href="https://qureskincaredns.com/sections/global/banner-with-text/banner-text.css" rel="stylesheet" type="text/css">
<div id="results" class="qure__section after no_hype_evidence" style="--section-padding-top: 40px; --section-padding-bottom: 80px; --section-padding-top-mob: 20px; --section-padding-bottom-mob: 20px;">
    <div class="container">
        <div class="heading_wrapper mb-40">
          {% if section.settings.heading != blank %}
            <h2 class="banner-text--heading text-start text-md-center">{{ section.settings.heading }}</h2>
          {% endif %}
        </div>
        <div class="row custom__grid" style="--column-gap:60px; --column-gap-mobile:32px;">
            <div class="col-12 custom__block">
                <div class="swiper qure__swiper" id="qure__swiper-evidence-slider" data-section-id="evidence-slider"
                    data-autoplay="false" data-loop="false" data-mobile="1" data-tablet="1" data-desktop="2"
                    data-spacing="32" data-pagination-fraction="true">
                    <div class="swiper-wrapper">
                      {% for block in section.blocks %}
                        {% if block.type == 'slider' %}
                          <div class="swiper-slide">
                            <div class="card skin-card p-16 p-md-24 m-1 border rounded-2"
                                style="--bs-border-radius: 10px;">
                                {% if block.settings.image != blank %}
                                  <img src="{{ block.settings.image | image_url }}" class="card-img-top rounded-2" alt="{{ block.settings.image.alt | escape }}">
                                {% endif %}
                                <div class="text-with-progress d-flex align-items-center col-gap my-10" style="--col-gap:12px">
                                    <div class="text-progress-circle position-relative d-inline-flex fw-600 fs-20">
                                      {% assign percent_str = block.settings.percent_value %}
                                      {% assign percent_num = percent_str | remove: "%" | plus: 0 %}
                                      {% assign dashoffset = 100 | minus: percent_num %}
                                        <svg class="vMQQx" height="77" width="77" viewBox="-29 -29 58 58">
                                            <defs>
                                                <linearGradient id="gradient" x1="0" x2="0" y1="1" y2="0">
                                                    <stop offset="0%" stop-color="#C7E7DC"></stop>
                                                    <stop offset="100%" stop-color="#C7E7DC"></stop>
                                                </linearGradient>
                                            </defs>
                                            <circle stroke="rgba(221, 224, 228, 1)" fill="none" pathLength="100" class="K4v4P" r="24" style="stroke-width: 1px;"></circle>
                                            <circle visibility="visible" fill="none" pathLength="100" transform="rotate(-90)" class="OKwUu" r="24" stroke="url(#gradient)" style="stroke-dasharray: 100; stroke-dashoffset: {{ dashoffset }}; stroke-width: 5px;">
                                            </circle>
                                        </svg>
                                        {% if block.settings.percent_value != blank %}
                                          <span>{{ block.settings.percent_value }}</span>
                                        {% endif %}
                                    </div>
                                    {% if block.settings.percent_scale_text != blank %}
                                      {{ block.settings.percent_scale_text }}
                                    {% endif %}
                                </div>
                                {% if block.settings.product_image !=blank and block.settings.product_url != blank and block.settings.product_title != blank %}
                                  
                                {% endif %}
                                <a href="{{ block.settings.product_url }}" class="prod_wrapper d-flex justify-content-between align-items-center">
                                    <div class="prod_img_with_title d-flex align-items-center gap-3">
                                        <img src="{{ block.settings.product_image | image_url }}" alt="{{ block.settings.product_image.alt | escape }}">
                                        <p class="text-decoration-underline">{{ block.settings.product_title }}</p>
                                    </div>
                                    <div class="arrow">
                                        <img src="{{ 'sections.proven-results-with-goods.arrow_image' | t }}" alt="{{ 'sections.proven-results-with-goods.arrow_image.alt' | t | escape }}">
                                    </div>
                                </a>
                            </div>
                        </div>
                        {% endif %}
                      {% endfor %}
                    </div>
                    <div class="swiper-arrows-with-pagination d-flex align-items-center justify-content-center gap-4 mt-30">
                        <div class="qure-swiper-button-prev qure-swiper-arrow"><i class="fa-regular fa-angle-left"></i>
                        </div>
                        <div class="swiper-pagination position-relative bottom-0 w-auto"></div>
                        <div class="qure-swiper-button-next qure-swiper-arrow"><i class="fa-regular fa-angle-right"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadScriptOnce('main-slider', 'https://qureskincaredns.com/assets/js/main-slider.js');
    });
</script>

{% schema %}
{
  "name": "t:sections.proven-results-with-goods.name",
  "settings": [
    {
        "type": "text",
        "id": "heading",
        "label": "t:common.header"
    }
  ],
  "blocks": [
    {
        "type": "slider",
        "name": "t:common.slider",
        "settings": [
            {
                "type": "image_picker",
                "id": "image",
                "label": "t:common.image"
            },
            {
                "type": "text",
                "id": "percent_value",
                "label": "t:common.percent-value"
            },
            {
                "type": "richtext",
                "id": "percent_scale_text",
                "label": "t:common.percent-scale-text"
            },
            {
                "type": "image_picker",
                "id": "product_image",
                "label": "t:common.product-image"
            },
            {
                "type": "text",
                "id": "product_title",
                "label": "t:common.product-title"
            },
            {
                "type": "url",
                "id": "product_url",
                "label": "t:common.product-url"
            }
        ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.proven-results-with-goods.name"
    }
  ]
}
{% endschema %}