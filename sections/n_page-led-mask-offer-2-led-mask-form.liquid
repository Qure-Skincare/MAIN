                        <div class="swiper-slide">
                            <img src="sections/isolated/led-mask-offer/images/4.webp" alt="Skin Bundle Offer" />
                        </div>
                        <div class="swiper-slide">
                            <img src="sections/isolated/led-mask-offer/images/5.webp" alt="Skin Bundle Offer" />
                        </div>
                    </div>
                </div>
                <button class="c-swiper-button-next"></button>
            </div>
        </div>
        <div class="hero-product__main">
            <div class="e-pill-badge e-pill-badge--md">Limited Time Offer</div>
            <h2>Q-Rejuvalight Pro LED Mask</h2>
            <h4>+ FREE Neck &amp; Décolletage LED System</h4>
            <div class="c-special-offer" data-label="Special Offer">
                <div class="e-price">
                    <div class="e-price__main">
                        <div class="e-price__current">{$dyn}</div>
                        <div class="e-price__old">{$dyn}</div>
                    </div>
                </div>
