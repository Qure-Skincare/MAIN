    <div class="hero-product__container container">
        <div class="hero-product__gallery">
            <div
                class="c-swiper"
                data-swiper-thumbs="#limited-offer .c-swiper-thumbs"
                data-swiper='{
                        "slidesPerView": 1,
                        "spaceBetween": 16,
                        "navigation": {
                            "prevEl": "#limited-offer .c-swiper-button-prev",
                            "nextEl": "#limited-offer .c-swiper-button-next"
                        }
                    }'>
                <div class="swiper-wrapper">
                    <div class="swiper-slide">
                        <img src="sections/isolated/led-mask-offer/images/1.webp" alt="Skin Bundle Offer" />
                    </div>
                    <div class="swiper-slide">
                        <img src="sections/isolated/led-mask-offer/images/2.webp" alt="Skin Bundle Offer" />
