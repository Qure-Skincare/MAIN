                    </div>
                </div>
            </div>
            <div class="c-swiper-thumbs-nav">
                <button class="c-swiper-button-prev"></button>
                <div
                    class="c-swiper c-swiper-thumbs"
                    data-swiper='{
                            "slidesPerView": "auto",
                            "spaceBetween": 12
                        }'>
                    <div class="swiper-wrapper">
                        <div class="swiper-slide">
                            <img src="sections/isolated/led-mask-offer/images/1.webp" alt="Skin Bundle Offer" />
                        </div>
                        <div class="swiper-slide">
                            <img src="sections/isolated/led-mask-offer/images/2.webp" alt="Skin Bundle Offer" />
                        </div>
                        <div class="swiper-slide">
                            <img src="sections/isolated/led-mask-offer/images/3.webp" alt="Skin Bundle Offer" />
