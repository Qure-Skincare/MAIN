{% doc %}
Renders a faq section.
{% enddoc %}


<!-- Faq section Start -->
<div id="faq" class="faq_section qure__section color-background" style="--section-padding-top: 80px; --section-padding-bottom: 80px; --section-background: #F6F6F7; --section-padding-top-mob: 50px; --section-padding-bottom-mob: 50px;">
    <div class="container">
        <div class="qure__section-header text-center">
            {% if section.settings.heading != blank %}
                <h2 class="qure__section-heading">{{ section.settings.heading }}</h2>
            {% endif %}
        </div>
        <div class="faq_content">
            <div class="accordion accordion-flush" id="qure_faq-main">
                {% for block in section.blocks %}
                    {% if block.type == 'accordion' %}
                        {% assign order = forloop.index %}
                        <div class="accordion-item qure__accordion-item">
                            {% if block.settings.heading != blank %}
                            <button class="accordion-button collapsed qure__accordion-header" type="button"
                                data-bs-toggle="collapse" data-bs-target="#qure_faq-{{ order }}" aria-expanded="false"
                                aria-controls="qure_faq-{{ order }}">
                                {{ block.settings.heading }}
                            </button>
                            {% endif %}
                            <div id="qure_faq-{{ order }}" class="accordion-collapse collapse qure__accordion-content" data-bs-parent="#qure_faq-main">
                                {% if block.settings.text != blank %}
                                {% assign link_tag = '<a href="' 
                                    | append: block.settings.link_url 
                                    | append: '" class="text-decoration-underline" style="--base-color: #212529;">' 
                                    | append: block.settings.link_text %}
                                    <div class="accordion-body">{{ block.settings.text 
                                        | replace: '[link]', link_tag 
                                        | replace: '[/link]', '</a>' 
                                        | replace: '<strong>', '<span class="fw-600">'
                                        | replace: '</strong>', '</span>' 
                                        | replace: '<p><em>', '<span>'
                                        | replace: '</em></p>', '</span>' }}
                                        {% if block.settings.image != blank %}
                                            <div class="my-3">
                                                <img src="{{ block.settings.image | image_url }}" alt="{{ block.settings.image.alt | escape }}">
                                            </div>
                                        {% endif %}
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    {% endif %}
                {% endfor %}
            </div>
            <div class="pt-md-50 pt-40 d-flex align-items-center justify-content-center gap-3">
                    <h6 class="fm-body fw-500 mb-0">
                        {% if section.settings.text != blank %}
                            {{ section.settings.text }}
                            {% else %}
                            {{ 'sections.faq.text_before_button' | t }}{% endif %}</h6>
                    <a href="{{ section.settings.button_url }}" class="btn btn-sm btn--secondary">{% if section.settings.button_label != blank %}{{ section.settings.button_label }} {% else %} {{ 'sections.faq.button_label' | t }} {% endif %}<span><img src="{{ 'sections.faq.arrow_image' | t }}" alt="{{ 'section.faq.arrow_image.alt' | escape }}"></span></a>
            </div>
        </div>
    </div>
</div>


{% schema %}
{
    "name": "t:sections.faq.name",
    "settings": [
    {
        "type": "text",
        "id": "heading",
        "label": "t:common.header"
    },
    {
        "type": "text",
        "id": "text",
        "label": "t:common.text"
    },
    {
        "type": "text",
        "id": "button_label",
        "label": "t:common.button-label",
        "default": "Ask us"
    },
    {
        "type": "url",
        "id": "button_url",
        "label": "t:common.button-url"
    }
    ],
    "blocks": [
    {
        "type": "accordion",
        "name": "t:common.accordion",
        "settings": [
        {
            "type": "text",
            "id": "heading",
            "label": "t:common.header"
        },
        {
            "type": "richtext",
            "id": "text",
            "label": "t:common.text"
        },
        {
            "type": "url",
            "id": "link_url",
            "label": "t:common.link-url"
        },
        {
            "type": "text",
            "id": "link_text",
            "label": "t:common.link-text"
        },
        {
            "type": "image_picker",
            "id": "image",
            "label": "t:common.image"
        }
        ]
    }
    ],
    "presets": [
    {
        "name": "t:sections.faq.name"
    }
    ]
}
{% endschema %}