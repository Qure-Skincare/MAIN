{% doc %}
  Renders a faq section.
{% enddoc %}
<!-- Faq section Start -->
<div id="faq" class="faq_section qure__section color-background"
    style="--section-padding-top: 80px; --section-padding-bottom: 80px; --section-background: #F6F6F7; --section-padding-top-mob: 50px; --section-padding-bottom-mob: 50px;">
    <div class="container">
        <div class="qure__section-header text-center">
            {% if section.settings.heading != blank %}
                <h2 class="qure__section-heading">{{ section.settings.heading }}</h2>
            {% endif %}
        </div>
        <div class="faq_content">
            <div class="accordion accordion-flush" id="qure_faq-main">
                {% for block in section.blocks %}
                    {% if block.type == 'accordion' and block.settings.heading != blank and block.settings.text != blank %}
                        {% assign order = forloop.index %}
                        <div class="accordion-item qure__accordion-item">
                            <button class="accordion-button collapsed qure__accordion-header" type="button"
                                data-bs-toggle="collapse" data-bs-target="#qure_faq-{{ order }}" aria-expanded="false"
                                aria-controls="qure_faq-{{ order }}">
                                {{ block.settings.heading }}
                            </button>
                            <div id="qure_faq-{{ order }}" class="accordion-collapse collapse qure__accordion-content"
                                data-bs-parent="#qure_faq-main">
                                <div class="accordion-body">
                                    {{ block.settings.text }}
                                </div>
                            </div>
                    </div>
                    {% endif %}
                {% endfor %} 
            </div>
            <div class="pt-md-50 pt-40 d-flex align-items-center justify-content-center gap-3">
                {% if section.settings.text != blank %}
                    <h6 class="fm-body fw-500 mb-0">{{ section.settings.text }}</h6>
                {% endif %}
                {% if section.settings.button != blank and section.settings.url != blank %}
                    <a href="{{ section.settings.url }}" class="btn btn-sm btn--secondary">{{ section.settings.button }} <span><img src="{{ 'sections.faq.arrow_image' | t }}" alt="{{ 'section.faq.arrow_image.alt' | escape }}"></span></a>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% schema %}
{
  "name": "t:sections.faq.name",
  "settings": [
    {
        "type": "text",
        "id": "heading",
        "label": "t:common.header"
    },
    {
        "type": "text",
        "id": "text",
        "label": "t:common.text"
    },
    {
        "type": "text",
        "id": "button",
        "label": "t:common.button-label",
        "default": "Ask us"
    },
    {
        "type": "url",
        "id": "url",
        "label": "t:common.button-url"
    }
  ],
  "blocks": [
    {
        "type": "accordion",
        "name": "t:common.accordion",
        "settings": [
            {
                "type": "text",
                "id": "heading",
                "label": "t:common.header"
            },
            {
                "type": "richtext",
                "id": "text",
                "label": "t:common.text"
            }
        ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.faq.name"
    }
  ]
}
{% endschema %}