{% doc %}
  Renders a page banner section for microinfusion limited edition bundle page.
{% enddoc %}

<link rel="stylesheet" href="https://qureskincaredns-main.com/sections/isolated/page-banner/page-banner.css" />
    <div class="page__banner position-relative">
        <picture>
            {% if section.settings.image != blank %}
                <source media="(min-width:1920px)" srcset="{{ section.settings.image | image_url }}" class="img-fluid" width="1440" height="557">
                <source media="(min-width:1600px)" srcset="{{ section.settings.image | image_url }}" class="img-fluid" width="1440" height="557">
                <source media="(min-width:1100px)" srcset="{{ section.settings.image | image_url }}" class="img-fluid" width="1440" height="557">
                <source media="(min-width:767px)" srcset="{{ section.settings.image | image_url }}" class="img-fluid" width="1440" height="557">
            {% endif %}
            {% if section.settings.image_mobile != blank %}
                <source media="(min-width:540px)" srcset="{{ section.settings.image_mobile | image_url }}" class="img-fluid" width="1440" height="557">
                <img src="{{ section.settings.image_mobile | image_url }}" width="225" height="281" alt="{{ section.settings.image_mobile.alt | escape }}" class="img-fluid w-100">
            {% endif %}
        </picture>
        <div
            class="page__banner-wrapper position-absolute d-flex align-items-md-center justify-content-end top-0 bottom-0 start-0 end-0 pb-20">
            <div class="container">
                <div class="d-flex pt-md-0 pt-50">
                    <div class="ctm-width ctm-color mx-auto mx-md-0 add_clss" style="--ctm-width:550px;">
                        {% if section.settings.rating_image != blank and section.settings.rating_text != blank %}
                            <div class="align-items-center ct-banner-rating d-flex fs-16 gap-3 mb-10"><img src="{{ section.settings.rating_image | image_url }}" alt="{{ section.settings.rating_image.alt | escape }}" height="16px">
                                {{ section.settings.rating_text | replace: '<p>', '<span>' | replace: '</p>', '</span>' }}
                            </div>
                        {% endif %}
                        {% if section.settings.heading != blank %}
                            <h2 class="page-banner-title" style="--pg-title-mob:#212428; --font-h2:46px; --font-h2-mob:32px;">{{ section.settings.heading }}</h2>
                        {% endif %}
                        {% if section.settings.text != blank %}
                            <p class="py-25">{{ section.settings.text | replace: '<p>', '' | replace: '</p>', '' }}</p>
                        {% endif %}
                        <div class="ctm-width" style="--ctm-width:450px">
                            {% if section.settings.list != blank %}
                                <ul class="mb-20 check_list adi_cls d-none d-md-block">
                                    {{ section.settings.list | replace: '<p>', '<li>' | replace: '</p>', '</li>' }}
                                </ul>
                            {% endif %}
                           {% if section.settings.list_mobile != blank %}
                            <ul class="mb-20 check_list adi_cls d-md-none">
                                {{ section.settings.list_mobile | replace: '<p>', '<li>' | replace: '</p>', '</li>' }}
                            </ul>
                           {% endif %}
                            {% if section.settings.button_label != blank and section.settings.button_url != blank %}
                                <a href="{{ section.settings.button_url }}" class="btn btn--primary mb-5 mt-10 w-100 text-center fs-18">{{ section.settings.button_label }}</a>
                            {% endif %}
                        <div class="d-flex justify-content-center gap-4 mt-10 ltd_stock">
                            {% for block in section.blocks %}
                                {% if block.type == 'image_with_text' %}
                                    <div class="d-flex gap-2">
                                        {% if block.settings.image != blank %}
                                            <img src="{{ block.settings.image | image_url }}" alt="{{ block.settings.image.alt | escape }}">
                                        {% endif %}
                                        {% if block.settings.text != blank %}
                                            {{ block.settings.text }}
                                        {% endif %}
                                    </div>
                                {% endif %}
                            {% endfor %}
                        </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

{% schema %}
{
  "name": "t:sections.micro-infusion-lim-ed-bundle-page-banner.name",
  "settings": [
   {
        "type": "text",
        "id": "heading",
        "label": "t:common.header"
   },
   {
        "type": "richtext",
        "id": "text",
        "label": "t:common.text"
   },
   {
        "type": "richtext",
        "id": "list",
        "label": "t:common.list"
   },
   {
        "type": "richtext",
        "id": "list_mobile",
        "label": "t:common.list-mobile"
   },
   {
        "type": "richtext",
        "id": "rating_text",
        "label": "t:common.rating-text"
   },
   {
        "type": "image_picker",
        "id": "rating_image",
        "label": "t:common.rating-image"
   },
   {
        "type": "text",
        "id": "button_label",
        "label": "t:common.button-label"
   },
   {
        "type": "url",
        "id": "button_url",
        "label": "t:common.button-url"
   },
   {
        "type": "image_picker",
        "id": "image",
        "label": "t:common.image"
   },
   {
        "type": "image_picker",
        "id": "image_mobile",
        "label": "t:common.image-mobile"
   }
  ],
  "blocks": [
   {
      "type": "image_with_text",
      "name": "t:common.image-with-text",
      "settings": [
         {
            "type": "richtext",
            "id": "text",
            "label": "t:common.text"
         },
         {
            "type": "image_picker",
            "id": "image",
            "label": "t:common.image"
         }
      ]
   }
  ]
}
{% endschema %}