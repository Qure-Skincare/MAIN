{% comment %}
  Skincare routine: tabbed media (Wistia or image) + How / When copy (new layout).
{% endcomment %}

<!-- SKINCARE ROUTINE -->
{% if section.settings.use_own_file %}
  <link rel="stylesheet" href="https://qureskincaredns.com/sections/new/skincare-routine/skincare-routine.css">
{% endif %}
<section class="skincare-routine">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <h2 class="skincare-routine__title">{{ section.settings.heading }}</h2>
    {%- endif -%}
    <article class="skincare-routine__content">
      <div class="skincare-routine__media">
        {%- for block in section.blocks -%}
          {%- if block.type == 'tab' -%}
            <div class="skincare-routine__media-item{% if forloop.index == 1 %} show{% endif %}">
              {% if block.settings.wistia_url != blank %}
                <div class="c-wistia-embed-video">
                  <div class="wistia_responsive_padding">
                    <div class="wistia_responsive_wrapper">
                      <div class="wistia_embed wistia_async_{{ block.settings.wistia_url }} seo=false videoFoam=true">
                        <div class="wistia_swatch">
                          <img src="https://fast.wistia.com/embed/medias/{{ block.settings.wistia_url }}/swatch" alt="Watch: Doctorly">
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              {% endif %}
              {% if block.settings.image != blank %}
                <img src="{{ block.settings.image | image_url }}" alt="{{ block.settings.image.alt }}">
              {% endif %}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
      <ul class="skincare-routine__switcher">
        {% for block in section.blocks %}
          {% if block.type == 'tab' %}
            <li><button type="button" class="{% if forloop.index == 1 %}active{% endif %}">{{ block.settings.tab_heading }}</button></li>
          {% endif %}
        {% endfor %}
      </ul>
      <div class="skincare-routine__info">
        {% for block in section.blocks %}
          {% if block.type == 'tab' %}
            <div class="skincare-routine__info-item{% if forloop.index == 1 %} show{% endif %}">
              {{ block.settings.text }}
              <hr>
              {{ block.settings.sub_text }}
              {%- if block.settings.am_or_pm_1 != 'none' -%}
                <div class="badges">
                  <div class="e-pill-badge e-pill-badge--sm">
                    <i class="e-icon e-icon-{{ block.settings.am_or_pm_1 }}"></i>
                    {% if block.settings.am_or_pm_1 == 'am' %} {{ 'sections.n_skincare-routine.settings.am_text' | t }}{% elsif block.settings.am_or_pm_1 == 'pm' %} {{ 'sections.n_skincare-routine.settings.pm_text' | t }}{% endif %}
                  </div>
                  {%- if block.settings.am_or_pm_2 != 'none' -%}
                    <span>{{ 'sections.n_skincare-routine.settings.or_text' | t }}</span>
                    <div class="e-pill-badge e-pill-badge--sm">
                      <i class="e-icon e-icon-{{ block.settings.am_or_pm_2 }}"></i>
                      {% if block.settings.am_or_pm_2 == 'am' %} {{ 'sections.n_skincare-routine.settings.am_text' | t }}{% elsif block.settings.am_or_pm_2 == 'pm' %} {{ 'sections.n_skincare-routine.settings.pm_text' | t }}{% endif %}
                    </div>
                  {%- endif -%}
                </div>
              {%- endif -%}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </article>
  </div>
</section>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    loadScriptOnce('skincare-routine', 'https://qureskincaredns.com/sections/new/skincare-routine/skincare-routine.js');
  });
</script>
<!-- SKINCARE ROUTINE END -->

{% schema %}
{
  "name": "t:sections.n_skincare-routine.name",
  "settings": [
    {
      "type": "checkbox",
      "id": "use_own_file",
      "label": "t:common.use-own-file",
      "default": false
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:common.header",
      "default": "Meet your new skincare routine"
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "t:common.tab",
      "settings": [
        {
          "type": "text",
          "id": "tab_heading",
          "label": "t:common.tab-heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "t:common.text"
        },
        {
          "type": "richtext",
          "id": "sub_text",
          "label": "t:common.sub-text"
        },
        {
          "type": "select",
          "id": "am_or_pm_1",
          "label": "t:common.am-or-pm",
          "default": "none",
          "options": [
            { 
              "value": "am", 
              "label": "t:common.am" 
            },
            { 
              "value": "pm", 
              "label": "t:common.pm" 
            },
            { 
              "value": "none", 
              "label": "t:common.none" 
            }
          ]
        },
        {
          "type": "select",
          "id": "am_or_pm_2",
          "label": "t:common.am-or-pm",
          "default": "none",
          "options": [
            { 
              "value": "am",
              "label": "t:common.am" 
            },
            { 
              "value": "pm", 
              "label": "t:common.pm" 
            },
            { 
              "value": "none", 
              "label": "t:common.none" 
            }
          ]
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:common.image"
        },
        {
          "type": "text",
          "id": "wistia_url",
          "label": "t:common.wistia-url"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.n_skincare-routine.name"
    }
  ]
}
{% endschema %}
