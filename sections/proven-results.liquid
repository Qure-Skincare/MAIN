{% doc %}
  Renders a proven results section
{% enddoc %}

<link href="https://qureskincaredns-main.com/sections/global/banner-with-text/banner-text.css" rel="stylesheet" type="text/css">
<div id="results" class="qure__section after no_hype_evidence"
    style="--section-padding-top: 80px; --section-padding-bottom: 80px; --section-padding-top-mob: 40px; --section-padding-bottom-mob: 40px;" id="evidence_section">
    <div class="container">
        <div class="heading_wrapper d-md-none">
            {% if section.settings.heading != blank %}
                <h2 class="banner-text--heading">{{ section.settings.heading }}</h2>
            {% endif %}
            {% if section.settings.text != blank %}
                <div class="banner-text--des" style="--text-mt: 20px; --text-mb: 20px;">{{ section.settings.text }}</div>
            {% endif %}
        </div>
        <div class="row custom__grid" style="--column-gap:60px; --column-gap-mobile:32px;">
            <div class="col-md-6 custom__block order-mob-2">
                <div class="heading_wrapper d-none d-md-block">
                    {% if section.settings.heading != blank %}
                        <h2 class="banner-text--heading">{{ section.settings.heading }}</h2>
                    {% endif %}
                   {% if section.settings.text != blank %}
                    <div class="banner-text--des" style="--text-mt: 32px; --text-mb: 20px;">{{ section.settings.text }}</div>
                   {% endif %}
                </div>
                {% for block in section.blocks %}
                    {% if block.type == 'text_with_progress' %}
                        <div class="text-with-progress d-flex align-items-center col-gap my-10" style="--col-gap:12px">
                        <div class="text-progress-circle position-relative d-inline-flex fw-600 fs-20">
                            {% assign percent_str = block.settings.percent_value %}
                            {% assign percent_num = percent_str | remove: "%" | plus: 0 %}
                            {% assign dashoffset = 100 | minus: percent_num %}
                            <svg class="vMQQx" height="77" width="77" viewBox="-29 -29 58 58">
                            <defs>
                                <linearGradient id="gradient" x1="0" x2="0" y1="1" y2="0">
                                <stop offset="0%" stop-color="#C7E7DC"></stop>
                                <stop offset="100%" stop-color="#C7E7DC"></stop>
                                </linearGradient>
                            </defs>
                            <circle stroke="rgba(221, 224, 228, 1)" fill="none" pathLength="100" class="K4v4P" r="24" style="stroke-width: 1px;"></circle>
                            <circle visibility="visible" fill="none" pathLength="100" transform="rotate(-90)" class="OKwUu" r="24" stroke="url(#gradient)" style="stroke-dasharray: 100; stroke-dashoffset: {{ dashoffset }}; stroke-width: 5px;"> </circle>
                            </svg>
                            {% if block.settings.percent_value != blank %}
                                <span>{{ block.settings.percent_value }}</span>
                            {% endif %}
                        </div>
                        {% if block.settings.text != blank %}
                            {{ block.settings.text }}
                        {% endif %}
                        </div>
                    {% endif %}
                {% endfor %}
                {% if section.settings.button_label != blank and section.settings.button_url != blank %}
                    <div class="pt-24 mw" style="--mw:300px; --mw-mob:300px">
                        <a href="{{ section.settings.button_url }}" data-bs-toggle="modal" data-bs-target="#ingredients_popup" class="filter-card-item filter-card-video text-decoration-underline" style="--base-color: #212428;">
                        <img src="{{ 'sections.proven-results.info_image' | t }}" alt="{{ 'sections.proven-results.info_image.alt' | t | escape }}">{{ section.settings.button_label }}</a>
                    </div>
                {% endif %}
                <!-- modal start -->
                <div class="modal fade ingredient_modal" id="ingredients_popup" data-bs-backdrop="static"
                    data-bs-keyboard="false" tabindex="-1" aria-labelledby="ingredients_popupLabel"
                    aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered filter-dialog pb-md-0 p-15"
                        style="--bs-modal-width:940px">
                        <div class="modal-content bg-white">
                            <div class="modal-header border-0">
                                <button type="button"
                                    class="btn btn-close bg-transparent border-0 btn btn-close text-black p-0"
                                    data-bs-dismiss="modal" aria-label="Close"><i
                                        class="fa-solid fa-xmark fs-30"></i></button>
                            </div>
                            <div class="modal-body pb-40 px-20 px-md-40">
                                {% assign slider_count = 0 %}
                                <ul class="nav nav-tabs" id="myTab" role="tablist">
                                    {% for block in section.blocks %}
                                        {% if block.type == 'slider' %}
                                            {% assign slider_count = slider_count | plus: 1 %}
                                            <li class="nav-item" role="presentation">
                                                <button class="nav-link{% if slider_count == 1 %} active{% endif %}" id="tab-{{ slider_count }}" data-bs-toggle="tab" data-bs-target="#pane-{{ slider_count }}" type="button" role="tab" aria-controls="pane-{{ slider_count }}"
                                                        {% if slider_count == 1 %}aria-selected="true"{% else %}aria-selected="false"{% endif %}>
                                                    {{ 'sections.proven-results.study_text' | t }} {{ slider_count }}
                                                </button>
                                            </li>
                                        {% endif %}
                                    {% endfor %}
                                </ul>
                                <div class="tab-content pt-25" id="myTabContent">
                                    {% assign slider_count = 0 %}
                                    {% for block in section.blocks %}
                                        {% if block.type == 'slider' %}
                                            {% assign slider_count = slider_count | plus: 1 %}
                                            <div class="tab-pane fade{% if slider_count == 1 %} show active{% endif %}"
                                                 id="pane-{{ slider_count }}"
                                                 role="tabpanel"
                                                 aria-labelledby="tab-{{ slider_count }}"
                                                 tabindex="0">
                                                {% if block.settings.button_label != blank  %}
                                                    <button class="btn btn--primary btn-sm mb-20"
                                                            style="--btn-primary-bg: #c8e6dc;--btn-primary-color: #212428;">
                                                        {{ block.settings.button_label }}
                                                    </button>
                                                {% endif %}
                                                {% if block.settings.text != blank %}
                                                    {{ block.settings.text | replace: '[line]', '<hr>'}}
                                                {% endif %}
                                            </div>
                                        {% endif %}
                                    {% endfor %}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- modal end-->
            </div>
            <!-- view_full_ingr end -->
            <div class="col-md-6 custom__block">
                <div class="swiper qure__swiper" id="qure__swiper-evidence-slider" data-section-id="evidence-slider"
                    data-autoplay="false" data-loop="false" data-mobile="1" data-tablet="1" data-desktop="1"
                    data-spacing="0" data-pagination-fraction="true">
                    <div class="swiper-wrapper">
                        {% for block in section.blocks %}
                            {% if block.type == 'slider' %}
                                <div class="swiper-slide">
                                    <div class="clinic_prvn p-16 p-md-24 m-1 border rounded-2" style="--bs-border-radius: 10px;">
                                        {% if block.settings.image != blank %}
                                            <img src="{{ block.settings.image | image_url }}" class="card-img-top rounded-2" alt="{{ block.settings.image.alt | escape }}">
                                        {% endif %}
                                        <div class="d-flex flex-wrap align-items-center justify-content-center gap-4 mt-18">
                                            {% if block.settings.heading %}
                                                <span>{{ block.settings.heading }}</span>
                                            {% endif %}
                                            {% if block.settings.button_label_image != blank %}
                                                <button class="btn btn--primary btn-sm" style="--btn-primary-bg: #c8e6dc;--btn-primary-color: #212428;">{{ block.settings.button_label_image }}</button>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                            {% endif %}
                        {% endfor %}
                    </div>
                    <div
                        class="swiper-arrows-with-pagination d-flex align-items-center justify-content-center gap-4 mt-30">
                        <div class="qure-swiper-button-prev qure-swiper-arrow"><i
                                class="fa-regular fa-angle-left"></i>
                        </div>
                        <div class="swiper-pagination position-relative bottom-0 w-auto"></div>
                        <div class="qure-swiper-button-next qure-swiper-arrow"><i
                                class="fa-regular fa-angle-right"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadScriptOnce('main-slider', 'https://qureskincaredns-main.com/assets/js/main-slider.js');
    });
</script>


{%  schema  %}
{
  "name": "t:sections.proven-results.name",
  "settings": [
    {
        "type": "text",
        "id": "heading",
        "label": "t:common.header"
    },
    {
        "type": "richtext",
        "id": "text",
        "label": "t:common.text"
    },
    {
        "type": "text",
        "id": "button_label",
        "label": "t:common.button-label"
    },
    {
        "type": "url",
        "id": "button_url",
        "label": "t:common.button-url"
    }
  ],
  "blocks": [
    {
        "type": "slider",
        "name": "t:common.slider",
        "settings": [
            {
                "type": "richtext",
                "id": "heading",
                "label": "t:common.header"
            },
            {
                "type": "richtext",
                "id": "text",
                "label": "t:common.text"
            },
            {
                "type": "image_picker",
                "id": "image",
                "label": "t:common.image"
            },
            {
                "type": "text",
                "id": "button_label",
                "label": "t:common.button-label"
            },
            {
                "type": "text",
                "id": "button_label_image",
                "label": "t:common.button-label-image"
            }
        ]
    },
    {
        "type": "text_with_progress",
        "name": "t:sections.proven-results.blocks.text-with-progress.name",
        "settings": [
            {
                "type": "richtext",
                "id": "text",
                "label": "t:common.text"
            },
            {
                "type": "text",
                "id": "percent_value",
                "label": "t:common.percent-value"
            }
        ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.proven-results.name"
    }
  ]
}
{% endschema %}
