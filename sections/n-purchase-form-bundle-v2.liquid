{% doc %}
  Renders a purchase form bundle v2 section.
{% enddoc %}

{% include 'assoc-array', section: section, __parent_title: 'type', __separator: '###' %}

<!-- BUNDLES -->
<link rel="stylesheet" href="https://qureskincaredns.com/sections/new/bundles/bundles.css" />
<section id="purchase-form-bundle" class="bundles {{ section.id }}">
    <div class="container">
        {% if section.settings.heading != blank %}
            <h2>{{ section.settings.heading }}</h2>
        {% endif %}

        {% render 'n-purchase-form-bundle-types' section: section, __idsArray1: __idsArray1, __idsArray2: __idsArray2, __idsArray3: __idsArray3 %}
        {% include 'n-purchase-form-bundle-v2-products' section: section, __idsArray1: __idsArray1, __idsArray2: __idsArray2, __idsArray3: __idsArray3 %}
    </div>
</section>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadScriptOnce("dialog", "https://qureskincaredns.com/assets/js-new/dialog.js");
        loadScriptOnce("bundles", "https://qureskincaredns.com/sections/new/bundles/bundles.js");
    });
</script>
<!-- BUNDLES END -->

<script src="https://qureskincaredns.com/shopify/js/purchase-form-bundle.js" data-form="{{ section.settings.form_name }}" data-section="{{ section.id }}" defer></script>

{%- schema -%}
{
    "name":"t:sections.purchase-form-bundle.name",
    "class":"purchase-form-bundle",
    "settings":[
        {
            "type": "text",
            "id": "heading",
            "label": "t:common.header"
        },
        {
            "type": "text",
            "id": "text",
            "label": "t:common.text"
        },
        {
            "type": "checkbox",
            "id": "hide_types",
            "label": "t:sections.purchase-form-bundle.settings.hide_types",
            "default": false
        },
        {
            "type": "text",
            "id": "form_name",
            "label": "t:sections.purchase-form-bundle.settings.form_name",
            "default": "purchase-form-bundle"
        }
    ],
    "blocks":[
        {
            "type": "type",
            "limit": 3,
            "name": "t:common.type",
            "settings": [
                {
                    "type": "header",
                    "content": "TYPE"
                }
            ]
        },
        {
            "type": "product_type",
            "name": "t:common.product-type",
            "limit": 3,
            "settings": [
                {
                    "type": "text",
                    "id": "heading",
                    "label": "t:common.header"
                },
                {
                    "type": "image_picker",
                    "id": "image",
                    "label": "t:common.image"
                },
                {
                    "type": "checkbox",
                    "id": "preselected",
                    "label": "t:common.preselect",
                    "default": false
                }
            ]
        },
        {
            "type": "product",
            "name": "t:common.product",
            "settings": [
                {
                    "type": "product",
                    "id": "product",
                    "label": "t:common.product"
                },
                {
                    "type": "image_picker",
                    "id": "image",
                    "label": "t:common.image"
                },
                {
                    "type": "checkbox",
                    "id": "preselected",
                    "label": "t:common.preselect",
                    "default": false
                },
                {
                    "type": "checkbox",
                    "id": "soldout",
                    "label": "t:common.soldout",
                    "default": false
                },
                {
                    "type": "checkbox",
                    "id": "reserved",
                    "label": "t:common.reserved",
                    "default": false
                }
            ]
        },
    ],
    "presets":[
        {
            "name":"t:sections.purchase-form-bundle.name"
        }
    ]
}
{%- endschema -%}