{% doc %}
  Renders a how to use with picture section.
{% enddoc %}

<link rel="stylesheet" href="https://qureskincaredns.com/sections/isolated/review-slider/card-slide.css" />
<div id="how_to_use-picture" class="qure__trusted-ingredients qure__section"
    style="--section-padding-top:80px;--section-padding-bottom:80px;">
    <div class="offset-right-container" style="--column-gap:100px; --column-gap-mobile:30px;">
        <div class="row align-items-center custom__grid">
            <div class="col-md-12 col-lg-5 custom__block">
                <div class="qure__section-header mb-0">
                    {% if section.settings.heading != blank %}
                        <h2 class="qure__section-heading d-none d-md-block">{{ section.settings.heading }}</h2>
                    {% endif %}
                    {% if section.settings.heading-mobile != blank %}
                        <h2 class="qure__section-heading d-md-none">{{ section.settings.heading-mobile }}</h2>
                    {% endif %}
                    {% if section.settings.text != blank %}
                        {{ section.settings.text | replace: '<p>', '<p class="mt-20 mt-lg-30 pb-0 d-none d-md-block">' }}
                    {% endif %}
                    {% if section.settings.text-mobile != blank %}
                        {{ section.settings.text-mobile | replace: '<p>', '<p class="mt-20 mt-lg-30 pb-0 d-md-none">' }}
                    {% endif %}
                    {% if section.settings.sub-text != blank %}
                        {{ section.settings.sub-text | replace: '<p>', '<p class="fs-18 fw-600">' }}
                    {% endif %}
                </div>
            </div>
            <div class="col-md-12 col-lg-7 custom__block">
                <div class="swiper qure__swiper d-none d-lg-block" id="qure__swiper-col-slider"
                    data-section-id="col-slider" data-autoplay="false" data-loop="false" data-mobile="1"
                    data-tablet="1.4" data-desktop="1.8" data-spacing="32" data-pagination-fraction="true"
                    data-slidecenter="true">
                    <div class="swiper-wrapper">
                        {% for block in section.blocks %}
                            {% if block.type == 'list' %}
                                <div class="swiper-slide">
                                    <div class="card skin-card border"
                                        style="--bs-border-color: #DFE0E0; --bs-card-border-radius: 10px;">
                                        {% if block.settings.image != blank %}
                                            <img src="{{ block.settings.image | image_url }}" class="card-img-top" alt="{{ block.settings.image.alt | escape }}">
                                        {% endif %}
                                        <div class="card-body skin-card-body">
                                            {% if block.settings.heading != blank %}
                                                <h5 class="card-title fm-body mb-15">{{ block.settings.heading }}</h5>
                                            {% endif %}
                                            {% if block.settings.text != blank %}
                                                {{ block.settings.text | replace: '<p>', '<p class="card-text">' }}
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                            {% endif %}
                        {% endfor %}
                    </div>
                    <div
                        class="swiper-arrows-with-pagination d-flex align-items-center justify-content-center gap-4 mt-30">
                        <div class="qure-swiper-button-prev qure-swiper-arrow"><i class="fa-regular fa-angle-left"></i>
                        </div>
                        <div class="swiper-pagination position-relative bottom-0 w-auto"></div>
                        <div class="qure-swiper-button-next qure-swiper-arrow"><i class="fa-regular fa-angle-right"></i>
                        </div>
                    </div>
                </div>
                <div class="d-block d-lg-none">
                    {% for block in section.blocks %}
                        {% if block.type == 'list' %}
                             <div class="p-ing-card mb-24">
                                {% if block.settings.image-mobile != blank %}
                                    <img src="{{ block.settings.image-mobile | image_url }}" class="card-img-top" alt="{{ block.settings.image-mobile.alt | escape }}">
                                {% endif %}
                                <div class="skin-card-body">
                                    {% if block.settings.heading-mobile != blank %}
                                        <h5 class="card-title fm-body mb-10 fs-20 fw-500">{{ block.settings.heading-mobile }}</h5>
                                    {% endif %}
                                    {% if block.settings.text-mobile != blank %}
                                        {{ block.settings.text-mobile | replace: '<p>', '<p class="card-text fs-16">' }}    
                                    {% endif %}
                                </div>
                            </div>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadScriptOnce('main-slider', 'https://qureskincaredns.com/assets/js/main-slider.js');
    });
</script>

{% schema %}
{
  "name": "t:sections.how-to-use-picture.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:common.header"
    },
    {
        "type": "text",
        "id": "heading-mobile",
        "label": "t:common.header-mobile"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "t:common.text"
    },
    {
        "type": "richtext",
        "id": "text-mobile",
        "label": "t:common.text-mobile"
    },
    {
        "type": "richtext",
        "id": "sub-text",
        "label": "t:common.sub-text"
    }
  ],
  "blocks": [
    {
        "type": "list",
        "name": "t:common.list",
        "settings": [
            {
                "type": "text",
                "id": "heading",
                "label": "t:common.header"
            },
            {
                "type": "text",
                "id": "heading-mobile",
                "label": "t:common.header-mobile"
            },
            {
                "type": "richtext",
                "id": "text",
                "label": "t:common.text"
            },
            {
                "type": "richtext",
                "id": "text-mobile",
                "label": "t:common.text-mobile"
            },
            {
                "type": "image_picker",
                "id": "image",
                "label": "t:common.image"
            },
            {
                "type": "image_picker",
                "id": "image-mobile",
                "label": "t:common.image-mobile"
            }
        ]
    }

  ],
  "presets": [
    {
      "name": "t:sections.how-to-use-picture.name"
    }
  ]
}
{% endschema %}