{% doc %}
  Contact form with base-form layout (stockist / generic enquiries).
{% enddoc %}

{% if section.settings.use_own_file %}
  <link rel="stylesheet" href="https://qureskincaredns.com/sections/new/base-form/base-form.css" />
{% endif %}
<section class="base-form" id="contact_form">
  <div class="container">
    {% form 'contact', class: 'base-form__form' %}
      {% if form.posted_successfully? %}
        <p class="base-form__form-success">{{ 'sections.contact-form.success_text' | t }}</p>
      {% endif %}

      {{ form.errors | default_errors }}

      <div class="base-form__form-field">
        <input
          type="text"
          class="form-control"
          placeholder="Name"
          name="contact[name]"
          value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
          required
        >
      </div>
      <div class="base-form__form-field">
        <input
          type="email"
          class="form-control"
          placeholder="Email address"
          name="contact[email]"
          value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
          required
        >
      </div>
      <div class="base-form__form-field">
        <input
          type="tel"
          class="form-control"
          placeholder="Phone number"
          name="contact[phone]"
          value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
          required
        >
      </div>
      <div class="base-form__form-field">
        <input
          type="text"
          class="form-control"
          placeholder="Company Name"
          name="contact[company]"
          value="{% if form.company %}{{ form.company }}{% endif %}"
        >
      </div>
      <div class="base-form__form-field">
        <input
          type="text"
          class="form-control"
          placeholder="Location (City, Country)"
          name="contact[location]"
          value="{% if form.location %}{{ form.location }}{% endif %}"
        >
      </div>
      <div class="base-form__form-field">
        <input
          type="url"
          class="form-control"
          placeholder="Website URL"
          name="contact[website]"
          value="{% if form.website %}{{ form.website }}{% endif %}"
        >
      </div>
      <div class="base-form__form-field">
        <textarea class="form-control" name="contact[body]" placeholder="Message" rows="6">{% if form.body %}{{ form.body }}{% endif %}</textarea>
      </div>
      <div class="base-form__form-submit">
        <button class="btn btn--primary" type="submit">{{ 'sections.contact-form.send_text' | t }}</button>
      </div>
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.n_base-form.name",
  "settings": [
    {
      "type": "checkbox",
      "id": "use_own_file",
      "label": "t:common.use-own-file",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "t:sections.n_base-form.name"
    }
  ]
}
{% endschema %}
