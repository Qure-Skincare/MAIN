        {
            "type": "image_picker",
            "id": "image",
            "label": "t:common.image"
        }
      ]
    },
    {
        "type": "items",
        "name": "t:common.items",
        "limit": 1,
        "settings": [
            {
                "type": "text",
                "id": "text_item_1",
                "label": "t:sections.why-it-works.blocks.items.text-item-1.name"
            },
            {
                "type": "image_picker",
                "id": "image_1",
                "label": "t:sections.why-it-works.blocks.items.image-1.name"
            },
            {
                "type": "text",
                "id": "text_item_2",
                "label": "t:sections.why-it-works.blocks.items.text-item-2.name"
            },
            {
                "type": "image_picker",
                "id": "image_2",
                "label": "t:sections.why-it-works.blocks.items.image-2.name"
            },
            {
                "type": "text",
                "id": "text_item_3",
                "label": "t:sections.why-it-works.blocks.items.text-item-3.name"
            },
            {
                "type": "image_picker",
                "id": "image_3",
                "label": "t:sections.why-it-works.blocks.items.image-3.name"
            },
            {
                "type": "text",
                "id": "text_item_4",
                "label": "t:sections.why-it-works.blocks.items.text-item-4.name"
            },
            {
                "type": "image_picker",
                "id": "image_4",
                "label": "t:sections.why-it-works.blocks.items.image-4.name"
            }
        ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.why-it-works.name"
    }
  ]
}
{% endschema %}