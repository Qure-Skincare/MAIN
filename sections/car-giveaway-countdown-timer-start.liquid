{% doc %}
  Renders a countdown timer start section for car giveaway page.
{% enddoc %}

<link rel="stylesheet" href="https://qureskincaredns-main.com/sections/isolated/sticky-cta/skincare-sticky-cta.css" />
<div id="sticky_cta_cart" class="qure__sticky-atc skincare_plan_cta">
    <div class="qure__section color-background" style="--section-background:#212428;--section-padding-top:15px;--section-padding-bottom:15px;
            --section-padding-top-mob:6px;--section-padding-bottom-mob:6px;">
        <div class="container">
            <div class="countdown" data-target="2025-10-02T00:00:00">
                {% if section.settings.heading != blank %}
                    <p class="extra_entries">{{ section.settings.heading }}</p>
                {% endif %}
                <div>
                    <div class="days">{{ 'sections.car-giveaway-countdown-timer-start.00' | t }}</div><span>{{ 'sections.car-giveaway-countdown-timer-start.days' | t }}</span>
                </div>
                <div><img src="{{ 'sections.car-giveaway-countdown-timer-start.white_line_image' | t }}" alt=""></div>
                <div>
                    <div class="hours">{{ 'sections.car-giveaway-countdown-timer-start.00' | t }}</div><span>{{ 'sections.car-giveaway-countdown-timer-start.hours' | t }}</span>
                </div>
                <div><img src="{{ 'sections.car-giveaway-countdown-timer-start.white_line_image' | t }}" alt=""></div>
                <div>
                    <div class="minutes">{{ 'sections.car-giveaway-countdown-timer-start.00' | t }}</div><span>{{ 'sections.car-giveaway-countdown-timer-start.minutes' | t }}</span>
                </div>
                <div><img src="{{ 'sections.car-giveaway-countdown-timer-start.white_line_image' | t }}" alt=""></div>
                <div>
                    <div class="seconds">{{ 'sections.car-giveaway-countdown-timer-start.00' | t }}</div><span>{{ 'sections.car-giveaway-countdown-timer-start.seconds' | t }}</span>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadScriptOnce('skincare-sticky-cta', 'https://qureskincaredns-main.com/assets/js/skincare-sticky-cta.js');
        loadScriptOnce('countdown-timer', 'https://qureskincaredns-main.com/sections/isolated/countdown-timer/countdown-timer.js');
    });
</script>

{% schema %}
{
  "name": "t:sections.car-giveaway-countdown-timer-start.name",
  "settings": [
   {
        "type": "text",
        "id": "heading",
        "label": "t:common.header"
   }
  ]
}
{% endschema %}