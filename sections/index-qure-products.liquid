{% doc %}
  Renders a qure products section for index page
{% enddoc %}


<link rel="stylesheet" href="https://qureskincaredns-main.com/sections/isolated/top-products/products-card.css" />
<div class="qure__section"
   style="--section-padding-top: 40px;--section-padding-bottom: 40px;--section-padding-top-mob: 30px;--section-padding-bottom-mob: 30px;">
   <div class="qure__section-header text-center mb-30 mb-md-60">
    {% if section.settings.heading != blank %}
        <h2 class="qure__section-heading">{{ section.settings.heading }}</h2>
    {% endif %}
   </div>
   <div class="container" style="--column-gap:24px; --column-gap-mobile:16px;">
      <div class="row custom__grid">
        {% for block in section.blocks %}
            {% if block.type == 'hover_image' %}
                <div class="col-6 col-md-3 custom__block">
                    <div class="qure__product-item">
                            {% if block.settings.url != blank %}
                                <a href="{{ block.settings.url }}" class="qure__product-img overflow-hidden position-relative d-block">
                            {% endif %}
                                {% if block.settings.image != blank %}
                                    <div class="qure__product-main-img"><img
                                        src="{{ block.settings.image | image_url }}" alt="{{ block.settings.image.alt | escape }}" />
                                    </div>
                                {% endif %}
                                    {% if block.settings.hover_image != blank %}
                                        <div class="qure__product-hover-img position-absolute inset-0"><img
                                                    src="{{ block.settings.hover_image | image_url }}" alt="{{ block.settings.image.alt | escape }}" />
                                        </div>
                                    {% endif %}
                                        {% if block.settings.image_text == 'Bestseller' %}
                                            <div class="badge rounded-pill badge-bestseller">{{ block.settings.image_text }}</div>    
                                        {% endif %}
                                        {% if block.settings.image_text == 'Trending' %}
                                            <div class="badge rounded-pill badge-bestseller" style="--text-clr:#FF5429; --badge-bg:#FFEEEA">{{ block.settings.image_text }}</div>
                                        {% endif %} 
                                </a>
                    <div class="qure__product-details pt-15">
                        {% if block.settings.rating_image != blank %}
                            <div class="qure__product-reviews fs-14 d-flex gap-3 align-items-center mb-10">
                            <img src="{{ block.settings.rating_image |  image_url }}" alt="{{ block.settings.image.alt | escape }}" /><span>{{ block.settings.rating_text }}</span>
                        </div>
                        {% endif %}
                        {% if block.settings.url != blank %}
                            <h3 class="fm-body mb-0 qure__product-name">
                            <a class="limited-line capitalize d-block" href="{{ block.settings.url }}">{{ block.settings.heading }}</a>
                        </h3>
                        {% endif %}
                       <div class="qure__product-price mt-10">{{ block.settings.label_price }} {$dyn}</div>
                    </div>
                </div>
            </div>
            {% endif %}
        {% endfor %}
      </div>
   </div>
</div>
{% schema %}
{
  "name": "t:sections.index-qure-products.name",
  "settings": [
    {
        "type": "text",
        "id": "heading",
        "label": "t:common.header"
    }
  ],
  "blocks": [
    {
    "type": "hover_image",
    "name": "t:sections.index-qure-products.blocks.hover-image.name",
        "settings": [
            {
                "type": "text",
                "id": "heading",
                "label": "t:common.header"
            },
            {
                "type": "text",
                "id": "image_text",
                "label": "t:sections.index-qure-products.blocks.image-text.name"
            },
            {
                "type": "image_picker",
                "id": "image",
                "label": "t:common.image"
            },
            
            {
                "type": "image_picker",
                "id": "hover_image",
                "label": "t:sections.index-qure-products.blocks.hover-image.name"
            },
            {
                "type": "url",
                "id": "url",
                "label": "t:common.link-url"
            },
            {
                "type": "text",
                "id": "rating_text",
                "label": "t:common.rating-text"
            },
            {
                "type": "image_picker",
                "id": "rating_image",
                "label": "t:sections.index-qure-products.blocks.rating-image.name"
            },
            {
                "type": "text",
                "id": "label_price",
                "label": "t:sections.index-qure-products.blocks.label-price.name"
            }
        ]
    }
   ]
}
{% endschema %}