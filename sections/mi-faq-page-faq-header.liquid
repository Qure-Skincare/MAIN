{% doc %}
Renders a faq header for microinfusion faq page.
{% enddoc %}


<link rel="stylesheet" href="https://qureskincaredns-main.com/sections/isolated/faqs/qure__faqs.css">
<div class="qure__section"
    style="--section-padding-top: 60px; --section-padding-bottom: 30px;--section-padding-top-mob: 30px; --section-padding-bottom-mob: 20px;">
    <div class="container">
        <div class="common_faq">
            <div class="healthier_skin">
                {% if section.settings.heading != blank %}
                    <h1 class="qure__product-title fw-600 mb-24" style="--heading-font-family: 'TT Commons';">{{ section.settings.heading }}</h1>
                {% endif %}
                <div class="align-items-center border-bottom border-top d-flex justify-content-between py-md-15 py-5">
                    {% if section.settings.text != blank %}
                        <p class="fs-md-18 fs-14">{{ section.settings.text 
                            | replace: '<strong>', '<span class="fw-600">' 
                            | replace: '</strong>', '</span>'
                            | replace: '<p>', ''
                            | replace: '</p>', '' }}
                        </p>
                    {% endif %}
                    <div class="d-flex gap-4">
                        {% if section.settings.number_of_views != blank %}
                            <div class="d-flex">
                                <img src="{{ 'sections.faq-header.view_image' | t }}" alt="{{ 'sections.faq-header.view_image.alt' | t | escape}}">
                                <p class="pl-5 fs-md-18 fs-14">{{ section.settings.number_of_views }}</p>
                            </div>
                        {% endif %}
                        {% if section.settings.number_of_shared != blank %}
                            <div class="d-flex">
                                <img src="{{ 'sections.faq-header.shared_image' | t }}" alt="{{ 'sections.faq-header.shared_image.alt' | t | escape }}">
                                <p class="pl-5 fs-md-18 fs-14">{{ section.settings.number_of_shared }}</p>
                            </div>
                        {% endif %}
                    </div>
                </div>
                <div class="pt-md-40 pt-25 mw-mob-100">
                    <picture>
                        {% if section.settings.image != blank %}
                            <source media="(min-width:1920px)" srcset="{{ section.settings.image | image_url }}" class="img-fluid" width="1440" height="557">
                            <source media="(min-width:1600px)" srcset="{{ section.settings.image | image_url }}" class="img-fluid" width="1440" height="557">
                            <source media="(min-width:1100px)" srcset="{{ section.settings.image | image_url }}" class="img-fluid" width="1440" height="557">
                            <source media="(min-width:767px)" srcset="{{ section.settings.image | image_url }}" class="img-fluid" width="1440" height="557">
                        {% endif %}
                        {% if section.settings.image_mobile != blank %}
                            <source media="(min-width:540px)" srcset="{{ section.settings.image_mobile | image_url }}" class="img-fluid" width="1440" height="557">
                            <img src="{{ section.settings.image_mobile | image_url }}" width="225" height="281" alt="{{ section.settings.image_mobile.alt | escape }}" class="img-fluid w-100">
                        {% endif %}
                    </picture>
                </div>
            </div>
        </div>
    </div>
</div>

{% schema %}
{
    "name": "t:sections.faq-header.name",
    "settings": [
    {
        "type": "text",
        "id": "heading",
        "label": "t:common.header"
    },
    {
        "type": "richtext",
        "id": "text",
        "label": "t:common.text"
    },
    {
        "type": "text",
        "id": "number_of_views",
        "label": "t:common.number-of-views",
    },
    {
        "type": "text",
        "id": "number_of_shared",
        "label": "t:common.nubmber-of-shared",
    },
    {
        "type": "image_picker",
        "id": "image",
        "label": "t:common.image"
    },
    {
        "type": "image_picker",
        "id": "image_mobile",
        "label": "t:common.image-mobile"
    }
    ]
}
{% endschema %}