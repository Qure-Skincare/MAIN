{% doc %}
  Renders a quick links slider section for index page 
{% enddoc %}

<!-- QUICK LINKS -->
 {% if section.settings.use_own_file %}
    <link rel="stylesheet" href="https://qureskincaredns.com/sections/new/quick-links/quick-links.css" />
 {% endif %}
<section class="quick-links">
    <div class="container">
        <div
            class="c-swiper"
            data-swiper='{
                "slidesPerView": "4",
                "spaceBetween": 10,
                "breakpoints": {
                    "480": {
                        "slidesPerView": 6
                    },
                    "600": {
                        "slidesPerView": 7
                    }
                }
            }'>
            <div class="swiper-wrapper">
                {% for block in section.blocks %}
                    {% if block.type == 'slider' %}
                        <div class="swiper-slide">
                            <a href="{{ block.settings.url }}">
                                {% if block.settings.image != blank %}
                                    <img src="{{ block.settings.image | image_url }}" alt="{{ block.settings.image.alt | escape }}" />
                                {% endif %}
                                {% if block.settings.heading != blank %}
                                    <span>{{ block.settings.heading }}</span>
                                {% endif %}
                            </a>
                        </div>
                    {% endif %}
                {% endfor %}
            </div>
        </div>
    </div>
</section>
<!-- QUICK LINKS END -->


{% schema %}
{
  "name": "t:sections.n_index-quick-links.name",
  "settings": [
    {
        "type": "checkbox",
        "id": "use_own_file",
        "label": "t:common.use-own-file",
        "default": false
    }
  ],
  "blocks": [
        {
        "type": "slider",
        "name": "t:common.slider",
            "settings": [
                {
                    "type": "text",
                    "id": "heading",
                    "label": "t:common.header"
                },
                {
                    "type": "url",
                    "id": "url",
                    "label": "t:common.link-url"
                },
                {
                    "type": "image_picker",
                    "id": "image",
                    "label": "t:common.image"
                }
            ]
        }
    ]
}
{% endschema %}