{% doc %}
Renders a page banner section second for index page
{% enddoc %}

<!-- Page banner -->
<link rel="stylesheet" href="https://qureskincaredns-main.com/sections/isolated/page-banner/page-banner.css" />

<!-- promotional banner  -->
<div class="page__banner position-relative">
    <picture>
        {% if section.settings.image != blank %}
            <source media="(min-width:1920px)" srcset="{{ section.settings.image | image_url }}" class="img-fluid" width="1440" height="557">
            <source media="(min-width:1600px)" srcset="{{ section.settings.image | image_url }}" class="img-fluid" width="1440" height="557">
            <source media="(min-width:1100px)" srcset="{{ section.settings.image | image_url }}" class="img-fluid" width="1440" height="557">
            <source media="(min-width:767px)" srcset="{{ section.settings.image | image_url }}" class="img-fluid" width="1440" height="557">
        {% endif %}
        {% if section.settings.image_mobile != blank %}
            <source media="(min-width:540px)" srcset="{{ section.settings.image_mobile | image_url }}" class="img-fluid" width="1440" height="557">
            <img src="{{ section.settings.image_mobile | image_url }}" width="225" height="281" alt="{{ section.settings.image_mobile.alt | escape }}" class="img-fluid w-100">
        {% endif %}
    </picture>
    <div
        class="page__banner-wrapper position-absolute d-flex align-items-md-center justify-content-end top-0 start-0 end-0 pt-md-50">
        <div class="container">
            <div class="d-flex justify-content-end align-items-start">
                <div class="ctm-width ctm-color text-center text-md-center offset-md-6"
                    style="--ctm-width:500px; --txt-color-mob:#000;">
                    {% if section.settings.heading != blank %}
                        <h1 class="page-banner-title pt-20 pt-md-0" style="--pg-title-mob:#000;">{{ section.settings.heading }}</h1>
                    {% endif %}

                    {% if section.settings.button_label_mobile != blank and section.settings.button_url_mobile != blank %}
                        <a href="{{ section.settings.button_url_mobile }}" class="btn mt-20 text-center d-md-none">{{ section.settings.button_label_mobile }}</a>
                    {% endif %}

                    {% if section.settings.button_label != blank and section.settings.button_url != blank %}
                        <div class="ctm-width d-none d-md-block mx-auto" style="--ctm-width:450px">
                            <a href="{{ section.settings.button_url }}" class="btn btn--primary mt-20 mt-lg-30 mb-5 w-100 text-center mw" style="--mw:400px;">{{ section.settings.button_label }}</a>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
<div class="container">
    <div class="d-flex justify-content-center flex-row-reverse flex-md-row px-md-10 pb-md-30 stronger_together">
        <div class="stronger_together_patch">
            <img src="https://qureskincaredns-main.com/sections/isolated/page-banner/images/promo-patch.webp" alt="promo-patch">
        </div>
        <div class="stronger_together_content">
            <img src="https://qureskincaredns-main.com/sections/isolated/page-banner/images/stronger_together.svg" alt="stronger_together">

            {% if section.settings.text != blank %}
                {{ section.settings.text | replace: '<p>', '<p class="pink_headband">' }}
            {% endif %}

            {% if section.settings.subtext != blank %}
                {{ section.settings.subtext | replace: '<p>', '<p class="prevent_breast_cancer d-none d-md-block">' }}
            {% endif %}
        </div>
    </div>

    {% if section.settings.subtext != blank %}
        {{ section.settings.subtext | replace: '<p>', '<p class="prevent_breast_cancer d-md-none pb-30 text-center">' }}
    {% endif %}
</div>
<!-- promotional banner end -->

<!-- Page banner end -->

{% schema %}
    {
      "name": "t:sections.t:sections.index-banner-with-text-second.name",
      "settings": [
        {
            "type": "text",
            "id": "heading",
            "label": "t:common.header"
        },
        {
            "type": "richtext",
            "id": "text",
            "label": "t:common.text"
        },
        {
            "type": "richtext",
            "id": "subtext",
            "label": "t:common.text"
        },
        {
            "type": "image_picker",
            "id": "image",
            "label": "t:common.image"
        },
        {
            "type": "image_picker",
            "id": "image_mobile",
            "label": "t:common.image-mobile"
        },
        {
            "type": "text",
            "id": "button_label",
            "label": "t:common.button-label"
        },
        {
            "type": "url",
            "id": "button_url",
            "label": "t:common.button-url"
        },
        {
            "type": "text",
            "id": "button_label_mobile",
            "label": "t:common.button-label-mobile"
        },
        {
            "type": "url",
            "id": "button_url_mobile",
            "label": "t:common.button-url-mobile"
        }
      ]
    }
{% endschema %}