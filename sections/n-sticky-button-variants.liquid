<link rel="stylesheet" href="https://qureskincaredns.com/sections/new/cta-bar/cta-bar.css" />
<section class="cta-bar">
    <div class="container">
        <div class="cta-bar__content">
            <div class="cta-bar__selector" data-label="{{ 'sections.sticky-button-variants.select_color' | t }}">
                {% assign stop = false %}
                {% for block in section.blocks %}
                    {% unless stop %}
                        {% assign product_type_title = block.settings.heading | strip_newlines | strip | replace: ' ', '' | downcase %}
                        <button type="button">
                            {% if block.settings.image != blank %}
                                <img src="{{ block.settings.image | img_url: '250x' }}" alt="{{ block.settings.image.alt | escape }}">
                            {% endif %}
                            {{ product_type_title }}
                        </button>
                        {% assign stop = true %}
                    {% endunless %}
                {% endfor %}

                <ul>
                    {% for block in section.blocks %}
                        {% assign product_title_tag = block.settings.heading | strip_html | strip_newlines | strip | replace: ' ', '' | downcase %}
                        <li>
                            <label for="sticky_{{ product_title_tag }}">
                                {% if block.settings.image != blank %}
                                    <img src="{{ block.settings.image | img_url: '250x' }}" alt="{{ block.settings.image.alt | escape }}">
                                {% endif %}
                                <input type="radio" name="variant-title" id="sticky_{{ product_title_tag }}" data-variant-title="{{ product_title_tag }}" {% if forloop.index == 1 %}checked{% endif %}>
                                <span>{{ block.settings.heading }}</span>
                            </label>
                        </li>
                    {% endfor %}
                </ul>
            </div>
        </div>
        <div class="cta-bar__button">
            <a href="{% if section.settings.button-url != blank %}{{ section.settings.button-url }}{% else %}javascript:;{% endif %}" class="btn btn--primary add-cart-button add-cart-sticky-button">{% if section.settings.button-label != blank %}{{ section.settings.button-label }}{% else %}{{ 'product.settings.buy-button-label' | t }}{% endif %}</a>
        </div>
    </div>
    {% if section.settings.text != blank %}
        <div class="cta-bar__bottom">{{ section.settings.text }}</div>
    {% endif %}
</section>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadScriptOnce("cta-bar", "https://qureskincaredns.com/sections/new/cta-bar/cta-bar.js");
        loadScriptOnce("n-sticky-button-variants", "{{ 'n-sticky-button-variants.js' | asset_url }}");
    });
</script>

{%  schema  %}  
{
  "name": "t:sections.sticky-button-variants.name",
  "class": "cta-bar-position",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:common.header"
    },
    {
      "type": "text",
      "id": "text",
      "label": "t:common.text"
    },
    {
      "type": "text",
      "id": "button-label",
      "label": "t:common.button-label"
    },
    {
      "type": "text",
      "id": "button-url",
      "label": "t:common.button-url"
    }
  ],
  "blocks": [
        {
            "type": "variant",
            "name": "t:common.variant",
            "limit": 3,
            "settings": [
                {
                    "type": "text",
                    "id": "heading",
                    "label": "t:common.header"
                },
                {
                    "type": "image_picker",
                    "id": "image",
                    "label": "t:common.image"
                }
            ]
        }
  ],
  "presets": [
    {
      "name": "t:sections.sticky-button-variants.name"
    }
  ]
}
{% endschema %}