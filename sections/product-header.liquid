{% doc %}
  Renders a product header section
{% enddoc %}

{% include 'get-product-data' %}

<link rel="stylesheet" href="https://qureskincaredns-main.com/sections/isolated/targeted-patches/section-targeted-patches.css" />
<div id="buy_box" class="qure__trageted-patches qure__section"
    style="--section-padding-top: 40px; --section-padding-bottom: 80px;">
    <div class="container" style="--column-gap:80px; --column-gap-mobile:30px;">
        <div class="row custom__grid">
            <div class="col-lg-6 custom__block">
                <div class="qure-product-details">

                    {% render 'product-page-slider', product: product, page: blank, class: 'tp-product-gallery d-block d-lg-none mb-30' %}
                    {% render 'product-rating', product: product %}

                    {% if section.settings.seo_heading != blank %}
                        <p class="mb-10 fs-16 fw-400">{{ section.settings.seo_heading }}</p>
                    {% endif %}
                    {% if section.settings.heading != blank %}
                        <h1 class="qure__product-title mb-10">{{ section.settings.heading }}</h1>
                    {% endif %}

                    <h4 class="fw-500 fm-body" style="--font-h4: 22px; --font-h4-mob: 20px;">{{ product_sale_price }}</h4>

                    {% if section.settings.description != blank %}
                        <div class="patch__single-shortdes mt-20">
                            {{ section.settings.description }}
                        </div>
                    {% endif %}

                    {% render 'product-buy-button', product_price: product_sale_price, product_variant_id: product_variant_id, section: section %}
                    {% render 'product-buy-button-bottom', product_price_divided: product_price_divided %}
                    {% render 'product-next-ships', section: section %}

                </div>
            </div>
            <div class="col-lg-6 custom__block">
                {% render 'product-page-slider', product: product, page: blank, class: 'tp-product-gallery d-none d-lg-block' %}
                {% render 'product-page-cross-sell', product: product %}
                {% render 'product-page-benefits-list' %}
                {% render 'product-page-collapsed', product: product, page: blank, class: 'mt-15 tp-product-accordion' %}
                {% render 'product-page-jumpto', section: section %}
            </div>

        </div>
    </div>
</div>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadScriptOnce('main-slider', 'https://qureskincaredns-main.com/assets/js/main-slider.js');
        loadScriptOnce('youtube-popup', 'https://qureskincaredns-main.com/assets/js/yt-popup.js');
        loadScriptOnce('slider-script', 'https://qureskincaredns-main.com/assets/js/slider-with-thumb.js');
    });
</script>

{% render 'product-data-json', product: product %}

{% schema %}
{
    "name": "t:sections.product-header.name",
    "settings": [
        {
            "type": "text",
            "id": "seo_heading",
            "label": "t:common.seo_heading"
        },
        {
            "type": "text",
            "id": "heading",
            "label": "t:common.header"
        },
        {
            "type": "richtext",
            "id": "description",
            "label": "t:common.description"
        },
        {
            "type": "checkbox",
            "id": "reserved",
            "label": "t:common.reserved",
            "default": false
        },
        {
            "type": "checkbox",
            "id": "soldout",
            "label": "t:common.soldout",
            "default": false
        }
    ],
    "blocks": [
        {
            "type": "jumpto",
            "name": "t:common.jumpto",
            "limit": 10,
            "settings": [
                {
                    "type": "text",
                    "id": "button-label",
                    "label": "t:common.button-label"
                },
                {
                    "type": "url",
                    "id": "button-url",
                    "label": "t:common.button-url"
                }
            ]
        },
        {
            "type": "nextships",
            "name": "t:common.nextships",
            "limit": 1,
            "settings": [
                {
                    "type": "text",
                    "id": "date",
                    "label": "t:common.date"
                },
                {
                    "type": "range",
                    "id": "percent",
                    "min": 0,
                    "max": 100,
                    "step": 1,
                    "unit": "%",
                    "label": "t:common.percent",
                    "default": 48
                },
                {
                    "type": "text",
                    "id": "date_soldout",
                    "label": "t:common.soldout"
                },
                {
                    "type": "text",
                    "id": "date_reserved",
                    "label": "t:common.reserved"
                }
            ]
        }
    ],
    "presets": [
        {
        "name": "t:sections.product-header.name"
        }
    ]
}
{% endschema %}