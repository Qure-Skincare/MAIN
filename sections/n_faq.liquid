{% doc %}
    Renders a faq section.
{% enddoc %}

{% if section.settings.use_own_file %}
    <link rel="stylesheet" href="https://qureskincaredns.com/sections/new/have-questions/have-questions.css" />
{% endif %}
<div class="have-questions">
    <div class="container">
        {{ section.settings.heading }}
        <div class="c-faq-accordion c-faq-accordion--lines">
            <div class="c-faq-accordion__list">
                {% for block in section.blocks %}
                    {% if block.type == 'accordion' %}
                        <div class="c-faq-accordion__item">
                            {% if block.settings.heading != blank %}
                                <div class="c-faq-accordion__header">
                                    <button type="button" data-bs-toggle="collapse" data-bs-target="#c-faq-accordion-{{ forloop.index }}" aria-expanded="false">{{ block.settings.heading }}</button>
                                </div>
                            {% endif %}
                            {% if block.settings.text != blank %}
                                <div id="c-faq-accordion-{{ forloop.index }}" class="c-faq-accordion__body collapse">
                                    <div class="c-faq-accordion__content">
                                        {{ block.settings.text }}
                                    </div>
                                </div>
                            {% endif %}
                        </div>
                    {% endif %}
                {% endfor %}
            </div>
            {% if section.settings.button_label != blank and section.settings.button_url != blank %}
                <div class="c-faq-accordion__ask-us">
                    {{ section.settings.text }} <a href="{{ section.settings.button_url }}" class="btn btn-sm btn--secondary">{{ section.settings.button_label }}<i class="e-icon e-icon-arrow"></i></a>
                </div>
            {% endif %}
        </div>
    </div>
</div>

{% schema %}
{
    "name": "t:sections.n_faq.name",
    "settings": [
        {
            "type": "checkbox",
            "id": "use_own_file",
            "label": "t:common.use-own-file",
            "default": false
        },
        {
            "type": "richtext",
            "id": "heading",
            "label": "t:common.header"
        },
        {
            "type": "text",
            "id": "text",
            "label": "t:common.text",
            "default": "Don't see your question? "
        },
        {
            "type": "text",
            "id": "button_label",
            "label": "t:common.button-label",
            "default": "Ask us "
        },
        {
            "type": "url",
            "id": "button_url",
            "label": "t:common.button-url"
        }
    ],
    "blocks": [
        {
            "type": "accordion",
            "name": "t:common.accordion",
            "settings": [
                {
                    "type": "text",
                    "id": "heading",
                    "label": "t:common.header"
                },
                {
                    "type": "richtext",
                    "id": "text",
                    "label": "t:common.text"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "t:sections.n_faq.name"
        }
    ]
}
{% endschema %}