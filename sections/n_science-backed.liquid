{% doc %}
  Renders a science backed section
{% enddoc %}

<!-- SCIENCE BACKED -->
{% if section.settings.use_own_file %}
    <link rel="stylesheet" href="https://qureskincaredns.com/sections/new/science-backed/science-backed.css" />
{% endif %}
<section class="science-backed">
    <div class="container">
        {% if section.settings.text != blank %}
            <article class="science-backed__text">
                {{ section.settings.text }}
            </article>
        {% endif %}
        
        <div class="science-backed__content">
            <div class="science-backed__data">
                {% if section.settings.left_image != blank %}
                    <img src="{{ section.settings.left_image | image_url }}" alt="{{ section.settings.left_image.alt | escape }}" />
                {% endif %}
                {{ section.settings.left_heading }}
                <ul>
                    {% for block in section.blocks %}
                        {% if block.type == 'left_text_with_image' %}
                            {% if block.settings.text != blank %}
                                <li>
                                    <i class="e-icon e-icon-{{ block.settings.icon }}"></i>
                                    {{ block.settings.text }}
                                </li>
                            {% endif %}
                        {% endif %}
                    {% endfor %}
                </ul>
                <div class="c-accordion c-accordion--lines">
                    <div class="c-accordion__list">
                        {% for block in section.blocks %}
                            {% if block.type == 'left_accordion' %}
                                <details class="c-accordion__item">
                                    {% if block.settings.heading != blank %}
                                        <summary class="c-accordion__summary">{{ block.settings.heading }}</summary>
                                    {% endif %}
                                    {% if block.settings.text != blank %}
                                        <article class="c-accordion__content">
                                            {{ block.settings.text | replace: '<p>[note]', '<small>' | replace: '[/note]</p>', '</small>' }}
                                        </article>
                                    {% endif %}
                                </details>
                            {% endif %}
                        {% endfor %}
                    </div>
                </div>
                {% for block in section.blocks %}
                    {% if block.type == 'left_feedback' %}
                        <div class="quote">
                            {% if block.settings.rating != blank %}
                                <div class="e-rating-stars" style="--rating: {{ block.settings.rating }}"></div>
                            {% endif %}
                            {{ block.settings.text }}
                            {% if block.settings.country_image != blank and block.settings.username != blank %}
                                <div class="e-author">
                                    <img src="{{ block.settings.country_image | image_url }}" alt="{{ block.settings.country_image.alt | escape }}" />
                                    {{ block.settings.username }}
                                </div>
                            {% endif %}
                            {% if block.settings.badge_text != blank %}
                                <small>{{ block.settings.badge_text }}</small>
                            {% endif %}
                        </div>
                    {% endif %}
                {% endfor %}
                
            </div>
            {% for block in section.blocks %}
                {% if block.type == 'text_between' %}
                    {% if block.settings.text != blank %}
                        <div class="science-backed__or">{{ block.settings.text }}</div>
                    {% endif %}
                {% endif %}
            {% endfor %}
            
            <div class="science-backed__data">
                {% if section.settings.right_image != blank %}
                    <img src="{{ section.settings.right_image | image_url }}" alt="{{ section.settings.right_image.alt | escape }}" />
                {% endif %}
                {{ section.settings.right_heading }}
                <ul>
                    {% for block in section.blocks %}
                        {% if block.type == 'right_text_with_image' %}
                            {% if block.settings.text != blank %}
                                <li>
                                    <i class="e-icon e-icon-{{ block.settings.icon }}"></i>
                                    {{ block.settings.text }}
                                </li>
                            {% endif %}
                        {% endif %}
                    {% endfor %}
                </ul>
                <div class="c-accordion c-accordion--lines">
                    <div class="c-accordion__list">
                        {% for block in section.blocks %}
                            {% if block.type == 'right_accordion' %}
                                <details class="c-accordion__item">
                                    {% if block.settings.heading != blank %}
                                        <summary class="c-accordion__summary">{{ block.settings.heading }}</summary>
                                    {% endif %}
                                    {% if block.settings.text != blank %}
                                        <article class="c-accordion__content">
                                            {{ block.settings.text | replace: '<p>[note]', '<small>' | replace: '[/note]</p>', '</small>' }}
                                        </article>
                                    {% endif %}
                                </details>
                            {% endif %}
                        {% endfor %}
                    </div>
                </div>
                {% for block in section.blocks %}
                    {% if block.type == 'right_feedback' %}
                        <div class="quote">
                            {% if block.settings.rating != blank %}
                                <div class="e-rating-stars" style="--rating: {{ block.settings.rating }}"></div>
                            {% endif %}
                            {{ block.settings.text }}
                            {% if block.settings.country_image != blank and block.settings.username != blank %}
                                <div class="e-author">
                                    <img src="{{ block.settings.country_image | image_url }}" alt="{{ block.settings.country_image.alt | escape }}" />
                                    {{ block.settings.username }}
                                </div>
                            {% endif %}
                            {% if block.settings.badge_text != blank %}
                                <small>{{ block.settings.badge_text }}</small>
                            {% endif %}
                        </div>
                    {% endif %}
                {% endfor %}
                
            </div>
        </div>
    </div>
</section>
<!-- SCIENCE BACKED END -->

