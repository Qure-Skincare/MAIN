{% doc %}
  Renders a bundle banner section
{% enddoc %}


<link rel="stylesheet" href="https://qureskincaredns-main.com/sections/isolated/bundle-banner/bundle-banner.css" />
<div class="bundle__banner position-relative">
   <div class="bundle__banner-img">
    {% if section.settings.image != blank and section.settings.image_mobile != blank %}
        <picture>
         <source media="(min-width:1920px)" srcset="{{ section.settings.image | image_url }}" class="img-fluid" width="1440" height="557">
         <source media="(min-width:1600px)" srcset="{{ section.settings.image | image_url }}" class="img-fluid" width="1440" height="557">
         <source media="(min-width:1100px)" srcset="{{ section.settings.image | image_url }}" class="img-fluid" width="1440" height="557">
         <source media="(min-width:767px)" srcset="{{ section.settings.image | image_url }}" class="img-fluid" width="1440" height="557">
         <source media="(min-width:540px)" srcset="{{ section.settings.image_mobile | image_url }}" class="img-fluid" width="1440" height="557">
         <img src="{{ section.settings.image_mobile | image_url }}" width="225" height="281" alt="{{ section.settings.image.alt | escape }}" class="img-fluid w-100">
      </picture>
    {% endif %}
   </div>
   <div class="bundle__banner-content position-absolute d-flex align-items-center justify-content-end top-0 bottom-0 start-0 end-0"{% if section.settings.button_url != blank %} onclick="window.location.href='{{ section.settings.button_url }}'" style="cursor: pointer;"{% endif %}>
      <div class="container bundle__container py-40" style="--column-gap:60px; --column-gap-mobile:30px;">
         <div class="row custom__grid justify-content-end align-items-center">
            <div class="custom__block col-lg-5">
                {% if section.settings.heading != blank and section.settings.text != blank and section.settings.text_mobile != blank %}
                    <h5 class="fm-body fw-600 mb-5">{{ section.settings.heading }}</h5>
                    {{ section.settings.text | replace: '<p>', '<p class="d-none d-lg-block">' }}
                    {{ section.settings.text_mobile | replace: '<p>', '<p class="d-block d-lg-none">' }}
                {% endif %}    
            </div>
            {% if section.settings.button != blank and section.settings.button_url != blank %}
                <div class="custom__block col-lg-3">
                <a href="{{ section.settings.button_url }}" class="btn btn--primary">{{ section.settings.button }}</a>
            </div>
            {% endif %}
         </div>
      </div>
   </div>
</div>
{% schema %}
{
  "name": "t:sections.bundle-banner.name",
  "settings": [
   {
        "type": "text",
        "id": "heading",
        "label": "t:common.header"
    },
    {
        "type": "richtext",
        "id": "text",
        "label": "t:common.text"
    },
    {
        "type": "richtext",
        "id": "text_mobile",
        "label": "t:common.text-mobile"
    },
    {
        "type": "text",
        "id": "button",
        "label": "t:common.button-label"
    },
    {
        "type": "url",
        "id": "button_url",
        "label": "t:common.button-url"
    },
    {
        "type": "image_picker",
        "id": "image",
        "label": "t:common.image"
    },
    {
        "type": "image_picker",
        "id": "image_mobile",
        "label": "t:common.image-mobile"
    }
  ],
  "presets": [
    {
        "name": "t:sections.bundle-banner.name"
    }
  ]
}
{% endschema %}