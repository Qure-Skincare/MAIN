{% doc %}
    Renders a test page for the micro-infusion landing page
{% enddoc %}

<!-- Banner with text -->
<link href="https://qureskincaredns.com/sections/global/banner-with-text/banner-text.css" rel="stylesheet" type="text/css">
<div id="image_text" class="qure__section banner-with-text"
    style="--section-padding-top:60px; --section-padding-bottom:0;">
    <div class="container">
        <div class="row custom__grid align-items-center" style="--column-gap:40px; --column-gap-mobile:32px;">
            <div class="col-md-6 custom__block">
                <div class="banner-with-text-content">
                    <h2 class="banner-text--heading">Qure’s Micro-Infusion goes where your skin cream can’t…</h2>
                    <div class="it_img mt-20 d-md-none">
                        <div class="wistia_responsive_padding" style="position:relative;">
                            <div class="wistia_responsive_wrapper"
                                style="height:100%;left:0;position:absolute;top:0;width:100%;">
                                <div class="wistia_embed wistia_async_a1pykz2tp0 seo=false videoFoam=true"
                                    style="height:100%;position:relative;width:100%">&nbsp;</div>
                            </div>
                        </div>
                    </div>
                    <div class="banner-text--des" style="--text-mt: 32px; --text-mb: 32px;">
                        <p>Its tiny, almost painless, microneedles penetrate beyond the skin’s surface increasing serum absorption and delivering powerful active ingredients exactly where they’re needed!<br><br><span class="fw-600 bg-transparent">How Qure repairs your skin in 3 easy steps:</span></p>
                    </div>
                    <div class="banner-text--steps">
                        <div class="banner-step-box"><strong>Stamp</strong><br> Patented 24k Gold Hollow Needles create micro-channels.</div>
                        <div class="banner-step-box"><strong>Infuse</strong><br> Clinically formulated serum flows directly into the dermis, not on top of it.</div>
                        <div class="banner-step-box"><strong>Renews</strong><br> Triggers your body's natural healing response to boost collagen.</div>
                    </div>
                </div>
            </div>
            <div class="col-md-6 custom__block d-none d-md-block">
                <div class="it_img pl-md-20">
                    <div class="wistia_responsive_padding" style="position:relative;">
                        <div class="wistia_responsive_wrapper"
                            style="height:100%;left:0;position:absolute;top:0;width:100%;">
                            <div class="wistia_embed wistia_async_a1pykz2tp0 seo=false videoFoam=true"
                                style="height:100%;position:relative;width:100%">&nbsp;</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="info-banner">
            <h6><i class="fas fa-question-circle"></i> Does it hurt?</h6>
            No, it feels like Velcro. No numbing cream needed. Most users rate the sensation a 2/10. Visible redness fades within hours, not days!
        </div>
    </div>
</div>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadScriptOnce('wistia-script', 'https://fast.wistia.com/assets/external/E-v1.js');
    });
</script>
<!-- Banner with text end -->

