{% doc %}
Renders a money back guarantee section.
{% enddoc %}

<link rel="stylesheet" href="https://qureskincaredns-main.com/sections/isolated/guarantee/guarantee.css" />
   <div class="qure__section section-guarantee"
      style="--section-padding-top: 40px; --section-padding-bottom: 80px; --section-padding-top-mob: 30px; --section-padding-bottom-mob: 30px;">
      <div class="container">
         <div class="qure__guarantee-container">
            {% if section.settings.image != blank %}
                <img src="{{ section.settings.image | image_url }}" alt="{{ section.settings.image.alt | escape }}" class="guarantee-badge img-fluid ctm-width" style="--ctm-width: 190px; --ctm-width-mob:114px" />
            {% endif %}
            {% if section.settings.heading != blank %}
                {{ section.settings.heading | replace: '<p>', '<h2 class="guarantee-title my-30">' | replace: '</p>', '</h2>' }}
            {% endif %}
            {% if section.settings.text != blank %}
                {{ section.settings.text | replace: '<p>', '<div class="guarantee-desc">' | replace: '</p>', '</div>' }}
            {% endif %}
         </div>
      </div>
   </div>
   <div class="bg-primary text-center fs-18 py-13 py-lg-16 fw-500">
    {% if section.settings.sub_text != blank %}
         {{ section.settings.sub_text | replace: '<p>', '<span>' | replace: '</p>', '</span>' }}
    {% endif %}
   </div>

   {% schema %}
{
    "name": "t:sections.money-back-guarantee.name",
    "settings": [
    {
        "type": "richtext",
        "id": "heading",
        "label": "t:common.header"
    },
    {
        "type": "richtext",
        "id": "text",
        "label": "t:common.text"
    },
    {
        "type": "richtext",
        "id": "sub_text",
        "label": "t:common.sub-text"
    },
    {
        "type": "image_picker",
        "id": "image",
        "label": "t:common.image"
    }
    ],
    "presets": [
    {
        "name": "t:sections.money-back-guarantee.name"
    }
    ]
}
{% endschema %}