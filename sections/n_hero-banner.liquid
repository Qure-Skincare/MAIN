{% doc %}
  Renders a hero banner section
{% enddoc %}


{% if section.settings.use_own_file %}
    <link href="https://qureskincaredns.com/sections/new/hero-banner/hero-banner.css" rel="stylesheet" type="text/css"> 
{% endif %}
    <section class="hero-banner{% if section.settings.modifier != 'none' %} hero-banner--{{ section.settings.modifier }}{% endif %}">
        <picture>
            {% if section.settings.image != blank %}
                <source media="(min-width:768px)" srcset="{{ section.settings.image | image_url }}">
            {% endif %}
            {% if section.settings.image_mobile != blank %}
                <img src="{{ section.settings.image_mobile | image_url }}" alt="{{ section.settings.image_mobile.alt | escape }}">
            {% endif %}
        </picture>
        <div class="container">
            <article>
                {% if section.settings.text != blank %}
                    {{ section.settings.text }}
                {% endif %}

                
                <ul>
                    {% for block in section.blocks %}
                        {% if block.type == 'text'%}
                            <li>
                                {{ block.settings.text 
                                | replace: '<p>[small]', '<small>' 
                                | replace: '[/small]', '</small>' 
                                | replace: '<p>', '' 
                                | replace: '</p>', ''}}

                            </li>
                        {% endif %}
                    {% endfor %}
                </ul>

            </article>
        </div>
    </section>


{% schema %}
{
    "name": "t:sections.n_hero-banner.name",
        "settings": [
        {
            "type": "checkbox",
            "id": "use_own_file",
            "label": "t:common.use-own-file",
            "default": false
        },
        {
            "type": "select",
            "id": "modifier",
            "label": "t:common.modifier",
            "default": "none",
            "options": [
                {
                    "value": "none",
                    "label": "t:sections.n_hero-banner.settings.modifier-options.none"
                },
                {
                    "value": "holidays",
                    "label": "t:sections.n_hero-banner.settings.modifier-options.holidays"
                },
                {
                    "value": "easter",
                    "label": "t:sections.n_hero-banner.settings.modifier-options.easter"
                }
            ]
        },
        {
            "type": "richtext",
            "id": "text",
            "label": "t:common.text"
        },
        {
            "type": "image_picker",
            "id": "image",
            "label": "t:common.image"
        },
        {
            "type": "image_picker",
            "id": "image_mobile",
            "label": "t:common.image-mobile"
        }
    ],
    "blocks": [
        {
            "type": "text",
            "name": "t:common.text",
            "settings": [
                {
                    "type": "richtext",
                    "id": "text",
                    "label": "t:common.text"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "t:sections.n_hero-banner.name"
        }
    ]
}
{% endschema %}