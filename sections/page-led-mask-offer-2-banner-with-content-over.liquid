{% doc %}
  Renders a banner with content over section on page led-mask-offer-2
{% enddoc %}

<link rel="stylesheet"
    href="https://qureskincaredns.com/sections/isolated/content-over-image/content-over-image.css" />
<div class="content-over-image-banner position-relative">
    <div class=" ct-over-parent">
        <div class="ct-banner-img">
            <picture>
                {% if section.settings.image != blank %}
                    <source media="(min-width:1920px)" srcset="{{ section.settings.image | image_url }}" class="img-fluid" width="1440" height="557">
                    <source media="(min-width:1600px)" srcset="{{ section.settings.image | image_url }}" class="img-fluid" width="1440" height="557">
                    <source media="(min-width:1100px)" srcset="{{ section.settings.image | image_url }}" class="img-fluid" width="1440" height="557">
                    <source media="(min-width:575px)" srcset="{{ section.settings.image | image_url }}" class="img-fluid" width="1440" height="557">
                {% endif %}
                {% if section.settings.image_mobile != blank %}
                    <source media="(min-width:540px)" srcset="{{ section.settings.image_mobile | image_url }}" class="img-fluid" width="1440" height="557">
                    <img src="{{ section.settings.image_mobile | image_url }}" width="225" height="281" alt="{{ section.settings.image_mobile.alt | escape }}" class="img-fluid w-100">
                {% endif %}
            </picture>
        </div>
        <div class="align-items-start align-items-sm-center ct-banner-content d-flex inset-0 position-absolute qure__section"
            style="--section-padding-top: 80px; --section-padding-bottom: 80px; --section-background: #F6F6F7; --section-padding-top-mob: 30px; --section-padding-bottom-mob: 30px;">
            <div class="container">
                <div class="ct-over-child ct-banner-inner d-flex flex-column gap-3 bg-white p-16 p-md-30 rounded-10 ctm-width"
                    roun="" style="--ctm-width: 580px;    --ctm-width-mob: 100%;">
                    <div class="align-items-center ct-banner-rating d-flex fs-16 gap-3">
                        {% if section.settings.rating_image != blank %}
                            <img src="{{ section.settings.rating_image | image_url }}" alt="{{ section.settings.rating_image.alt | escape }}" height="16px">
                        {% endif %}
                        {% if section.settings.rating_text != blank %}
                            {{ section.settings.rating_text | replace: '<p>', '<span>' | replace: '</p>', '</span>' }}
                        {% endif %}  
                    </div>
                    {% if section.settings.heading != blank %}
                         <h2>{{ section.settings.heading }}</h2>
                    {% endif %}
                    <div class="ct-banner-price d-flex gap-3 text-uppercase">
                        {% if section.settings.price != blank %}
                            {{ section.settings.price 
                            | replace: '<p><em>', '<span class="color-grey text-decoration-line-through">' 
                            | replace: '</em></p>', '</span>'
                            | replace: '<p><strong>', '<span class="qure__product-label text-uppercase px-14">'
                            | replace: '</strong></p>', '</span>'
                            | replace: '<p>[span]', ''
                            | replace: '[/span]</p>', '' }}
                        {% endif %}
                    </div>
                    {% if section.settings.text != blank %}
                        {{ section.settings.text | replace: '<ul>', '<ul class="qure__list-check d-flex flex-column gap-2">' }}
                    {% endif %}
                    {% if section.settings.button_url != blank and section.settings.button_label != blank %}
                        <a href="{{ section.settings.button_url }}" class="add-cart-button product-form__submit btn btn--primary w-100 d-flex align-items-center gap-3 justify-content-center mt-15">{{ section.settings.button_label }} <i class="fa-regular fa-arrow-right-long "></i></a>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadScriptOnce('equal-height', 'https://qureskincaredns.com/assets/js/equal-height.js');
    });
</script>

{% schema %}
{
  "name": "t:sections.banner-with-content.name",
  "settings": [
        {
            "type": "text",
            "id": "heading",
            "label": "t:common.header"
        },
        {
            "type": "richtext",
            "id": "text",
            "label": "t:common.text"
        },
        {
            "type": "image_picker",
            "id": "image",
            "label": "t:common.image"
        },
        {
            "type": "image_picker",
            "id": "image_mobile",
            "label": "t:common.image-mobile"
        },
        {
            "type": "richtext",
            "id": "rating_text",
            "label": "t:common.rating-text"
        },
        {
            "type": "image_picker",
            "id": "rating_image",
            "label": "t:common.rating-image"
        },
        {
            "type": "richtext",
            "id": "price",
            "label": "t:common.price"
        },
        {
            "type": "text",
            "id": "button_label",
            "label": "t:common.button-label"
        },
        {
            "type": "url",
            "id": "button_url",
            "label": "t:common.button-url"
        }
    ]
}
{% endschema %}