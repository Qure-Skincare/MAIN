{% doc %}
Renders a quick and easy section for microinfusion faq page.
{% enddoc %}

<div class="qure__section"
    style="--section-padding-top: 30px; --section-padding-bottom: 30px;--section-padding-top-mob: 20px; --section-padding-bottom-mob: 20px;">
    <div class="container">
        <div class="common_faq">
            <div class="quick-and-easy">
                {% if section.settings.heading != blank %}
                    <p class="faq_block-heading fs-md-34 fs-26 pb-10 mb-15">{{ section.settings.heading }}</p>
                {% endif %}
                {% if section.settings.text != blank %}
                    <p class="pb-15 d-md-none">{{ section.settings.text }}</p>
                {% endif %}
                <div class="row flex-md-nowrap flex-wrap custom__grid align-items-center"
                    style="--column-gap:40px; --column-gap-mobile:30px;">
                    <div class="custom__block ctm-width" style="--ctm-width:340px; --ctm-width-mob:100%;">
                        {% if section.settings.wistia_url != blank %}
                            <div class="wistia__player">
                                <div class="wistia_responsive_padding" style="position:relative;">
                                    <div class="wistia_responsive_wrapper" style="height:100%;left:0;position:absolute;top:0;width:100%;">
                                        <div class="wistia_embed wistia_async_{{ section.settings.wistia_url }} seo=false videoFoam=true" style="height:100%;position:relative;width:100%">
                                            <div class="wistia_swatch" style="height:100%;left:0;opacity:0;overflow:hidden;position:absolute;top:0;transition:opacity 200ms;width:100%;">
                                                <img src="https://fast.wistia.com/embed/medias/section.{{ settings.wistia_url }}/swatch" style="filter:blur(5px);height:100%;object-fit:contain;width:100%;" alt="" aria-hidden="true" onload="this.parentNode.style.opacity=1;" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endif %}
                    </div>
                    <div class="col custom__block">
                        {% if section.settings.text != blank %}
                            <p class="pb-15 d-none d-md-block">{{ section.settings.text }}</p>
                        {% endif %}
                        <div class="row custom__grid flex-column" style="--column-gap:24px; --column-gap-mobile:24px;">
                            {% for block in section.blocks %}
                                {% if block.type == 'list' %}
                                    <div class="col-md-6 col-lg-12 custom__block">
                                        <div class="qe__card-block d-flex gap-4 align-items-center"
                                            style="--bs-border-radius:10px">
                                            <div class="img_with-number overflow-hidden position-relative ctm-width" style="--ctm-width:200px; --ctm-width-mob:100px;" data-number="{{ forloop.index }}">
                                                {% if block.settings.image != blank %}
                                                    <img src="{{ block.settings.image | image_url }}" alt="{{ block.settings.image.alt | escape }}" class="img-fluid rounded-2 d-none d-lg-block" />
                                                {% endif %}
                                                {% if block.settings.image_mobile != blank %}
                                                    <img src="{{ block.settings.image_mobile | image_url }}" alt="{{ block.settings.image_mobile.alt | escape }}" class="img-fluid rounded-2 d-block d-lg-none" />
                                                {% endif %}
                                            </div>
                                            <div class="qe__content">
                                                {% if block.settings.heading != blank %}
                                                    <h3 class="fs-20 fw-600 fm-body mb-10">{{ block.settings.heading }}</h3>
                                                {% endif %}
                                                {% if block.settings.text != blank %}
                                                    <div class="fs-16">{{ block.settings.text }}</div>
                                                {% endif %}
                                            </div>
                                        </div>
                                    </div>
                                {% endif %}
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadScriptOnce('wistia-script', 'https://fast.wistia.com/assets/external/E-v1.js');
    });
</script>


{% schema %}
{
    "name": "t:sections.quick-and-easy.name",
    "settings": [
    {
        "type": "text",
        "id": "heading",
        "label": "t:common.header"
    },
    {
        "type": "text",
        "id": "text",
        "label": "t:common.text"
    },
    {
        "type": "text",
        "id": "wistia_url",
        "label": "t:common.wistia-url"
    }
    ],
    "blocks": [
        {
        "type": "list",
        "name": "t:common.list",
        "settings": [
            {
                "type": "text",
                "id": "heading",
                "label": "t:common.header"
            },
            {
                "type": "text",
                "id": "text",
                "label": "t:common.text"
            },
            {
                "type": "image_picker",
                "id": "image",
                "label": "t:common.image"
            },
            {
                "type": "image_picker",
                "id": "image_mobile",
                "label": "t:common.image-mobile"
            }
        ]
    }
    ]
}
{% endschema %}