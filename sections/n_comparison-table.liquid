                    {
                        "value": "none",
                        "label": "t:common.none"
                    },
                    {
                        "value": "colorize",
                        "label": "t:common.colorize"
                    }
                ]
            }
        ]
    },
    {
        "type": "comparison_table",
        "name": "t:common.comparison-table",
        "settings": [
            {
                "type": "image_picker",
                "id": "image",
                "label": "t:common.image"
            },
            {
                "type": "richtext",
                "id": "heading",
                "label": "t:common.header"
            },
            {
                "type": "text",
                "id": "text_1",
                "label": "t:common.text"
            },
            {
                "type": "select",
                "id": "select_1",
                "label": "t:common.select",
                "options": [
                    {
                        "value": "checkmark",
                        "label": "t:common.checkmark"
                    },
                    {
                        "value": "cross",
                        "label": "t:common.cross"
                    }
                ]
            },
            {
                "type": "text",
                "id": "text_2",
                "label": "t:common.text"
            },
            {
                "type": "select",
                "id": "select_2",
                "label": "t:common.select",
                "options": [
                    {
                        "value": "checkmark",
                        "label": "t:common.checkmark"
                    },
                    {
                        "value": "cross",
                        "label": "t:common.cross"
                    }
                ]
            },
            {
                "type": "text",
                "id": "text_3",
                "label": "t:common.text"
            },
            {
                "type": "select",
                "id": "select_3",
                "label": "t:common.select",
                "options": [
                    {
                        "value": "checkmark",
                        "label": "t:common.checkmark"
                    },
                    {
                        "value": "cross",
                        "label": "t:common.cross"
                    }
                ]
            },
            {
                "type": "text",
                "id": "text_4",
                "label": "t:common.text"
            },
            {
                "type": "select",
                "id": "select_4",
                "label": "t:common.select",
                "options": [
                    {
                        "value": "checkmark",
                        "label": "t:common.checkmark"
                    },
                    {
                        "value": "cross",
                        "label": "t:common.cross"
                    }
                ]
            }
        ]
    }
],
"presets": [
    {
        "name": "t:sections.n_comparison-table.name"
    }
]
}
{% endschema %}