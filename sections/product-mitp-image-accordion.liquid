{% doc %}
Renders a micro-infusion targeted patches ingredients.
{% enddoc %}

<link rel="stylesheet" href="https://qureskincaredns.com/sections/isolated/img-accordion/img-accordion.css" />
<div class="image-accordion qure__section"
    style="--section-padding-top: 80px; --section-padding-bottom: 80px; --section-padding-top-mob: 30px; --section-padding-bottom-mob: 30px;"
    id="ingredients">
    <div class="container container-small" style="--container-width: 850px;">
        <div class="qure__section-header text-center mb-60">
            {% if section.settings.heading != blank %}
                <h2 class="qure__section-heading">{{ section.settings.heading }}</h2>
            {% endif %}
        </div>
    </div>
    <div class="container" style="--column-gap:32px; --column-gap-mobile:24px;">
        <div class="row accordion accordion-flush custom__grid" id="img-acc-main">
            {% for block in section.blocks %}
                {% if block.type == 'accordion' %}
                    <div class="col-md-6 custom__block">
                        <div class="img__accordion-item">
                            <button class="collapsed img__accordion-header position-relative" type="button"
                                data-bs-toggle="collapse" data-bs-target="#{{ block.settings.heading | downcase }}" aria-expanded="false"
                                aria-controls="{{ block.settings.heading | downcase }}">
                                {% if block.settings.image != blank %}
                                    <img src="{{ block.settings.image | image_url }}" alt="{{ block.settings.image.alt | escape }}" class="img-fluid w-100" />
                                {% endif %}
                                <div class="img__accordion-inner">
                                    {% if block.settings.heading != blank %}
                                        <div class="img__accordion-label">{{ block.settings.heading }}</div>
                                    {% endif %}
                                </div>
                            </button>
                            <div id="{{ block.settings.heading | downcase }}" class="collapse img__accordion-content" data-bs-parent="#img-acc-main">
                                <div class="img__accordion-body">
                                    {% if block.settings.text != blank %}
                                        <div class="px-12 pt-12">{{ block.settings.text }}</div>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                {% endif %}
            {% endfor %}
        </div>
        <link href="https://qureskincaredns.com/assets/css/popup-modal.css" rel="stylesheet">
        <div class="ctm_modal_derm_mist d-flex justify-content-center mt-30">
            <div class="modal fade" id="exampleModalToggle" aria-hidden="true" aria-labelledby="exampleModalToggleLabel" tabindex="-1">
                <div class="modal-dialog modal-dialog-centered" style="--bs-modal-width: 1150px;">
                    <div class="modal-content p-30 pt-5 pr-5 rounded-0">
                        <div class="modal-header border-0 p-0">
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"><i class="fa-solid fa-xmark"></i></button>
                        </div>
                        <div class="modal-body p-0">
                            {% if section.settings.popup_heading != blank %}
                                <h5 class="modal-title fs-16 fw-600 fm-body mb-4" id="exampleModalToggleLabel">{{ section.settings.popup_heading }}</h5>
                            {% endif %}
                            {% if section.settings.popup_text != blank %}
                                <p class="fs-16 fw-400 fm-body">{{ section.settings.popup_text }}</p>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
            {% if section.settings.button_label != blank and section.settings.button_url != blank %}
                <a class="btn color-background text-black border-0 fs-18 fw-500" data-bs-toggle="modal" href="{{ section.settings.button_url }}" role="button">{{ section.settings.button_label }}</a>
            {% endif %}
        </div>
        <!-- popup modal end  -->
    </div>
</div>

{% schema %}
{
    "name": "t:sections.image-accordion.name",
    "settings": [
        {
            "type": "text",
            "id": "heading",
            "label": "t:common.header"
        },
        {
            "type": "text",
            "id": "popup_heading",
            "label": "t:common.popup-header"
        },
        {
            "type": "text",
            "id": "popup_text",
            "label": "t:common.popup-text"
        },
        {
            "type": "text",
            "id": "button_label",
            "label": "t:common.button-label"
        },
        {
            "type": "url",
            "id": "button_url",
            "label": "t:common.button-url"
        }
    ],
    "blocks": [
        {
            "type": "accordion",
            "name": "t:common.accordion",
            "settings": [
            {
                "type": "text",
                "id": "heading",
                "label": "t:common.header"
            },
            {
                "type": "richtext",
                "id": "text",
                "label": "t:common.text"
            },
            {
                "type": "image_picker",
                "id": "image",
                "label": "t:common.image"
            }
            ]
        }
    ]
}
{% endschema %}