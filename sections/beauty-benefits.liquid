{% doc %}
  Renders a beauty benefits section
{% enddoc %}


<link rel="stylesheet" href="https://qureskincaredns.com/sections/isolated/archive/archive-skincare.css" />
   <div id="achieve_skincare_goals" class="qure__section"
      style="--section-padding-top:40px; --section-padding-bottom:80px;">
      <div class="container">
         <div class="qure__section-header text-center mb-30 mb-md-60">
            {% if section.settings.heading != blank %}
                <h2 class="qure__section-heading">{{ section.settings.heading }}</h2>
            {% endif %}
         </div>
         <div class="qure__swiper-wrapper">
            <div class="ctm-width mx-auto" style="--ctm-width: 850px;">
               <div class="swiper qure__product-gallery tp-thumbnails-desktop qure__swiper-gallery-thumbnails"
                  data-section-id="tp-thumbnails-desktop" data-mobile="1.5" data-tablet="2" data-desktop="3"
                  data-autoplay="false" data-loop="false" data-spacing="20" data-pagination=".my-pagination"
                  data-pagination-fraction="true">
                  <div class="swiper-wrapper">
                    {% for block in section.blocks %}
                        {% if block.type == 'heading' %}
                            {% if block.settings.heading != blank %}
                                <div class="swiper-slide"><button class="nav-link">{{ block.settings.heading }}</button></div>
                            {% endif %}
                        {% endif %}
                    {% endfor %}
                  </div>
               </div>
            </div>
            <div class="swiper qure__product-gallery qure__swiper-gallery ctm_cls_press_slider mt-40"
               data-section-id="tp-gallery-desktop" data-mobile="1" data-tablet="3" data-desktop="4"
               data-autoplay="false" data-loop="true" data-spacing="0" data-pagination-fraction="true">
               <div class="swiper-wrapper" style="--perload-gap: 10px" data-nav-thumb>
                {% for block in section.blocks %}
                    {% if block.type == 'content' %}
                        <div class="swiper-slide">
                            <div class="row custom__grid align-items-center"
                                style="--column-gap:60px; --column-gap-mobile:30px;">
                                <div class="col-md-6 custom__block">
                                <div class="card qure-card">
                                    {% if block.settings.image != blank %}
                                        <img src="{{ block.settings.image | image_url }}" class="card-img-top" alt="{{ block.settings.image.alt | escape }}">
                                    {% endif %}
                                    <div class="card-body af-card-body">
                                        <div class="reviews-header d-flex align-items-center justify-content-between"style="--bg-light: rgb(199 229 219 / 30%);">
                                            <div class="card-user">
                                                {% if block.settings.country_image != blank %}
                                                        <img src="{{ block.settings.country_image | image_url }}" alt="{{ block.settings.country_image.alt | escape }}">
                                                {% endif %}
                                                {% if block.settings.username != blank %}
                                                    <span class="username">{{ block.settings.username }}</span>
                                                {% endif %}
                                                </div>
                                                <div class="icon-with-text d-flex align-items-center gap-2">
                                                <img src="{{'sections.beauty-benefits.review_image' | t }}" alt="review" width="18px" height="18px">
                                                <span>{{ 'sections.beauty-benefits.verified_text' | t }}</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                </div>
                                <div class="col-md-6 custom__block">
                                <div class="qure__content">
                                    {% if block.settings.heading != blank %}
                                        <h4>{{ block.settings.heading }}</h4>
                                    {% endif %}
                                    {% if block.settings.text != blank %}
                                        <div class="qure--desc mt-24">{{ block.settings.text | replace: '<p>', '' | replace: '</p>', '' }}</div>
                                    {% endif %}
                                    <div class="border-top my-24"></div>
                                    {% if block.settings.list != blank %}
                                    <ul class="qure__list-check">
                                        {{ block.settings.list | replace: '<p>', '<li>' | replace: '</p>', '</li>' }}
                                    </ul>
                                    {% endif %}
                                    
                                </div>
                                </div>
                            </div>
                        </div>
                    {% endif %}
                {% endfor %}
               </div>
               <div
                  class="swiper-arrows-with-pagination d-flex d-md-none align-items-center justify-content-center gap-4 mt-30">
                  <div class="qure-swiper-arrow swiper-prev"><i class="fa-regular fa-angle-left"></i></div>
                  <div class="my-pagination position-relative bottom-0 w-auto"></div>
                  <div class="qure-swiper-arrow swiper-next"><i class="fa-regular fa-angle-right"></i></div>
               </div>
            </div>
         </div>
      </div>
   </div>
   <script>
      document.addEventListener("DOMContentLoaded", function () {
         loadScriptOnce('slider-with-thumb', 'https://qureskincaredns.com/assets/js/slider-with-thumb.js');
      });
   </script>


{% schema %}
{
  "name": "t:sections.beauty-benefits.name",
  "settings": [
    {
        "type": "text",
        "id": "heading",
        "label": "t:common.header"
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "t:common.header",
        "settings": [
            {
                "type": "text",
                "id": "heading",
                "label": "t:common.header"
            }
        ]
    },
    {
        "type": "content",
        "name": "t:common.content",
        "settings": [
            {
                "type": "text",
                "id": "heading",
                "label": "t:common.header"
            },
            {
                "type": "richtext",
                "id": "text",
                "label": "t:common.text"
            },
            {
                "type": "richtext",
                "id": "list",
                "label": "t:common.list"
            },
            {
                "type": "text",
                "id": "username",
                "label": "t:common.username"
            },
            {
                "type": "image_picker",
                "id": "image",
                "label": "t:common.image"
            },
            {
                "type": "image_picker",
                "id": "country_image",
                "label": "t:common.country-image"
            }
        ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.beauty-benefits.name"
    }
  ]
}
{% endschema %}