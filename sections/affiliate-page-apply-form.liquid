{% doc %}
  Renders an apply form section for affiliate page.
{% enddoc %}

<link rel="stylesheet" href="https://qureskincaredns.com/sections/isolated/contact-info/contact.css">
<div class="qure__section" style="--section-padding-top: 60px; --section-padding-bottom: 60px; --section-padding-top-mob: 50px; --section-padding-bottom-mob: 30px;">
    <div class="container qure__form">
        {% if section.settings.heading != blank %}
            <h2 class="qure__section-heading mb-md-30 text-md-center">{{ section.settings.heading }}</h2>
        {% endif %}
        {% render 'socialsnowball-form-affiliate-page' %}
    </div>
</div>
<div class="popup-message">
    <div class="popup-message-body">
        <button class="closePopup btn btn-reset"><i class="fa-regular fa-xmark"></i></button>
        {% if section.settings.popup_heading != blank %}
            <h5 class="fs-24 fm-body fw-500 mb-16">{{ section.settings.popup_heading }}</h5>
        {% endif %}
        {% if section.settings.popup_text != blank %}
            <p class="fs-16">{{ section.settings.popup_text }}</p>
        {% endif %}
    </div>
</div>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadScriptOnce('form-success', 'https://qureskincaredns.com/assets/js/form-submission.js');
    });
</script>

{% schema %}
{
  "name": "t:sections.affiliate-page-apply-form.name",
  "settings": [
    {
        "type": "text",
        "id": "heading",
        "label": "t:common.header"
    },
    {
        "type": "text",
        "id": "popup_heading",
        "label": "t:common.popup-header"
    },
    {
        "type": "text",
        "id": "popup_text",
        "label": "t:common.popup-text"
    }
  ]
}
{% endschema %}