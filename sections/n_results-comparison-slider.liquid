{% doc %}
  Renders a results comparison slider section
{% enddoc %}


<!-- BASE SLIDER -->
 {% if section.settings.use_own_file %}
    <link rel="stylesheet" href="https://qureskincaredns.com/sections/new/base-slider/base-slider.css" />
 {% endif %}
<section class="base-slider base-slider--two-cards">
    <div class="container">
        {% if section.settings.heading != blank %}
            {{ section.settings.heading }}
        {% endif %}
        <div 
            class="c-swiper"
            data-swiper='{
                "slidesPerView": 1.1,
                "spaceBetween": 15,
                "loop": false,
                "pagination": { 
                    "el": ".c-swiper-pagination", 
                    "type": "custom" 
                },
                "navigation": {
                    "prevEl": ".c-swiper-button-prev",
                    "nextEl": ".c-swiper-button-next"
                },
                "breakpoints": {
                    "768": { 
                        "slidesPerView": 2
                    },
                    "1200": { 
                        "slidesPerView": 2,
                        "spaceBetween": 30
                    }
                }
            }'
        >
            <div class="swiper-wrapper">
                {% for block in section.blocks %}
                    {% if block.type == 'slider' %}
                        <div class="swiper-slide">
                            <div class="c-visual-compare-card">
                                <picture>
                                    {% if block.settings.image != blank %}
                                        <img src="{{ block.settings.image | image_url }}" alt="{{ block.settings.image.alt | escape }}" />
                                    {% endif %}
                                </picture>
                                <article>
                                    {% if block.settings.heading != blank %}
                                        {{ block.settings.heading }}
                                    {% endif %}
                                    {% if block.settings.badge_text != blank %}
                                        <span>{{ block.settings.badge_text }}</span>
                                    {% endif %}
                                </article>
                            </div>
                        </div>
                    {% endif %}
                {% endfor %}
            </div>
            <div class="c-swiper-nav">
                <button class="c-swiper-button-prev"></button>
                <div class="c-swiper-pagination"></div>
                <button class="c-swiper-button-next"></button>
            </div>
        </div>
    </div>
</section>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadScriptOnce('base-slider', 'https://qureskincaredns.com/sections/new/base-slider/base-slider.js');
    });
</script>  
<!-- BASE SLIDER END -->


{% schema %}
{
    "name": "t:sections.n_results-comparison-slider.name",
        "settings": [
            {
                "type": "checkbox",
                "id": "use_own_file",
                "label": "t:common.use-own-file",
                "default": false
            },
            {
                "type": "richtext",
                "id": "heading",
                "label": "t:common.header"
            }
    ],
    "blocks": [
        {
            "type": "slider",
            "name": "t:common.slider",
            "settings": [
                {
                    "type": "richtext",
                    "id": "heading",
                    "label": "t:common.header"
                },
                {
                    "type": "text",
                    "id": "badge_text",
                    "label": "t:common.badge-text"
                },
                {
                    "type": "image_picker",
                    "id": "image",
                    "label": "t:common.image"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "t:sections.n_results-comparison-slider.name"
        }
    ]
}
{% endschema %}