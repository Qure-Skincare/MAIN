<!-- COOKIES -->
<link rel="stylesheet" href="https://qureskincaredns.com/sections/new/cookies/cookies.css" />
<section class="cookies">
    <div class="cookies__wrapper d-none" id="qure_cookie_main">
        <div class="cookies__content">
            <div class="cookies__message">
                <div class="cookies__message-text">
                    <p>{{ 'GDPR.settings.main.header' | t }}</p>
                </div>
                <div class="cookies__message-buttons">
                    <button class="btn btn--md btn--primary" type="button" id="gdpr-accept-button">{{ 'GDPR.settings.main.button-label' | t }}</button>
                    <button class="btn btn--md btn--secondary" type="button" id="gdpr-decline-button">{{ 'GDPR.settings.main.button-label-decline' | t }}</button>
                </div>
                <div class="cookies__message-preferences">
                    <button class="btn-preferences manage_pref">{{ 'GDPR.settings.main.button-label-manage' | t }}</button>
                </div>
            </div>
        </div>
    </div>
    <div class="cookies__wrapper d-none" id="qure_cookie_preferences">
        <div class="cookies__content">
            <div class="cookies__preferences">
                <div class="cookies__preferences-text">
                    <p><strong>{{ 'GDPR.settings.preferences.header' | t }}</strong></p>
                    {{ 'GDPR.settings.preferences.text_html' | t: privacy_policy_url: '/pages/privacy-page' }}
                    <button class="btn btn--md btn--primary" type="button" id="gdpr-save-preferences-button">{{ 'GDPR.settings.preferences.button-label' | t }}</button>
                </div>
                <div class="cookies__preferences-options">
                    <div class="c-accordion c-accordion--lines">
                        <div class="c-accordion__list">
                            <details class="c-accordion__item">
                                <summary class="c-accordion__summary">
                                    {{ 'GDPR.settings.preferences.collapse_tab_1.header' | t }}
                                    <label class="toggle">
                                        <input type="checkbox" id="strictly-necessary-cookies" />
                                        <span class="toggle__slider"></span>
                                    </label>
                                </summary>
                                <p>{{ 'GDPR.settings.preferences.collapse_tab_1.text' | t }}</p>
                            </details>
                            <details class="c-accordion__item">
                                <summary class="c-accordion__summary">
                                    {{ 'GDPR.settings.preferences.collapse_tab_2.header' | t }}
                                    <label class="toggle">
                                        <input type="checkbox" id="performance-cookies" />
                                        <span class="toggle__slider"></span>
                                    </label>
                                </summary>
                                <p>{{ 'GDPR.settings.preferences.collapse_tab_2.text' | t }}</p>
                            </details>
                            <details class="c-accordion__item">
                                <summary class="c-accordion__summary">
                                    {{ 'GDPR.settings.preferences.collapse_tab_3.header' | t }}
                                    <label class="toggle">
                                        <input type="checkbox" id="functional-cookies" />
                                        <span class="toggle__slider"></span>
                                    </label>
                                </summary>
                                <p>{{ 'GDPR.settings.preferences.collapse_tab_3.text' | t }}</p>
                            </details>
                            <details class="c-accordion__item">
                                <summary class="c-accordion__summary">
                                    {{ 'GDPR.settings.preferences.collapse_tab_4.header' | t }}
                                    <label class="toggle">
                                        <input type="checkbox" id="advertising-cookies" />
                                        <span class="toggle__slider"></span>
                                    </label>
                                </summary>
                                <p>{{ 'GDPR.settings.preferences.collapse_tab_4.text' | t }}</p>
                            </details>
                        </div>
                    </div>
                </div>
            </div>
            <div class="cookies__close">
                <button class="btn-close" type="button" id="ba-cookie-dismiss-secondary">
                    <i class="e-icon e-icon-cross"></i>
                </button>
            </div>
        </div>
    </div>
</section>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadScriptOnce("footer-gdpr", "https://qureskincaredns.com/sections/new/cookies/cookies.js");
    });
</script>
<!-- COOKIES END -->