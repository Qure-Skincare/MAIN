{% doc %}
  Renders a sticky CTA Build your own section.
{% enddoc %}

<!-- Sticky CTA start -->
<link rel="stylesheet" href="https://qureskincaredns.com/sections/isolated/sticky-cta/build-your-own-sticky-cta.css" />
{{ 'build-your-own-selection.css' | asset_url | stylesheet_tag }}
<div id="sticky_cta_cart" class="qure__sticky-atc skincare_plan_cta">
    <div class="container-fluid px-0">
        <div class="accordion accordion-flush tp-product-accordion border-0" id="tp-product-qure">
            <div class="accordion-item qure__accordion-item border-0">
                <button class="accordion-button qure__accordion-header collapsed border-0" type="button" data-bs-toggle="collapse" data-bs-target="#key-benefits" aria-expanded="false" aria-controls="key-benefits">Bundle & Save up to 25%</button>
                <div id="key-benefits" class="accordion-collapse qure__accordion-content collapse" data-bs-parent="#tp-product-qure">
                    <div class="accordion-body px-16 px-md-60">
                        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-center gap-4">
                            <!-- Bundle progress -->
                            <div class="bundle-progress">
                                <div class="bundle-item" data-step="1">
                                    <div class="discount-box"><span class="plus">+</span></div>
                                </div>
                                <!-- Product 1 -->
                                <div class="bundle-item" data-step="2">
                                    <div class="discount-box">
                                        20% <br />
                                        OFF
                                    </div>
                                    <div class="item-box d-none">
                                        <img src="https://qureskincaredns.com/sections/isolated/sticky-cta/images/build-your-own-1.webp" alt="Product 1" />
                                        <button class="remove-item"><i class="e-icon e-icon-cross"></i></button>
                                    </div>
                                </div>

                                <!-- Product 2 -->
                                <div class="bundle-item" data-step="3">
                                    <div class="discount-box">
                                        25% <br />
                                        OFF
                                    </div>
                                    <div class="item-box d-none">
                                        <img src="https://qureskincaredns.com/sections/isolated/sticky-cta/images/build-your-own-2.webp" alt="Product 2" />
                                        <button class="remove-item"><i class="e-icon e-icon-cross"></i></button>
                                    </div>
                                </div>

                                <!-- Product 2 -->
                                <div class="bundle-item" data-step="4">
                                    <div class="discount-box">
                                        25% <br />
                                        OFF
                                    </div>
                                    <div class="item-box d-none">
                                        <img src="https://qureskincaredns.com/sections/isolated/sticky-cta/images/build-your-own-2.webp" alt="Product 2" />
                                        <button class="remove-item"><i class="e-icon e-icon-cross"></i></button>
                                    </div>
                                </div>

                                <!-- Progress Line -->
                                <div class="progress-line">
                                    <div class="progress-fill" style="width: 0%"></div>
                                </div>
                            </div>

                            <!-- Subtotal -->
                            <div class="d-flex subtotal_cta gap-3">
                                <p>Subtotal:</p>
                                <p class="compare_price"></p>
                                <p class="discounted_price"></p>
                            </div>

                            <!-- Button -->
                            <div class="btn_wrap">
                                <button class="btn" disabled>Add an item to unlock savings!</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- JS Loader -->
<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadScriptOnce("skincare-sticky-cta", "https://qureskincaredns.com/assets/js/skincare-sticky-cta.js");
    });
</script>
<!-- Sticky CTA end -->


{%  schema  %}  
{
  "name": "t:sections.static-sticky-cta.name",
  "settings": [
  ],
  "presets": [
    {
      "name": "t:sections.static-sticky-cta.name"
    }
  ]
}
{% endschema %}