{% doc %}
  Renders a quiz section on an index page
{% enddoc %}


<link rel="stylesheet" href="https://qureskincaredns-main.com/sections/isolated/quiz/quiz-box.css" />
<div class="qure__section color-background"
   style="--section-padding-top: 80px;--section-padding-bottom: 80px;--section-padding-top-mob: 50px;--section-padding-bottom-mob: 50px;">
   <div class="container" style="--column-gap:100px; --column-gap-mobile:32px;">
      <div class="row custom__grid align-items-center">
         <div class="custom__block col-lg-6">
            {% if section.settings.heading != blank and section.settings.text != blank %}
                <h2 class="mb-20">{{ section.settings.heading }}</h2>
                {{ section.settings.text | replace: '<p>', '' }}
            {% endif %}  
         </div>
         <div class="custom__block col-lg-6">
            <div class="quiz__container">
               <div class="quiz-stepper">
                  <div class="quiz-stepper__line"></div>
                  <div
                     class="quiz-stepper__step quiz-stepper__step--active position-relative d-flex align-items-start mb-40">
                     <div class="quiz-stepper__circle">1</div>
                     <div class="quiz-stepper__content">
                        {% for block in section.blocks %}
                            {% if  block.settings.heading != blank and block.settings.text != blank %}
                                <p class="quiz-stepper__title mb-10 fs-24 fw-600">{{ block.settings.heading }}</p>
                                {{ block.settings.text | replace: '<p>', '<span class="quiz-stepper__desc">'
                                                       | replace: '</p>', '</span>' }}
                            {% endif %}
                            {% if block.settings.button-label != blank and block.settings.image_text != blank %}
                                <div class="ctm-width" style="--ctm-width: 350px;">
                                    <a href="{{ block.settings.button-url }}" class="quiz-stepper__button btn btn--primary w-100 mt-20">{{ block.settings.button-label }}</a>
                                    <div class="align-items-center d-flex fs-16 gap-2 justify-content-center mt-6 quiz-stepper__time">
                                        <span class="quiz-stepper__clock"><i class="fa-light fa-clock-three"></i></span> 
                                        {{ block.settings.image_text | replace: '<p>', '' | replace: '</p>' , ''}}
                                    </div>
                                </div>
                            {% endif %}
                        {% endfor %}
                     </div>
                  </div>
                  <div
                     class="quiz-stepper__step quiz-stepper__step--inactive position-relative d-flex align-items-center">
                     <div class="quiz-stepper__circle">2</div>
                     {% if section.settings.sub_text != blank %}
                        <div class="quiz-stepper__content m-0">
                            <span class="quiz-stepper__desc quiz-stepper__desc--inactive">{{ section.settings.sub_text }}</span>
                        </div>
                     {% endif %}
                  </div>
               </div>
            </div>
         </div>
      </div>
   </div>
</div>
{% schema %}
{
  "name": "t:sections.index-quiz.name",
  "settings": [
    {
        "type": "text",
        "id": "heading",
        "label": "t:common.header"
    },
    {
        "type": "richtext",
        "id": "text",
        "label": "t:common.text"
    },
    {
        "type": "text",
        "id": "sub_text",
        "label": "t:common.sub-text"
    }
  ],
  "blocks": [
    {
      "type": "take_quiz",
      "name": "t:sections.index-quiz.name",
      "limit": 1,
      "settings": [
        {
            "type": "text",
            "id": "heading",
            "label": "t:common.header"
        },
        {
            "type": "richtext",
            "id": "text",
            "label": "t:common.text"
        },
        {
            "type": "richtext",
            "id": "image_text",
            "label": "t:common.image-text"
        },
        {
            "type": "text",
            "id": "button-label",
            "label": "t:common.button-label",
            "default": "Take The Quiz"
        },
        {
            "type": "url",
            "id": "button-url",
            "label": "t:common.button-url"
        }
      ]
    }
  ]
}
{% endschema %}