{% schema %}
{
  "name": "t:sections.affiliate-page-scrolling-banner.name",
  "settings": [
   {
        "type": "text",
        "id": "heading",
        "label": "t:common.header"
   },
   {
        "type": "richtext",
        "id": "text",
        "label": "t:common.text"
   },
   {
        "type": "text",
        "id": "creator_button_label",
        "label": "t:sections.affiliate-page-scrolling-banner.settings.creator-button-label"
   },
   {
        "type": "url",
        "id": "creator_button_url",
        "label": "t:sections.affiliate-page-scrolling-banner.settings.creator-button-url"
   },
   {
        "type": "text",
        "id": "influencer_button_label",
        "label": "t:sections.affiliate-page-scrolling-banner.settings.influencer-button-label"
   },
   {
        "type": "url",
        "id": "influencer_button_url",
        "label": "t:sections.affiliate-page-scrolling-banner.settings.influencer-button-url"
   },
   {
        "type": "text",
        "id": "popup_heading",
        "label": "t:common.popup-header"
   },
   {
        "type": "text",
        "id": "popup_text",
        "label": "t:common.popup-text"
   }
  ]
}
{% endschema %}