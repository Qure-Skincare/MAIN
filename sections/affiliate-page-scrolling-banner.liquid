{% doc %}
  Renders a scrolling banner section for affiliate page 
{% enddoc %}

<link rel="stylesheet" href="https://qureskincaredns.com/sections/isolated/scrolling-banner/scrolling-banner.css" />
    <div class="scrolling-banner color-background">
        <div class="offset-right-container pr-0">
            <div class="align-items-center gap-5 row custom__grid" style="--column-gap:60px; --column-gap-mobile:32px;">
                <div class="ctm-width custom__block position-relative z-2" style="--ctm-width: 565px;">
                    <div class="scrolling-vid-content">
                        {% if section.settings.heading != blank %}
                            <h1 class="scrolling-vid--heading">{{ section.settings.heading }}</h1>
                        {% endif %}
                        {% if section.settings.text != blank %}
                            <div class="scrolling-vid--des" style="--text-mt: 32px; --text-mb: 32px;">{{ section.settings.text }}</div>
                        {% endif %}
                        <div class="d-flex flex-wrap flex-md-nowrap gap-4">
                            {% if section.settings.creator_button_label != blank and section.settings.creator_button_url != blank %}
                                <a href="{{ section.settings.creator_button_url }}" class="banner-text--button btn btn--primary w-100" data-bs-toggle="modal" data-bs-target="#ingredients_popup">{{ section.settings.creator_button_label }}</a>
                            {% endif %}
                            {% if section.settings.influencer_button_url != blank and section.settings.influencer_button_label != blank %}
                                <a href="{{ section.settings.influencer_button_url }}" class="banner-text--button btn btn--primary w-100">{{ section.settings.influencer_button_label }}</a>
                            {% endif %}
                        </div>
                    </div>
                </div>
