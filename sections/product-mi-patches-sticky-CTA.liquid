{% doc %}
Renders a sticky CTA section for mi patches page.
{% enddoc %}


   <link rel="stylesheet" href="https://qureskincaredns-main.com/sections/isolated/sticky-cta/sticky-cta.css" />
   <div class="qure__sticky-atc mi-patches-sticky-cta">
      <div class="container">
         <div class="d-flex flex-wrap justify-content-between align-items-center py-16">
            <div class="patch__product-variants d-flex align-items-center gap-5">
               <div class="select_qty fw-600 fs-20">Select Quantity</div>
                     <div class="d-none d-md-grid grid_dynamic_cols" style="--grid_dynamic_cols:3;--col-gap:12px">
                        <div class="patch__value-pack">
                           <input type="radio" class="vp__input" name="vaule-pack" id="3-months-cta" checked="">
                           <label for="3-months-cta" class="vp-pack-cta px-12 py-8 d-flex align-items-center gap-2">
                              <div class="vp-img"><img src="https://qureskincaredns-main.com/sections/isolated/targeted-patches/images/24-pairs.webp">
                              </div>
                              <div class="vp-content">
                                 <p class="mb-0">3 Months</p>
                              </div>
                           </label>
                        </div>

                        <div class="patch__value-pack">
                           <input type="radio" class="vp__input" name="vaule-pack" id="two_month_bx">
                           <label for="two_month_bx" class="vp-pack-cta px-12 py-8 d-flex align-items-center gap-2">
                              <div class="vp-img"><img src="https://qureskincaredns-main.com/sections/isolated/targeted-patches/images/16-pairs.webp">
                              </div>
                              <div class="vp-content">
                                 <p class="mb-0">2 Months</p>
                              </div>
                           </label>
                        </div>
                        <div class="patch__value-pack">
                           <input type="radio" class="vp__input" name="vaule-pack" id="one-month-cta">
                           <label for="one-month-cta" class="vp-pack-cta px-12 py-8 d-flex align-items-center gap-2">
                              <div class="vp-img"><img src="https://qureskincaredns-main.com/sections/isolated/targeted-patches/images/8-pairs.webp">
                              </div>
                              <div class="vp-content">
                                 <p class="mb-0">1 Month</p>
                              </div>
                           </label>
                        </div>

                     </div>

  <!-- Dropdown Wrapper -->
  <div class="dropdown-wrapper d-md-none">
    <!-- Dropdown (opens upward) -->
    <div class="dropdown-inner-container" id="dropdownContainer">
      <div class="dropdown-option" onclick="selectOption('1 Month', '8-pairs.webp')">
        <img src="https://qureskincaredns-main.com/sections/isolated/targeted-patches/images/8-pairs.webp" alt="">
        <span>1 Month</span>
      </div>
      <div class="dropdown-option" onclick="selectOption('2 Months', '16-pairs.webp')">
        <img src="https://qureskincaredns-main.com/sections/isolated/targeted-patches/images/16-pairs.webp" alt="">
        <span>2 Months</span>
      </div>
      <div class="dropdown-option" onclick="selectOption('3 Months', '24-pairs.webp')">
        <img src="https://qureskincaredns-main.com/sections/isolated/targeted-patches/images/24-pairs.webp" alt="">
        <span>3 Months</span>
      </div>
    </div>
  <!-- Button to show current selection -->
    <button type="button" class="dropdown-button" id="dropdownBtn" onclick="toggleDropdown()">
      <img src="https://qureskincaredns-main.com/sections/isolated/targeted-patches/images/24-pairs.webp" /> 3 Months
      <i class="fa-solid fa-angle-down"></i>
    </button>
  </div>
  <input type="hidden" name="properties[Duration]" id="selectedDuration" value="3 Months">

                  </div>

            <a href="#buy_box" class="btn btn--primary fs-11 fs-md-20 px-10 mw" style="--mw-mob:170px">Buy Now & Save {dyn}%</a>
         </div>
      </div>
      <div
         class="align-items-center bg-light d-flex fs-16 gap-4 justify-content-center py-6 qure__user-online text-center">
         <div class="pulse"></div>218 purchased in last 48 hours
      </div>
   </div>
   <script> 
	 document.addEventListener("DOMContentLoaded", function () {
		loadScriptOnce('sticky-cta', 'https://qureskincaredns-main.com/assets/js/sticky-cta.js');
	 });
   </script>


{% schema %}
{
    "name": "t:sections.sticky-cta.name",
    "settings": [
    ]
}
{% endschema %}
