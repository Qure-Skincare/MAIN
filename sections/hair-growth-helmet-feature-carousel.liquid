{% doc %}
    Renders a feature carousel section for hair growth helmet page.
{% enddoc %}

<link rel="stylesheet" href="https://qureskincaredns.com/alex/sections/isolated/why-carousel/why-carousel.css" />
<div class="qure__section why-carousel" id="why-carousel">
    <div class="container">
        <div class="why-carousel__content">
            {% if section.settings.heading != blank %}
                <h2 class="why-carousel__title">{{ section.settings.heading }}</h2>
            {% endif %}
            <div class="why-carousel__carousel">
                <div class="swiper qure__swiper" id="qure__swiper-why-carousel" data-section-id="why-carousel"
                    data-mobile="1.05" data-tablet="2.2" data-desktop="3" data-autoplay="false" data-loop="false"
                    data-spacing="-6" data-spacingmob="-18" data-pagination-fraction="true"
                    data-arrowleft="why-carousel-arrow-left" data-arrowright="why-carousel-arrow-right">
                    <div class="swiper-wrapper">
                        {% for block in section.blocks %}
                            {% if block.type == 'section' %}
                                <div class="swiper-slide">
                                    <div class="why-carousel__item">
                                        {% if block.settings.image != blank %}
                                            
                                        {% endif %}
                                        <img src="{{ block.settings.image | image_url }}" alt="{{ block.settings.image.alt | escape }}" />
                                        {% if block.settings.heading != blank %}
                                            {{ block.settings.heading }}
                                        {% endif %}
                                        {% if block.settings.text != blank %}
                                            {{ block.settings.text }}
                                        {% endif %}
                                    </div>
                                </div>
                            {% endif %}
                        {% endfor %}
                    </div>
                    <div class="swiper-arrows-with-pagination">
                        <div class="qure-swiper-button-prev qure-swiper-arrow why-carousel-arrow-left"><i
                                class="fa-regular fa-angle-left"></i></div>
                        <div class="swiper-pagination"></div>
                        <div class="qure-swiper-button-next qure-swiper-arrow why-carousel-arrow-right"><i
                                class="fa-regular fa-angle-right"></i></div>
                    </div>
                </div>
            </div>
            {% if section.settings.button_url != blank and section.settings.button_label != blank %}
                <a href="{{ section.settings.button_url }}" class="btn why-carousel__button">{{ section.settings.button_label }}</a>
            {% endif %}
            
        </div>
    </div>
</div>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadScriptOnce('main-slider', 'https://qureskincaredns.com/assets/js/main-slider.js');
    });
</script>

{%  schema  %}
{
  "name": "t:sections.hair-growth-helmet-feature-carousel.name",
  "settings": [
    {
        "type": "text",
        "id": "heading",
        "label": "t:common.header"
    },
    {
        "type": "text",
        "id": "button_label",
        "label": "t:common.button-label"
    },
    {
        "type": "url",
        "id": "button_url",
        "label": "t:common.button-url"
    }
  ],
  "blocks": [
    {
        "type": "section",
        "name": "t:common.section",
        "settings": [
            {
                "type": "image_picker",
                "id": "image",
                "label": "t:common.image"
            },
            {
                "type": "richtext",
                "id": "heading",
                "label": "t:common.header"
            },
            {
                "type": "richtext",
                "id": "text",
                "label": "t:common.text"
            }
        ]
    }
  ]
}

{% endschema %}