{% doc %}
    Renders a our advisors section.
{% enddoc %}

<!-- BOARD ADVISORS -->
{% if section.settings.use_own_file %}
    <link rel="stylesheet" href="https://qureskincaredns.com/sections/new/base-slider/base-slider.css" />
{% endif %}
<section class="base-slider">
    <div class="container">
        {{ section.settings.text }}
        <div
            class="c-swiper"
            data-swiper='{
                "slidesPerView": 1.1,
                "spaceBetween": 15,
                "loop": false,
                "pagination": {
                    "el": ".c-swiper-pagination",
                    "type": "custom"
                },
                "navigation": {
                    "prevEl": ".c-swiper-button-prev",
                    "nextEl": ".c-swiper-button-next"
                },
                "breakpoints": {
                    "580": {
                        "slidesPerView": 2
                    },
                    "992": {
                        "slidesPerView": 3
                    },
                    "1200": {
                        "slidesPerView": 4,
                        "spaceBetween": 20
                    }
                }
            }'>
            <div class="swiper-wrapper">
                {% for block in section.blocks %}
                    {% if block.type == 'accordion' %}
                        <div class="swiper-slide">
                            <details class="c-advisory-collapse-card">
                                <summary>
                                    {% if block.settings.image != blank %}
                                        <picture>
                                            <img src="{{ block.settings.image | image_url }}" alt="{{ block.settings.image.alt | escape }}" />
                                        </picture>
                                    {% endif %}
                                    {{ block.settings.heading }}
                                </summary>
                                {{ block.settings.text }}
                            </details>
                        </div>
                    {% endif %}
                {% endfor %}
            </div>
            <div class="c-swiper-nav">
                <button class="c-swiper-button-prev"></button>
                <div class="c-swiper-pagination"></div>
                <button class="c-swiper-button-next"></button>
            </div>
        </div>
    </div>
</section>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadScriptOnce("base-slider", "https://qureskincaredns.com/sections/new/base-slider/base-slider.js");
    });
</script>
<!-- BOARD ADVISORS END -->

{% schema %}
{
    "name": "t:sections.our-advisors.name",
    "settings": [
        {
            "type": "checkbox",
            "id": "use_own_file",
            "label": "t:common.use-own-file",
            "default": false
        },
        {
            "type": "richtext",
            "id": "text",
            "label": "t:common.text"
        }
    ],
    "blocks": [
        {
            "type": "accordion",
            "name": "t:common.accordion",
            "settings": [
                {
                    "type": "richtext",
                    "id": "heading",
                    "label": "t:common.header"
                },
                {
                    "type": "richtext",
                    "id": "text",
                    "label": "t:common.text"
                },
                {
                    "type": "image_picker",
                    "id": "image",
                    "label": "t:common.image"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "t:sections.our-advisors.name"
        }
    ]
}
{% endschema %}