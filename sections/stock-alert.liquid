{% doc %}
  Renders a stock alert section.
{% enddoc %}

<div class="bg-primary text-center py-13 py-lg-16">
    {% if section.settings.text != blank %}
        {{ section.settings.text | replace: '<p>', '<span class="fs-20 fw-500 ">' | replace: '</p>', '</span>' }}
    {% endif %}
</div>

{% schema %}
{
"name": "t:sections.stock-alert.name",
"settings": [
    {
    "type": "richtext",
    "id": "text",
    "label": "t:common.text"
    }
],
"presets": [
    {
    "name": "t:sections.stock-alert.name"
    }
]
}
{% endschema %}