<!--Collection Block-->

{% schema %}
{
    "name": "Build Your Own Products",
    "settings": [
        {
            "type": "text",
            "id": "title",
            "label": "Title",
            "default": "Build Your Own"
        }
    ],
    "blocks": [
        {
            "type": "product",
            "name": "Product",
            "limit": 4,
            "settings": [
                {
                    "type": "product",
                    "id": "product",
                    "label": "Product"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "Build Your Own Products"
        }
    ]
}
{% endschema %}
