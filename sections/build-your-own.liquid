{% doc %}
  Renders a build your own section
{% enddoc %}

{% assign section_title = section.settings.heading | strip_newlines | strip | replace: ' ', '' | downcase %}

<template id="{{ section_title }}">
    {% for block in section.blocks %}
        {% if block.type == 'product_card' %}
            {% if block.settings.product != blank %}
                {% include 'get-product-data', product_handle: block.settings.product, product_prefix: 'build-your-own-products-' %}
            {% endif %}
            <div class="col-6 col-md-3 custom__block project">
                <div class="qure__product-item silver-badge"
                    data-byo-product
                    data-variant-id="{{ product_variant_id }}"
                    data-handle="{{ product_handle }}"
                    data-title="{{ product_title | escape }}"
                    data-price="{{ product_price_original }}"
                    data-image="{{ product_featured_image | img_url: '250x' }}">
                    <a href="{{ block.settings.url }}" class="qure__product-img overflow-hidden position-relative d-block">
                        {% if block.settings.image != blank %}
                            <div class="qure__product-main-img">
                                <img src="{{ block.settings.image | image_url }}" alt="{{ block.settings.image.alt | escape }}" />
                            </div>
                        {% endif %}

                        {% if block.settings.hover_image != blank %}
                            <div class="qure__product-hover-img position-absolute inset-0">
                                <img src="{{ block.settings.hover_image | image_url }}" alt="{{ block.settings.hover_image.alt | escape }}" />
                            </div>
                        {% endif %}

                        {% assign image_text = block.settings.image_text | downcase %}

                        {% if image_text == 'bestseller' %}
                            <div class="badge rounded-pill badge-bestseller">{{ block.settings.image_text }}</div>    
                        {% endif %}
                    </a>
                    <div class="qure__product-details">
                        {% if block.settings.rating_image != blank %}
                            <div class="qure__product-reviews fs-14 d-flex gap-3 align-items-center">
                                <img src="{{ block.settings.rating_image |  image_url }}" alt="{{ block.settings.image.alt | escape }}" /><span>{{ block.settings.rating_text }}</span>
                            </div>
                        {% endif %}

                        <h3 class="fm-body mb-0 qure__product-name">
                            <a class="limited-line capitalize d-block" href="{{ block.settings.url }}">{{ block.settings.heading }}</a>
                        </h3>

                        {% if block.settings.product == 'shower-filter' or block.settings.product == 'faucet-filter' %}
                            {% if product_variants.size > 1 %}
                                <div class="select-color" data-text="Select Color:">
                                    {% for variant in product_variants %}
                                        {% assign option = variant.option1 | handleize %}
                                        <label data-option-value="{{ variant.option1 | handleize }}">
                                            <input type="radio"
                                                name="variant-{{ product_id }}"
                                                {% case option %}
                                                    {% when 'white' %}
                                                        value="light"
                                                    {% when 'black' %}
                                                        value="dark"
                                                    {% when 'silver' %}
                                                        value="silver"
                                                {% endcase %}
                                                data-value="{{ variant.id }}"
                                                data-variant-price="{{ variant.price }}"
                                                data-variant-image="{{ variant.featured_image | img_url: '250x' }}"
                                                {% if forloop.index == 1 %}checked="checked"{% endif %} />
                                        </label>
                                    {% endfor %}
                                </div>
                            {% endif %}
                        {% endif %}

                        {% if product_sale_price != blank %}
                            {% if black_friday_discount_percent > 0 %}
                                <div class="qure__product-price">
                                    <div class="dis_red_line">
                                        {% if product_before_price != blank %}
                                            <span class="bef_price text-decoration-line-through">{{ product_before_price }}</span>
                                        {% endif %}
                                        <span class="aft_price">{{ product_sale_price }}</span>
                                    </div>
                                    <div class="black_friday_price">{{ product_black_friday_price }}</div>
                                </div>
                            {% else %}
                                <div class="bundle_price d-flex align-items-center justify-content-start gap-3 my-3 pb-2">
                                    {% if product_before_price != blank %}
                                        <div class="bef_price text-decoration-line-through fs-20 igComparePrice">{{ product_before_price }}</div>
                                    {% endif %}

                                    <div class="aft_price fs-20 igPrice">{{ product_sale_price }}</div>
                                </div>
                            {% endif %}
                        {% endif %}
                    </div>


                    <div class="qure__product-action-inner">
                        {% if block.settings.soldout == true %}
                            <button type="button" class="btn btn--primary w-100" disabled>{{ 'product.settings.soldout-button-label' | t }}</button>
                        {% else %}
                            <form method="post" action="#" enctype="multipart/form-data">
                                <input type="checkbox" name="added_in_cart" value="" />
                                <button type="button" class="add-cart-button product-form__submit btn btn--primary w-100">Add <i class="e-icon e-icon-plus"></i></button>
                                <div class="e-quantity e-quantity--pill-xl" data-e-quantity>
                                    <button type="button" data-e-quantity-action="decrement">
                                        <i class="e-icon e-icon-minus"></i>
                                    </button>
                                    <input type="number" name="qty" value="1" min="1" readonly="readonly" />
                                    <button type="button" data-e-quantity-action="increment">
                                        <i class="e-icon e-icon-plus"></i>
                                    </button>
                                </div>
                            </form>
                        {% endif %}
                    </div>
                </div>
            </div>
        {% endif %}
    {% endfor %}
</template>

{% schema %}
{
  "name": "t:sections.build-your-own-products.name",
  "settings": [
    {
        "type": "text",
        "id": "heading",
        "label": "t:common.header"
    }
  ],
  "blocks": [
    {
        "type": "product_card",
        "name": "t:common.product",
        "settings": [
            {
                "type": "text",
                "id": "heading",
                "label": "t:common.header"
            },
            {
                "type": "product",
                "id": "product",
                "label": "t:common.product"
            },
            {
                "type": "checkbox",
                "id": "soldout",
                "label": "t:common.soldout",
                "default": false
            },
            {
                "type": "text",
                "id": "image_text",
                "label": "t:sections.build-your-own-products.blocks.image-text.name"
            },
            {
                "type": "image_picker",
                "id": "image",
                "label": "t:common.image"
            },
            
            {
                "type": "image_picker",
                "id": "hover_image",
                "label": "t:sections.build-your-own-products.blocks.hover_image.name"
            },
            {
                "type": "url",
                "id": "url",
                "label": "t:common.link-url"
            },
            {
                "type": "text",
                "id": "rating_text",
                "label": "t:common.rating-text"
            },
            {
                "type": "image_picker",
                "id": "rating_image",
                "label": "t:sections.build-your-own-products.blocks.rating-image.name"
            }
        ]
    }
   ]
}
{% endschema %}