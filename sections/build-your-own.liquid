{% doc %}
  Renders a build your own section
{% enddoc %}

{% assign collection = collections['easter-collection'] %}

<!--Collection Block-->
<link rel="stylesheet" href="https://qureskincaredns.com/sections/isolated/collection-block/section-collection-block.css" />
<div class="collection_block qure__section" style="--section-padding-top: 30px; --section-padding-top-mob: 30px">
    <div class="container">
        <div class="collection_content">
            <div class="qure_tabs_wrap d-flex flex-wrap flex-md-nowrap justify-content-between gap-10 align-items-center fs-16">
                <ul class="filters qure_tabs">
                    <li><a href="#section-mi" class="active">Micro-Infusion</a></li>
                </ul>
            </div>
            <div class="row projects custom__grid" style="--column-gap: 32px; --column-gap-mobile: 16px" id="section-mi" data-label="Micro-Infusion">
                <div class="col-6 col-md-3 custom__block project" data-filter="fine_lines dark_spots">
                    <div class="qure__product-item silver-badge">
                        <a href="#" class="qure__product-img overflow-hidden position-relative d-block">
                            <div class="qure__product-main-img"><img src="https://qureskincaredns.com/sections/isolated/top-products/images/micro-infusion-facial-system.webp" alt="" /></div>
                            <div class="qure__product-hover-img position-absolute inset-0"><img src="https://qureskincaredns.com/sections/isolated/top-products/images/micro-infusion-facial-system-hover.webp" alt="" /></div>
                            <div class="badge rounded-pill badge-bestseller">Bestseller</div>
                        </a>
                        <div class="qure__product-details">
                            <div class="qure__product-reviews fs-14 d-flex gap-3 align-items-center"><img src="https://qureskincaredns.com/sections/isolated/top-products/images/stars.svg" alt="" /><span>1,312 Reviews</span></div>
                            <h3 class="fm-body mb-0 qure__product-name">
                                <a class="limited-line capitalize d-block" href="#">Micro-Infusion Facial System</a>
                            </h3>
                            <div class="qure__product-price">
                                <div class="dis_red_line">
                                    <span class="bef_price text-decoration-line-through">$238</span>
                                    <span class="aft_price">$149</span>
                                </div>
                                <div class="black_friday_price">$133.51</div>
                            </div>
                        </div>
                        <div class="qure__product-action-inner">
                            <form method="post" action="#" enctype="multipart/form-data">
                                <input type="checkbox" name="added_in_cart" value="" />
                                <button type="button" class="add-cart-button product-form__submit btn btn--primary w-100">Add <i class="e-icon e-icon-plus"></i></button>
                                <div class="e-quantity e-quantity--pill-xl" data-e-quantity>
                                    <button type="button" data-e-quantity-action="decrement">
                                        <i class="e-icon e-icon-minus"></i>
                                    </button>
                                    <input type="number" name="qty" value="1" min="1" readonly="readonly" />
                                    <button type="button" data-e-quantity-action="increment">
                                        <i class="e-icon e-icon-plus"></i>
                                    </button>
                                </div>
                            </form>
