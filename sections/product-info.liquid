                      {% if section.settings.heading != blank %}
                          <h2 class="qure__section-heading text-md-start pb-20">{{ section.settings.heading }}</h2>
                      {% endif %}
                      {% if section.settings.text != blank %}
                          {{ section.settings.text | replace: '<em>', '<span style="background: #C7E5DB;">' | replace: '</em>', '</span>' }}
                      {% endif %}
                    <div class="accordion accordion-flush mt-15 tp-product-accordion technical_specifications" id="sci_backed">
                      {% for block in section.blocks %}
                        {% if block.type == 'accordion' %}
                          <div class="accordion-item qure__accordion-item border-0">
                            {% if block.settings.heading != blank %}
                              <button class="accordion-button collapsed qure__accordion-header" type="button" data-bs-toggle="collapse" data-bs-target="#technical_specifications" aria-expanded="false" aria-controls="technical_specifications">{{ block.settings.heading }}</button>
                            {% endif %}
                            <div id="technical_specifications" class="accordion-collapse collapse qure__accordion-content" data-bs-parent="#sci_backed">
                              {% if block.settings.text != blank %}
                                <div class="accordion-body">{{ block.settings.text }}</div>
                              {% endif %}  
                            </div>
                          </div>
                        {% endif %}
                      {% endfor %}  
                    </div>
                  </div>
              </div>
            {% else %}
                <div class="col-md-7 d-flex justify-content-center align-items-center order-mob-2">
