{% doc %}
    Renders a products guide section for products guide page
{% enddoc %}

<!-- GUIDES LIST -->
{% if section.settings.use_own_file %}
    <link rel="stylesheet" href="https://qureskincaredns.com/sections/new/guides-list/guides-list.css" />
{% endif %}
<section class="guides-list">
    <div class="container">
        <article>
           {{ section.settings.text }}
            <ul>
                {% for block in section.blocks %}
                    {% if block.type == 'items' %}
                        {% if block.settings.link_url != blank %}
                            <li>
                                <a href="{{ block.settings.link_url }}">
                                    {% if block.settings.image != blank %}
                                        <img src="{{ block.settings.image | image_url }}" alt="{{ block.settings.image.alt | escape }}" />
                                    {% endif %}
                                    {{ block.settings.heading }}
                                    <i class="e-icon e-icon-chevron"></i>
                                </a>
                            </li>
                        {% endif %}
                    {% endif %}
                {% endfor %}
            </ul>
        </article>
    </div>
</section>
<!-- GUIDES LIST END -->


{% schema %}
{
    "name": "t:sections.products-guide.name",
    "settings": [
    {
        "type": "checkbox",
        "id": "use_own_file",
        "label": "t:common.use-own-file",
        "default": false
    },
    {
        "type": "richtext",
        "id": "text",
        "label": "t:common.text"
    }
    ],
    "blocks": [
    {
        "type": "items",
        "name": "t:common.items",
        "settings": [
        {
            "type": "text",
            "id": "heading",
            "label": "t:common.header"
        },
        {
            "type": "url",
            "id": "link_url",
            "label": "t:common.link-url"
        },
        {
            "type": "image_picker",
            "id": "image",
            "label": "t:common.image"
        }
        ]
    }
    ]
}
{% endschema %}