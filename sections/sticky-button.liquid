{% doc %}
  Renders a sticky CTA section.
{% enddoc %}

{% include 'get-product-data', product_handle: product.handle, product_prefix: 'sticky-button-' %}

<link rel="stylesheet" href="https://qureskincaredns.com/sections/isolated/sticky-cta/sticky-cta.css" />
<div class="qure__sticky-atc">
  <div class="container">
    <div class="d-flex flex-wrap justify-content-between align-items-center py-16">
      {% if section.settings.heading != blank %}
        <h3 class="fs-20 m-0 d-none d-md-block">{{ section.settings.heading }} {% if section.settings.limited != blank %}<span class="limited_edition ml-15">{{ 'product.settings.limited-edition' | t }}</span>{% endif %}</h3>
      {% endif %}
      {% if section.settings.button-url != blank %}
        <a href="{{ section.settings.button-url }}" class="btn btn--primary">{% if section.settings.button-label != blank %}{{ section.settings.button-label }}{% else %}{{ 'product.settings.buy-button-label' | t }}{% endif %}</a>
      {% else %}
        <form method="post" action="/cart/add" enctype="multipart/form-data" class="w-100 mw" style="--mw:400px;">
          <button id="sticky-cta-button" type="submit" class="btn btn--primary">{% if section.settings.button-label != blank %}{{ section.settings.button-label }}{% else %}{{ 'product.settings.buy-button-label' | t }}{% endif %}</button>
          <input type="hidden" name="quantity" id="quantity" value="1">
          <input type="hidden" name="id" value="{{ product_variant_id }}">
        </form>
      {% endif %}
    </div>
  </div>
  <div class="align-items-center bg-light d-flex fs-16 gap-4 justify-content-center py-6 qure__user-online text-center">
    {% if section.settings.text != blank %}
      <div class="pulse"></div>{{ section.settings.text }}
    {% endif %}
  </div>
</div>
<script>
  document.addEventListener("DOMContentLoaded", function () {
    loadScriptOnce('sticky-cta', 'https://qureskincaredns.com/shopify/js/sticky-cta.js');
  });
</script>


{%  schema  %}  
{
  "name": "t:sections.sticky-button.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:common.header"
    },
    {
      "type": "text",
      "id": "text",
      "label": "t:common.text"
    },
    {
        "type": "checkbox",
        "id": "limited",
        "label": "t:common.limited",
        "default": false
    },
    {
      "type": "text",
      "id": "button-label",
      "label": "t:common.button-label"
    },
    {
      "type": "text",
      "id": "button-url",
      "label": "t:common.button-url"
    }
  ],
  "presets": [
    {
      "name": "t:sections.sticky-button.name"
    }
  ]
}
{% endschema %}