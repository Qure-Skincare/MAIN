{% doc %}
  Renders a hero section
{% enddoc %}

{% if section.settings.use_own_file %}
    <link rel="stylesheet" href="https://qureskincaredns.com/sections/new/hero-section/hero-section.css" />
{% endif %}
<section class="hero-section">
    <div class="container">
        <picture class="hero-section__image">
            {% if section.settings.image != blank %}
                <source media="(min-width:768px)" srcset="{{ section.settings.image | image_url }}" />
            {% endif %}
            {% if section.settings.image_mobile != blank %}
                <img src="{{ section.settings.image_mobile | image_url }}" alt="{{ section.settings.image_mobile.alt | escape }}" />
            {% endif %}
        </picture>
        <article class="hero-section__content">
            <div class="hero-section__content-header">
                    <div class="c-approved-by">
                        <ul>
                            {% for block in section.blocks %}
                                {% if block.type == 'approved-by' %}
                                    <li><img src="{{ block.settings.image | image_url }}" alt="{{ block.settings.image.alt | escape }}" /></li>
                                {% endif %}
                            {% endfor %}
                        </ul>
                        {% for block in section.blocks %}
                            {% if block.type == 'approved-by' %}
                                {% if block.settings.text != blank %}
                                    {{ block.settings.text }}
                                {% endif %}
                            {% endif %}
                        {% endfor %}
                    </div>
                {% if section.settings.text != blank %}
                    {{ section.settings.text }}
                {% endif %}
            </div>
            <div class="hero-section__content-button">
                {% if section.settings.button_url != blank and section.settings.button_label != blank %}
                    <a href="{{ section.settings.button_url }}" class="btn btn--primary">{{ section.settings.button_label }}</a>
                {% endif %}
                {% if section.settings.sub_text != blank %}
                    <div class="c-info-bar">{{ section.settings.sub_text | replace: '<p>', '' | replace: '</p>', '' }}</div>
                {% endif %}
            </div>
            <div class="hero-section__content-footer">
                {% if section.settings.marked_list != blank %}
                    {{ section.settings.marked_list | replace: '<ul>', '<ul class="c-marked-list">' }}
                {% endif %}
                {% if section.settings.video_image_cover != blank %}
                    <picture
                        data-label-text="Watch: How To Use"
                        data-bs-toggle="modal"
                        data-bs-target="#shower2"
                    >
                        <img src="{{ section.settings.video_image_cover | image_url }}" alt="{{ section.settings.video_image_cover.alt | escape }}" />
                    </picture>
                {% endif %}
            </div>
        </article>
    </div>
</section>
{% if section.settings.wistia_url != blank %}
    <div class="modal fade filter-modal" id="shower2" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="shower2Label" style="display: none;" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-md filter-dialog">
            <div class="modal-content">
                <div class="modal-header border-0">
                    <button type="button" class="btn btn-close" data-bs-dismiss="modal"
                        aria-label="Close"><i class="fa-solid fa-xmark"></i></button>
                </div>
                <div class="modal-body">
                    <style>
                        wistia-player[media-id='{{ section.settings.wistia_url }}']:not(:defined) {
                            background: center / contain no-repeat url('https://fast.wistia.com/embed/medias/{{ section.settings.wistia_url }}/swatch');
                            display: block;
                            filter: blur(5px);
                            padding-top: 177.78%;
                        }
                    </style>
                    <div class="filter-modal-video">
                        <wistia-player media-id="{{ section.settings.wistia_url }}" seo="false" aspect="0.5625"
                            unique-id="wistia-{{ section.settings.wistia_url }}-23"></wistia-player>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endif %}

{% schema %}
{
    "name": "t:sections.n_hero-section.name",
        "settings": [
        {
            "type": "checkbox",
            "id": "use_own_file",
            "label": "t:common.use-own-file",
            "default": false
        },
        {
            "type": "richtext",
            "id": "text",
            "label": "t:common.text"
        },
        {
            "type": "image_picker",
            "id": "image",
            "label": "t:common.image"
        },
        {
            "type": "image_picker",
            "id": "image_mobile",
            "label": "t:common.image-mobile"
        },
        {
            "type": "url",
            "id": "button_url",
            "label": "t:common.button-url"
        },
        {
            "type": "text",
            "id": "button_label",
            "label": "t:common.button-label"
        },
        {
            "type": "richtext",
            "id": "sub_text",
            "label": "t:common.sub-text"
        },
        {
            "type": "richtext",
            "id": "marked_list",
            "label": "t:common.marked-list"
        },
        {
            "type": "text",
            "id": "wistia_url",
            "label": "t:common.wistia-url"
        },
        {
            "type": "image_picker",
            "id": "video_image_cover",
            "label": "t:common.video-image-cover"
        }
    ],
    "blocks": [
        {
            "type": "approved-by",
            "name": "t:common.approved-by",
            "settings": [
                {
                    "type": "image_picker",
                    "id": "image",
                    "label": "t:common.image"
                },
                {
                    "type": "richtext",
                    "id": "text",
                    "label": "t:common.text"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "t:sections.n_hero-section.name"
        }
    ]
}
{% endschema %}