{% doc %}
  Renders a page header section
{% enddoc %}

<link rel="stylesheet" href="https://qureskincaredns-main.com/sections/isolated/micro-infusion-pdp/section-micro-infusion-pdp.css" />
<div class="qure__trageted-patches qure__section" style="--section-padding-top: 40px; --section-padding-bottom: 80px;">
   <div class="container" style="--column-gap:80px; --column-gap-mobile:30px;">
      <div class="row custom__grid">
         <div class="col-lg-6 custom__block">
            <div class="qure-product-details">
                {% render 'product-page-slider', product: blank, page: page, class: 'tp-product-gallery d-block d-lg-none mb-30' %}
                {% render 'page-rating', section: section %}

               {% if section.settings.heading != blank %}
                    <h1 class="qure__product-title mb-10">{{ section.settings.heading }}</h1>
               {% endif %}

               {% if section.settings.button-label != blank %}
                    <div class="qure__product-action-inner my-30 max-w-ctm" style="--max-w-ctm:500px">
                        <a href="{{ section.settings.button-url }}" class="add-cart-button product-form__submit btn btn--primary w-100 text-uppercase fs-md-20 fs-18" aria-label="{{ section.settings.button-label | escape }}">{{ section.settings.button-label }}</a>
                    </div>
               {% endif %}

                {% if section.settings.description != blank %}
                    <div class="patch__single-shortdes mt-20">
                        {{ section.settings.description }}
                    </div>
                {% endif %}


                {% if request.path == '/pages/microinfusion' %}
                    
                    <!-- start -->
                    <div class="border-top  max-w-ctm my-25" style="--max-w-ctm:500px"></div>
                    <div class="product_shower-variants">
                        <div class="qure__variant-label mb-15">Select Your Serum:</div>
                        <div class="d-flex col-gap" style="--col-gap:12px; --col-gap-mb:5px">
                            <div class="col qure__variant-item">
                                <input type="radio" id="white" name="serum_main" class="variant__input">
                                <label for="white" class="qure__variant-box">
                                    <div class="qv-frame">
                                        <div class="qv-frame-inner">
                                            <img class="qv-img"
                                                src="https://qureskincaredns-main.com/sections/isolated/micro-infusion-pdp/images/serum_1.webp">
                                        </div>
                                    </div>
                                    <div class="div">Dark Spots</div>
                                </label>
                            </div>
                            <div class="col qure__variant-item">
                                <input id="black" type="radio" name="serum_main" class="variant__input">
                                <label for="black" class="qure__variant-box">
                                    <div class="qv-frame">
                                        <img class="qv-img"
                                            src="https://qureskincaredns-main.com/sections/isolated/micro-infusion-pdp/images/serum_2.webp">
                                    </div>
                                    <div class="div">Wrinkles</div>
                                </label>
                            </div>
                            <div class="col qure__variant-item">
                                <input id="silver" type="radio" name="serum_main" class="variant__input" checked>
                                <label for="silver" class="qure__variant-box">
                                    <div class="qv-frame">
                                        <img class="qv-img"
                                            src="https://qureskincaredns-main.com/sections/isolated/micro-infusion-pdp/images/serum_3.webp">
                                    </div>
                                    <div class="div">Mixed</div>
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="patch__product-variants max-w-ctm" style="--max-w-ctm:500px">
                        <div class="patch__variant-label mb-15 mt-20">Select Your supply:</div>
                        <div class="d-grid vp-grid" style="--col-gap:12px">
                            <div class="patch__value-pack">
                                <input type="radio" class="vp__input" name="vaule-pack" id="three-month" checked />
                                <label for="three-month" class="vp-pack vp-best-pack pt-0">
                                    <div class="vp-best-value">Best Value <i
                                            class="fa-sharp fa-solid fa-star-sharp"></i>
                                    </div>
                                    <div class="vp-img"><img
                                            src="https://qureskincaredns-main.com/sections/isolated/micro-infusion-pdp/images/3_month_mixed.webp"
                                            class="img-fluid" />
                                    </div>
                                    <div class="vp-content">
                                        <p class="mb-0">3 Months</p>
                                        <p class="fs-14 mb-15">(6 treatments)</p>
                                        <div class="vp-price">
                                            <span class="vp-price-sale">{$dyn}</span>
                                            <span class="vp-price-reg">{$dyn}</span>
                                        </div>
                                        <span class="vp-badge">{dyn}% OFF</span>
                                    </div>
                                </label>
                            </div>
                            <div class="patch__value-pack">
                                <input type="radio" class="vp__input" name="vaule-pack" id="two-month" />
                                <label for="two-month" class="vp-pack">
                                    <div class="vp-img"><img
                                            src="https://qureskincaredns-main.com/sections/isolated/micro-infusion-pdp/images/2_month_mixed.webp"
                                            class="img-fluid" />
                                    </div>
                                    <div class="vp-content">
                                        <p class="mb-0">2 Months</p>
                                        <p class="fs-14 mb-15">(4 treatments)</p>
                                        <div class="vp-price">
                                            <span class="vp-price-sale">{$dyn}</span>
                                            <span class="vp-price-reg">{$dyn}</span>
                                        </div>
                                        <span class="vp-badge">{dyn}% OFF</span>
                                    </div>
                                </label>
                            </div>
                            <div class="patch__value-pack">
                                <input type="radio" class="vp__input" name="vaule-pack" id="one-month" />
                                <label for="one-month" class="vp-pack">
                                    <div class="vp-img"><img
                                            src="https://qureskincaredns-main.com/sections/isolated/micro-infusion-pdp/images/1_month_mixed.webp"
                                            class="img-fluid" />
                                    </div>
                                    <div class="vp-content">
                                        <p class="mb-0">1 Months</p>
                                        <p class="fs-14 mb-15">(2 treatments)</p>
                                        <div class="vp-price">
                                            <span class="vp-price-sale-one-month">{$dyn}</span>
                                            <span class="vp-price-reg d-none">{$dyn}</span>
                                        </div>
                                    </div>
                                </label>
                            </div>

                        </div>
                    </div>
                    <div class="qure__product-action-inner mt-30 mt-md-40 mb-10 max-w-ctm" style="--max-w-ctm:500px">
                        <button type="submit" class="add-cart-button product-form__submit btn btn--primary w-100">Buy
                            Now & Save {dyn}%</button>
                    </div>

                    {% render 'product-buy-button-bottom', product_price_divided: '$555' %}

                    <!-- end -->

                {% endif %}






                {% render 'page-video', section: section %}
            </div>
         </div>
         <div class="col-lg-6 custom__block">
            {% render 'product-page-slider', product: blank, page: page, class: 'tp-product-gallery d-none d-lg-block' %}
            {% render 'product-page-cross-sell', product: blank, page: page %}
            {% render 'product-page-benefits-list' %}
            {% render 'product-page-collapsed', product: blank, page: page, class: 'mt-15 tp-product-accordion' %}
            {% render 'product-page-jumpto', section: section %}
            </div>
         </div>
      </div>
   </div>

   <!-- Reusable Wistia Modal (outside slider) -->
   <div class="modal fade filter-modal" id="reusableWistiaModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered modal-md filter-dialog">
         <div class="modal-content">
            <div class="modal-header border-0">
               <button type="button" class="btn btn-close" data-bs-dismiss="modal" aria-label="Close">
                  <i class="fa-solid fa-xmark"></i>
               </button>
            </div>
            <div class="modal-body">
               <div id="wistiaVideoContainer" class="filter-modal-video"></div>
            </div>
         </div>
      </div>
   </div>
</div>

{% schema %}
{
    "name": "t:sections.page-header.name",
    "settings": [
        {
            "type": "richtext",
            "id": "rating",
            "label": "t:common.rating",
            "default": "<p><strong>4.8</strong>/5 Rated by Customers</p>"
        },
        {
            "type": "text",
            "id": "heading",
            "label": "t:common.header"
        },
        {
            "type": "richtext",
            "id": "description",
            "label": "t:common.description"
        },
        {
            "type": "text",
            "id": "button-label",
            "label": "t:common.button-label"
        },
        {
            "type": "url",
            "id": "button-url",
            "label": "t:common.button-url"
        }
    ],
    "blocks": [
        {
            "type": "video",
            "name": "t:common.video",
            "limit": 1,
            "settings": [
                {
                    "type": "text",
                    "id": "heading",
                    "label": "t:common.header"
                },
                {
                    "type": "image_picker",
                    "id": "image",
                    "label": "t:common.image"
                },
                {
                    "type": "text",
                    "id": "wistia_url",
                    "label": "t:common.wistia-url"
                }
            ]
        },
        {
            "type": "jumpto",
            "name": "t:common.jumpto",
            "limit": 10,
            "settings": [
                {
                    "type": "text",
                    "id": "button-label",
                    "label": "t:common.button-label"
                },
                {
                    "type": "url",
                    "id": "button-url",
                    "label": "t:common.button-url"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "t:sections.page-header.name"
        }
    ]
}
{% endschema %}