{% doc %}
Renders a purchase banner with text section for microinfusion faq page.
{% enddoc %}

<div class="qure__section"
    style="--section-padding-top: 30px; --section-padding-bottom: 30px;--section-padding-top-mob: 20px; --section-padding-bottom-mob: 20px;">
    <div class="container">
        <div class="common_faq">
            <div class="banner_text">
                {% if section.settings.heading != blank %}
                    <p class="faq_block-heading fs-md-34 fs-26 pb-10">{{ section.settings.heading }}</p>
                {% endif %}
                <div class="row custom__grid" style="--column-gap:60px; --column-gap-mobile:30px;">
                    <div class="custom__block ctm-width" style="--ctm-width:560px; --ctm-width-mob:100%;">
                        {% if section.settings.image != blank %}
                            <img src="{{ section.settings.image | image_url }}" class="img-fluid" alt="{{ section.settings.image.alt | escape }}">
                        {% endif %}
                    </div>
                    <div class="col custom__block">
                        <div class="d-flex flex-column justify-content-between h-100 py-20">
                            {% if section.settings.text != blank %}
                                {{ section.settings.text }}
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{% schema %}
{
    "name": "t:sections.purchase-banner-with-text.name",
    "settings": [
    {
        "type": "text",
        "id": "heading",
        "label": "t:common.header"
    },
    {
        "type": "richtext",
        "id": "text",
        "label": "t:common.text"
    },
    {
        "type": "image_picker",
        "id": "image",
        "label": "t:common.image"
    }
    ]
}
{% endschema %}