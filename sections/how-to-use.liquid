{% doc %}
  Renders a how to use section.
{% enddoc %}

<link rel="stylesheet" href="https://qureskincaredns.com/sections/isolated/target-specific/tg-icons.css" />
<div id="how_to_use" class="quick-and-easy qure__section"
    style="--section-padding-top: 80px; --section-padding-bottom: 80px; --section-padding-top-mob: 40px; --section-padding-bottom-mob: 40px;"
    id="steps">
    <div class="container">
        {% if section.settings.heading_mobile != blank %}
            <h2 class="qure__section-heading mb-30 d-block d-md-none">{{ section.settings.heading_mobile }}</h2>
        {% endif %}
        <div class="row custom__grid align-items-center" style="--column-gap:60px; --column-gap-mobile:30px;">
            <div class="col-md-4 col-lg-4 custom__block">
                {% if section.settings.wistia_url != blank %}
                     <div class="wistia__player">
                        <div class="wistia_responsive_padding" style="position:relative;">
                            <div class="wistia_responsive_wrapper"
                                style="height:100%;left:0;position:absolute;top:0;width:100%;">
                                <div class="wistia_embed wistia_async_{{ section.settings.wistia_url }} seo=false videoFoam=true"
                                    style="height:100%;position:relative;width:100%">
                                    <div class="wistia_swatch"
                                        style="height:100%;left:0;opacity:0;overflow:hidden;position:absolute;top:0;transition:opacity 200ms;width:100%;">
                                        <img src="https://fast.wistia.com/embed/medias/{{ section.settings.wistia_url }}/swatch"
                                            style="filter:blur(5px);height:100%;object-fit:contain;width:100%;" alt="video"
                                            aria-hidden="true" onload="this.parentNode.style.opacity=1;" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endif %}
            </div>
            <div class="col-md-8 col-lg-8 custom__block" style="--column-gap:40px; --column-gap-mobile:24px;">
                 {% if section.settings.heading != blank %}
                    <h2 class="qure__section-heading mb-50 d-none d-md-block">{{ section.settings.heading }}</h2>
                {% endif %}
                {% if section.settings.text != blank %}
                    <p class="mb-30">{{ section.settings.text }}</p>
                {% endif %}
                <div class="row custom__grid">
                    {% for block in section.blocks %}
                        {% if block.type == 'list' %}
                            <div class="col-md-6 col-lg-4 custom__block">
                                <div class="qe__card-block d-flex flex-nowrap flex-md-wrap" style="--bs-border-radius:10px">
                                    <div class="img_with-number mb-md-24 overflow-hidden position-relative" data-number="{{ forloop.index }}">
                                        {% if block.settings.image != blank %}
                                            <img src="{{ block.settings.image | image_url }}" alt="{{ block.settings.image.alt | escape }}" class="img-fluid rounded-2 d-none d-lg-block" />
                                        {% endif %}
                                        {% if block.settings.image_mobile != blank %}
                                            <img src="{{ block.settings.image_mobile | image_url }}" alt="{{ block.settings.image_mobile.alt | escape }}" class="img-fluid rounded-2 d-block d-lg-none" />
                                        {% endif %}
                                    </div>
                                    <div class="qe__content">
                                        {% if block.settings.heading != blank %}
                                            <h3 class="fs-20 fw-600 fm-body mb-10">{{ block.settings.heading }}</h3>
                                        {% endif %}
                                        {% if block.settings.text != blank %}
                                            <div class="fs-16">{{ block.settings.text | replace: '<p>', '' | replace: '</p>', '' }}</div>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        {% endif %}
                    {% endfor %}
                </div>
                {% if section.settings.button_label != blank and section.settings.button_url != blank %}
                    <div class="text-center mt-30 mt-lg-60">
                        <a href="{{ section.settings.button_url }}" class="btn btn--primary fs-18">{{ section.settings.button_label }} </a>
                    </div>
                {% endif %}

                {%- assign image_with_text_count = 0 -%}
                {%- for block in section.blocks -%}
                    {%- if block.type == 'image_with_text' -%}
                        {%- assign image_with_text_count = image_with_text_count | plus: 1 -%}
                    {%- endif -%}
                {%- endfor -%}
                {% if image_with_text_count > 0 %}
                  <div class="d-flex justify-content-center gap-4 mt-10 ltd_stock">
                      {% for block in section.blocks %}
                          {% if block.type =='image_with_text' %}
                              <div class="d-flex gap-2">
                                  {% if block.settings.image != blank %}
                                      <img src="{{ block.settings.image | image_url }}" alt="{{ block.settings.image.alt | escape }}">
                                  {% endif %}
                                  {% if block.settings.text != blank %}
                                      {{ block.settings.text }}
                                  {% endif %}
                              </div>
                          {% endif %}
                      {% endfor %}
                  </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadScriptOnce('wistia-script', 'https://fast.wistia.com/assets/external/E-v1.js');
    });
</script>

{% schema %}
{
  "name": "t:sections.how-to-use.name",
  "settings": [
    {
        "type": "text",
        "id": "heading",
        "label": "t:common.header"
    },
    {
        "type": "text",
        "id": "text",
        "label": "t:common.text"
    },
    {
        "type": "text",
        "id": "heading_mobile",
        "label": "t:common.header-mobile"
    },
    {
        "type": "text",
        "id": "wistia_url",
        "label": "t:common.wistia-url"
    },
    {
        "type": "text",
        "id": "button_label",
        "label": "t:common.button-label"
    },
    {
        "type": "url",
        "id": "button_url",
        "label": "t:common.button-url"
    }
  ],
  "blocks": [
    {
        "type": "list",
        "name": "t:common.list",
        "settings": [
            {
                "type": "text",
                "id": "heading",
                "label": "t:common.header"
            },
            {
                "type": "richtext",
                "id": "text",
                "label": "t:common.text"
            },
            {
                "type": "image_picker",
                "id": "image",
                "label": "t:common.image"
            },
            {
                "type": "image_picker",
                "id": "image_mobile",
                "label": "t:common.image-mobile"
            }
        ]
    },
    {
        "type": "image_with_text",
        "name": "t:common.image-with-text",
        "settings": [
            {
                "type": "image_picker",
                "id": "image",
                "label": "t:common.image"
            },
            {
                "type": "richtext",
                "id": "text",
                "label": "t:common.text"
            }
        ]
    }
  ]
}
{% endschema %}