{% doc %}
  Renders a purchase form section.
{% enddoc %}

{% include 'assoc-array', section: section, __parent_title: 'type', __separator: '###' %}

<link rel="stylesheet" href="https://qureskincaredns.com/sections/new/treatment/treatment.css" />
<section id="purchase-form" class="treatment {{ section.id }}">
    <div class="container">
        <article class="treatment__content">
            {% if section.settings.heading != blank %}
                <h2>{{ section.settings.heading }}</h2>
            {% endif %}

            {% if section.settings.text != blank %}
                <p>{{ section.settings.text }}</p>
            {% endif %}

            {% if section.settings.image != blank %}
                <picture>
                    <img src="{{ section.settings.image | img_url: 'master' }}" alt="{{ section.settings.image.alt | escape }}" id="purchase_form_image" />
                </picture>
            {% endif %}
        </article>
        <div class="treatment__form">
            <div class="treatment__box">
                <div class="treatment__steps">
                    {% render 'n-purchase-form-types' section: section, __idsArray1: __idsArray1, __idsArray2: __idsArray2, __idsArray3: __idsArray3 %}
                    {% include 'n-purchase-form-products' section: section, __idsArray1: __idsArray1, __idsArray2: __idsArray2, __idsArray3: __idsArray3 %}
                    {% render 'n-purchase-form-klaviyo', section: section %}
                    {% render 'n-purchase-form-payments' section: section %}
                </div>
                <div class="treatment__buy">
                    {% render 'n-product-page-buy-button', product_price: null, product_variant_id: null, section: section, product_available: true %}
                </div>
            </div>
        </div>
        <div class="treatment__extra">
            <ul class="e-features-list">
                <li>
                    <i class="e-icon e-icon-guarantee"></i>
                    {{ 'product.settings.benefits-list.guaranteed_text' | t }}
                </li>
                <li>
                    <i class="e-icon e-icon-shipping-order"></i>
                    {{ 'product.settings.benefits-list.shipping_text' | t }}
                </li>
                <li>
                    <i class="e-icon e-icon-proven"></i>
                    {{ 'product.settings.benefits-list.science_text' | t }}
                </li>
            </ul>
            <div class="treatment__questions">{{ 'purchase-form.settings.n-questions_html' | t }}</div>
        </div>
    </div>
</section>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadScriptOnce("treatment-new", "https://qureskincaredns.com/sections/new/treatment/treatment.js");
    });
</script>

<script src="{{ 'n-purchase-form.js' | asset_url }}" data-form="{{ section.settings.form_name }}" data-section="{{ section.id }}" defer></script>

{%- schema -%}
{
