        {
            "type": "type",
            "limit": 3,
            "name": "t:common.type",
            "settings": [
                {
                    "type": "header",
                    "content": "TYPE"
                }
            ]
        },
        {
            "type": "product_type",
            "name": "t:common.product-type",
            "limit": 3,
            "settings": [
                {
                    "type": "text",
                    "id": "heading",
                    "label": "t:common.header"
                },
                {
                    "type": "image_picker",
                    "id": "image",
                    "label": "t:common.image"
                },
                {
                    "type": "checkbox",
                    "id": "preselected",
