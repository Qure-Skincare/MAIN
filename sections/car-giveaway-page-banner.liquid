{% doc %}
  Renders a page banner section for car giveaway page.
{% enddoc %}


<link rel="stylesheet" href="https://qureskincaredns-main.com/sections/isolated/page-banner/page-banner.css" />
<div class="page__banner position-relative">
    <picture>
        {% if section.settings.image != blank %}
            <source media="(min-width:1920px)" srcset="{{ section.settings.image | image_url }}" class="img-fluid" width="1440" height="557">
            <source media="(min-width:1600px)" srcset="{{ section.settings.image | image_url }}" class="img-fluid" width="1440" height="557">
            <source media="(min-width:1100px)" srcset="{{ section.settings.image | image_url }}" class="img-fluid" width="1440" height="557">
            <source media="(min-width:767px)" srcset="{{ section.settings.image | image_url }}" class="img-fluid" width="1440" height="557">
        {% endif %}
        {% if section.settings.image_mobile != blank %}
            <source media="(min-width:540px)" srcset="{{ section.settings.image_mobile | image_url }}" class="img-fluid" width="1440" height="557">
            <img src="{{ section.settings.image_mobile | image_url }}" width="225" height="281" alt="{{ section.settings.image_mobile.alt | escape }}" class="img-fluid w-100">
        {% endif %}
    </picture>
    <div
        class="page__banner-wrapper position-absolute d-flex align-items-md-center justify-content-end top-0 bottom-0 start-0 end-0">
        <div class="container">
            <div class="d-flex justify-content-center justify-content-md-end align-items-start h-100 position-relative">
                <div class="ctm-width ctm-color text-center text-md-center offset-md-6 pt-15 pt-md-0"
                    style="--ctm-width:345px;--txt-color-mob:#000;">
                    {% if section.settings.heading != blank %}
                        <p class="mb-8 fs-14">{{ section.settings.heading }}</p>
                    {% endif %}
                    <h1 class="page-banner-title pt-0 px-10 px-md-0" style="--pg-title-mob:#000;--font-h1:38px;--font-h1-mob:32px;">{{ 'sections.car-giveaway-page-banner.cta_text' | t }}<img src="{{ 'sections.car-giveaway-page-banner.qure_logo' | t }}" class="qure_logo_title">{{ 'sections.car-giveaway-page-banner.after_logo_text' | t }} </h1>
                    {% if section.settings.text != blank %}
                        <p class="mt-8 mb-0 fs-16 fs-md-18">{{ section.settings.text }}</p>
                    {% endif %}
                    <div class="ctm-width mx-auto" style="--ctm-width:450px">
                        {% if section.settings.button_label != blank and section.settings.button_url != blank %}
                            <a href="{{ section.settings.button_url }}" class="btn btn--primary mt-20 mt-lg-25 mb-5 w-100 text-center mw enter_now_btn" style="--mw:400px;">{{ section.settings.button_label }}</a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


{% schema %}
{
  "name": "t:sections.car-giveaway-page-banner.name",
  "settings": [
   {
        "type": "text",
        "id": "heading",
        "label": "t:common.header"
   },
   {
      "type": "text",
      "id": "text",
      "label": "t:common.text"
   },
   {
      "type": "text",
      "id": "button_label",
      "label": "t:common.button-label"
   },
   {
      "type": "url",
      "id": "button_url",
      "label": "t:common.button-url"
   },
   {
      "type": "image_picker",
      "id": "image",
      "label": "t:common.image"
   },
   {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "t:common.image-mobile"
   }
  ]
}
{% endschema %}