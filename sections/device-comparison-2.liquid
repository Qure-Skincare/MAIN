{% doc %}
  Renders a device comparison section
{% enddoc %}

<link rel="stylesheet"
    href="https://qureskincaredns.com/sections/isolated/serum-compare/section-serum-compare.css" />
<div class="qure__section compare_section color-background"
    style="--section-padding-top: 80px; --section-padding-bottom: 80px; --section-background: #F6F6F7; --section-padding-top-mob: 50px; --section-padding-bottom-mob: 50px;">
    <div class="container">
        <div class="qure__section-header text-center">
            <h2 class="qure__section-heading">More actives, less hassle, better results</h2>
        </div>

        <div class="compare_listRow qure__eqBox-parent">
            <div class="compare_listHeadings">
                <div class="cp__heading-box">
                    <div class="cp__heading-item">Active Ingredients</div>
                    <div class="cp__heading-item">Multi-Benefit Formula</div>
                    <div class="cp__heading-item">Ease of Use</div>
                    <div class="cp__heading-item">Cost</div>
                </div>
            </div>
            <div class="compare_list_column">
                <qure-swiper-settings>
                    <div class="swiper qure__swiper" id="qure__swiper-compare-slider" data-section-id="compare-slider"
                        data-autoplay="false" data-loop="false" data-mobile="1" data-tablet="2" data-desktop="3"
                        data-spacing="0" data-pagination-fraction="true" data-arrowright="compare-arrow-right"
                        data-arrowleft="compare-arrow-left" data-pagination="compare-pagination"
                        data-arrowleft="arrow-left-compare-slider" data-arrowright="arrow-right-compare-slider">
                        <div class="swiper-wrapper">
                            <div class="swiper-slide">
                                <div class="cp__compare-box compare-box-active">
                                    <div class="cp__compare-inner">
                                        <div class="cp__compare-header position-relative qure__eqBox-child">
                                            <div class="cp__compare-img"><img
                                                    src="https://qureskincaredns.com/sections/isolated/serum-compare/images/all-in-one.webp"
                                                    alt="all-in-one" class="img-fluid" /></div>
                                            <h3 class="cp__compare-title" style="--font-h3:22px;">Qure <br />All-In-One
                                                Serum
                                            </h3>
                                        </div>
                                        <div class="cp__compare-content position-relative">
                                            <div class="cp__compare-item compare-check">Retinol, peptides, niacinamide,
                                                bakuchiol
                                            </div>
                                            <div class="cp__compare-item compare-check">Targets 5+ concerns in one
                                                easy-to-use
                                                formula</div>
                                            <div class="cp__compare-item compare-check">One step, AM or PM</div>
                                            <div class="cp__compare-item compare-check">Great value</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="swiper-slide">
                                <div class="cp__compare-box">
                                    <div class="cp__compare-inner">
                                        <div class="cp__compare-header position-relative">
                                            <div class="cp__compare-img"><img
                                                    src="https://qureskincaredns.com/sections/isolated/serum-compare/images/high-end.webp"
                                                    alt="high end" class="img-fluid" /></div>
                                            <h3 class="cp__compare-title" style="--font-h3:22px;">High-End<br />Serums
                                            </h3>
                                        </div>
                                        <div class="cp__compare-content position-relative">

                                            <div class="cp__compare-item compare-check">Usually 1–2 premium actives per
                                                product
                                            </div>
                                            <div class="cp__compare-item compare-close">Often one concern per product
                                            </div>
                                            <div class="cp__compare-item compare-close">Multi-step routine</div>
                                            <div class="cp__compare-item compare-close">High ($90+ per product)</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="swiper-slide">
                                <div class="cp__compare-box cp__compare-box-last">
                                    <div class="cp__compare-inner">
                                        <div class="cp__compare-header position-relative">
                                            <div class="cp__compare-img">
                                                <img src="https://qureskincaredns.com/sections/isolated/serum-compare/images/drugstore.webp"
                                                    alt="drugstore" class="img-fluid" />
                                            </div>
                                            <h3 class="cp__compare-title" style="--font-h3:22px;">Drugstore<br />Serums
                                            </h3>
                                        </div>
                                        <div class="cp__compare-content position-relative">
                                            <div class="cp__compare-item compare-close">Basic actives in lowest
                                                concentrations
                                            </div>
                                            <div class="cp__compare-item compare-close">Often one concern per product
                                            </div>
                                            <div class="cp__compare-item compare-close">Multi-step routine</div>
                                            <div class="cp__compare-item compare-close">Low</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </qure-swiper-settings>
            </div>
        </div>
        <div class="swiper-arrows-with-pagination d-flex align-items-center justify-content-center gap-4">
            <div class="arrow-left-compare-slider qure-swiper-arrow compare-arrow-left mt-30"><i
                    class="fa-regular fa-angle-left"></i></div>
            <div class="swiper-pagination compare-pagination position-relative bottom-0 w-auto mt-30"></div>
            <div class="arrow-right-compare-slider qure-swiper-arrow compare-arrow-right mt-30"><i
                    class="fa-regular fa-angle-right"></i></div>
        </div>
    </div>
</div>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadScriptOnce('main-slider', 'https://qureskincaredns.com/assets/js/main-slider.js');
        loadScriptOnce('equal-height', 'https://qureskincaredns.com/assets/js/equal-height.js');
    });
</script>


{% schema %}
{
    "name": "t:sections.device-comparison-2.name",
        "settings": [
    
  ],
  "presets": [
    {
      "name": "t:sections.device-comparison-2.name"
    }
  ]
}
{% endschema %}