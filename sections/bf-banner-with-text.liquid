{% doc %}
    Renders a banner with text section for black friday.
{% enddoc %}

<link href="https://qureskincaredns-main.com/alex/sections/global/banner-with-text/banner-text.css" rel="stylesheet" type="text/css">
   <div class="qure__section banner-with-text color-background">
      <div class="offset-right-container">
         <div class="row custom__grid">
            <div class="col-md-5 custom__block">
               <div class="banner-with-text-content text-center">
                  <img src="{{ 'sections.bf-banner-with-text.bf_sale_image' | t }}" alt="{{ 'sections.bf-banner-with-text.bf_sale_image.alt' | t | escape}}">
                  {% if section.settings.heading != blank %}
                    {{ section.settings.heading }}
                  {% endif %}
                  {% if section.settings.text != blank %}
                    {{ section.settings.text }}
                  {% endif %}
                  {% if section.settings.button_url != blank and section.settings.button_label != blank %}
                    <a href="{{ section.settings.button_url }}" class="banner-text--button btn btn--primary-white">{{ section.settings.button_label }}</a>
                  {% endif %}
               </div>
            </div>
            <div class="col-md-7 custom__block">
               <div class="banner-text--media banner-text-mob-full">
                  <div class="qure__swiper-wrapper">
                     <div class="swiper qure__swiper-gallery" data-section-id="bf-bundles-slider" data-mobile="1" data-tablet="1" data-desktop="1" data-autoplay="true" data-loop="true" data-spacing="0">
                        <div class="swiper-wrapper">
                            {% for block in section.blocks %}
                                {% if block.type == 'carousel' %}
                                    <div class="swiper-slide">
                                        {% if block.settings.image != blank %}
                                            <img src="{{ block.settings.image | image_url }}" alt="{{ block.settings.image.alt | escape }}">
                                        {% endif %}
                                        {% if block.settings.percent_value != blank %}
                                            <div class="bf-discont-badge" data-text-top="Up to" data-text-bottom="Off">{{ block.settings.percent_value }}</div>
                                        {% endif %}
                                    </div>
                                {% endif %}
                            {% endfor %}
                        </div>
                     </div>
                     <div class="swiper-thumbnail-press-slider">
                        <div class="swiper qure__swiper-gallery-thumbnails" data-section-id="bf-bundles-slider-thumbnails" data-mobile="3" data-tablet="3" data-desktop="3" data-autoplay="true" data-loop="true" data-spacing="15">
                           <div class="swiper-wrapper">
                                {% for block in section.blocks %}
                                    {% if block.type == 'carousel' %}
                                        {% if block.settings.heading != blank %}
                                            <div class="swiper-slide">{{ block.settings.heading }}</div>
                                        {% endif %}
                                    {% endif %}
                                {% endfor %}
                           </div>
                        </div>
                     </div>
                  </div>
               </div>
            </div>
         </div>
      </div>
   </div>
   <script>
      document.addEventListener("DOMContentLoaded", function () {
         loadScriptOnce('slider-script', 'https://qureskincaredns-main.com/assets/js/slider-with-thumb.js');
      });
   </script>

{%  schema  %}
{
  "name": "t:sections.bf-banner-with-text.name",
  "settings": [
    {
        "type": "richtext",
        "id": "heading",
        "label": "t:common.header"
    },
    {
        "type": "richtext",
        "id": "text",
        "label": "t:common.text"
    },
    {
        "type": "text",
        "id": "button_label",
        "label": "t:common.button-label"
    },
    {
        "type": "url",
        "id": "button_url",
        "label": "t:common.button-url"
    }
  ],
  "blocks": [
    {
      "type": "carousel",
      "name": "t:common.carousel",
        "settings": [
            {
                "type": "text",
                "id": "heading",
                "label": "t:common.header"
            },
            {
                "type": "text",
                "id": "percent_value",
                "label": "t:common.percent-value"
            },
            {
                "type": "image_picker",
                "id": "image",
                "label": "t:common.image"
            }
        ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.bf-banner-with-text.name"
    }
  ]
}
{% endschema %}