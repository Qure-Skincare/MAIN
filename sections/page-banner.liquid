<link rel="stylesheet" href="https://qureskincaredns-main.com/sections/isolated/page-banner/page-banner.css" />
<div class="page__banner position-relative">
   <picture>
      {% if section.settings.image != blank %}
         <source media="(min-width:1920px)" srcset="{{ section.settings.image | image_url }}" class="img-fluid"
            width="1440" height="557">
         <source media="(min-width:1600px)" srcset="{{ section.settings.image | image_url }}" class="img-fluid"
            width="1440" height="557">
         <source media="(min-width:1100px)" srcset="{{ section.settings.image | image_url }}" class="img-fluid"
            width="1440" height="557">
         <source media="(min-width:767px)" srcset="{{ section.settings.image  | image_url}}" class="img-fluid"
            width="1440" height="557">
      {% endif %}
      {% if section.settings.image_mobile != blank %}
         <source media="(min-width:540px)" srcset="{{ section.settings.image_mobile | image_url }}" class="img-fluid"
            width="1440" height="557">
         <img src="{{ section.settings.image_mobile | image_url }}" width="225" height="281" alt=""
            class="img-fluid w-100">
      {% endif %}
   </picture>
   <div
      class="page__banner-wrapper position-absolute d-flex align-items-center justify-content-end top-0 bottom-0 start-0 end-0 pb-20">
      <div class="container">
         <div class="d-flex">
            <div class="ctm-width ctm-color text-center text-md-start mx-auto mx-md-0"
               style="--ctm-width:550px; --txt-color-mob:#fff;">
               {% if section.settings.heading != blank %}
                  <h1 class="page-banner-title">{{ section.settings.heading }}</h1>
               {% endif %}
               {% if section.settings.button_mobile != blank and section.settings.button_url_mobile != blank %}
                  <a href="{{ section.settings.button_url_mobile }}" class="btn btn--primary-white mt-20 text-center d-md-none">{{ section.settings.button_mobile }}</a>
               {% endif %}           
               <div class="ctm-width d-none d-md-block" style="--ctm-width:450px">
                  {% if section.settings.button != blank and section.settings.button_url != blank %}
                     <a href="{{ section.settings.button_url }}" class="btn btn--primary mt-20 mt-lg-30 mb-5 w-100 text-center">{{ section.settings.button }}</a>
                  {% endif %}
                  {% if section.settings.text != blank %}
                     <span class="fs-16 d-block text-center">{{ section.settings.text }}</span>
                  {% endif %} 
               </div>
            </div>
         </div>
      </div>
   </div>
</div>
{% schema %}
{
  "name": "t:sections.index-read-our-story.name",
  "settings": [
   {
        "type": "text",
        "id": "heading",
        "label": "t:common.header",
        "default": "Get clinic-level results from home – minus the ‘clinical’ costs."
    },
    {
        "type": "text",
        "id": "text",
        "label": "t:common.text",
        "default": "Join 30,000+ customers feeling more confident."
    },
    {
        "type": "text",
        "id": "button",
        "label": "t:common.button-label",
        "default": "Shop All Best Sellers"
    },
    {
        "type": "url",
        "id": "button_url",
        "label": "t:common.button-url"
    },
    {
        "type": "text",
        "id": "button_mobile",
        "label": "t:common.button-label-mobile",
        "default": "Shop Best Sellers"
    },
    {
        "type": "url",
        "id": "button_url_mobile",
        "label": "t:common.button-url-mobile"
    },
    {
        "type": "image_picker",
        "id": "image",
        "label": "t:common.image"
    },
    {
        "type": "image_picker",
        "id": "image_mobile",
        "label": "t:common.image-mobile"
    }
  ],
  "presets": [
   {
      "name": "t:sections.page-banner.name"
   }
  ]
}
{% endschema %}