{% doc %}
  Renders a page banner section 
{% enddoc %}


<link rel="stylesheet" href="https://qureskincaredns-main.com/sections/isolated/page-banner/page-banner.css" />
<div class="page__banner position-relative">
   <picture>
      {% if section.settings.image != blank %}
         <source media="(min-width:1920px)" srcset="{{ section.settings.image | image_url }}" class="img-fluid" width="1440" height="557">
         <source media="(min-width:1600px)" srcset="{{ section.settings.image | image_url }}" class="img-fluid" width="1440" height="557">
         <source media="(min-width:1100px)" srcset="{{ section.settings.image | image_url }}" class="img-fluid" width="1440" height="557">
         <source media="(min-width:767px)" srcset="{{ section.settings.image  | image_url}}" class="img-fluid" width="1440" height="557">
      {% endif %}
      {% if section.settings.image_mobile != blank %}
         <source media="(min-width:540px)" srcset="{{ section.settings.image_mobile | image_url }}" class="img-fluid" width="1440" height="557">
         <img src="{{ section.settings.image_mobile | image_url }}" width="225" height="281" alt="{{ section.settings.image_mobile.alt | escape }}" class="img-fluid w-100">
      {% endif %}
   </picture>
   <div class="page__banner-wrapper position-absolute d-flex align-items-md-center justify-content-end top-0 bottom-0 start-0 end-0 pb-20">
      <div class="container">
         <div class="d-flex pt-md-0 pt-50">
            <div class="ctm-width ctm-color mx-auto mx-md-0 text-center text-md-start" style="--ctm-width:550px; --pg-title-mob:#212428;">
               {% if template.name == 'collection' and collection.handle != 'best-sellers' %}
                  <h1 class="ctm-width ctm-color text-center text-md-start mx-auto mx-md-0 d-none d-md-block" style="--ctm-width:550px; --pg-title-mob:#212428;">{{ collection.handle | replace: '-', ' ' | capitalize }}</h1>
                  <h1 class="ctm-width ctm-color text-center text-md-start mx-auto mx-md-0 d-block d-md-none" style="--ctm-width:550px; --pg-title-mob:#212428; margin-top:-20px;">{{ collection.handle | replace: '-', ' ' | capitalize }}</h1>
               {% else %}
                  {% if section.settings.heading != blank %}
                     <h1 class="ctm-width ctm-color text-center text-md-start mx-auto mx-md-0 d-none d-md-block" style="--ctm-width:550px; --pg-title-mob:#212428;">{{ section.settings.heading }}</h1>
                     <h1 class="ctm-width ctm-color text-center text-md-start mx-auto mx-md-0 d-block d-md-none" style="--ctm-width:550px; --pg-title-mob:#212428; margin-top:-20px;">{{ section.settings.heading }}</h1>
                  {% endif %}
               {% endif %}
               {% if section.settings.text != blank %}
                  <p class="py-15">{{ section.settings.text | replace: '<p>', '' | replace: '</p>', '' }}</p>
               {% endif %}
               {% assign button_blocks_size = section.blocks | where: 'type', 'button' | size %}
               {% if button_blocks_size > 0 %}
                  <div class="ctm-width mt-20 d-flex justify-content-center justify-content-md-start gap-3">
                     {% for block in section.blocks %}
                        {% if block.type == 'button' %}
                           {% if block.settings.link_url != blank and block.settings.image != blank %}
                              <a href="{{ block.settings.link_url }}"><img src="{{ block.settings.image | image_url }}" alt="{{ block.settings.image.alt | escape }}" /></a>
                           {% endif %}
                        {% endif %}
                     {% endfor %}
                  </div>
               {% endif %}         
               <div class="ctm-width" style="--ctm-width:450px">
                  {% if section.settings.button_mobile != blank and section.settings.button_url_mobile != blank %}
                     <a href="{{ section.settings.button_url_mobile }}" class="btn btn--primary mb-5 mt-10 w-100 text-center d-md-none">{{ section.settings.button_mobile }}</a>
                  {% endif %}  
                  {% if section.settings.button != blank and section.settings.button_url != blank %}
                     <a href="{{ section.settings.button_url }}" class="btn btn--primary mt-20 mt-lg-30 mb-5 w-100 text-center d-none d-md-block">{{ section.settings.button }}</a>
                  {% endif %}
                  {% if section.settings.sub_text != blank %}
                     {{ section.settings.sub_text | replace: '<p>', '<span class="fs-16 d-block text-center">'}}
                  {% endif %}
                  {% assign image_blocks_size = section.blocks | where: 'type', 'image_with_text' | size %}
                  {% if image_blocks_size > 0 %}
                     <div class="d-flex flex-nowrap align-items-center justify-content-md-center justify-content-between col-gap" style="--col-gap-mb:10px;">
                        {% for block in section.blocks %}
                           {% if block.type == 'image_with_text' %}
                              <div class="icon-with-text d-flex align-items-center fs-16 text-md-center text-lg-start">
                                 {% if block.settings.image != blank %}
                                    <img src="{{ block.settings.image | image_url }}" alt="{{ block.settings.image.alt | escape }}" class="mr-md-10">
                                 {% endif %}
                                 {% if block.settings.text != blank %}
                                    <span class="fs-14">{{ block.settings.text | replace: '<p>', '' | replace: '</p>', '' }}</span>
                                 {% endif %}
                              </div>
                           {% endif %}
                        {% endfor %}
                     </div>
                  {% endif %}
               </div>
            </div>
         </div>
      </div>
   </div>
</div>


{% schema %}
{
  "name": "t:sections.page-banner.name",
  "settings": [
   {
        "type": "text",
        "id": "heading",
        "label": "t:common.header"
   },
   {
      "type": "richtext",
      "id": "text",
      "label": "t:common.text"
   },
   {
      "type": "richtext",
      "id": "sub_text",
      "label": "t:common.sub-text"
   },
   {
      "type": "text",
      "id": "button",
      "label": "t:common.button-label"
   },
   {
      "type": "url",
      "id": "button_url",
      "label": "t:common.button-url"
   },
   {
      "type": "text",
      "id": "button_mobile",
      "label": "t:common.button-label-mobile"
   },
   {
      "type": "url",
      "id": "button_url_mobile",
      "label": "t:common.button-url-mobile"
   },
   {
      "type": "image_picker",
      "id": "image",
      "label": "t:common.image"
   },
   {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "t:common.image-mobile"
   }
  ],
  "blocks": [
   {
      "type": "image_with_text",
      "name": "t:common.image-with-text",
      "settings": [
         {
            "type": "image_picker",
            "id": "image",
            "label": "t:common.image"
         },
         {
            "type": "text",
            "id": "text",
            "label": "t:common.text"
         }
      ]
   },
   {
      "type": "button",
      "name": "t:common.button",
      "settings": [
         {
            "type": "url",
            "id": "link_url",
            "label": "t:common.link-url"
         },
         {
            "type": "image_picker",
            "id": "image",
            "label": "t:common.image"
         }
      ]
   }
  ],
  "presets": [
    {
      "name": "t:sections.page-banner.name"
    }
  ]
}
{% endschema %}