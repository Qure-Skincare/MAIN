{% doc %}
  Renders a countdown timer section for car giveaway page.
{% enddoc %}

<link rel="stylesheet" href="https://qureskincaredns-main.com/sections/isolated/countdown-timer/countdown-timer.css">
<div class="qure__section color-background"
    style="--section-background:#212428;--section-padding-top:40px;--section-padding-bottom:40px;">
    <div class="container">
        {% if section.settings.heading != blank %}
            <p class="extra_entries">{{ section.settings.heading }}</p>
        {% endif %}
        <div class="countdown" data-target="2025-10-02T00:00:00">
            <div>
                <div class="days">{{ 'sections.car-giveaway-countdown-timer.00' | t }}</div><span>{{ 'sections.car-giveaway-countdown-timer.days' | t }}</span>
            </div>
            <div><img src="{{ 'sections.car-giveaway-countdown-timer.white_line_image' | t }}" alt=""></div>
            <div>
                <div class="hours">{{ 'sections.car-giveaway-countdown-timer.00' | t }}</div><span>{{ 'sections.car-giveaway-countdown-timer.hours' | t }}</span>
            </div>
            <div><img src="{{ 'sections.car-giveaway-countdown-timer.white_line_image' | t }}" alt=""></div>
            <div>
                <div class="minutes">{{ 'sections.car-giveaway-countdown-timer.00' | t }}</div><span>{{ 'sections.car-giveaway-countdown-timer.minutes' | t }}</span>
            </div>
            <div><img src="{{ 'sections.car-giveaway-countdown-timer.white_line_image' | t }}" alt=""></div>
            <div>
                <div class="seconds">{{ 'sections.car-giveaway-countdown-timer.00' | t }}</div><span>{{ 'sections.car-giveaway-countdown-timer.seconds' | t }}</span>
            </div>
        </div>
    </div>
</div>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadScriptOnce('countdown-timer', 'https://qureskincaredns-main.com/sections/isolated/countdown-timer/countdown-timer.js');
    });
</script>


{% schema %}
{
  "name": "t:sections.car-giveaway-countdown-timer.name",
  "settings": [
   {
        "type": "text",
        "id": "heading",
        "label": "t:common.header"
   }
  ]
}
{% endschema %}
