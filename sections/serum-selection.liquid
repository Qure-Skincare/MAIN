{% doc %}
  Renders a serum selection section
{% enddoc %}

<link rel="stylesheet" href="https://qureskincaredns-main.com/sections/isolated/serum/section-serum.css" />
<div id="science_backed" class="qure__section compare_section"
    style="--section-padding-top: 60px; --section-padding-bottom: 40px; --section-padding-top-mob: 50px; --section-padding-bottom-mob: 30px;">
    <div class="container container-small" style="--container-width:850px">
        <div class="qure__section-header text-center mb-60">
            {% if section.settings.heading != blank %}
                <h2 class="qure__section-heading">{{ section.settings.heading }}</h2>
            {% endif %}
            {% if section.settings.text != blank %}
                <div class="qure__section-desc mt-30 px-lg-40">{{ section.settings.text }}</div>
            {% endif %}
        </div>
    </div>
    <div class="container">
        <div class="row custom__grid qure__eqBox-parent" style="--column-gap:50px; --column-gap-mobile:30px;">
            <div class="col custom__block">
                <div class="qure__serum">
                    <div class="qure__serum-hdr qure__eqBox-child">
                        {% if section.settings.left_image != blank %}
                            <div class="qure__serum-img">
                                <img src="{{ section.settings.left_image | image_url}}" alt="{{ section.settings.left_image.alt | escape }}" class="img-fluid" />
                            </div>
                        {% endif %}
                        {% if section.settings.left_heading != blank %}
                            <h4 class="qure__serum-title" style="--font-h4-mob:28px;">{{ section.settings.left_heading }}</h4>
                        {% endif %}
                        <div class="qure__serum-qualities">
                            {% for block in section.blocks %}
                                {% if block.type == 'left_text_with_image' %}
                                    <div class="quality-list">
                                        {% if block.settings.image != blank %}
                                            <img src="{{ block.settings.image | image_url }}" alt="{{ block.settings.image.alt | escape }}">
                                        {% endif %}
                                        {% if block.settings.text != blank %}
                                            {{ block.settings.text | replace: '<p>', '<span>' | replace: '</p>', '</span>' }}
                                        {% endif %}
                                    </div>
                                {% endif %}
                            {% endfor %}
                        </div>
                    </div>
                    <div class="qure__serum-tabs">
                        <div class="accordion accordion-flush" id="qure_wrikle-main">
                            {% for block in section.blocks %}
                                {% if block.type == 'left_accordion' %}
                                    <div class="accordion-item qure__accordion-item">
                                        {% if block.settings.heading != blank %}
                                            <button class="accordion-button collapsed qure__accordion-header px-0" type="button"
                                            data-bs-toggle="collapse" data-bs-target="#qure_wrinkle-{{ forloop.index }}" aria-expanded="false"
                                            aria-controls="qure_wrinkle-{{ forloop.index }}">{{ block.settings.heading }}</button>
                                        {% endif %}
                                        <div id="qure_wrinkle-{{ forloop.index }}" class="accordion-collapse collapse qure__accordion-content" data-bs-parent="#qure_wrikle-main">
                                            {% if block.settings.text != blank %}
                                                 <div class="accordion-body px-0">{{ block.settings.text | replace: '<em>', '<div class="bg-light rounded-10 p-18 fs-14">' | replace: '</em>', '</div>' }}</div>
                                            {% endif %}
                                        </div>
                                    </div>
                                {% endif %}
                            {% endfor %}
                        </div>
                    </div>
                    {% for block in section.blocks %}
                        {% if block.type == 'left_feedback' %}
                            <div class="qure__serum-feedback">
                                <div class="qs-stars"><img src="{{ 'sections.serum-selection.review_stars' | t }}" /></div>
                                {% if block.settings.text != blank %}
                                    <div class="qs-feedback py-10">{{ block.settings.text }}</div>
                                {% endif %}
                                {% if block.settings.country_image != blank and block.settings.username != blank %}
                                    <div class="qs-user"><img src="{{ block.settings.country_image | image_url }}" alt="{{ block.settings.country_image.alt | escape }}"><span>{{ block.settings.username }}</span></div>
                                {% endif %}
                                <span class="fs-12">{{ 'sections.serum-selection.verified_customer_text' | t }}</span>
                            </div>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
            <div class="col-md-1 custom__block">
                <div class="align-items-end d-flex justify-content-center qure__serum-or">
                    <h2>{{ 'sections.serum-selection.or_text' | t }}</h2>
                </div>
            </div>
            <div class="col custom__block">
                <div class="qure__serum">
                    <div class="qure__serum-hdr qure__eqBox-child">
                        {% if section.settings.right_image != blank %}
                            <div class="qure__serum-img">
                                <img src="{{ section.settings.right_image | image_url }}" alt="{{ section.settings.right_image.alt | escape }}" class="img-fluid" />
                            </div>
                        {% endif %}
                        {% if section.settings.right_heading != blank %}
                            <h4 class="qure__serum-title" style="--font-h4-mob:28px;">{{ section.settings.right_heading }}</h4>
                        {% endif %}
                        <div class="qure__serum-qualities">
                            {% for block in section.blocks %}
                                {% if block.type == 'right_text_with_image' %}
                                    <div class="quality-list">
                                        {% if block.settings.image != blank %}
                                            <img src="{{ block.settings.image | image_url }}" alt="{{ block.settings.image.alt | escape }}">
                                        {% endif %}
                                        {% if block.settings.text != blank %}
                                            {{ block.settings.text | replace: '<p>', '<span>' | replace: '</p>', '</span>' }}
                                        {% endif %}  
                                    </div>
                                {% endif %}
                            {% endfor %}
                        </div>
                    </div>
                    <div class="qure__serum-tabs">
                        <div class="accordion accordion-flush" id="qure_dark-main">
                            {% for block in section.blocks %}
                                {% if block.type == 'right_accordion' %}
                                    <div class="accordion-item qure__accordion-item">
                                        {% if block.settings.heading != blank %}
                                            <button class="accordion-button collapsed qure__accordion-header px-0" type="button"
                                                data-bs-toggle="collapse" data-bs-target="#qure_dark-{{ forloop.index }}" aria-expanded="false"
                                                aria-controls="qure_dark-{{ forloop.index }}">{{ block.settings.heading }}</button>
                                        {% endif %}
                                        <div id="qure_dark-{{ forloop.index }}" class="accordion-collapse collapse qure__accordion-content"
                                            data-bs-parent="#qure_dark-main">
                                            {% if block.settings.text != blank %}
                                                <div class="accordion-body px-0">{{ block.settings.text | replace: '<em>', '<div class="bg-light rounded-10 p-18 fs-14">' | replace: '</em>', '</div>' }}</div>
                                            {% endif %}
                                        </div>
                                    </div>
                                {% endif %}
                            {% endfor %}
                         </div>
                    </div>
                    {% for block in section.blocks %}
                        {% if block.type == 'right_feedback' %}
                            <div class="qure__serum-feedback">
                                <div class="qs-stars"><img src="{{ 'sections.serum-selection.review_stars' | t }}" /></div>
                                {% if block.settings.text != blank %}
                                    <div class="qs-feedback py-10">{{ block.settings.text }}</div>
                                {% endif %}
                                {% if block.settings.country_image != blank and block.settings.username != blank %}
                                    <div class="qs-user"><img src="{{ block.settings.country_image | image_url }}" alt="{{ block.settings.country_image.alt | escape }}"><span>{{ block.settings.username }}</span></div>
                                {% endif %}
                                <span class="fs-12">{{ 'sections.serum-selection.verified_customer_text' | t }}</span>
                            </div>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadScriptOnce('equal-height', 'https://qureskincaredns-main.com/assets/js/equal-height.js');
    });
</script>


