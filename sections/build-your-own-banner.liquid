    <div class="container">
        <article>
            <h2>More Glow, More Savings</h2>
            <ul>
                <li>
                    <small>Buy 2 products</small>
                    <strong>-20%</strong>
                </li>
                <li>
                    <small>Buy 3+ products</small>
                    <strong>-25%</strong>
                </li>
            </ul>
        </article>
    </div>
</section>
