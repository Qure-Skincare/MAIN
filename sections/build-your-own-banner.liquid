<!-- HERO BANNER -->
<link href="https://qureskincaredns.com/sections/new/hero-banner/hero-banner.css" rel="stylesheet" type="text/css" />
<section class="hero-banner hero-banner--easter">
    <picture>
        <source media="(min-width:768px)" srcset="https://qureskincaredns.com/sections/new/hero-banner/images/easter.webp" />
