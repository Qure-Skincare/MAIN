{% doc %}
  Proven results slider for Our Story (compare image, circle percent, product link).
{% enddoc %}

{% if section.settings.use_own_file %}
    <link rel="stylesheet" href="https://qureskincaredns.com/sections/new/base-slider/base-slider.css" />
{% endif %}
<section class="base-slider base-slider--two-cards">
    <div class="container">
        {% if section.settings.heading != blank %}
            {{ section.settings.heading }}
        {% endif %}
        <div
            class="c-swiper"
            data-swiper='{
                "slidesPerView": 1.1,
                "spaceBetween": 15,
                "loop": false,
                "pagination": {
                    "el": ".c-swiper-pagination",
                    "type": "custom"
                },
                "navigation": {
                    "prevEl": ".c-swiper-button-prev",
                    "nextEl": ".c-swiper-button-next"
                },
                "breakpoints": {
                    "768": {
                        "slidesPerView": 2
                    },
                    "1200": {
                        "slidesPerView": 2,
                        "spaceBetween": 30
                    }
                }
            }'
        >
            <div class="swiper-wrapper">
                {% for block in section.blocks %}
                    {% if block.type == 'slide' %}
                        <div class="swiper-slide">
                            <div class="c-visual-compare-card">
                                <picture>
                                    {% if block.settings.image != blank %}
                                        <img src="{{ block.settings.image | image_url }}" alt="{{ block.settings.image.alt | escape }}" />
                                    {% endif %}
                                </picture>
                                <article>
                                    {% if block.settings.percent_value != blank %}
                                        <div class="e-circle-percent" style="--percent-value: {{ block.settings.percent_value }}">
                                            <span>{{ block.settings.percent_value }}%</span>
                                        </div>
                                    {% endif %}
                                    {% if block.settings.caption != blank %}
                                        <p>{{ block.settings.caption }}</p>
                                    {% endif %}
                                    {% if block.settings.product_title != blank %}
                                        <a href="{{ block.settings.product_url | default: '#' }}">
                                            {% if block.settings.product_image != blank %}
                                                {% liquid
                                                    assign product_alt = block.settings.product_image.alt | default: block.settings.product_title
                                                %}
                                                <img
                                                    src="{{ block.settings.product_image | image_url }}"
                                                    alt="{{ product_alt | escape }}"
                                                />
                                            {% endif %}
                                            <span>{{ block.settings.product_title }}</span>
                                            <i class="e-icon e-icon-arrow"></i>
                                        </a>
                                    {% endif %}
                                </article>
                            </div>
                        </div>
                    {% endif %}
                {% endfor %}
            </div>
            <div class="c-swiper-nav">
                <button type="button" class="c-swiper-button-prev"></button>
                <div class="c-swiper-pagination"></div>
                <button type="button" class="c-swiper-button-next"></button>
            </div>
        </div>
    </div>
</section>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadScriptOnce("base-slider", "https://qureskincaredns.com/sections/new/base-slider/base-slider.js");
    });
</script>

{% schema %}
{
    "name": "t:sections.n_our-story-proven-results-slider.name",
    "settings": [
        {
            "type": "checkbox",
            "id": "use_own_file",
            "label": "t:common.use-own-file",
            "default": false
        },
        {
            "type": "richtext",
            "id": "heading",
            "label": "t:common.header"
        }
    ],
    "blocks": [
        {
            "type": "slide",
            "name": "t:sections.n_our-story-proven-results-slider.blocks.slide.name",
            "settings": [
                {
                    "type": "image_picker",
                    "id": "image",
                    "label": "t:common.image"
                },
                {
                    "type": "range",
                    "id": "percent_value",
                    "label": "t:common.percent-value",
                    "min": 0,
                    "max": 100,
                    "step": 1,
                    "unit": "%",
                    "default": 70
                },
                {
                    "type": "text",
                    "id": "caption",
                    "label": "t:common.text"
                },
                {
                    "type": "image_picker",
                    "id": "product_image",
                    "label": "t:common.product-image"
                },
                {
                    "type": "text",
                    "id": "product_title",
                    "label": "t:common.product-title"
                },
                {
                    "type": "url",
                    "id": "product_url",
                    "label": "t:common.product-url"
                }
            ]
        }
    ]
}
{% endschema %}
