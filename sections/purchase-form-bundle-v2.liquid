{% doc %}
  Renders a purchase form bundle v2 section.
{% enddoc %}

{% include 'assoc-array', section: section, __parent_title: 'type', __separator: '###' %}

<link rel="stylesheet" href="https://qureskincaredns.com/sections/global/purchase-form-bundle/purchase-form-bundle.css">
<link rel="stylesheet" href="https://qureskincaredns.com/sections/new/text-section/text-section.css" />
<link rel="stylesheet" href="https://qureskincaredns.com/alex/sections/isolated/offer-bundle/offer-bundle.css">

<div id="purchase-form-bundle" class="offer_bundle qure__section {{ section.id }}" 
    style="--section-padding-top: 40px;--section-padding-bottom: 80px;--section-padding-top-mob: 30px;--section-padding-bottom-mob: 50px;">
    <div class="container">
        {% if section.settings.heading != blank %}
            <section class="text-section">
                <div class="container">
                    <article>
                        <h2>{{ section.settings.heading }}</h2>
                    </article>
                </div>
            </section>
        {% endif %}
        {% render 'purchase-form-bundle-types' section: section, __idsArray1: __idsArray1, __idsArray2: __idsArray2, __idsArray3: __idsArray3 %}
        {% include 'purchase-form-bundle-v2-products' section: section, __idsArray1: __idsArray1, __idsArray2: __idsArray2, __idsArray3: __idsArray3 %}
    </div>
</div>

<script src="https://qureskincaredns.com/shopify/js/purchase-form-bundle.js" data-form="{{ section.settings.form_name }}" data-section="{{ section.id }}" defer></script>

{%- schema -%}
{
    "name":"t:sections.purchase-form-bundle.name",
    "class":"purchase-form-bundle",
    "settings":[
        {
            "type": "text",
            "id": "heading",
            "label": "t:common.header"
        },
        {
            "type": "text",
            "id": "text",
            "label": "t:common.text"
        },
        {
            "type": "checkbox",
            "id": "hide_types",
            "label": "t:sections.purchase-form-bundle.settings.hide_types",
            "default": false
        },
        {
            "type": "text",
            "id": "form_name",
            "label": "t:sections.purchase-form-bundle.settings.form_name",
            "default": "purchase-form-bundle"
        }
    ],
    "blocks":[
        {
            "type": "type",
            "limit": 3,
            "name": "t:common.type",
            "settings": [
                {
                    "type": "header",
                    "content": "TYPE"
                }
            ]
        },
        {
            "type": "product_type",
            "name": "t:common.product-type",
            "limit": 3,
            "settings": [
                {
                    "type": "text",
                    "id": "heading",
                    "label": "t:common.header"
                },
                {
                    "type": "image_picker",
                    "id": "image",
                    "label": "t:common.image"
                },
                {
                    "type": "checkbox",
                    "id": "preselected",
                    "label": "t:common.preselect",
                    "default": false
                }
            ]
        },
        {
            "type": "product",
            "name": "t:common.product",
            "settings": [
                {
                    "type": "product",
                    "id": "product",
                    "label": "t:common.product"
                },
                {
                    "type": "image_picker",
                    "id": "image",
                    "label": "t:common.image"
                },
                {
                    "type": "checkbox",
                    "id": "preselected",
                    "label": "t:common.preselect",
                    "default": false
                },
                {
                    "type": "checkbox",
                    "id": "soldout",
                    "label": "t:common.soldout",
                    "default": false
                },
                {
                    "type": "checkbox",
                    "id": "reserved",
                    "label": "t:common.reserved",
                    "default": false
                }
            ]
        },
    ],
    "presets":[
        {
            "name":"t:sections.purchase-form-bundle.name"
        }
    ]
}
{%- endschema -%}