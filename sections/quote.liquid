{% doc %}
  Renders a quote section
{% enddoc %}


<div class="qure__section bg-light">
    <div class="container container-small" style="--container-width:850px">
        <div class="quote__block text-center">
            {% if section.settings.heading != blank %}
                <h3 class="quote__heading">{{ section.settings.heading }}</h3>
            {% endif %}
        <div class="quote__content pt-25 pt-md-45">
            {% if section.settings.text != blank %}
                <div class="quote__desc">{{ section.settings.text }}</div>
            {% endif %}
            {% if section.settings.image != blank %}
                <div class="quote__logo mt-15"><img src="{{ section.settings.image | image_url }}" alt="{{ section.settings.image.alt | escape }}" /></div>
            {% endif %}
        </div>
        </div>
    </div>
</div>
{% schema %}
{
    "name": "t:sections.quote.name",
        "settings": [
    {
        "type": "text",
        "id": "heading",
        "label": "t:common.header"
    },
    {
        "type": "text",
        "id": "text",
        "label": "t:common.text"
    },
    {
        "type": "image_picker",
        "id": "image",
        "label": "t:common.image"
    }
  ],
  "presets": [
    {
      "name": "t:sections.quote.name"
    }
  ]
}
{% endschema %}