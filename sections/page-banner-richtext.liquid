{% doc %}
  Renders a page banner with richtext section 
{% enddoc %}

<link rel="stylesheet" href="https://qureskincaredns-main.com/sections/isolated/page-banner/page-banner.css" />
<div class="page__banner position-relative">
    <picture>
        {% if section.settings.image != blank %}
            <source media="(min-width:1920px)" srcset="{{ section.settings.image | image_url }}" class="img-fluid" width="1440" height="557">
            <source media="(min-width:1600px)" srcset="{{ section.settings.image | image_url }}" class="img-fluid" width="1440" height="557">
            <source media="(min-width:1100px)" srcset="{{ section.settings.image | image_url }}" class="img-fluid" width="1440" height="557">
            <source media="(min-width:720px)" srcset="{{ section.settings.image | image_url }}" class="img-fluid" width="1440" height="557">
        {% endif %}
        {% if section.settings.image_mobile %}
            <source media="(min-width:540px)"  srcset="{{ section.settings.image_mobile | image_url }}" class="img-fluid" width="1440" height="557">
            <img src="{{ section.settings.image_mobile | image_url }}" width="225" height="281" alt="{{ section.settings.image_mobile.alt | escape }}" class="img-fluid w-100">
        {% endif %}
    </picture>
    <div class="page__banner-wrapper position-absolute d-flex align-items-end align-items-lg-center justify-content-end top-0 bottom-0 start-0 end-0 pb-20">
        <div class="container">
            <div class="d-flex justify-content-lg-end ctm_cls_content_wrapper">
                <div class="ctm_cls_title_wrapper">
                    {% if section.settings.heading != blank %}
                        <h1 class="page-banner-title">{{ section.settings.heading }}</h1>
                    {% endif %}
                    <div class="d-md-block d-none">
                        {% if section.settings.sub_heading != blank %}
                            <div class="fs-16 fw-600 pt-15 mb-1">{{ section.settings.sub_heading }}</div>
                        {% endif %}
                        {% if section.settings.text != blank %}
                             <div class="fs-16">{{ section.settings.text }}</div>
                        {% endif %}
                    </div>
                    <div class="d-md-none text-white">
                        {% if section.settings.sub_heading != blank %}
                            <div class="fs-16 fw-600 pt-15">{{ section.settings.sub_heading }}</div>
                        {% endif %}
                        {% if section.settings.text != blank %}
                            <div class="fs-16 fw-400">{{ section.settings.text }}</div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{% schema %}
{
  "name": "t:sections.page-banner-richtext.name",
  "settings": [
    {
        "type": "text",
        "id": "heading",
        "label": "t:common.header"
    },
    {
        "type": "text",
        "id": "sub_heading",
        "label": "t:common.subheader"
    },
    {
        "type": "text",
        "id": "text",
        "label": "t:common.text"
    },
    {
        "type": "image_picker",
        "id": "image",
        "label": "t:common.image"
    },
    {
        "type": "image_picker",
        "id": "image_mobile",
        "label": "t:common.image-mobile"
    }
  ],
  "presets": [
    {
        "name": "t:sections.page-banner-richtext.name"
    }
  ]
}
{% endschema %}