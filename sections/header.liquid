<link rel="stylesheet" href="{{ 'header.css' | asset_url }}">
<header class="page-header" id="page-header">
   <div class="container">
      <div class="d-flex align-items-center">
         <div class="col-header-left mb-col-3 d-flex justify-content-start align-items-center">
            <div data-action="toggle-nav" class="nav-toggle sticky-toggle d-block d-lg-none">
               <div class="toggle-line"></div>
               <div class="toggle-line"></div>
               <div class="toggle-line"></div>
            </div>
            {% render 'header-menu-desktop' %}
            {% render 'header-menu-mobile' %}
         </div>
         <div class="col-header-center mb-col-6">
            <div class="header__logo logo-center">
               <a class="logo-img d-block" href="{{ shop.url }}" title="logo">
                  <img src="https://qureskincaredns.com/assets/images/logo.svg" alt="logo" />
               </a>
            </div>
         </div>
         <div class="col-header-right mb-col-3 d-flex justify-content-end align-items-center">
            <nav class="navigation main-nav qure-mb-menu d-none d-lg-block">
               <ul class="horizontal-list horizontal-list-right">
                  <li class="level0 quer__menu-parent menu-width-full-width">
                        <a class="position-relative" role="link"><span>{{ 'header.settings.navigation_header_4' | t }}</span></a>
                        <div class="submenu position-absolute">
                           <div class="container">
                              <div class="row">
                                    <div class="quer-menu-item type_link col-sm-3">
                                       <div class="quer-menu-inner">
                                          <div class="quer-menu-block">
                                                <ul class="subchildmenu sub-column">
                                                   {% render 'header-menu-items' label: 'Learn More' %}
                                                </ul>
                                          </div>
                                       </div>
                                    </div>
                                    <div class="quer-menu-item type_banner col-sm-8 offset-sm-1">
                                       <div class="quer-menu-banner">
                                          {% render 'header-menu-desktop-pages-item', title: settings.header_learn_more_menu1_title, image: settings.header_learn_more_menu1_image, url: settings.header_learn_more_menu1_url %}
                                          {% render 'header-menu-desktop-pages-item', title: settings.header_learn_more_menu2_title, image: settings.header_learn_more_menu2_image, url: settings.header_learn_more_menu2_url %}
                                       </div>
                                    </div>
                              </div>
                           </div>
                        </div>
                  </li>
               </ul>
            </nav>
            <div class="header_gift header-item">
               <button class="btn-reset header__icon" aria-label="gift" onclick="window.location = '{{ shop.url }}/pages/loyalty-program'">
                  <svg width="92" height="92" viewBox="0 0 92 92" fill="none" xmlns="http://www.w3.org/2000/svg">
                     <path
                        d="M83.8869 27.0569H8.11099C5.49538 27.0569 3.375 29.1772 3.375 31.7929V41.2649C3.375 43.8805 5.49538 46.0008 8.11099 46.0008H83.8869C86.5025 46.0008 88.6229 43.8805 88.6229 41.2649V31.7929C88.6229 29.1772 86.5025 27.0569 83.8869 27.0569Z"
                        stroke="currentColor" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" />
                     <path d="M46 27.0569V88.6248" stroke="currentColor" stroke-width="5" stroke-linecap="round"
                        stroke-linejoin="round" />
                     <path
                        d="M79.1526 46.0012V79.1532C79.1526 81.6653 78.1546 84.0745 76.3783 85.8509C74.6019 87.6272 72.1927 88.6251 69.6806 88.6251H22.3206C19.8085 88.6251 17.3993 87.6272 15.6229 85.8509C13.8466 84.0745 12.8486 81.6653 12.8486 79.1532V46.0012"
                        stroke="currentColor" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" />
                     <path
                        d="M24.6886 27.057C21.5485 27.057 18.5369 25.8096 16.3165 23.5892C14.0961 21.3688 12.8486 18.3572 12.8486 15.2171C12.8486 12.0769 14.0961 9.06535 16.3165 6.84492C18.5369 4.62449 21.5485 3.37707 24.6886 3.37707C29.2574 3.29747 33.7345 5.51423 37.5361 9.73827C41.3378 13.9623 44.2875 19.9976 46.0006 27.057C47.7137 19.9976 50.6634 13.9623 54.4651 9.73827C58.2667 5.51423 62.7438 3.29747 67.3126 3.37707C70.4527 3.37707 73.4643 4.62449 75.6847 6.84492C77.9051 9.06535 79.1526 12.0769 79.1526 15.2171C79.1526 18.3572 77.9051 21.3688 75.6847 23.5892C73.4643 25.8096 70.4527 27.057 67.3126 27.057"
                        stroke="currentColor" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
               </button>
            </div>
            <div class="header_account header-item d-none d-lg-block">
               <button class="btn-reset header__icon" aria-label="account" onclick="window.location = '{{ shop.url }}/account/login'">
                  <svg width="106" height="106" viewBox="0 0 106 106" fill="none" xmlns="http://www.w3.org/2000/svg">
                     <path
                        d="M83.2259 93.3001C83.2259 85.284 80.0415 77.5961 74.3732 71.9278C68.7049 66.2595 61.017 63.0751 53.0009 63.0751C44.9847 63.0751 37.2969 66.2595 31.6286 71.9278C25.9603 77.5961 22.7759 85.284 22.7759 93.3001"
                        stroke="currentColor" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" />
                     <path
                        d="M52.9991 63.0751C64.1277 63.0751 73.1491 54.0536 73.1491 42.9251C73.1491 31.7965 64.1277 22.7751 52.9991 22.7751C41.8706 22.7751 32.8491 31.7965 32.8491 42.9251C32.8491 54.0536 41.8706 63.0751 52.9991 63.0751Z"
                        stroke="currentColor" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" />
                     <path
                        d="M53 103.375C80.8213 103.375 103.375 80.8213 103.375 53C103.375 25.1787 80.8213 2.625 53 2.625C25.1787 2.625 2.625 25.1787 2.625 53C2.625 80.8213 25.1787 103.375 53 103.375Z"
                        stroke="currentColor" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
               </button>
            </div>
            <div class="header_cart header-item ">
               <a data-bs-toggle="offcanvas" id="cartCanvasBtn" href="#cartCanvas" role="button"
                  aria-controls="cartCanvas" class="btn-reset header__icon position-relative" aria-label="cart">
                  <div class="cart-count h-count">{{ cart.item_count }}</div>
                  <svg width="80" height="102" viewBox="0 0 80 102" fill="none" xmlns="http://www.w3.org/2000/svg">
                     <path
                        d="M69.3909 24.0904H10.0019C9.09056 24.0821 8.20946 24.5762 7.52866 25.4771C6.84785 26.3781 6.41563 27.622 6.31539 28.9689L3.40314 93.9534C3.38777 94.6793 3.4726 95.4021 3.6524 96.0778C3.83226 96.753 4.10323 97.3664 4.44865 97.8803C4.79408 98.3937 5.20667 98.7966 5.66088 99.0642C6.1151 99.3317 6.60134 99.4576 7.0896 99.4348H72.9117C73.8894 99.4348 74.8274 98.8574 75.5186 97.829C76.2098 96.8012 76.5985 95.4069 76.5985 93.9534L73.0776 28.9142C72.9691 27.5771 72.5328 26.3464 71.8531 25.4567C71.1734 24.567 70.2968 24.0806 69.3909 24.0904Z"
                        stroke="currentColor" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" />
                     <path
                        d="M20.623 41.3138V21.0155C20.623 16.1214 22.6644 11.4279 26.2981 7.96725C29.9317 4.50663 34.8599 2.5625 39.9987 2.5625C45.1374 2.5625 50.0657 4.50663 53.6994 7.96725C57.3333 11.4279 59.3741 16.1214 59.3741 21.0155V41.3138"
                        stroke="currentColor" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
               </a>
            </div>
         </div>
      </div>
   </div>
</header>



<script>
    document.addEventListener("DOMContentLoaded", function () {
      loadScriptOnce('carousel', 'https://qureskincaredns.com/sections/global/header/js/carousel.js');
      loadScriptOnce('slider-with-thumb', 'https://qureskincaredns.com/assets/js/slider-with-thumb.js');
      {% if settings.header_scrolling_hide == true %}
      loadScriptOnce('header', 'https://qureskincaredns.com/shopify/js/header.js')
      {% endif %}
    });
</script>