{%  schema  %}
{
  "name": "t:sections.n_hair-growth-helmet-product-comparison.name",
  "settings": [
    {
        "type": "checkbox",
        "id": "use_own_file",
        "label": "t:common.use-own-file",
        "default": false
    },
    {
        "type": "text",
        "id": "heading",
        "label": "t:common.header"
    }
  ],
  "blocks": [
    {
        "type": "heading_prof",
        "name": "t:sections.n_hair-growth-helmet-product-comparison.blocks.header-prof.name",
        "limit": 1,
        "settings": [
            {
                "type": "image_picker",
                "id": "left_image",
                "label": "t:common.left-image"
            },
            {
                "type": "richtext",
                "id": "left_heading",
                "label": "t:common.left-header"
            },
            {
                "type": "image_picker",
                "id": "right_image",
                "label": "t:common.right-image"
            },
            {
                "type": "richtext",
                "id": "right_heading",
                "label": "t:common.right-header"
            }
        ]
    },
    {
        "type": "heading_hair_growth",
        "name": "t:sections.n_hair-growth-helmet-product-comparison.blocks.header-hair-growth.name",
        "limit": 1,
        "settings": [
            {
                "type": "image_picker",
                "id": "left_image",
                "label": "t:common.left-image"
            },
            {
                "type": "richtext",
                "id": "left_heading",
                "label": "t:common.left-header"
            },
            {
                "type": "image_picker",
                "id": "right_image",
                "label": "t:common.right-image"
            },
            {
                "type": "richtext",
                "id": "right_heading",
                "label": "t:common.right-header"
            }
        ]
    },
    {
        "type": "heading_red_light_hat",
        "name": "t:sections.n_hair-growth-helmet-product-comparison.blocks.header-red-light-hat.name",
        "limit": 1,
        "settings": [
            {
                "type": "image_picker",
                "id": "left_image",
                "label": "t:common.left-image"
            },
            {
                "type": "richtext",
                "id": "left_heading",
                "label": "t:common.left-header"
