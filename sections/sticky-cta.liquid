{% doc %}
  Renders a sticky CTA section. 
{% enddoc %}


<link rel="stylesheet" href="https://qureskincaredns-main.com/sections/isolated/sticky-cta/sticky-cta.css" />
   <div class="qure__sticky-atc">
        <div class="container">
            <div class="d-flex flex-wrap justify-content-between align-items-center py-16">
                {% if section.settings.heading != blank %}
                <h3 class="fs-20 m-0 d-none d-md-block">{{ section.settings.heading }}</h3>
                {% endif %}
                {% if section.settings.button_url != blank and section.settings.button_label != blank %}
                <a href="{{ section.settings.button_url }}" class="btn btn--primary">{{ section.settings.button_label }}</a>
                {% endif %}
            </div>
        </div>
        <div
         class="align-items-center bg-light d-flex fs-16 gap-4 justify-content-center py-6 qure__user-online text-center">
         {% if section.settings.text != blank %}
            <div class="pulse"></div>{{ section.settings.text }}
         {% endif %}
        </div>
   </div>


{%  schema  %}  
{
  "name": "t:sections.sticky-cta.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:common.header",
      "default": "Q-Rejuvalight Pro LED Mask"
    },
    {
      "type": "text",
      "id": "text",
      "label": "t:common.text"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:common.button-label",
      "default": "Buy Now"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "t:common.button-url"
    }
  ],
  "presets": [
    {
      "name": "t:sections.sticky-cta.name"
    }
  ]
}
{% endschema %}