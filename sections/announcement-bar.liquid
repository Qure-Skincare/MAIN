{% doc %}
  Renders an announcement bar section
{% enddoc %}

<!-- Announcement Bar -->
<link rel="stylesheet" href="https://qureskincaredns.com/sections/isolated/announcement/announcement-bar.css" />
<div id="announcement-bar" class="announcement-bar" style="--ans-bar-font-size:16px; --anc-bar-font-weight :400;{% if section.settings.show != blank %}visibility:visible{% endif %}">
   <div class="container">
        {% if section.settings.heading != blank %}
            <div class="announcement-bar-content text-center">
                {{ section.settings.heading }} {% if section.settings.button-label != blank %}<a href="{{ section.settings.button-url }}">{{ section.settings.button-label }}</a>{% endif %}
            </div>
        {% endif %}
   </div>
</div>

{% schema %}
{
  "name": "t:sections.announcement-bar.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:common.header"
    },
    {
      "type": "text",
      "id": "button-label",
      "label": "t:common.button-label"
    },
    {
      "type": "text",
      "id": "button-url",
      "label": "t:common.button-url"
    },
    {
      "type": "checkbox",
      "id": "show",
      "label": "t:common.show",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "t:sections.announcement-bar.name"
    }
  ]
}
{% endschema %}