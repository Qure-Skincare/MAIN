{% doc %}
  Renders a video review slider section
{% enddoc %}


<div id="video-review-slider" class="review_videos qure__section color-background"
    style="--section-padding-top: 80px; --section-padding-bottom: 80px; --section-background: {{ section.settings.background_color | default: '#F6F6F7' }}; --section-padding-top-mob: 50px; --section-padding-bottom-mob: 50px;">
    <div class="container">
        <div class="qure__section-header text-center">
            {% if section.settings.heading != blank %}
                <h2 class="qure__section-heading">{{ section.settings.heading }}</h2>
            {% endif %}
        </div>
        <div class="swiper qure__swiper" id="qure__swiper-video-slider" data-section-id="video-slider"
            data-autoplay="false" data-loop="false" data-mobile="1.3" data-tablet="3" data-desktop="4" data-spacing="32"
            data-pagination-fraction="true">
            <div class="swiper-wrapper">
                {% for block in section.blocks %}
                    {% if block.type == 'slider' %}
                        {% if block.settings.youtube_url != blank %}
                            <div class="swiper-slide">
                            <div class="play_btn">
                                <a class="popup-youtube lvideo" data-url="{{ block.settings.youtube_url }}">
                                    <span class="justify-content-center">
                                        {% if block.settings.video_cover_image != blank %}
                                            <img src="{{ block.settings.video_cover_image | image_url }}" alt="{{ block.settings.video_cover_image.alt | escape }}" class="img-fluid h-100">
                                        {% endif %}
                                    </span>
                                </a>
                            </div>
                        </div>
                        {% endif %}
                        {% if block.settings.wistia_url != blank %}
                            <div class="swiper-slide">
                                <div class="videosQure_exernal">
                                    <div class="wistia_responsive_padding" style="position:relative;">
                                        <div class="wistia_responsive_wrapper"
                                            style="height:100%;left:0;position:absolute;top:0;width:100%;">
                                            <div class="wistia_embed wistia_async_{{ block.settings.wistia_url }} popover=true seo=false videoFoam=true"
                                                style="height:100%;position:relative;width:100%">
                                                <div class="wistia_swatch"
                                                    style="height:100%;left:0;opacity:0;overflow:hidden;position:absolute;top:0;transition:opacity 200ms;width:100%;bottom:0;">
                                                    <img src="https://fast.wistia.com/embed/medias/{{ block.settings.wistia_url }}/swatch" style="filter:blur(5px);height:100%;object-fit:contain;width:100%;" alt="video" aria-hidden="true" onload="this.parentNode.style.opacity=1;" />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endif %}
                    {% endif %}
                {% endfor %}
            </div>
            <div class="swiper-arrows-with-pagination d-flex align-items-center justify-content-center gap-4 mt-30">
                <div class="qure-swiper-button-prev qure-swiper-arrow"><i class="fa-regular fa-angle-left"></i></div>
                <div class="swiper-pagination position-relative bottom-0 w-auto"></div>
                <div class="qure-swiper-button-next qure-swiper-arrow"><i class="fa-regular fa-angle-right"></i></div>
            </div>
        </div>
    </div>
</div>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadScriptOnce('main-slider', 'https://qureskincaredns-main.com/assets/js/main-slider.js');
        loadScriptOnce('youtube-popup', 'https://qureskincaredns-main.com/assets/js/yt-popup.js');
        loadScriptOnce('wistia-script', 'https://fast.wistia.com/assets/external/E-v1.js');
    });
</script>
{% schema %}
{
    "name": "t:sections.video-review-slider.name",
    "settings": [
        {
            "type": "text",
            "id": "heading",
            "label": "t:common.header"
        },
        {
            "type": "color",
            "id": "background_color",
            "label": "t:common.background-color",
            "default": "#F6F6F7"
        }
    ],
    "blocks": [
        {
            "type": "slider",
            "name": "t:common.slider",
            "settings": [
                {
                    "type": "url",
                    "id": "youtube_url",
                    "label": "t:common.youtube-url"
                },
                {
                    "type": "image_picker",
                    "id": "video_cover_image",
                    "label": "t:common.video-image-cover"
                },
                {
                    "type": "text",
                    "id": "wistia_url",
                    "label": "t:common.wistia-url"
                }
    ]
    }
],
"presets": [
    {
        "name": "t:sections.video-review-slider.name"
    }
]
}
{% endschema %}