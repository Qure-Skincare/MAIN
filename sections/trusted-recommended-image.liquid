{% doc %}
  Renders a trusted recommended image section
{% enddoc %}
<div class="trusted_recom qure__section"
    style="--section-padding-top: 80px; --section-padding-bottom: 80px; --section-padding-top-mob: 50px; --section-padding-bottom-mob: 10px;">
    <div class="container" style="--column-gap:35px; --column-gap-mobile:18px;">
        <h2 class="qure__section-heading d-md-none mb-3 text-center">Trusted and Recommended by Experts</h2>
        <div class="row align-items-center custom__grid">
            <div class="col-lg-8 custom__block order-1 order-md-0">
                <div class="trusted_left mw-680">
                    <div class="section_header py-0 mw-100">
                        <div class="trusted_verified d-none d-md-flex">
                            <img src="{{ 'sections.trusted-recommended-image.tick_image' | t }}" alt="{{ 'sections.trusted-recommended-image.tick_image.alt' | escape }}">
                            <p class="p-0">{{ 'sections.trusted-recommended-image.text' | t }}</p>
                        </div>
                        <div class="qure__section-header text-md-start text-center mb-30">
                            {% if section.settings.heading != blank %}
                                 <h2 class="qure__section-heading text-md-start pb-20 d-none d-md-block">{{section.settings.heading }}</h2>
                            {% endif %}
                            {% if section.settings.text != blank %}
                                {{ section.settings.text | replace: '<strong>', '<span style="background:#C7E5DB">' | replace: '</strong>', '</span>'}}
                            {% endif %}
                        </div>
                        <div class="trusted_verified d-md-none d-flex mt-3">
                            <img src="{{ 'sections.trusted-recommended-image.tick_image_mobile' | t }}" alt="{{ 'sections.trusted-recommended-image.tick_image_mobile.alt' | escape }}">
                            <p class="p-0">{{ 'sections.trusted-recommended-image.text' | t }}</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 custom__block">
                <div class="dr_img my-3 trusted-experts rounded-10 overflow-hidden d-block">
                    {% if section.settings.image != blank %}
                        <img src="{{ section.settings.image | image_url }}" class="img-fluid d-md-block d-none" alt="{{ section.settings.image.alt | escape }}">
                    {% endif %}
                    {% if section.settings.image_mobile != blank %}
                        <img src="{{ section.settings.image_mobile | image_url }}" class="img-fluid d-md-none" alt="{{ section.settings.image_mobile.alt | escape }}">
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% schema %}
{
"name": "t:sections.trusted-recommended-image.name",
"settings": [
    {
        "type": "text",
        "id": "heading",
        "label": "t:common.header",
        "default": "Trusted and Recommended by Experts"
    },
    {
        "type": "richtext",
        "id": "text",
        "label": "t:common.text"
    },
    {
        "type": "image_picker",
        "id": "image",
        "label": "t:common.image"
    },
    {
        "type": "image_picker",
        "id": "image_mobile",
        "label": "t:common.image-mobile"
    },
],
"presets": [
    {
      "name": "t:sections.trusted-recommended-image.name"
    }
]
}
{% endschema %}