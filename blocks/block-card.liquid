{% doc %}
  Renders a block card.

  @example
  {% content_for 'block', type: 'block-card', id: 'block-card' %}
{% enddoc %}


<!-- Block card with text -->
<link href="https://qureskincaredns.com/sections/isolated/block-card/block-card.css" rel="stylesheet" type="text/css">
<div class="qure__section" style="--section-padding-top:80px; --section-padding-bottom:80px;">
    <div class="container" style="--column-gap:100px; --column-gap-mobile:32px;">
        <div class="row custom__grid align-items-center">
            <div class="custom__block col-lg-6">
                <div class="text-center text-md-start">
                    {% if block.settings.heading != blank %}
                        <h2 class="mb-lg-20">{{ block.settings.heading }}</h2>
                    {% endif %}
                    {% if block.settings.text != blank %}
                        <p class="d-none d-lg-block">{{ block.settings.text }}</p>
                    {% endif %}
                    {% if block.settings.button-label != blank %}
                        <a href="{{ block.settings.button-url }}" class="d-none d-md-inline-block btn btn--primary mt-20">{{ block.settings.button-label }}</a>
                    {% endif %}
                </div>
            </div>
            <div class="custom__block col-lg-6">
                <div class="block-card__container">
                    {% content_for 'blocks' %}
                </div>
                {% if block.settings.button-label != blank %}
                    <div class="text-center">
                        <a href="{{ block.settings.button-url }}" class="d-inline-block d-md-none btn btn--primary mt-30">{{ block.settings.button-label }}</a>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
<!-- Block card with text -->

{% schema %}
{
  "name": "t:blocks.block-card.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:common.header"
    },
    {
      "type": "text",
      "id": "text",
      "label": "t:common.text"
    },
    {
      "type": "text",
      "id": "button-label",
      "label": "t:common.button-label"
    },
    {
      "type": "text",
      "id": "button-url",
      "label": "t:common.button-url"
    }
  ],
  "blocks": [
    {
        "type": "_block-card-item"
    }
  ],
  "presets": [
    {
      "name": "t:blocks.block-card.name",
      "settings": {
        "heading": "Learn more and share your skincare journey",
        "text": "Achieve your best skin yet with our simple 3-step skincare routine.",
        "button-label": "Join Our Community",
        "button-url": "https://m.facebook.com/groups/140594262121805/?ref=d6cb54b2-d73b-423e-8d66-3b5b3a661340"
      }
    }
  ]
}
{% endschema %}