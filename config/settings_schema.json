  {
    "name": "Endrock Gamification Settings",
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_gamification",
        "label": "Enable Gamification",
        "default": false,
        "info": "Enable or disable the gamification feature."
      },
      { 
        "type": "textarea", 
        "id": "gamification_exception", 
        "label": "Exception" 
      },
      {
        "type": "header",
        "content": "A. Gamification Event Texts"
      },
      {
        "type": "html",
        "id": "gamification_info_sidecart",
        "label": "Default Header Text. Use {{ add_more }} as a placeholder for the dynamic amount.",
        "default": "{{ add_more }} to Unlock:"
      },
      {
        "type": "html",
        "id": "gamification_info_sidecart_completed",
        "label": "Completed Header Text",
        "default": "You've unlocked:",
        "info": "Text displayed when the gamification level is complete."
      },

      {
        "type": "html",
        "id": "gamification_info_homepage",
        "label": "Default Header Text. Use {{ add_more }} as a placeholder for the dynamic amount and {{ milestone_name }} for the milestone name.",
        "default": "You’re {{ add_more }} away from {{ milestone_name }}:"
      },
      {
        "type": "html",
        "id": "gamification_info_homepage_completed",
        "label": "Completed Header Text. Use {{ gift_name }} as a placeholder for the unlocked gift name.",
        "default": "Congrats! You've unlocked your {{ gift_name }}:",
        "info": "Text displayed when the gamification level is complete."
      },

      {
        "type": "header",
        "content": "B. Event Scheduling & Timer (Global)"
      },

      {
        "type": "text",
        "id": "event_name",
        "label": "Event Name",
        "placeholder": "Black Friday",
        "default": "Black Friday",
        "info": "The name of the gamification event."
      },

      {
        "type": "text",
        "id": "event_start_date",
        "label": "Timer Start Date",
        "placeholder": "2025-10-20",
        "default": "2025-10-21",
        "info": "The date from which the timer duration is calculated. Format: YYYY-MM-DD"
      },
      {
        "type": "range",
        "id": "event_start_time_hour",
        "label": "Timer Start Time - Hour (24h format)",
        "default": 0,
        "min": 0,
        "max": 23,
        "step": 1,
        "info": "The hour of the day when the timer starts (0-23)."
      },
      {
        "type": "range",
        "id": "event_start_time_minute",
        "label": "Timer Start Time - Minute",
        "default": 0,
        "min": 0,
        "max": 59,
        "step": 1,
        "info": "The minute of the hour when the timer starts (0-59)."
      },

      {
        "type": "text",
        "id": "event_end_date",
        "label": "Timer End Date",
        "placeholder": "2025-11-05",
        "default": "2025-11-03",
        "info": "The date when the timer ends. Format: YYYY-MM-DD"
      },
      {
        "type": "range",
        "id": "event_end_time_hour",
        "label": "Timer End Time - Hour (24h format)",
        "default": 23,
        "min": 0,
        "max": 23,
        "step": 1,
        "info": "The hour of the day when the timer ends (0-23)."
      },
      {
        "type": "range",
        "id": "event_end_time_minute",
        "label": "Timer End Time - Minute",
        "default": 59,
        "min": 0,
        "max": 59,
        "step": 1,
        "info": "The minute of the hour when the timer ends (0-59)."
      }
      
    ]
  },
