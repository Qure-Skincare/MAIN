{% capture preorder_box %}
    {% render 'product-page-next-ships', section: section, block: blank, class: 'hide preorder_box' %}
{% endcapture %}

<div class="qure__bundle-steps">
    <div class="qure-bundle-stps-title mb-16">{{ 'purchase-form.settings.select-product' | t }}</div>
        {% case section.settings.type %}
            {% when 'box' %}
                {% include 'purchase-form-products-item' array: __idsArray1, preorder_box: preorder_box %}
                {% include 'purchase-form-products-item' array: __idsArray2, preorder_box: preorder_box %}
                {% include 'purchase-form-products-item' array: __idsArray3, preorder_box: preorder_box %}
            {% when 'list' %}
                {% include 'purchase-form-products-type_list-item' array: __idsArray1, preorder_box: preorder_box %}
                {% include 'purchase-form-products-type_list-item' array: __idsArray2, preorder_box: preorder_box %}
                {% include 'purchase-form-products-type_list-item' array: __idsArray3, preorder_box: preorder_box %}
            {% when 'list_bf26' %}
                {% include 'purchase-form-products-type_list_bf26-item' array: __idsArray1, preorder_box: preorder_box %}
                {% include 'purchase-form-products-type_list_bf26-item' array: __idsArray2, preorder_box: preorder_box %}
                {% include 'purchase-form-products-type_list_bf26-item' array: __idsArray3, preorder_box: preorder_box %}
        {% endcase %}
     <div id="{{ section.settings.form_name }}-body-{{ section.id }}"></div>
</div> 