{% doc %}
  Renders a "Next Ships" snippet for the product-header/page-header section

  @param {object} - A section object.
  @param {string} - A class value.

  @example
  {% render 'n-product-page-next-ships', section: '', class: '' %}
{% enddoc %}

{% if block == blank %}
    {% for _block in section.blocks %}
        {% if _block.type == 'nextships' %}
            {% assign block = _block %}
        {% endif %}
    {% endfor %}
{% endif %}

<div class="c-next-batch {{ class }}">
    <p class="preorder_text">
        {{ 'product.settings.product-next-ships.header' | t }} {{ block.settings.date }}:<br />
        {{ 'product.settings.product-next-ships.text' | t: product_title: 'product' }}
    </p>
    <ul>
        {% if block.settings.date_soldout != blank %}
            <li>
                <span class="preorder_date_soldout">{{ block.settings.date_soldout }}</span>
                <span>{{ 'product.settings.product-next-ships.soldout' | t }}</span>
            </li>
        {% endif %}
        {% if block.settings.date_reserved != blank %}
            <li class="preorder_percent_style" style="--data-reserved: {{ block.settings.percent }}%">
                <span class="preorder_date_reserved">{{ block.settings.date_reserved }}</span>
                <span><span class="preorder_percent">{{ block.settings.percent }}</span>% {{ 'product.settings.product-next-ships.reserved' | t }}</span>
            </li> 
        {% endif %}
    </ul>
</div>