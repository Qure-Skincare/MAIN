{% doc %}
  Renders a buy button for the `n_product-you-may-also-like` product tile.
  Mirrors `product-page-buy-button` (label / reserved / soldout handling)
  without any Black Friday branches. The click is handled by the shared
  `.js-add-bundle` listener from `assets/n_add-bundle.js`, matching the
  pattern used in `n_page-microinfusion-complete-system`.

  @param {string}  product_variant_id - Selected variant ID
  @param {boolean} product_available  - Whether the product is available
  @param {object}  section            - Optional section scope for label / state overrides
{% enddoc %}

{% assign reserved = null %}
{% assign soldout = null %}

{% assign default_button_label = 'product.settings.buy-button-label' | t %}

{% if section.settings.button_label != blank %}
  {% assign default_button_label = section.settings.button_label %}
{% endif %}

{% assign button_label_text = default_button_label %}

{% if product_available == false %}
  {% assign soldout = true %}
{% endif %}

{% if section != blank %}
  {% if section.settings.reserved != blank %}
    {% assign reserved = true %}
  {% endif %}
  {% if section.settings.soldout != blank %}
    {% assign soldout = true %}
  {% endif %}
{% endif %}

{% if reserved == true %}
  {% assign button_label_text = 'product.settings.reserved-button-label' | t %}
{% endif %}

{% if soldout == true %}
  {% assign button_label_text = 'product.settings.soldout-button-label' | t %}
{% endif %}

<form class="c-product-tile__button" action="#">
  <button
    type="button"
    class="btn btn--primary js-add-bundle"
    data-cart-items='[{"id":{{ product_variant_id }},"quantity":1}]'
    {% if soldout %}disabled{% endif %}
  >
    {{ button_label_text }}
  </button>
</form>
