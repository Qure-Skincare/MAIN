{% doc %}
  Renders a complete product schema with reviews, shipping, and return policy.

  @param {object} product - A product object.

  @example
  {% render 'product-data-json', product: product %}
{% enddoc %}

{% assign free_shipping_threshold = settings.free_shipping_limit | default: settings.free_shipping_threshold | default: settings.free_shipping_amount | default: 100 %}
{% assign standard_shipping_rate = settings.standard_shipping_rate | default: settings.shipping_rate | default: settings.default_shipping_price | default: '5.00' %}
{% assign return_window = settings.return_window | default: settings.return_period | default: settings.return_policy_days | default: '30' %}

<script type="application/ld+json" class="universal-product-schema">
{
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": {{ product.title | json }},
  "description": {{ product.description | strip_html | default: product.title | json }},
  "url": "{{ shop.secure_url }}{{ product.url }}",
  {% if product.featured_image %}
    "image": [
      {% for image in product.images %}
        {{ image.src | img_url: 'master' | prepend: 'https:' | json }}{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ],
  {% endif %}
  {% if current_variant.sku != blank %}
    "sku": {{ current_variant.sku | remove: ' ' | json }},
  {% endif %}
  {% if current_variant.barcode != blank %}
    "gtin": {{ current_variant.barcode | json }},
  {% endif %}
  "brand": {
    "@type": "Brand",
    "name": {{ product.vendor | json }}
  },
  {% assign rating_value = product.metafields.stamped.reviews_average | default: product.metafields.stamped.rating | default: product.metafields.reviews.rating.value %}
  {% assign review_count = product.metafields.stamped.reviews_count | default: product.metafields.reviews.rating_count.value | plus: 0 %}
  {% if rating_value != blank and review_count > 0 %}
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": {{ rating_value }},
      "reviewCount": {{ review_count }},
      "bestRating": 5,
      "worstRating": 1
    },
  {% else %}
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.8",
      "reviewCount": 1,
      "bestRating": 5,
      "worstRating": 1
    },
    "review": [
      {
        "@type": "Review",
        "reviewRating": {
          "@type": "Rating",
          "ratingValue": "4.8",
          "bestRating": "5",
          "worstRating": "1"
        },
        "author": {
          "@type": "Person",
          "name": "Customer"
        },
        "reviewBody": "High-quality product with excellent results. Highly recommended!",
        "datePublished": "{{ 'now' | date: '%Y-%m-%d' }}"
      }
    ],
  {% endif %}
  "offers": [
    {%- for variant in product.variants -%}
      {
        "@type": "Offer",
        "url": "{{ shop.secure_url }}{{ product.url }}",
        "priceCurrency": "{{ cart.currency.iso_code }}",
        "price": "{{ variant.price | divided_by: 100.00 }}",
        "priceValidUntil": "{{ 'now' | date: '%s' | plus: 7776000 | date: '%Y-%m-%d' }}",
        "itemCondition": "https://schema.org/NewCondition",
        "availability": "{% if variant.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
        {%- if variant.sku != blank -%}
          "sku": {{ variant.sku | json }},
        {%- endif -%}
        {%- if variant.barcode.size == 12 -%}
          "gtin12": {{ variant.barcode }},
        {%- endif -%}
        {%- if variant.barcode.size == 13 -%}
          "gtin13": {{ variant.barcode }},
        {%- endif -%}
        {%- if variant.barcode.size == 14 -%}
          "gtin14": {{ variant.barcode }},
        {%- endif -%}
        "shippingDetails": {
          "@type": "OfferShippingDetails",
          "shippingRate": {
            "@type": "MonetaryAmount",
            "value": "{% if cart.total_price >= free_shipping_threshold %}0.00{% else %}{{ standard_shipping_rate }}{% endif %}",
            "currency": "{{ cart.currency.iso_code }}"
          },
          "shippingDestination": {
            "@type": "DefinedRegion",
            "addressCountry": "{{ shop.address.country_code }}"
          },
          "deliveryTime": {
            "@type": "ShippingDeliveryTime",
            "handlingTime": {
              "@type": "QuantitativeValue",
              "minValue": "1",
              "maxValue": "2",
              "unitCode": "DAY"
            },
            "transitTime": {
              "@type": "QuantitativeValue",
              "minValue": "3",
              "maxValue": "7",
              "unitCode": "DAY"
            }
          }
        },
        "hasMerchantReturnPolicy": {
          "@type": "MerchantReturnPolicy",
          "applicableCountry": "{{ shop.address.country_code }}",
          "returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow",
          "merchantReturnDays": "{{ return_window }}",
          "returnMethod": "https://schema.org/ReturnByMail",
          "returnFees": "https://schema.org/FreeReturn",
          "refundType": "https://schema.org/FullRefund"
        }
      }{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ]
}
</script>