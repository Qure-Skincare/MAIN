{% doc %}
  Renders the crosssell products snippet for the product-header/page-header section

  @param {object} - A product object.
  @param {object} - A page object.

  @example
  {% include 'n-product-page-cross-sell' product: product, page: page %}
{% enddoc %}

{% assign source = blank %}

{% if product != blank %}
    {% assign source = product.metafields.custom.cross_sell.value %}
{% endif %}

{% if page != blank %}
    {% assign source = page.metafields.custom.cross_sell.value %}
{% endif %}

{% if source != blank %}
    <div class="hero-product__best-with">
        <h6>{{ 'product.settings.cross-sell.header' | t }}</h6>
        <div
            class="c-swiper"
            data-swiper='{
                "slidesPerView": "1.25",
                "spaceBetween": 12,
                "breakpoints": {
                    "992": {
                        "slidesPerView": 2
                    }
                }
            }'>
            <div class="swiper-wrapper">
                {% for item in source %}
                    {% include 'get-product-data', product_handle: item.product.value.handle, product_prefix: 'product-page-cross-sell-' %}
                    <div class="swiper-slide">
                        <img src="{{ product_featured_image | img_url: '240x' }}" alt="{{ product_title | escape }}" />
                        <a href="{{ product_url }}" aria-label="{{ product_handle | escape }}">{{ product_title }}</a>

                        {% if product_available == true %}
                            <form method="post" action="/cart/add" enctype="multipart/form-data">
                            {% if black_friday_discount_percent > 0 %}
                                <button type="submit" class="btn btn--primary btn--sm">{{ 'product.settings.cross-sell.buy-button-label' | t }} - <span class="igPrice">{{ product_black_friday_price }}</span></button>
                            {% else %}
                                <button type="submit" class="btn btn--primary btn--sm">{{ 'product.settings.cross-sell.buy-button-label' | t }} - <span class="igPrice">{{ product_sale_price }}</span></button>
                            {% endif %}
                            <input type="hidden" name="quantity" id="quantity" value="1">
                            <input type="hidden" name="id" value="{{ product_variant_id }}">
                        </form>
                        {%- else -%}
                            <button class="btn btn--primary btn--sm" disabled="true">{{ 'product.settings.cross-sell.soldout-button-label' | t }}</button>
                        {%- endif -%}
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
{% endif %}