{% doc %}
  Renders sections blocks for product-header section

  @param {section} - A section object.
  @param {allowed_types} - A string value.
  @param {render} - A string value.

  @example
  {% render 'n-product-page-blocks-render', section: section, allowed_types: '', render: '' %}
{% enddoc %}

{% if render != blank %}
    {{ render }}
{% endif %}

{% for block in section.blocks %}
    {% case block.type %}
        {% when 'description' %}
            {% render 'n-product-description', description: section.settings.description %}
        {% when 'price' %}
            {% if black_friday_discount_percent > 0 %}
                {% render 'n-product-price-special-offer', product_sale_price: product_sale_price, product_before_price: product_before_price, product_discount: product_discount, product_black_friday_price: product_black_friday_price, black_friday_discount: black_friday_discount %}
            {%- else -%}
                {% render 'n-product-price', product_sale_price: product_sale_price, product_before_price: product_before_price, product_discount: product_discount, section: section, block: block %}
            {%- endif -%}
        {% when 'saveup-offer' %}
            {% render 'n-product-saveup-offer' %}
        {% when 'limited-offer' %}
            {% render 'n-product-limited-time-offer', section: section, block: block %}
        {% when 'black-friday-discount' %}
            {% render 'n-product-page-black-friday-discount', section: section, block: block %}
        {% when 'exclusive-offer' %}
            {% include 'n-product-exclusive-offer', section: section, block: block %}
        {% when 'nextships' %}        
            {% render 'n-product-page-next-ships', section: section %}
        {% when 'button' %}
            {% render 'n-product-page-buy-button', product_price: null, product_variant_id: product_variant_id, product_price_divided: product_price_divided, section: section, product_available: product_available %}
        {% when 'video' %}
            {% render 'n-page-video', section: section, block: block %}
        {% when 'section' %}
            {% render 'n-product-page-async-section', section: section, block: block %}
        {% when 'results' %}
            {% render 'n-product-page-results', section: section, block: block %}
        {% when 'link' %}
            {% render 'n-page-link-button', section: section %}
        {% when 'money-back' %}
            {% render 'n-product-money-back', section: section, block: block %}
        {% endcase %}
{% endfor %}