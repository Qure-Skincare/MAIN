{% doc %}
  Renders a bundle type item snippet for purchase form bundle section.
{% enddoc %}

{% if array != blank %}
    {%- for __id in array -%}
        {% assign block = section.blocks | where: "id", __id | first %}
        {% if block.type == 'product_type' %}
            {% assign product_type_title = block.settings.heading | strip_newlines | strip | replace: ' ', '' | downcase %}
            <li class="nav-item bundle_heading {{ class }}" id="{{ section.id }}-{{ product_type_title }}">
                <input type="radio" style="display:none;" name="bundle_section_{{ section.settings.form_name }}" id="{{ section.id }}-{{ block.id }}" data-name="{{ block.settings.heading | escape }}" {% if block.settings.preselected == true %} checked{% endif %}/>
                <button class="nav-link{% if block.settings.preselected == true %} active{% endif %}">{{ block.settings.heading }}</button>
            </li>
        {% endif %}
    {%- endfor -%}
{% endif %}