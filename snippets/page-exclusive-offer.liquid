{% doc %}
  Renders a page exclusive offer snippet for the page-header section

  @param {object} - A section object.
  @param {object} - A block object.

  @example
  {% render 'page-exclusive-offer', section: '', block: '' %}
{% enddoc %}

{% if block == blank %}
    {% for _block in section.blocks %}
        {% if _block.type == 'exclusive-offer' %}
            {% assign block = _block %}
        {% endif %}
    {% endfor %}
{% endif %}

<div class="d-flex flex-nowrap align-items-center justify-content-center col-gap">
    <div class="icon-with-text d-flex flex-nowrap flex-row align-items-center fs-16 text-center text-lg-start">
        <img src="https://qureskincaredns-main.com/sections/isolated/protect-your-skin/images/one-year-guarantee.svg" alt="dermatologist" class="mr-5">
        <span>{{ 'page.exclusive-offer.guarantee-text' | t }} </span>
    </div>
    <div class="icon-with-text d-flex flex-nowrap flex-row align-items-center fs-16 text-center text-lg-start">
        <img src="https://qureskincaredns-main.com/sections/isolated/protect-your-skin/images/shipping.svg" alt="shipping" class="mr-5">
        <span>{{ 'page.exclusive-offer.shipping-text' | t }}</span>
    </div>
</div>

<div class="qure__exclusive-offer border rounded-10 pt-30 p-24 mt-30 position-relative">
    {{ 'page.exclusive-offer.header_html' | t }}
    <div class="eo-offers">
        <div class="eo-offer-box">
            <input type="radio" id="ledBox" name="offerBox">
            <label for="ndBox" class="position-relative pb-8 pr-8">
                {% if block.settings.image_product1 != blank %}
                    <img src="{{ block.settings.image_product1 | img_url: '250x' }}" alt="{{ block.settings.image_product1.alt | escape }}" />
                {% endif %}
                <span class="offerBox-price">$399</span>
            </label>
        </div>
        <span class="eo-plus"><i class="fa-solid fa-plus"></i></span>
        <div class="eo-offer-box">
            <input type="radio" id="ndBox" name="offerBox" checked>
            <label for="ndBox" class="position-relative pb-8 pr-8">
                {% if block.settings.image_product2 != blank %}
                    <img src="{{ block.settings.image_product1 | img_url: '250x' }}" alt="{{ block.settings.image_product1.alt | escape }}" />
                {% endif %}
                <span class="offerBox-price oldPrice"><span>$299</span><strong>{{ 'page.exclusive-offer.free' | t }}</strong></span>
            </label>
        </div>
    </div>
    {% if block.settings.text != blank %}
        <div class="text-center mt-10">{{ block.settings.text |  replace: '<p>', '' |  replace: '</p>', '' }}</div>
    {% endif %}
</div>