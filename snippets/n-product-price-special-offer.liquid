{% doc %}
  Renders special offer product price

  @param {product_sale_price} - A string value.
  @param {product_before_price} - A string value.
  @param {product_discount} - A string value.
  @param {object} - A section object.
  @param {object} - A block object.

  @example
  {% render 'n-product-price-special-offer', product_sale_price: '', product_before_price: '', product_discount: product_discount, product_black_friday_price: '', black_friday_discount: '' %}
{% enddoc %}

<div class="c-special-offer" data-label="{{ 'special-offer.settings.header' | t }}">
    <div class="e-price">
        <div class="e-price__main">
            <div class="e-price__current">{{ product_black_friday_price }}</div>
            <div class="e-price__old">{{ product_sale_price }}</div>
        </div>
    </div>
    <div class="e-pill-save">{{ 'product.settings.save' | t }} {{ black_friday_discount }}%</div>
</div>

{%- capture button-label -%}{{ 'product.settings.buy-and-save-button-label' | t }}{%- endcapture -%}

{% if section != blank %}
    {% if section.settings.reserved != blank %}
    {% capture button-label %}{{ 'product.settings.reserve-and-save-button-label' | t }}{% endcapture %}
    {% endif %}
    {% if section.settings.soldout != blank %}
    {% capture button-label %}{{ 'product.settings.soldout-button-label' | t }}{% endcapture %}
    {% endif %}
{% endif %}

<script>

    {% if section.settings.soldout != blank %}
    let buy_and_save_button_label = '{{ button-label }}';
    {% else %}
    {% if product_discount %}
        let buy_and_save_button_label = '{{ button-label }} {{ product_discount }}%';
    {% else %}
        let buy_and_save_button_label = '{{ button-label }} {{ black_friday_discount }}%';
    {% endif %}
    {% endif %}

    document.addEventListener("DOMContentLoaded", function () {
        loadScriptOnce('n-product-price-special-offer.js', '{{ 'n-product-price-special-offer.js' | asset_url }}');
    });
</script>