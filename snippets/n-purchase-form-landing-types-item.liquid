{% if array != blank %}
    {%- for __id in array -%}
        {% assign block = section.blocks | where: "id", __id | first %}
        {% if block.type == 'product_type' %}
            {% assign product_type_title = block.settings.heading | strip_newlines | strip | replace: ' ', '' | downcase %}
            <li class="serumBlock" id="{{ section.id }}-{{ product_type_title }}">
                <label for="{{ section.id }}-{{ block.id }}">
                    <input type="radio" class="color variant__input" name="serum_{{ section.settings.form_name }}" id="{{ section.id }}-{{ block.id }}" data-name="{{ block.settings.heading | escape }}" {% if block.settings.preselected == true %} checked{% endif %}>
                    {% if block.settings.image != blank %}
                        <img src="{{ block.settings.image | img_url: '250x' }}" alt="{{ block.settings.heading | escape }}" />
                    {% endif %}
                    <span>{{ block.settings.heading }}</span>
                </label>
            </li>
        {% endif %}
    {%- endfor -%}
{% endif %}