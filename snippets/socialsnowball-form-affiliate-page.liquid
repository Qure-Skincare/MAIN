{% liquid
  assign ss_iframe_src = section.settings.affiliate_signup_iframe_url | strip
  if ss_iframe_src == blank
    assign ss_iframe_src = 'https://api.socialsnowball.io/register-form/12963/92dcd279-8f4d-4230-a1b8-2933b3ac0833'
  endif
%}
<div class="apply-to-join__ss-embed" data-ss-affiliate-embed>
  <div class="apply-to-join__ss-iframe-holder">
    <iframe
      id="affiliate-sign-up-form"
      title="{{ 'sections.n_affiliate-page-apply-form.settings.create-account' | t | escape }} — Social Snowball"
      src="{{ ss_iframe_src | escape }}"
      loading="lazy"
    ></iframe>
  </div>
</div>
<style>
  .apply-to-join__ss-embed {
    margin: 0;
    padding: 0;
    line-height: 0;
  }
  .apply-to-join__ss-iframe-holder {
    margin: 0;
    padding: 0;
    line-height: 0;
    overflow: hidden;
    width: 100%;
    max-height: min(90vh, 960px);
  }
  .apply-to-join__ss-iframe-holder iframe {
    border: 0;
    width: 100%;
    display: block;
    height: min(75vh, 820px);
    max-height: inherit;
  }
</style>
<script>
  (function () {
    var iframe = document.getElementById('affiliate-sign-up-form');
    if (!iframe) return;
    var holder = iframe.closest('.apply-to-join__ss-iframe-holder');
    var src = iframe.getAttribute('src');
    if (!src) return;
    var expectedOrigin;
    try {
      expectedOrigin = new URL(src, window.location.href).origin;
    } catch (err) {
      return;
    }
    function capHeight(px) {
      var softCap = Math.min(window.innerHeight * 0.9, 960);
      return Math.min(Math.max(px, 280), softCap);
    }
    window.addEventListener('message', function (ev) {
      if (ev.origin !== expectedOrigin) return;
      var data = ev.data;
      if (!data || typeof data !== 'object' || typeof data.height !== 'number') return;
      var h = capHeight(data.height);
      iframe.style.height = h + 'px';
      if (holder) holder.style.maxHeight = h + 'px';
    });
  })();
</script>
