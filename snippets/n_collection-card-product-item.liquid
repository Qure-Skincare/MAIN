{% doc %}
  Renders a review / testimonial card for n_collection (best-sellers__review).

  @param {object} block - Section block (product-item).

  @example
  {% include 'n_collection-card-product-item', block: block %}
{% enddoc %}

{% include 'get-product-data', product_handle: block.settings.product, product_prefix: 'n-collection-card-product-' %}
{% assign n_card_product = block.settings.product %}
{% if n_card_product != blank and n_card_product.id == blank %}
    {% assign n_card_product = all_products[block.settings.product] %}
{% endif %}

<div class="best-sellers__item">
    <a class="best-sellers__review" href="{{ product_url }}">
        {% if block.settings.image != blank %}
            <img src="{{ block.settings.image | img_url: '500x' }}" alt="{{ block.settings.image.alt | escape }}" />
        {% endif %}
        <div>
            {% if block.settings.text != blank %}
                <p class="d-md-block d-none">{{ block.settings.text }}</p>
            {% endif %}
            {% if block.settings.text_mobile != blank %}
                <p class="d-md-none">{{ block.settings.text_mobile }}</p>
            {% elsif block.settings.text != blank %}
                <p class="d-md-none">{{ block.settings.text }}</p>
            {% endif %}

            {% if product_id != null and n_card_product != blank %}
                {% assign n_card_product_title = product_title | split: '(' | first | strip %}
                <p>
                    {% if n_card_product.featured_image != blank %}
                        <img src="{{ n_card_product.featured_image | img_url: '250x' }}" alt="{{ n_card_product.featured_image.alt | escape }}" />
                    {% endif %}
                    {% if block.settings.client != blank %}
                        <small>{{ block.settings.client }} {{ 'sections.collection.uses' | t }}</small>
                    {% endif %}
                    <span>{{ n_card_product_title }}</span>
                </p>
            {% endif %}
        </div>
    </a>
</div>
