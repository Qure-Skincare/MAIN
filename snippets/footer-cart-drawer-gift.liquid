<style>
    .footer-cart-drawer-gift {
        display: none;
    }
</style>

{% if settings.cart_gift1_product != blank %}
    {% assign cart_gift_variant_id = all_products[settings.cart_gift1_product].variants.first.id %}

    {% if cart_gift_variant_id != null and settings.cart_gift1_price_limit > 0 %}
        <form id="gift_{{ settings.cart_gift1_product }}" method="post" action="/cart/add" enctype="multipart/form-data" class="footer-cart-drawer-gift">
            <input type="hidden" name="quantity" id="quantity" value="1">
            <input type="hidden" name="id" value="{{ cart_gift_variant_id }}">
            <input type="hidden" name="properties[_required_validation]" value="validated">
            <input type="hidden" name="properties[_price_limit]" value="{{ settings.cart_gift1_price_limit | times: 100 }}">
        </form>
    {% endif %}
{% endif %}


{% if settings.cart_gift2_product != blank %}
