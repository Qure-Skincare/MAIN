{% doc %}
  Renders a product money back snippet for the product-header section

  @param {object} - A section object.
  @param {object} - A block object.

  @example
  {% render 'n-product-money-back', section: '', block: '' %}
{% enddoc %}

{% if block == blank %}
    {% for _block in section.blocks %}
        {% if _block.type == 'money-back' %}
            {% assign block = _block %}
        {% endif %}
    {% endfor %}
{% endif %}

<div class="c-moneyback">
    {% if block.settings.image != blank %}
        <img src="{{ block.settings.image | image_url }}" alt="{{ block.settings.image.alt | escape }}" />
    {% else %}
        <img src="https://qureskincaredns.com/sections/isolated/micro-infusion-pdp/images/{{ 'product.settings.money-back.image' | t }}" alt="moneyback">
    {% endif %}
    {% if block.settings.heading != blank %}
        <strong>{{ block.settings.heading }}</strong>
    {% else %}
        <strong>{{ 'product.settings.money-back.header' | t }}</strong>
    {% endif %}
    <p>{{ 'product.settings.money-back.text' | t }}</p>
</div>