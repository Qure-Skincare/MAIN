{% doc %}
  Returns endrock properties.

  @example
  {% include '__endrock-get-data' %}
{% enddoc %}

{% assign path_lower = request.path | downcase %}
{% assign gamification_enable = settings.enable_gamification %}
{% assign gamification_exception = settings.gamification_exception %}
{% assign gamification_exception_list = gamification_exception | split: ',' %}

{% for exception in gamification_exception_list %}
    {% assign exception = exception | downcase %}
    {% if exception != blank and path_lower contains exception %}
        {% assign gamification_enable = false %}
        {% break %}
    {% endif %}
{% endfor %}