{% doc %}
  Renders a product/page proven results snippet for the product-header section

  @param {object} - A section object.
  @param {object} - A block object.

  @example
  {% render 'n-product-page-results', section: '', block: '' %}
{% enddoc %}

{% if block == blank %}
    {% for _block in section.blocks %}
        {% if _block.type == 'results' %}
            {% assign block = _block %}
        {% endif %}
    {% endfor %}
{% endif %}

<ul class="c-clinic-metrics" data-label="{{ block.settings.heading }}">
    {% if block.settings.text1 != blank %}
        <li data-value="90%">{{ block.settings.text1 }}</li>
    {% endif %}
    {% if block.settings.text2 != blank %}
        <li data-value="83%">{{ block.settings.text2 }}</li>
    {% endif %}
    {% if block.settings.text3 != blank %}
        <li data-value="70%">{{ block.settings.text3 }}</li>
    {% endif %}
</ul>