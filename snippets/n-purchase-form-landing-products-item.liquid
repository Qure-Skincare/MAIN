{% if array != blank %}

    <style>
        .hide {
            display: none !important; 
        }
    </style>

    {% capture preorder-box-items %}{% endcapture %}

    {%- for __id in array -%}
        {% assign block = section.blocks | where: "id", __id | first %}
        {% if block.type == 'product_type' %}
            {% assign product_type_title = block.settings.heading | strip_newlines | strip | replace: ' ', '' | downcase %}
        {% endif %}
    {%- endfor -%}

    <template id="{{ section.settings.form_name }}-source-{{ section.id }}-{{ product_type_title }}">

        <ul class="c-supply-selector__list" id="{{ section.id }}-{{ product_type_title }}">
            
            {% assign array_count = array.size %}

            {%- for __id in array -%}
                {% assign block = section.blocks | where: "id", __id | first %}
                {% if block.type == 'product' %}

                    {% include 'get-product-data', product_handle: block.settings.product, product_current_variant_id: block.settings.product_variant_id, product_prefix: 'purchase-form-landing-products-items-' %}

                    {% if product_id %}
                        {% assign product_title_tag = block.settings.heading | strip_html | strip_newlines | strip | replace: ' ', '' | downcase %}
                        {% assign array_count = array_count |  minus: 1 %}
                        {% assign product_type = array_count %}
                        
                        {% capture data-per %}{{ 'purchase-form.settings.buy-button-label' | t }} {% if product_discount != blank %} {{ 'purchase-form.settings.and' | t }} {{ 'purchase-form.settings.save' | t }} {{ product_discount }}%{% endif %}{% endcapture %}

                        {% if block.settings.preorder == true %}
                            {% capture data-per %}{{ 'purchase-form.settings.reserve-button-label' | t }} {% if product_discount != blank %} {{ 'purchase-form.settings.and' | t }} {{ 'purchase-form.settings.save' | t }} {{ product_discount }}%{% endif %}{% endcapture %}
                        {% endif %}

                        {% if block.settings.soldout == true %}
                            {% capture data-per %}{{ 'purchase-form.settings.soldout-button-label' | t }}{% endcapture %}
                        {% endif %}

                        <li class="c-supply-selector__item purchase_form_lading_product_variant_selector"
                            data-block-id="{{ block.id }}"
                            data-pay="{{ product_price_divided }}" 
                            data-per="{{ data-per }}" 
                            data-product_variant_id="{{ product_variant_id }}" 
                            data-soldout="{{ block.settings.soldout }}" 
                            data-preorder="{{ block.settings.preorder }}" 
                            data-product-type="{{ product_type }}"
                            data-product-name="{{ block.settings.heading | escape }}",
                            {% if block.settings.product_selling_plan > 0 %}
                            data-product-selling-plan="{{ block.settings.product_selling_plan }}"
                            {% endif %}
                            {% if block.settings.preselected == blank %}
                            data-preselected="{{ block.settings.preselected }}"
                            {% else %}
                            data-preselected="false"
                            {% endif %}
                            data-variant-title="{{ product_title_tag }}"
                            data-product-price="{{ product_sale_price }}">

                            <label class="c-supply-selector__label" for="{% if section.settings.hide_types %}{{ product_title_tag }}{% else %}{{ section.id }}-{{ product_title_tag }}{% endif %}">
                                <input type="radio" class="supply-tile" name="purchase_form_lading_product_variant_{{ section.settings.form_name }}" id="{% if section.settings.hide_types %}{{ product_title_tag }}{% else %}{{ section.id }}-{{ product_title_tag }}{% endif %}" {% if block.settings.preselected == true %} checked{% endif %}>
                                <div class="c-supply-selector__main">
                                    {% if block.settings.image != blank %}
                                        <picture class="c-supply-selector__image">
                                            <img src="{{ block.settings.image | img_url: '250x' }}" alt="{{ block.settings.image.alt | escape }}" />
                                        </picture>
                                    {% endif %}

                                    <div class="c-supply-selector__name">{{ block.settings.heading | replace: '(PRE-ORDER)', '' | strip }}</div>

                                    {% unless section.settings.type == 'variant' %}
                                        <div class="c-supply-selector__price">
                                            <div class="e-price{% if black_friday_discount_percent > 0 %} e-price--strikethrough{% endif %}">
                                                <div class="e-price__main">
                                                    <div class="e-price__current igPrice" data-variant-id="{{ product_variant_id }}">{{ product_sale_price }}</div>
                                                    {% if product_before_price != blank %}
                                                        <div class="e-price__old igComparePrice" data-variant-id="{{ product_variant_id }}">{{ product_before_price }}</div>
                                                    {% endif %}
                                                </div>
                                            </div>
                                            {% if product_black_friday_price != blank %}
                                                <div class="c-supply-selector__final-price">
                                                    <div class="e-price">
                                                        <div class="e-price__main">
                                                            <div class="e-price__current">{{ product_black_friday_price }}</div>
                                                        </div>
                                                    </div>
                                                </div>
                                            {% endif %}
                                        </div>

                                        <div class="c-supply-selector__desc">{{ block.settings.subheading }}</div>

                                        {% if product_discount != blank %}
                                            <div class="c-supply-selector__save">
                                                {% if section.settings.type != 'list' %}
                                                    <div class="e-pill-save"><span class="igSavePercent" data-variant-id="{{ product_variant_id }}">{{ product_discount }}</span>% {{ 'purchase-form.settings.off' | t }}</div>
                                                {% else %}
                                                    <span class="igSavePercent" data-variant-id="{{ product_variant_id }}">{{ product_discount }}</span>% {{ 'purchase-form.settings.off' | t }}
                                                {% endif %}
                                            </div>
                                        {% endif %}
                                    {% endunless %}
                                </div>

                                {% if section.settings.type != 'list' %}
                                    {% if product_type == 3 %}
                                        <div class="c-supply-selector__tag">
                                            <div class="selector-tag-up">{{ 'purchase-form.settings.best-value' | t }} <i class="e-icon e-icon-rating-fill"></i></div>
                                        </div>
                                    {% endif %}
                                {% else %}
                                    {% if block.settings.popular == true %}
                                        <div class="c-supply-selector__tag">
                                            <div class="selector-tag-down">{{ 'purchase-form.settings.popular' | t }}</div>
                                        </div>
                                    {% endif %}

                                    {% if block.settings.best == true %}
                                        <div class="c-supply-selector__tag">
                                            <div class="selector-tag-down">{{ 'purchase-form.settings.best-value' | t }}</div>
                                        </div>
                                    {% endif %}
                                {% endif %}
                            </label>
                        </li>

                        {% if block.settings.preorder == true %}
                            
                            {% capture preorder-box-items %}{{ preorder-box-items }}<div class="{{ section.settings.form_name }}-preorder-box-item {{ section.settings.form_name }}-preorder-box__{{ product_variant_id }}"></div>{% endcapture %}
                            
                            {% if block.settings.preorder_text != blank %}
                                <span class="{{ section.settings.form_name }}-product-preorder-text__{{ product_variant_id }} hide">{{ block.settings.preorder_text }}</span>
                            {% endif %}
                            {% if block.settings.preorder_date_soldout != blank %}
                                <span class="{{ section.settings.form_name }}-product-preorder_date_soldout__{{ product_variant_id }} hide">{{ block.settings.preorder_date_soldout }}</span>
                            {% endif %}
                            {% if block.settings.preorder_date_reserved != blank %}
                                <span class="{{ section.settings.form_name }}-product-preorder_date_reserved__{{ product_variant_id }} hide">{{ block.settings.preorder_date_reserved }}</span>
                            {% endif %}
                            {% if block.settings.preorder_percent != blank %}
                                <span class="{{ section.settings.form_name }}-product-preorder_percent__{{ product_variant_id }} hide">{{ block.settings.preorder_percent }}</span>
                            {% endif %}
                        {% endif %}

                    {% endif %}
                {% endif %}
            {%- endfor -%} 
        </ul>

        {{ preorder-box-items }}
        {{ preorder_box }} 
    </template>
{% endif %}