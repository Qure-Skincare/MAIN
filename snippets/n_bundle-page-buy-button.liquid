{% doc %}
  Bundle selection button for the We suggest card layout (`c-suggest-card__submit`).

  @param {string} product_variant_id - Variant ID
  @param {string} product_handle - Product handle
  @param {string} product_title - Product title
  @param {number} product_price_original - Price in cents
  @param {object} product_featured_image - Featured image object
  @param {object} section - Block settings scope (`block`)
  @param {string} button_id - Unique button id
{% enddoc %}

{% assign default_button_label = 'Add to Bundle' %}
{% assign selected_button_label = 'Added!' %}

{% if section.settings.button_label != blank %}
  {% assign default_button_label = section.settings.button_label %}
{% endif %}

{% if section.settings.button_label_selected != blank %}
  {% assign selected_button_label = section.settings.button_label_selected %}
{% endif %}

{% unless button_id %}
  {% assign button_id = product_handle | append: '-' | append: 'now' | date: '%s%N' %}
{% endunless %}

<form class="c-suggest-card__submit" action="#">
  <button
    type="button"
    class="bundle-add-button product-form__submit btn btn--primary"
    data-bundle-button
    data-button-id="{{ button_id }}"
    data-variant-id="{{ product_variant_id }}"
    data-handle="{{ product_handle }}"
    data-title="{{ product_title | escape }}"
    data-price="{{ product_price_original }}"
    data-image="{{ product_featured_image | image_url: width: 250 }}"
    data-default-text="{{ default_button_label | escape }}"
    data-selected-text="{{ selected_button_label | escape }}"
  >
    {{ default_button_label }}
  </button>
</form>
