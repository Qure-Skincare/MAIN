{% doc %}
  Renders a bundle selection button (does not add to cart directly).
  Used for skincare plan bundle pages with tiered discounts.

  @param {string} product_variant_id - Product variant ID
  @param {string} product_handle - Product handle
  @param {string} product_title - Product title
  @param {number} product_price_original - Product price in cents
  @param {string} product_featured_image - Product featured image URL
  @param {object} section - Section object with settings
  @param {string} button_id - Unique identifier for this button instance

  @example
  {% render 'bundle-page-buy-button', 
    product_variant_id: product_variant_id, 
    product_handle: product_handle,
    product_title: product_title,
    product_price_original: product_price_original,
    product_featured_image: product_featured_image,
    section: block,
    button_id: 'skincare-1'
  %}
{% enddoc %}

{% assign default_button_label = 'Add to Bundle' %}
{% assign selected_button_label = 'Remove from Bundle' %}

{% if section.settings.button_label != blank %}
  {% assign default_button_label = section.settings.button_label %}
{% endif %}

{% comment %} Generate unique button ID if not provided {% endcomment %}
{% unless button_id %}
  {% assign button_id = product_handle | append: '-' | append: 'now' | date: '%s%N' %}
{% endunless %}

<div class="qure__product-action-inner mt-30 mt-md-30 mb-10 max-w-ctm" style="--max-w-ctm:500px">
  <button 
    type="button" 
    class="bundle-add-button product-form__submit btn btn--primary w-100"
    data-bundle-button
    data-button-id="{{ button_id }}"
    data-variant-id="{{ product_variant_id }}"
    data-handle="{{ product_handle }}"
    data-title="{{ product_title | escape }}"
    data-price="{{ product_price_original }}"
    data-image="{{ product_featured_image | img_url: '250x' }}"
    data-default-text="{{ default_button_label | escape }}"
    data-selected-text="{{ selected_button_label | escape }}"
  >
    {{ default_button_label }}
  </button>
</div>

