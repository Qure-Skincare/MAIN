{% doc %}
  Renders the reviews videos snippet for the product-header

  @param {object} - A product object.
  @param {object} - A page object.

  @example
  {% render 'product-reviews-videos' product: product, page: page %}
{% enddoc %}

{% assign source = blank %}

{% if product != blank %}
    {% assign source = product.metafields.custom.review_videos.value %}
{% endif %}

{% if source != blank %}
    <!-- Review Videos section Start -->
    <div class="review_videos qure__section"
        style="--section-padding-top: 40px; --section-padding-bottom: 80px; --section-padding-top-mob: 20px; --section-padding-bottom-mob: 40px;">
        <div class="container">
            <div class="mb-20">
                <p><strong>{{ 'product.settings.reviews-videos.header' | t }}</strong></p>
            </div>
            <div class="swiper qure__swiper" id="qure__swiper-video-slider" data-section-id="video-slider"
                data-autoplay="false" data-loop="false" data-mobile="4" data-tablet="4" data-desktop="4" data-spacing="10"
                data-pagination-fraction="true">

                <div class="swiper-wrapper">
                    {% for wistia_id in source.wistia_id.value %}
                        <div class="swiper-slide">
                            <div class="videosQure_exernal">
                                <div class="wistia_responsive_padding" style="position:relative;">
                                    <div class="wistia_responsive_wrapper"
                                        style="height:100%;left:0;position:absolute;top:0;width:100%;">
                                        <div class="wistia_embed wistia_async_{{ wistia_id }} popover=true seo=false videoFoam=true"
                                            style="height:100%;position:relative;width:100%">
                                            <div class="wistia_swatch"
                                                style="height:100%;left:0;opacity:0;overflow:hidden;position:absolute;top:0;transition:opacity 200ms;width:100%;">
                                                <img src="https://fast.wistia.com/embed/medias/{{ wistia_id }}/swatch"
                                                    style="filter:blur(5px);height:100%;object-fit:contain;width:100%;" alt=""
                                                    aria-hidden="true" onload="this.parentNode.style.opacity=1;" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
                <div
                    class="swiper-arrows-with-pagination d-flex align-items-center justify-content-center gap-4 mt-30 d-none">
                    <div class="qure-swiper-button-prev qure-swiper-arrow"><i class="fa-regular fa-angle-left"></i>
                    </div>
                    <div class="swiper-pagination position-relative bottom-0 w-auto"></div>
                    <div class="qure-swiper-button-next qure-swiper-arrow"><i class="fa-regular fa-angle-right"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Review Videos section Start -->
{% endif %}