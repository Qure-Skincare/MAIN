{% doc %}
  Renders sections blocks according to allowed_types for product-header/page-header section

  @param {section} - A section object.
  @param {allowed_types} - A string value.
  @param {render} - A string value.

  @example
  {% render 'product-page-blocks-render', section: section, allowed_types: '', render: '' %}
{% enddoc %}

{% if render != blank %}
    {{ render }}
{% endif %}

{% if allowed_types != blank %}
    {% assign allowed_types = allowed_types | split: "," %}
    
    {% for block in section.blocks %}
        {% if allowed_types contains block.type %}
            {% case block.type %}
                {% when 'description' %}
                    {% render 'product-description', description: section.settings.description %}
                {% when 'price' %}
                    {% if black_friday_discount_percent > 0 %}
                        {% render 'product-page-black-friday-price', product_sale_price: product_sale_price, product_before_price: product_before_price, product_discount: product_discount, product_black_friday_price: product_black_friday_price, black_friday_discount: black_friday_discount %}
                    {%- else -%}
                        {% render 'product-price', product_sale_price: product_sale_price, product_before_price: product_before_price, product_discount: product_discount, section: section, block: block %}
                    {%- endif -%}
                {% when 'limited-offer' %}
                    {% render 'product-limited-time-offer', section: section, block: block %}
                {% when 'black-friday-discount' %}
                    {% render 'product-page-black-friday-discount', section: section, block: block %}
                {% when 'exclusive-offer' %}
                    {% if product_variant_id %}
                        {% include 'product-exclusive-offer', section: section, block: block %}
                    {% else %}
                        {% include 'page-exclusive-offer', section: section, block: block %}
                    {% endif %}
                {% when 'nextships' %}        
                    {% render 'product-page-next-ships', section: section, block: block %}
                {% when 'button' %}
                    {% render 'product-page-buy-button', product_price: null, product_variant_id: product_variant_id, section: section %}
                    {% render 'product-page-buy-button-payments', product_price_divided: product_price_divided %}
                    {% render 'product-page-buy-button-bottom' %}
                {% when 'video' %}
                    {% render 'page-video', section: section, block: block %}
                {% when 'section' %}
                    {% render 'product-page-async-section', section: section, block: block %}
                {% when 'link' %}
                    {% render 'page-link-button', section: section %}
                {% when 'money-back' %}
                    {% render 'product-money-back', section: section, block: block %}
                {% when 'reviews-videos' %}
                    {% render 'product-reviews-videos', section: section, block: block %}
            {% endcase %}
        {% endif %}
    {% endfor %}
{% endif %}