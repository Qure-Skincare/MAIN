{% if array != blank %}

    <style>
        .hide {
            display: none !important; 
        }
    </style>

    {% capture preorder-box-items %}{% endcapture %}

    {%- for __id in array -%}
        {% assign block = section.blocks | where: "id", __id | first %}
        {% if block.type == 'product_type' %}
            {% assign product_type_title = block.settings.heading | strip_newlines | strip | replace: ' ', '' | downcase %}
        {% endif %}
    {%- endfor -%}

    <template id="{{ section.settings.form_name }}-source-{{ section.id }}-{{ product_type_title }}">
        <div class="step_content" id="{{ section.id }}-{{ product_type_title }}">
            <div class="d-flex col-gap step_conten_blocks" style="--col-gap:12px">

                {% assign array_count = array.size %}

                {%- for __id in array -%}
                    {% assign block = section.blocks | where: "id", __id | first %}
                    {% if block.type == 'product' %}
                        {% include 'get-product-data', product_handle: block.settings.product, product_prefix: 'purchase-form-landing-products-type_variant-items-' %}

                        {% if product_id %}
                            {% if block.settings.product_variant_id != null %}
                                {% assign product_variant_id = block.settings.product_variant_id %}
                            {% endif %}

                            {% assign product_title_tag = block.settings.heading | strip_html | strip_newlines | strip | replace: ' ', '' | downcase %}
                            {% assign array_count = array_count |  minus: 1 %}
                            {% assign product_type = array_count %}
                            
                            {% capture data-per %}{{ 'purchase-form.settings.buy-button-label' | t }} {% if product_discount != blank %} {{ 'purchase-form.settings.save' | t }} {{ product_discount }}%{% endif %}{% endcapture %}

                            {% if block.settings.preorder == true %}
                                {% capture data-per %}{{ 'purchase-form.settings.reserve-button-label' | t }} {% if product_discount != blank %} {{ 'purchase-form.settings.save' | t }} {{ product_discount }}%{% endif %}{% endcapture %}
                            {% endif %}

                            {% if block.settings.soldout == true %}
                                {% capture data-per %}{{ 'purchase-form.settings.soldout-button-label' | t }}{% endcapture %}
                            {% endif %}

                            <div class="planBlock col qure__variant-item" href="javascript:void(0)"
                                data-block-id="{{ block.id }}"
                                data-pay="{{ product_price_divided }}" 
                                data-per="{{ data-per }}" 
                                data-product_variant_id="{{ product_variant_id }}" 
                                data-soldout="{{ block.settings.soldout }}" 
                                data-preorder="{{ block.settings.preorder }}" 
                                data-product-type="{{ product_type }}"
                                data-product-name="{{ block.settings.heading | escape }}"
                                {% if block.settings.product_selling_plan > 0 %}
                                data-product-selling-plan="{{ block.settings.product_selling_plan }}"
                                {% endif %}
                                {% if block.settings.preselected == true %}
                                data-preselected="{{ block.settings.preselected }}"
                                {% else %}
                                data-preselected="false"
                                {% endif %}
                                data-variant-title="{{ product_title_tag }}"
                                data-product-price="{{ product_sale_price }}">

                                <input type="radio" class="variant__input vp__input" name="monthlyPlan_{{ section.settings.form_name }}" id="{% if section.settings.hide_types %}{{ product_title_tag }}{% else %}{{ section.id }}-{{ product_title_tag }}{% endif %}" data-id="{{ product_title_tag }}" {% if block.settings.preselected == true %} checked{% endif %}>
                                <label for="{% if section.settings.hide_types %}{{ product_title_tag }}{% else %}{{ section.id }}-{{ product_title_tag }}{% endif %}" data-id="{{ product_title_tag }}" class="qure__variant-box">
                                    <div class="qv-frame">
                                        {% if block.settings.image != blank %}
                                            <div class="qv-frame-inner">
                                                <img src="{{ block.settings.image | img_url: '250x' }}" alt="{{ block.settings.image.alt | escape }}" class="qv-img" />
                                            </div>
                                        {% else %}
                                            <br />
                                        {% endif %}
                                    </div>
                                    <div class="div">{{ block.settings.heading }}</div>
                                </label>
                            </div>

                            {% if block.settings.preorder == true %}
                                
                                {% capture preorder-box-items %}{{ preorder-box-items }}<div class="{{ section.settings.form_name }}-preorder-box-item {{ section.settings.form_name }}-preorder-box__{{ product_variant_id }}"></div>{% endcapture %}
                                
                                {% if block.settings.preorder_text != blank %}
                                    <span class="{{ section.settings.form_name }}-product-preorder-text__{{ product_variant_id }} hide">{{ block.settings.preorder_text }}</span>
                                {% endif %}
                                {% if block.settings.preorder_date_soldout != blank %}
                                    <span class="{{ section.settings.form_name }}-product-preorder_date_soldout__{{ product_variant_id }} hide">{{ block.settings.preorder_date_soldout }}</span>
                                {% endif %}
                                {% if block.settings.preorder_date_reserved != blank %}
                                    <span class="{{ section.settings.form_name }}-product-preorder_date_reserved__{{ product_variant_id }} hide">{{ block.settings.preorder_date_reserved }}</span>
                                {% endif %}
                                {% if block.settings.preorder_percent != blank %}
                                    <span class="{{ section.settings.form_name }}-product-preorder_percent__{{ product_variant_id }} hide">{{ block.settings.preorder_percent }}</span>
                                {% endif %}
                            {% endif %}

                        {% endif %}
                    {% endif %}
                {%- endfor -%}                            
            </div>

            {{ preorder-box-items }}
            {{ preorder_box }} 

        </div>
    </template>
{% endif %}