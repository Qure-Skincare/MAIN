{% doc %}
  Renders a bundle type item snippet for purchase form bundle section.
{% enddoc %}
{% if array != blank %}
    {% if mode == 'sticky' %}
        {%- for __id in array -%}
            {% assign block = section.blocks | where: "id", __id | first %}
            {% if block.type == 'product_type' %}
                {% assign product_type_title = block.settings.heading | strip_newlines | strip | replace: ' ', '' | downcase %}
                <div class="sticky-item {% if block.settings.preselected == true %} active{% endif %}"  data-value="{{ block.settings.heading |  handleize }}">
                    {{ block.settings.heading }}
                </div>
            {% endif %}
        {%- endfor -%}   
    {% else %}
        {%- for __id in array -%}
            {% assign block = section.blocks | where: "id", __id | first %}
            {% if block.type == 'product_type' %}
                {% assign product_type_title = block.settings.heading | strip_newlines | strip | replace: ' ', '' | downcase %}
                <li class="nav-item bundle_heading {{ class }}" id="{{ section.id }}-{{ product_type_title }}" data-type="{{ type }}">
                <input type="radio" style="display:none;" name="bundle_section_{{ section.settings.form_name }}" id="{{ section.id }}-{{ block.id }}" {% if block.settings.preselected == true %} checked{% endif %}/>
                    <button class="nav-link{% if block.settings.preselected == true %} active{% endif %}" data-value="{{ block.settings.heading |  handleize }}">{{ block.settings.heading }}</button>
                </li>
            {% endif %}
        {%- endfor -%}
    {% endif %}
{% endif %}