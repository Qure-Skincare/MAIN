{% doc %}
  Renders limited offer for special-offer

  @example
  {% render 'product-page-limited-offer-black-friday' %}
{% enddoc %}

<link rel="stylesheet" href="https://qureskincaredns.com/shopify/css/product-page-limited-offer-black-friday.css">

<a href="{{ 'special-offer.limited-offer.link' | t }}" class="bf-limited-time-banner" style="display:none">
    <div class="bf-limited-time-banner__image">
       <img src="https://qureskincaredns.com/sections/isolated/product-bundle/images/black-friday-limited-time-bundle.webp" alt="black-friday-limited-time-bundle">
    </div>
    <div class="bf-limited-time-banner__content">
       <h6>{{ 'special-offer.limited-offer.header' | t }}</h6>
       <p>{{ 'special-offer.limited-offer.text' | t }}</p>
    </div>
    <div class="bf-limited-time-banner__label">
       <img src="https://qureskincaredns.com/sections/isolated/product-bundle/images/black-friday-limited-time.webp" alt="black-friday-limited-time">
    </div>
 </a>