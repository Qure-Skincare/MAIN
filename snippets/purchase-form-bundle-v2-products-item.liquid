{% if array != blank %}
    {%- for __id in array -%}
        {% assign block = section.blocks | where: "id", __id | first %}
        {% if block.type == 'product_type' %}
            {% assign product_type_block = block %}
            {% assign product_type_title = block.settings.heading | strip_newlines | strip | replace: ' ', '' | replace: ',', '_' | downcase %}
        {% endif %}
        {% if block.type == 'product' %}
            <script>
                window.get_form_bundle_products_data = window.get_form_bundle_products_data || {};
                window.get_form_bundle_products_data['{{ block.settings.product }}'] = {{ type }};
            </script>
        {% endif %}
    {%- endfor -%}

    <div class="offer-bundle">
        <div class="container">
            <div class="offer-bundle__content">
                {% render 'purchase-form-bundle-v2-products-item-header', type: type, block: product_type_block %}

                {% assign array_count = array.size %}

                {%- for __id in array -%}
                    {% assign block = section.blocks | where: "id", __id | first %}
                    {% if block.type == 'product' %}
                        {% include 'get-product-data', product_handle: block.settings.product, product_prefix: 'purchase-form-bundle-products-items-' %}

                        {% if product_id %}
                            {% assign product_title_tag = block.settings.heading | strip_html | strip_newlines | strip | replace: ' ', '' | replace: ',', '_' | downcase %}
                            {% assign array_count = array_count |  minus: 1 %}
                            {% assign product_type = array_count %}
                            
                            {% capture data-per %}{{ 'purchase-form.settings.buy-button-label' | t }} {% if product_discount != blank %} {{ 'purchase-form.settings.and' | t }} {{ 'purchase-form.settings.save' | t }} {{ product_discount }}%{% endif %}{% endcapture %}

                            {% if block.settings.preorder == true %}
                                {% capture data-per %}{{ 'purchase-form.settings.reserve-button-label' | t }} {% if product_discount != blank %} {{ 'purchase-form.settings.and' | t }} {{ 'purchase-form.settings.save' | t }} {{ product_discount }}%{% endif %}{% endcapture %}
                            {% endif %}

                            {% if block.settings.soldout == true %}
                                {% capture data-per %}{{ 'purchase-form.settings.soldout-button-label' | t }}{% endcapture %}
                            {% endif %}

                            {% capture button-label %}{{ 'product.settings.buy-button-label' | t }}{% endcapture %}

                            {% if block.settings.reserved == true %}
                                {% capture button-label %}{{ 'product.settings.reserved-button-label' | t }}{% endcapture %}
                            {% endif %}
                            
                            {% if block.settings.soldout == true %}
                                {% capture button-label %}{{ 'product.settings.soldout-button-label' | t }}{% endcapture %}
                            {% endif %}

                            <div id="{{ product_handle }}" class="offer-bundle__item custom__block">
                                <div class="offer-bundle__item-card">
                                    <div class="c-bundle-card">
                                        {% if product_discount != blank %}
                                            <div class="c-bundle-card__discount">
                                                <div class="e-pill-save discount_percentage">{{ 'purchase-form-bundle.settings.discount-text' | t }} {{ product_discount }}%</div>
                                            </div>
                                        {% endif %}
                                        <a href="#bundle-popup-{{ product_handle }}" data-bs-toggle="modal">
                                            {% if block.settings.image != blank %}
                                                <img
                                                    class="c-bundle-card__picture"
                                                    src="{{ block.settings.image | image_url }}"
                                                    alt="{{ product_title | escape }}"
                                                /> 
                                            {% endif %}
                                        </a>
                                        <article class="c-bundle-card__content">
                                            <div class="c-bundle-card__details">
                                                <div class="c-bundle-card__rating">
                                                    <div class="e-rating-stars" style="--rating: 4.4;"></div>
                                                    <small>{{ 'purchase-form-bundle.settings.rated' | t }} <strong>{{ product_rating | default: 4.8 }}</strong>/5</small>
                                                </div>
                                                <div class="c-bundle-card__name">{{ product_title }}</div>
                                                <div class="c-bundle-card__price">
                                                    <div class="e-price">
                                                        <div class="e-price__main">
                                                            <div class="e-price__currect igPrice">{{ product_sale_price }}</div>
                                                            {% if product_before_price != blank %}
                                                                <div class="e-price__old igComparePrice">{{ product_before_price }}</div>
                                                            {% endif %}
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="c-bundle-card__button">
                                                <a href="#bundle-popup-{{ product_handle }}" class="add-cart-button product-form__submit btn btn--primary w-100" data-bs-toggle="modal">{{ button-label }}</a>
                                                <div class="e-pay-options">
                                                    Buy Now, Pay Later available
                                                    <ul>
                                                        <li><img src="https://qureskincaredns.com/assets/images/klarna.svg" alt="Klarna" /></li>
                                                        <li><img src="https://qureskincaredns.com/assets/images/sezzle.svg" alt="Sezzle" /></li>
                                                        <li><img src="https://qureskincaredns.com/assets/images/afterpay.svg" alt="Afterpay" /></li>
                                                    </ul>
                                                </div>
                                            </div>
                                        </article>
                                    </div>
                                </div>
                                <div class="offer-bundle__item-modal">
                                    <div class="modal fade" id="bundle-popup-{{ product_handle }}">
                                        <div class="modal-dialog">
                                            <div class="modal-content">
                                                {% render 'product-page-slider', product: get_product_data, page: blank, class: 'tp-product-gallery qure__swiper-wrapper mb-20', element_id: block.id %}
                                                <p class="fs-20">{{ product_title }}</p>
                                                <div
                                                    class="bundle_price d-flex align-items-center justify-content-start gap-3 my-3 pb-2">
                                                    <div class="aft_price color-orange fs-20">{{ product_sale_price }}</div>
                                                    {% if product_before_price != blank %}
                                                        <div class="bef_price text-decoration-line-through fs-20">{{ product_before_price }}</div>
                                                    {% endif %}
                                                </div>
                                                {% render 'purchase-form-bundle-v2-products-item-bottom', product_handle: product_handle, product_sale_price: product_sale_price, product_before_price: product_before_price, product_variants: product_variants, product_bundle_list: product_bundle_list, block: block %}
                                                {% render 'product-page-buy-button', product_price: null, product_variant_id: product_variant_id, section: block, product_available: product_available, close_modal: true %}
                                                <button type="button" class="btn-close" data-bs-dismiss="modal">
                                                    <img src="https://qureskincaredns.com/assets/images/cross_black.svg" alt="cross_black" />
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endif %}
                    {% endif %}
                {%- endfor -%}
            </div>
        </div>
    </div>
{% endif %}