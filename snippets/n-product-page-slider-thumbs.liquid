{% doc %}
  Renders a product/page slider section for the product-header/page-header section.

  @param {object} - A product object.
  @param {object} - A page object.
  @param {element_id} - A string value.
  @param {slidesPerView} - A integer value.
  @param {element_id} - A integer value.

  @example
  {% render 'n-product-page-slider', product: product, page: page, slidesPerView: 'auto', spaceBetween: 12  %}
{% enddoc %}

<div class="c-swiper-thumbs-nav">
    <button class="c-swiper-button-prev"></button>
    <div
        class="c-swiper c-swiper-thumbs"
        data-swiper='{
            "slidesPerView": "{{ slidesPerView }}",
            "spaceBetween": {{ spaceBetween }}
        }'>
        <div class="swiper-wrapper">
            {% if product.metafields.custom.carousel_media.value != blank %}
                {% render 'n-product-page-media-carousel', input_media_carousel: product.metafields.custom.carousel_media.value, size: '240x', thumbnails: true %}
            {% elsif page.metafields.custom.carousel_media.value != blank %}
                {% render 'n-product-page-media-carousel', input_media_carousel: page.metafields.custom.carousel_media.value, size: '240x', thumbnails: true %}
            {% else %}
                {% render 'n-product-media', product_media: product.media, size: '240x' %}
            {% endif %}
        </div>
    </div>
    <button class="c-swiper-button-next"></button>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadScriptOnce("swiper", "https://qureskincaredns.com/assets/js-new/swiper.js");
    });
</script>