{% doc %}
  Renders a benefits list for the product template.

  @example
  {% render 'product-benefits-list' %}
{% enddoc %}

<div class="d-flex d-lg-none flex-nowrap align-items-start justify-content-center col-gap mt-30">
    <div class="col icon-with-text d-flex flex-wrap flex-lg-nowrap flex-column flex-lg-row align-items-center fs-16 text-center text-lg-start">
        <img src="https://qureskincaredns-main.com/sections/isolated/protect-your-skin/images/dermatologist.svg" alt="dermatologist" class="mr-0 mr-md-10 mb-10 mb-md-0">
        <span>{{ 'product.settings.benefits-list.guaranteed_text' | t }}</span>
    </div>
    <div class="col icon-with-text d-flex flex-wrap flex-lg-nowrap flex-column flex-lg-row align-items-center fs-16 text-center text-lg-start">
        <img src="https://qureskincaredns-main.com/sections/isolated/protect-your-skin/images/shipping.svg" alt="shipping" class="mr-0 mr-md-10 mb-10 mb-md-0">
        <span>{{ 'product.settings.benefits-list.shipping_text' | t }}</span>
    </div>
    <div class="col icon-with-text d-flex flex-wrap flex-lg-nowrap flex-column flex-lg-row align-items-center fs-16 text-center text-lg-start">
        <img src="https://qureskincaredns-main.com/sections/isolated/protect-your-skin/images/backed_science.svg" alt="dermatologist" class="mr-0 mr-md-10 mb-10 mb-md-0">
        <span>{{ 'product.settings.benefits-list.science_text' | t }}</span>
    </div>
</div>