{% doc %}
  Returns the product properties.

  @param {string} product_handle - An string value.
  @param {string} product_prefix - An string value.

  @example
  {% include 'get-product-data', product_handle: '', product_prefix: '' %}
{% enddoc %}

{% assign product_found = blank %}

{% if product != blank %}
  {% assign product_found = product %}
{% endif %}

{% if product_handle != blank %}
    {% assign product_found = blank %}
    {% assign product_found = all_products[product_handle] %}
{% endif %}

{% if product_found != blank %}
    {% assign product_id = product_found.id %}
    {% assign product_title = product_found.title %}
    {% assign product_handle = product_found.handle  %}
    {% assign product_description = product_found.description %}
    {% assign product_featured_image = product_found.featured_image %}
    {% assign product_variant_id = product_found.variants.first.id %}
    {% assign product_price_divided = product_found.price | divided_by: 4 | money_without_trailing_zeros %}
    {% assign product_discount = product_found.price | times: 1.0 | divided_by: product_found.compare_at_price | minus: 1 | abs | times: 100 | ceil %}
    {% assign product_title_tag = product_found.title | strip_newlines | strip | replace: ' ', '' | replace: ',', '_' | downcase %}
    {% assign product_price_original = product_found.price %}
    {% assign product_price = product_price_original | money_without_trailing_zeros %}
    {% assign product_price_compare_original = product_found.compare_at_price %}
    {% assign product_price_compare = product_price_compare_original | money_without_trailing_zeros %}
    {% assign product_sale_price = product_price %}
    {% assign product_before_price = product_price_compare %}
    {% assign product_variants = product_found.variants %}
    {% assign product_tags = product_found.tags %}
    {% assign product_url = product_handle | prepend: '/products/'  %}

    {% assign product_subscription_price = null %}
    {% assign subscription_discount = 0 %}

    {% if subscription_discount_percent != null %}

      {% if subscription_discount_percent > 0 %}
        {% assign subscription_discount = subscription_discount_percent %}
        {% assign product_subscription_discount_delta = product_found.price | times: subscription_discount | divided_by: 100 %}      
        {% assign product_subscription_price = product_found.price | minus: product_subscription_discount_delta | money_without_trailing_zeros %}      
      {% endif %}

    {% endif %}

    <script>
      window.get_products_data = window.get_products_data || {};
      window.get_products_data["{{ product_prefix }}{{ product_found.handle }}"] = {
        id: {{ product_id | json }},
        title: {{ product_title | json }},
        description: {{ product_description | strip_newlines | json }},
        featured_image: {{ product_featured_image | img_url: '800x' | prepend: 'https:' | json }},
        variant_id: {{ product_variant_id | json }},
        price_divided: '{{ product_price_divided | replace: ',', '.' }}',
        discount: '{{ product_discount }}',
        title_tag: {{ product_title_tag | json }},
        price_original: {{ product_price_original | default: 0 }},
        price: '{{ product_price | replace: ',', '.' }}',
        compare_at_price_original: {{ product_price_compare_original | default: 0 }},
        compare_at_price: '{{ product_price_compare | replace: ',', '.' }}',
        sale_price: '{{ product_sale_price | replace: ',', '.' }}',
        before_price: '{{ product_before_price | replace: ',', '.' }}',
        subscription_discount: '{{ subscription_discount }}',
        subscription_price: '{{ product_subscription_price | replace: ',', '.' }}',
        variants: {
          {% if product_found.variants.size > 0 %}
            {% for variant in product_variants %}
              {{ variant.title | json }}: {{ variant.id | json }}{% unless forloop.last %},{% endunless %}
            {% endfor %}
          {% endif %}
        }
      };
    </script>
{% endif %}