{% doc %}
  Returns the product properties.

  @param {string} product_handle - An string value.
  @param {string} product_prefix - An string value.

  @example
  {% include 'get-product-data', product_handle: '', product_prefix: '' %}
{% enddoc %}

{% assign black_friday_turn_on = settings.black_friday_turn_on %}
{% assign black_friday_discount_percent = settings.black_friday_discount_percent %}
{% assign black_friday_discount_exception = settings.black_friday_discount_exception %}

{% if black_friday_discount_exception != blank %}
  {% assign is_black_friday_exception = false %}
  {% assign exception_list = black_friday_discount_exception | split: ',' %}
  {% assign path_lower = request.path | downcase %}
  
  {% for exception in exception_list %}
      {% assign exception = exception | downcase %}
      {% if exception != blank and path_lower contains exception %}
          {% assign is_black_friday_exception = true %}
          {% break %}
      {% endif %}
  {% endfor %}
{% endif %}

{% if product.metafields.custom.bf_exclude == true or is_black_friday_exception == true %}
    {%- assign black_friday_discount_percent = 0 -%}
{% endif %}

{% assign product_id = null %}
{% assign get_product_data = blank %}

{% if product != blank %}
  {% assign get_product_data = product %}
{% endif %}

{% if product_handle != blank %}
    {% assign get_product_data = blank %}
    {% assign get_product_data = all_products[product_handle] %}
{% endif %}

{% assign product_discount = blank %}

{% if get_product_data != blank %}
    {% assign product_id = get_product_data.id %}
    {% assign product_title = get_product_data.title %}
    {% assign product_handle = get_product_data.handle  %}
    {% assign product_available = get_product_data.available %}
    {% assign product_description = get_product_data.description %}
    {% assign product_featured_image = get_product_data.featured_image %}
    {% assign product_variant_id = get_product_data.variants.first.id %}
    {% assign product_price_divided = get_product_data.price | divided_by: 4 | money_without_trailing_zeros %}
    {% assign product_discount_value = get_product_data.price | times: 1.0 | divided_by: get_product_data.compare_at_price | minus: 1 | abs | times: 100 %}
    {% assign product_discount_decimal = product_discount_value | modulo: 1 -%}
    {% if product_discount_decimal >= 0.5 %}
      {% assign product_discount = product_discount_value | ceil %}
    {% else %}
      {% assign product_discount = product_discount_value | floor %}
    {% endif %}
    {% assign product_title_tag = get_product_data.title | strip_html | strip_newlines | strip | replace: ' ', '' | replace: ',', '_' | downcase %}
    {% assign product_price_original = get_product_data.price %}
    {% assign product_price = product_price_original | money_without_trailing_zeros %}
    {% assign product_price_compare_original = get_product_data.compare_at_price %}
    {% assign product_price_compare = product_price_compare_original | money_without_trailing_zeros %}
    {% assign product_sale_price = product_price %}
    {% assign product_before_price = product_price_compare %}
    {% assign product_variants = get_product_data.variants %}
    {% assign product_tags = get_product_data.tags %}
    {% assign product_media = get_product_data.media %}
    {% assign product_url = product_handle | prepend: '/products/'  %}

    {% assign product_subscription_price = null %}
    {% assign subscription_discount = 0 %}

    {% assign product_black_friday_price = null %}
    {% assign black_friday_discount = 0 %}

    {% if subscription_discount_percent != null %}
      {% if subscription_discount_percent > 0 %}
        {% assign subscription_discount = subscription_discount_percent %}
        {% assign product_subscription_discount_delta = product_price_original | times: subscription_discount | divided_by: 100 %}
        {% assign product_subscription_price_original = product_price_original | minus: product_subscription_discount_delta %}   
        {% assign product_subscription_price = product_subscription_price_original | money_without_trailing_zeros %}  
        
        {% if black_friday_discount_percent > 0 %}
          {% assign product_subscription_discount_delta = product_subscription_price_original | times: black_friday_discount_percent | divided_by: 100 %}      
          {% assign black_friday_product_subscription_price_original = product_subscription_price_original | minus: product_subscription_discount_delta %}
          {% assign black_friday_product_subscription_price = black_friday_product_subscription_price_original | money_without_trailing_zeros %}
          {% assign subscription_discount_percent = black_friday_product_subscription_price_original | times: 1.0 | divided_by: product_price_original | minus: 1 | abs | times: 100 | floor %}
        {% endif %}

      {% endif %}
    {% endif %}


    {% if black_friday_discount_percent > 0 %}
      {% assign black_friday_discount = black_friday_discount_percent %}
      {% assign product_black_friday_discount_delta = product_price_original | times: black_friday_discount | divided_by: 100 %}      
      {% assign product_black_friday_price_original = product_price_original | minus: product_black_friday_discount_delta %}
      {% assign product_black_friday_price = product_black_friday_price_original | money_without_trailing_zeros %}

      {% if product_price_compare_original != blank %}
        {% assign product_black_friday_price_save = product_price_compare_original | minus: product_black_friday_price_original | money_without_trailing_zeros %}
      {% else %}
        {% assign product_black_friday_price_save = product_price_original | minus: product_black_friday_price_original | money_without_trailing_zeros %}
      {% endif %}

      {% if product_price_compare_original != blank %}
        {% assign product_discount = product_price_original | minus: product_black_friday_discount_delta | times: 1.0 | divided_by: product_price_compare_original | minus: 1 | abs | times: 100 | ceil %}
      {% else %}
        {% assign product_discount = product_price_original | minus: product_black_friday_discount_delta | times: 1.0 | divided_by: product_price_original | minus: 1 | abs | times: 100 | ceil %}
      {% endif %}

      {% assign product_price_divided = product_price_original | minus: product_black_friday_discount_delta | divided_by: 4 | money_without_trailing_zeros %}
    {% endif %}


    {% assign product_bundle_list = blank %}
    {% if get_product_data.metafields.custom.bundle.value != blank %}
      {% assign product_bundle_list = get_product_data.metafields.custom.bundle.value.products.value %}
    {% endif %}

    {% assign product_rating = blank %}
    {% assign product_rating_count = blank %}

    {% if get_product_data.metafields.reviews.rating.value != blank %}
      {% assign product_rating = get_product_data.metafields.reviews.rating.value | slice: 0, 3 %}
    {% endif %}

    {% if get_product_data.metafields.reviews.rating_count.value != blank %}
      {% assign product_rating_count = get_product_data.metafields.reviews.rating_count.value %}
    {% endif %}

    <script>
      window.get_products_data = window.get_products_data || {};
      window.get_products_data["{{ product_prefix }}{{ get_product_data.handle }}"] = {
        id: {{ product_id | json }},
        title: {{ product_title | json }},
        handle: {{ product_handle | json }},
        url: '{{ shop.url }}/products/{{ product_handle }}',
        description: {{ product_description | strip_newlines | json }},
        featured_image: {{ product_featured_image | img_url: '800x' | prepend: 'https:' | json }},
        variant_id: {{ product_variant_id | json }},
        price_divided: '{{ product_price_divided | replace: ',', '.' }}',
        discount: '{{ product_discount }}',
        title_tag: {{ product_title_tag | json }},
        price_original: {{ product_price_original | default: 0 }},
        price: '{{ product_price | replace: ',', '.' }}',
        compare_at_price_original: {{ product_price_compare_original | default: 0 }},
        compare_at_price: '{{ product_price_compare | replace: ',', '.' }}',
        sale_price: '{{ product_sale_price | replace: ',', '.' }}',
        before_price: '{{ product_before_price | replace: ',', '.' }}',
        subscription_discount: '{{ subscription_discount }}',
        subscription_price: '{{ product_subscription_price | replace: ',', '.' }}',
        black_friday_discount: '{{ black_friday_discount }}',
        black_friday_price: '{{ product_black_friday_price | replace: ',', '.' }}',
        bundle_list: {{ product_bundle_list | json }},
        rating_count: '{{ product_rating }}',
        product_rating_count: '{{ product_rating_count }}',
        variants: {
          {% if get_product_data.variants.size > 0 %}
            {% for variant in product_variants %}
              {{ variant.title | json }}: {{ variant.id | json }}{% unless forloop.last %},{% endunless %}
            {% endfor %}
          {% endif %}
        }
      };
    </script>
{% endif %}