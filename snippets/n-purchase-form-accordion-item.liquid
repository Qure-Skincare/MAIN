{% doc %}
  Renders a product accordion item snippet for purchase form section.
{% enddoc %}

{% assign product_type_id = blank %}
{% assign is_accordions_exists = false %}

{%- for __id in array -%}
    {% assign block = section.blocks | where: "id", __id | first %}
    {% if block.type == 'product_type_accordion' %}
        {%- assign is_accordions_exists = true -%}
    {% endif %}
{%- endfor -%}

{% if array != blank %}
    {%- for __id in array -%}
        {% assign block = section.blocks | where: "id", __id | first %}
        {% if block.type == 'product_type' %}
            {% capture product_type_id %}{{ section.id }}-{{ block.id }}{% endcapture %}

            <style>
                .info-items--{{ product_type_id }} {
                    display: none;
                }
                .treatment__step:has(input[type="radio"]#{{ product_type_id }}:checked) .info-items--{{ product_type_id }} {
                    display: block !important;
                }
            </style>
        {% endif %}
    {%- endfor -%}

    {% if is_accordions_exists == true and product_type_id != blank %}
        <div class="info-items info-items--{{ product_type_id }}">
            <div class="info-items__item">
                <div class="c-accordion c-accordion--lines">
                    <div class="c-accordion__list">
                        {%- for __id in array -%}
                            {% assign block = section.blocks | where: "id", __id | first %}
                            {% if block.type == 'product_type_accordion' %}
                                <details class="c-accordion__item">
                                    <summary class="c-accordion__summary">{{ block.settings.heading }}</summary>
                                    <article class="c-accordion__content">
                                        {{ block.settings.text }}
                                    </article>
                                </details>
                            {% endif %}
                        {%- endfor -%}
                    </div>
                </div>
            </div>
        </div> 
    {% endif %}
{% endif %}