{% doc %}
  Renders a cart upsells snippet for the cart drawer section

  @example
  {% include 'n-footer-cart-drawer-upsells' %}
{% enddoc %}

<div class="flyout-cart__upsells">
    <p>{{ 'cart.drawer.upsell.header' | t }}</p>
    <div
        class="c-swiper"
        data-swiper='{
            "slidesPerView": 1.1,
            "spaceBetween": 12,
            "loop": false
        }'>
        <div class="swiper-wrapper">
            {% include 'n-footer-cart-drawer-upsells-item', product_handle: global_upsell_product1_handle %}
            {% include 'n-footer-cart-drawer-upsells-item', product_handle: global_upsell_product2_handle %}
            {% include 'n-footer-cart-drawer-upsells-item', product_handle: global_upsell_product3_handle %}
            {% include 'n-footer-cart-drawer-upsells-item', product_handle: global_upsell_product4_handle %}
            {% include 'n-footer-cart-drawer-upsells-item', product_handle: global_upsell_product5_handle %}
        </div>
    </div>
</div>