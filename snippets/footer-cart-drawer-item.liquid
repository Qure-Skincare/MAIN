                        d="M53.8344 0.214691L54.9774 3.53811L58.5484 3.57871C58.8563 3.58223 58.9835 3.96681 58.7368 4.1468L55.8715 6.24114L56.9359 9.58953C57.0271 9.87765 56.6945 10.115 56.4437 9.94053L53.5303 7.91142L50.6165 9.94011C50.366 10.1147 50.0329 9.87689 50.1243 9.58912L51.1886 6.24073L48.3233 4.14641C48.0768 3.96642 48.204 3.58184 48.5114 3.57832L52.0827 3.53771L53.2257 0.214303C53.3243 -0.071499 53.7362 -0.0714989 53.8344 0.214691Z"
                        fill="#D9D9D9"></path>
                    <path fill-rule="evenodd" clip-rule="evenodd"
                        d="M54.9717 3.54394L53.8296 0.223303C53.7315 -0.0626503 53.32 -0.0626503 53.2215 0.222912L52.0794 3.54355L48.5111 3.58412C48.204 3.58764 48.0769 3.97189 48.3232 4.15174L51.186 6.24428L50.1226 9.58993C50.0313 9.8774 50.3642 10.115 50.6145 9.94064L53.5257 7.91358L55.4941 9.28458V3.54988L54.9717 3.54394Z"
                        fill="#91BAEC"></path>
                </svg>
            </div>
            <a href="#" class="rtng_count">78 Reviews</a>
        </div>

        {% unless preorder_exists %}
            <div class="product-shipping">
                <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 10 10"
                    fill="none" class="shp_icon">
                    <path
                    d="M5 10C7.76142 10 10 7.76142 10 5C10 2.23858 7.76142 0 5 0C2.23858 0 0 2.23858 0 5C0 7.76142 2.23858 10 5 10Z"
                    fill="#C7E5DB"></path>
                    <path d="M7.0455 3.59375L4.233 6.40625L2.95459 5.12784" stroke="#212428"
                    stroke-width="0.625" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
                {% if cart_item_selling_plan_name != null %}
                    <span class="shp_quote">{{ cart_item_selling_plan_name }}</span>
                {% else %}
                    <span class="shp_quote">{{ 'cart.drawer.settings.item-text-2days' | t }}</span>
                {% endif %}
            </div>
        {% endunless %}
    </div>
    <div class="product-footer d-flex align-items-center justify-content-between">
        <div class="product-price d-flex flex-row align-items-end">
            {% if cart_item_before_price != blank %}
                <div class="product-price old igComparePrice">{{ cart_item_before_price }}</div>
            {% endif %}
            <div class="product-price new igPrice">{{ cart_item_sale_price }}</div>
        </div>

        {% unless gift_exists or insurance_exists or selling_plan_exists or discount_100_exists %}
            <div class="product-qty">
                <div class="qty_box d-flex align-items-center justify-content-between">
                    <form id="{{ cart_item_id }}_minus" method="post" action="/cart/change" enctype="multipart/form-data">
                        <button class="qty-btn dec-qty"><i class="fa-regular fa-minus"></i></button>
                        <input type="hidden" name="quantity" value="{{ cart_item_quantity_minus }}">
                        <input type="hidden" name="id" value="{{ cart_item_key }}">
                    </form>
                    <input class="qty-input p-0" type="number" name="qty" value="{{ cart_item_quantity }}" min="0">
                    <form id="{{ cart_item_id }}_plus" method="post" action="/cart/change" enctype="multipart/form-data">
                        <button class="qty-btn inc-qty"><i class="fa-regular fa-plus"></i></button>
                        <input type="hidden" name="quantity" value="{{ cart_item_quantity_plus }}">
                        <input type="hidden" name="id" value="{{ cart_item_key }}">
                    </form>
                </div>
            </div>
        {% endunless %}
    </div>
    </div>
    {% unless gift_exists %}
        <form id="{{ cart_item_id }}_remove" method="post" action="/cart/change" enctype="multipart/form-data">
            <button class="product-remove">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="16" viewBox="0 0 15 16" fill="none">
                    <path
                        d="M14.75 8.33183C14.75 12.2981 11.5061 15.5172 7.5 15.5172C3.49389 15.5172 0.25 12.2981 0.25 8.33183C0.25 4.36551 3.49389 1.14648 7.5 1.14648C11.5061 1.14648 14.75 4.36551 14.75 8.33183Z"
                        stroke="#5C5C5C" stroke-width="0.5" />
                    <path d="M4.48242 11.5955L10.2683 5.64722" stroke="#5C5C5C" stroke-width="0.5" />
                    <path d="M10.375 11.489L4.375 5.75298" stroke="#5C5C5C" stroke-width="0.5" />
                </svg>
            </button>
            <input type="hidden" name="quantity" value="0">
            <input type="hidden" name="id" value="{{ cart_item_key }}">
        </form>
    {% endunless %}
</div>