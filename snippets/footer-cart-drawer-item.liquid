                    <path fill-rule="evenodd" clip-rule="evenodd"
                        d="M41.911 0.214692L43.054 3.5381L46.6253 3.57871C46.9326 3.58222 47.0599 3.96681 46.8134 4.1468L43.9481 6.24111L45.0124 9.58951C45.1038 9.87765 44.7711 10.115 44.5202 9.94051L41.6069 7.91141L38.6931 9.94012C38.4427 10.1146 38.1095 9.87687 38.2009 9.58912L39.2652 6.24072L36.4 4.14641C36.1535 3.96642 36.2807 3.58183 36.588 3.57832L40.1593 3.53771L41.3023 0.214302C41.4009 -0.071499 41.8128 -0.071499 41.911 0.214692Z"
