{% doc %}
  Renders a cart item snippet for the cart drawer section

  @example
  {% include 'footer-cart-drawer-item' %}
{% enddoc %}

<div class="minicart-item d-flex">
    <div class="mini-img-wrapper">
        <img class="mini-img" src="{{ cart_item_image | img_url: 'master' }}" alt="{{ cart_item_title | escape }}">
    </div>
    <div class="product-info">
    <div class="product_hdr">
        <h2 class="product-title">
            <a href="{{ cart_item_url }}">{{ cart_item_title }}</a>
        </h2>
    </div>
    <div class="product_rtngBx">
        <div class="product-rating">
            <div class="rtng_stars">
                <svg width="59" height="10" viewBox="0 0 59 10" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path fill-rule="evenodd" clip-rule="evenodd"
                        d="M6.14099 0.214692L7.28398 3.5381L10.8553 3.57871C11.1626 3.58222 11.2898 3.96681 11.0433 4.1468L8.1781 6.24111L9.24238 9.58951C9.33382 9.87765 9.00106 10.115 8.7502 9.94051L5.83685 7.91141L2.92311 9.94012C2.67264 10.1146 2.33948 9.87687 2.43092 9.58912L3.4952 6.24072L0.629959 4.14641C0.38347 3.96642 0.51069 3.58183 0.818007 3.57832L4.38932 3.53771L5.53232 0.214302C5.63091 -0.071499 6.04279 -0.071499 6.14099 0.214692Z"
                        fill="#91BAEC"></path>
                    <path fill-rule="evenodd" clip-rule="evenodd"
                        d="M18.0643 0.214692L19.2073 3.5381L22.7786 3.57871C23.086 3.58222 23.2132 3.96681 22.9667 4.1468L20.1014 6.24111L21.1657 9.58951C21.2572 9.87765 20.9244 10.115 20.6735 9.94051L17.7602 7.91141L14.8464 9.94012C14.596 10.1146 14.2628 9.87687 14.3543 9.58912L15.4185 6.24072L12.5533 4.14641C12.3068 3.96642 12.434 3.58183 12.7413 3.57832L16.3127 3.53771L17.4557 0.214302C17.5543 -0.071499 17.9661 -0.071499 18.0643 0.214692Z"
                        fill="#91BAEC"></path>
                    <path fill-rule="evenodd" clip-rule="evenodd"
                        d="M29.9877 0.214692L31.1307 3.5381L34.702 3.57871C35.0093 3.58222 35.1365 3.96681 34.89 4.1468L32.0248 6.24111L33.0891 9.58951C33.1805 9.87765 32.8477 10.115 32.5969 9.94051L29.6835 7.91141L26.7698 9.94012C26.5193 10.1146 26.1862 9.87687 26.2776 9.58912L27.3419 6.24072L24.4766 4.14641C24.2301 3.96642 24.3574 3.58183 24.6647 3.57832L28.236 3.53771L29.379 0.214302C29.4776 -0.071499 29.8895 -0.071499 29.9877 0.214692Z"
