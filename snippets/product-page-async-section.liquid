{% doc %}
  Renders a "async section" snippet for the product-header/page-header section

  @param {object} - A section object.

  @example
  {% render 'product-page-async-section', section: product %}
{% enddoc %}


{% capture async-section %}
    {% for block in section.blocks %}
        {% if block.type == 'section' %}
            <div id="async-section" data-async-section-id="{{ block.settings.section_id }}"></div>
        {% endif %}
    {% endfor %}
{% endcapture %}

{% if async-section != blank %}

    {{ async-section }}

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            document.querySelectorAll('[data-async-section-id]').forEach(container => {
                const sectionId = container.getAttribute('data-async-section-id');
                const pageUrl = window.location.pathname; // текущая страница

                fetch(`${pageUrl}?sections=${sectionId}`)
                .then(res => res.json())
                .then(data => {
                    if (data[sectionId]) {
                        let html = data[sectionId].trim();

                        // оборачиваем ответ во временный контейнер
                        const tempWrap = document.createElement('div');
                        tempWrap.innerHTML = html;

                        // если внутри есть <template>, берём его содержимое
                        const tpl = tempWrap.querySelector('template#async');
                        if (tpl) {
                        html = tpl.innerHTML.trim();
                        }

                        container.innerHTML = html;

                        container.querySelectorAll("script").forEach(oldScript => {
                        const newScript = document.createElement("script");

                        // скопировать все атрибуты
                        [...oldScript.attributes].forEach(attr => {
                            newScript.setAttribute(attr.name, attr.value);
                        });

                        // если inline-код
                        if (!oldScript.src) {
                            newScript.textContent = oldScript.textContent;
                        }

                        oldScript.replaceWith(newScript);
                        });
                    } else {
                        console.error('Section not found in response:', sectionId);
                    }
                })
                .catch(err => console.error(err));
            });
        });
    </script>
{% endif %}