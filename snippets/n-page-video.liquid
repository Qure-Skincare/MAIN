{% doc %}
  Renders a page video snippet for product-header section.

  @param {object} - A section object.
  @param {object} - A block object.

  @example
  {% render 'n-page-video', section: '', block: '' %}
{% enddoc %}

{% if block == blank %}
    {% for _block in section.blocks %}
        {% if _block.type == 'video' %}
            {% assign block = _block %}
        {% endif %}
    {% endfor %}
{% endif %}

<picture data-label-text="{{ block.settings.heading }}" data-bs-toggle="modal" data-bs-target="#reusableWistiaModal" data-video-id="{{ block.settings.wistia_url }}">
    <img src="{{ block.settings.image | img_url: 'master' }}" alt="{{ block.settings.image.alt | escape }}" />
</picture>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadScriptOnce("wistia-popup", "https://qureskincaredns.com/assets/js-new/wistia-popup.js");
        loadScriptOnce("wistia-script", "https://fast.wistia.com/assets/external/E-v1.js");
    });
</script>