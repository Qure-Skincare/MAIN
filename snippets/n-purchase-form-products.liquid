{% capture preorder_box %}
    {% render 'n-product-page-next-ships', section: section, block: blank, class: 'hide preorder_box' %}
{% endcapture %}

<div class="treatment__step">
    <div class="c-supply-selector{% if section.settings.type != 'list' %}  c-supply-selector--tiles{% endif %}">
        <p class="c-supply-selector__title">{{ 'purchase-form.settings.select-product' | t }}</p>
        {% include 'n-purchase-form-products-item' array: __idsArray1, preorder_box: preorder_box %}
        {% include 'n-purchase-form-products-item' array: __idsArray2, preorder_box: preorder_box %}
        {% include 'n-purchase-form-products-item' array: __idsArray3, preorder_box: preorder_box %}
        <div id="{{ section.settings.form_name }}-body-{{ section.id }}"></div>
    </div>
</div>